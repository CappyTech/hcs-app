########################################
# App (server)
########################################
# Use the prebuilt image from GitHub Container Registry (GHCR) when running with `--no-build`.
# Defaults assume a moving tag you maintain (e.g., ci-latest). For exact CI runs, set the SHA tag.
# Examples:
#   APP_IMAGE=ghcr.io/cappytech/sms
#   APP_IMAGE_TAG=ci-<commit-sha>
APP_IMAGE=
APP_IMAGE_TAG=

# used by: `app.js` (listen host)
HOST=0.0.0.0
# used by: `app.js` (env gating), `services/securityService.js`, `mongoose/services/sessionServiceMongoose.js`, `mongoose/services/taskServiceMongoose.js`
NODE_ENV=production
# used by: `app.js` (listen port)
PORT=3000

# Session (use a strong random value in production)
# used by: `mongoose/services/sessionServiceMongoose.js` (session secret + MongoStore crypto)
SESSION_SECRET=change-me
# Optional: share session across subdomains (e.g., .heroncs.co.uk)
# used by: `mongoose/services/sessionServiceMongoose.js` (cookie.domain)
# SESSION_COOKIE_DOMAIN=.heroncs.co.uk

# App meta (used in templates)
# used by: `app.js` → res.locals.contactEmail
# SUPPORTEMAIL=
# used by: `app.js` → res.locals.copyrightyearstart
INCORPORATION_YEAR=


########################################
# SSO (hcs-sync)
########################################
# JWT secret used by hcs-app to sign the SSO cookie. Must match hcs-sync.
# used by: `mongoose/controllers/ssoController.js`
# HCS_SSO_JWT_SECRET=

# Cookie domain for cross-subdomain sharing (e.g. .heroncs.co.uk)
# used by: `mongoose/controllers/ssoController.js`
# HCS_SSO_COOKIE_DOMAIN=.heroncs.co.uk

# Comma-separated allowlist of hosts that /sso/hcs-sync may redirect back to.
# used by: `mongoose/controllers/ssoController.js`
HCS_SSO_RETURN_HOSTS=sync.heroncs.co.uk

# Optional: allow http return_to (not recommended in production)
# used by: `mongoose/controllers/ssoController.js`
# HCS_SSO_ALLOW_HTTP=false


########################################
# Security
########################################
# HTTPS/HSTS controls
# Enable HTTP Strict-Transport-Security via Helmet. Recommended true in production when serving over HTTPS.
# Set to false for local/dev to avoid browsers forcing HTTPS. If unset, defaults to true when NODE_ENV=production.
# used by: `services/securityService.js`
ENABLE_HSTS=false

# Session cookie security
# Control the session cookie "secure" flag. True = cookies only sent over HTTPS.
# Set to false for local/dev over plain HTTP. If unset, defaults to (NODE_ENV === 'production').
# used by: `mongoose/services/sessionServiceMongoose.js`
COOKIE_SECURE=false

# Paths to bypass CSRF, comma-separated (e.g. "/webhook")
# used by: `services/csrfService.js`
# CSRF_EXEMPT_PATHS=
# Toggle strict CSRF enforcement
# used by: `services/csrfService.js`
# STRICT_MODE=false
# Encryption key for at-rest secrets (hex or text)
# used by: `services/encryptionService.js`; dev hint in `app.js`
ENCRYPTION_KEY=
# JWT signing secret
# used by: `services/generateTokenService.js`
# JWT_SECRET=


########################################
# MongoDB (no SSH in Docker)
########################################
# Build connection from discrete parts; no MONGO_URI needed
# used by: `mongoose/services/mongooseDatabaseService.js` (disable SSH tunnel) # required
SSH_TUNNEL_ENABLED=false
# used by: `mongoose/services/mongooseDatabaseService.js` (authSource in URI) # required
MONGO_AUTH_SOURCE=admin
# used by: `mongoose/services/mongooseDatabaseService.js` (INTERNAL models & session store) # required
MONGO_DBNAME_INTERNAL=internal
# used by: `mongoose/services/mongooseDatabaseService.js` (PAPERLESS models) # required
MONGO_DBNAME_PAPERLESS=paperless
# used by: `mongoose/services/mongooseDatabaseService.js` (REST models) # required
MONGO_DBNAME_REST=rest
# used by: `mongoose/services/mongooseDatabaseService.js` (host for all connections) # required
MONGO_HOST=host.docker.internal
# used by: `mongoose/services/mongooseDatabaseService.js` (password when auth enabled) # required
MONGO_PASS=
# used by: `mongoose/services/mongooseDatabaseService.js` (port for all connections) # required
MONGO_PORT=27017
# used by: `mongoose/services/mongooseDatabaseService.js` (username when auth enabled) # required
MONGO_USER=
# If you enable the in-compose MongoDB service (mongodb), use this host instead:
# MONGO_HOST=mongodb


########################################
# Paperless (optional)
########################################
# If you enable the paperless stack in docker-compose.yml, set:
# used by: `mongoose/services/paperless/paperlessClient.js` (base API URL) # required
PAPERLESS_BASE_URL=http://paperless:8000/api
# used by: `mongoose/services/paperless/paperlessClient.js` (only when building from base host without /api) # required
PAPERLESS_PORT=8000
# used by: `mongoose/services/paperless/paperlessClient.js` (Authorization header) # required
PAPERLESS_TOKEN=your-paperless-token
# used by: `mongoose/services/paperless/paperlessClient.js` (SSH tunnel toggle)
# PAPERLESS_SSH_TUNNEL_ENABLED=false
# used by: `mongoose/services/paperless/paperlessClient.js` (Accept header)
# PAPERLESS_ACCEPT=application/json; version=6
# used by: `mongoose/services/paperless/grabServicePaperless.js`, `mongoose/controllers/paperlessController.js`
# PAPERLESS_PAGE_SIZE=50
# used by: `mongoose/services/paperless/grabServicePaperless.js`, `mongoose/controllers/paperlessController.js`
# PAPERLESS_CONCURRENCY=5
# used by: `mongoose/services/paperless/paperlessClient.js`, `mongoose/services/paperless/grabServicePaperless.js`
# PAPERLESS_VERBOSE=false
# used by: `mongoose/services/paperless/grabServicePaperless.js`
# PAPERLESS_SINCE=
# used by: `mongoose/services/paperless/grabServicePaperless.js`
# PAPERLESS_QUERY=


########################################
# KashFlow (optional)
########################################
# used by: `mongoose/services/paperless/purchaseDraftService.js` (fallback currency)
# DEFAULT_CURRENCY=GBP
# used by: `services/kashflowSessionService.js`, `mongoose/controllers/paperlessController.js`
# KASHFLOW_API_BASE_URL=https://api.kashflow.com/v2
# used by: `services/kashflowSessionService.js` # required
KASHFLOW_API_PASSWORD=
# used by: `services/kashflowSessionService.js` # required
KASHFLOW_API_USERNAME=
# used by: `services/kashflowSessionService.js` (verbose session logs)
KASHFLOW_DEBUG_SESSION=1
# used by: `mongoose/services/paperless/purchaseDraftService.js` (omit defaults) # required
KASHFLOW_DEFER_DEFAULTS=true
# used by: `services/kashflowSessionService.js` (2-step auth) # required
KASHFLOW_MEMORABLE=
# used by: `mongoose/services/paperless/purchaseDraftService.js` (filter payload header fields)
# KASHFLOW_OMIT_HEADER_FIELDS=
# used by: `mongoose/services/paperless/purchaseDraftService.js` (filter payload line fields)
# KASHFLOW_OMIT_LINE_FIELDS=
# used by: `services/kashflowSessionService.js`, `mongoose/controllers/paperlessController.js` (direct auth)
# KASHFLOW_SESSION_TOKEN=


########################################
# Cloudflare Turnstile (optional)
########################################
# used by: `mongoose/controllers/userCRUDController.js` # required
TURNSTILE_SECRET_KEY=
# used by: `mongoose/controllers/userCRUDController.js` # required
TURNSTILE_SITE_KEY=


########################################
# SMTP (Email Service)
########################################
# used by: `services/emailService.js` (nodemailer transport)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@heroncs.co.uk

# used by: `services/emailService.js` (verification email links)
# BASE_URL=https://hcs.heroncs.co.uk

########################################
# Misc
########################################
# used by: many modules for extra logs (e.g. Paperless client, DB service, attendance services) # required
DEBUG=true
# used by: `kashflowAPI/routes.js`, `mongoose/routes/indexRoutes.js` (Bearer token check)
# FETCH_API_TOKEN=