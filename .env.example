# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/sms

# MariaDB/MySQL connection details
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=sms

# Session configuration
SESSION_SECRET=your_session_secret

# Encryption key used by encryptionService
ENCRYPTION_KEY=your_encryption_key

# Application environment
NODE_ENV=development
DEBUG=true
DATABASE_TYPE=mdb

# Default admin credentials
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# Support contact email
SUPPORTEMAIL=support@example.com

# SSO (hcs-sync)
# Comma-separated allowlist of hosts that /sso/hcs-sync may redirect back to.
# Example: HCS_SSO_RETURN_HOSTS=sync.heroncs.co.uk
HCS_SSO_RETURN_HOSTS=sync.heroncs.co.uk

# Cloudflare Turnstile keys
TURNSTILE_SITE_KEY=your_site_key
TURNSTILE_SECRET_KEY=your_secret_key
CFAPI_KEY=your_cloudflare_api_key

# KashFlow API credentials
KFUSERNAME=kf_user
KFPASSWORD=kf_password
FETCH_API_TOKEN=your_api_token

# KashFlow database (for Sequelize)
KF_DB=kf_database
KF_USER=kf_db_user
KF_PASS=kf_db_password

# Auto authentication details
appName=SMS
autoAuthKey=some_key

# Database migration service credentials
MigrateDB_DATABASE=migrate_database
MigrateDB_USER=migrate_user
MigrateDB_PASSWORD=migrate_password
MigrateDB_HOST=localhost

# SSH tunnel configuration for MongoDB
SSH_TUNNEL_ENABLED=true
SSH_USER=hcs-mongodb
SSH_HOST=your.local.machine.or.hostname
SSH_PORT=22
SSH_KEY_PATH=/absolute/path/to/id_rsa
SSH_REMOTE_HOST=127.0.0.1
SSH_REMOTE_PORT=27017
SSH_LOCAL_PORT=27000
MONGO_DBNAME=kashflowdbe

# Paperless API
# You can provide either:
#  - a host or host:port (we'll assume http and append /api), e.g. 127.0.0.1 or paperless:8000
#  - or a full URL including scheme and optional /api, e.g. http://paperless:8000 or https://paperless.my.net/api
PAPERLESS_BASE_URL=http://paperless:8000/api
PAPERLESS_TOKEN=your_paperless_token
PAPERLESS_ACCEPT=application/json; version=6

# Optional: SSH tunnel for Paperless API (like MongoDB)
PAPERLESS_SSH_TUNNEL_ENABLED=false
PAPERLESS_SSH_USER=your_ssh_user
PAPERLESS_SSH_HOST=your.ssh.host
PAPERLESS_SSH_PORT=22
PAPERLESS_SSH_KEY_PATH=/absolute/path/to/id_rsa
PAPERLESS_SSH_PASS=
PAPERLESS_REMOTE_HOST=127.0.0.1
PAPERLESS_REMOTE_PORT=8000