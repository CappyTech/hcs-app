<div class="container my-5">
    <h1 class="text-center mb-4">Projects</h1>

    <div class="row text-center mb-5">
        <div class="col-md-4">
            <div class="card text-bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Jobs</h5>
                    <h2 class="card-text"><%= totalProjects %></h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Active Jobs</h5>
                    <h2 class="card-text"><%= activeProjects %></h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-warning mb-3">
                <div class="card-body">
                    <h5 class="card-title">Completed Jobs</h5>
                    <h2 class="card-text"><%= completedProjects %></h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            Recent Jobs (Last 5 in 30 days)
        </div>
        <div class="card-body">
            <ul class="list-group">
                <% if (recentProjects && recentProjects.length > 0) { %>
                    <% recentProjects.slice(0, 5).forEach(project => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong><a href="/project/read/<%= project.uuid %>"><%= project.Name || project.Reference %></a></strong>
                                <p class="mb-0 text-muted">Start: <%= project.Date1 ? slimDateTime(project.Date1) : 'N/A' %></p>
                            </div>
                            <span><%= project.Status %></span>
                        </li>
                    <% }) %>
                <% } %>
            </ul>
        </div>
    </div>
</div>

<div class="container mt-5">
    <h2 class="mb-3 text-center">Jobs List</h2>
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Reference</th>
                <th>Start Date</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% projects.forEach(project => { %>
                <tr>
                    <td><a href="/project/read/<%= project.uuid %>"><%= project.Name || 'Unnamed' %></a></td>
                    <td><%= project.Reference || 'N/A' %></td>
                    <td><%= project.Date1 ? new Date(project.Date1).toLocaleDateString() : 'N/A' %></td>
                    <td><%= project.Status %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>
