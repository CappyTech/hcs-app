<div class="p-5 mb-4 bg-body-tertiary rounded-3 text-center">
  <% if (isAuthenticated) { %>
    <!-- Authenticated Welcome -->
    <h1 class="display-5 fw-bold">Welcome, <%= firstName %>.</h1>
    <p class="lead fw-light text-body-secondary">
      Role: <strong><%= role.charAt(0).toUpperCase() + role.slice(1) %></strong>
    </p>
  <% } else { %>
    <!-- Public Jumbotron -->
    <div class="container py-4">
      <div class="row align-items-center">
        <div class="col-lg-6 text-start">
          <h1 class="display-4 fw-bold">Subcontractor Management System</h1>
          <p class="lead fw-light text-body-secondary">
            Developed by <a class="hcs-green-text" href="https://heroncs.co.uk">Heron Constructive Solutions LTD</a>
          </p>
          <p class="fs-5">
            Streamline subcontractor management, compliance, and documentation—built for the modern construction team.
          </p>
          <a href="/user/login" class="btn btn-hcs-green btn-lg mt-3">Log In</a>
        </div>
        <div class="col-lg-6 d-none d-lg-block">
          <img src="https://via.placeholder.com/600x300?text=Subcontractor+Dashboard" class="img-fluid rounded shadow" alt="Dashboard Screenshot">
        </div>
      </div>
    </div>
  <% } %>
</div>

<!-- Authenticated Dashboard Cards -->
<% if (isAuthenticated) { %>
  <div class="card mb-3">
    <div class="card-header fw-bold">Your Tasks</div>
    <div class="card-body d-flex justify-content-between gap-4 flex-wrap">
      <!-- Task Sections -->
      <%- include('partials/taskCard', { title: 'Overdue Tasks', tasks: tasks.overdue, emptyMsg: 'No overdue tasks', showRecurrence: true }) %>
      <%- include('partials/taskCard', { title: 'Today', tasks: tasks.today, emptyMsg: 'No tasks today', showRecurrence: true }) %>
      <%- include('partials/taskCard', { title: 'This Week', tasks: tasks.week, emptyMsg: 'No tasks this week', showRecurrence: true }) %>
      <%- include('partials/taskCard', { title: 'This Month', tasks: tasks.month, emptyMsg: 'No tasks this month', showRecurrence: true }) %>
      <%- include('partials/taskCard', { title: 'General Tasks', tasks: tasks.general, emptyMsg: 'No general tasks', showRecurrence: true }) %>
      <%- include('partials/taskCard', { title: 'Recurring Tasks', tasks: tasks.recurring, emptyMsg: 'No recurring tasks', showRecurrence: true }) %>
    </div>
    <div class="card-footer text-center">
      <a class="btn btn-outline-secondary btn-sm" href="/tasks">View All Tasks</a>
    </div>
  </div>
<% } %>

<!-- Public Feature Highlights -->
<% if (!isAuthenticated) { %>
  <section class="container text-center my-5">
    <h2 class="fw-bold mb-3">Why Use Our System?</h2>
    <div class="row g-4 mt-4">
      <div class="col-md-4">
        <img src="https://via.placeholder.com/200x150?text=Profiles" class="img-fluid rounded mb-2" alt="Subcontractor Profiles">
        <h5>Manage Subcontractors</h5>
        <p class="text-muted">Easily store and track contact, compliance, and employment details.</p>
      </div>
      <div class="col-md-4">
        <img src="https://via.placeholder.com/200x150?text=Receipts" class="img-fluid rounded mb-2" alt="Receipts">
        <h5>Upload Documents</h5>
        <p class="text-muted">Centralised uploads for job documents, expenses, and evidence.</p>
      </div>
      <div class="col-md-4">
        <img src="https://via.placeholder.com/200x150?text=CIS+Returns" class="img-fluid rounded mb-2" alt="CIS Reports">
        <h5>Generate CIS Reports</h5>
        <p class="text-muted">Automatically build and export monthly or yearly HMRC-ready summaries.</p>
      </div>
    </div>
  </section>
<% } %>
