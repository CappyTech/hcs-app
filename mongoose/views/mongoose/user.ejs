<div class="container my-5">
  <h1 class="text-center mb-4">Users</h1>
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Username</th>
        <th>Email</th>
        <th>Role</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
      <tr>
        <td><a href="/user/read/<%= u.uuid %>"><%= u.username %></a></td>
        <td><%= u.email %></td>
        <td class="text-capitalize"><%= u.role %></td>
        <td><%= slimDateTime(u.createdAt) %></td>
        <td class="text-end">
          <a class="btn btn-sm btn-hcs-green" href="/user/update/<%= u.uuid %>">Edit</a>
          <% if (isAdmin) { %>
          <form action="/user/delete/<%= u.uuid %>" method="POST" class="d-inline">
            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this user?');">Delete</button>
          </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
