<div class="container my-5">
  <h1 class="mb-4">Contracts</h1>
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Title</th>
        <th>Location</th>
        <th>Status</th>
        <th>Start Date</th>
        <th>End Date</th>
      </tr>
    </thead>
    <tbody>
      <% contracts.forEach(c => { %>
        <tr>
          <td><a href="/contract/<%= c._id %>"><%= c.title %></a></td>
          <td><%= c.location %></td>
          <td><%= c.status %></td>
          <td><%= c.startDate ? c.startDate.toISOString().slice(0,10) : '' %></td>
          <td><%= c.endDate ? c.endDate.toISOString().slice(0,10) : '' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
