<div class="container mt-5">
    <h1 class="display-3">Project: <%= Project.Name || 'Unnamed Project' %></h1>
    <p><strong>Reference:</strong> <%= Project.Reference || 'N/A' %></p>
    <p><strong>Description:</strong> <%= Project.Description || 'N/A' %></p>
    <p><strong>Start Date:</strong> <%= Project.Date1 ? slimDateTime(Project.Date1) : 'N/A' %></p>
    <p><strong>End Date:</strong> <%= Project.Date2 ? slimDateTime(Project.Date2) : 'N/A' %></p>
    <p><strong>Status:</strong> <%= Project.Status %></p>

    <% if (Customer) { %>
        <h2 class="display-4">Customer Information</h2>
        <p><strong>Name:</strong> <a href="/customer/read/<%= Customer.uuid %>"><%= Customer.Name %></a></p>
    <% } %>
</div>
