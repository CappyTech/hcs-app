<div class="max-w-3xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <% const is403 = error.title && error.title.startsWith('403'); %>
    <% const is404 = error.title && error.title.startsWith('404'); %>

    <!-- Accent bar (color varies by error type) -->
    <div class="h-1.5 <%= is403 ? 'bg-gradient-to-r from-amber-500 to-amber-400' : is404 ? 'bg-gradient-to-r from-gray-400 to-gray-300' : 'bg-gradient-to-r from-red-500 to-red-400' %>"></div>

    <div class="p-8 sm:p-12 text-center">
    <% if (is403) { %>
      <i class="bi bi-shield-lock-fill text-amber-500 text-[5rem]"></i>
      <h1 class="mt-6 text-3xl font-bold text-gray-900 dark:text-gray-100">Access Denied</h1>
      <p class="mt-2 text-lg text-gray-500 dark:text-gray-400">
        You don't have permission to view this page.<br>
        If you think this is a mistake, contact your administrator.
      </p>
    <% } else if (is404) { %>
      <i class="bi bi-search text-gray-400 dark:text-gray-500 text-[5rem]"></i>
      <h1 class="mt-6 text-3xl font-bold text-gray-900 dark:text-gray-100">Page Not Found</h1>
      <p class="mt-2 text-lg text-gray-500 dark:text-gray-400">
        The page you're looking for doesn't exist or has been moved.
      </p>
    <% } else { %>
      <i class="bi bi-exclamation-triangle-fill text-red-500 text-[5rem]"></i>
      <h1 class="mt-6 text-3xl font-bold text-gray-900 dark:text-gray-100"><%= error.title %></h1>
      <p class="mt-2 text-lg text-gray-500 dark:text-gray-400"><%= error.message %></p>
    <% } %>

    <!-- Stack Trace (debug only) -->
    <% if (error.stack && process.env.DEBUG === 'true') { %>
      <div class="mt-6 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 text-amber-900 dark:text-amber-200 rounded-xl p-4 text-left">
        <details class="text-sm whitespace-pre-wrap">
          <summary class="cursor-pointer font-semibold">View Stack Trace</summary>
          <pre class="mt-2 overflow-x-auto"><code><%= error.stack %></code></pre>
        </details>
      </div>
    <% } %>

    <!-- Return Button -->
    <a href="/" class="inline-flex items-center gap-1.5 mt-8 px-6 py-3 rounded-lg text-sm font-medium text-white shadow-sm transition
      <%= is403 ? 'bg-amber-600 hover:bg-amber-700' : 'bg-red-600 hover:bg-red-700' %>">
      <i class="bi bi-house"></i> Return to Home
    </a>
    </div>
  </div>
</div>
