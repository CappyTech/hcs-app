<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">

  <!-- Header -->
  <div class="flex justify-between items-center mb-6 print:hidden">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Fleet Overview</h1>
    <div class="flex gap-2">
      <a href="/vehicle/create" class="inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">
        + Add Vehicle
      </a>
      <a href="/vehicles" class="inline-flex items-center gap-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">
        All Vehicles
      </a>
    </div>
  </div>

  <!-- Sub-model navigation -->
  <div class="flex flex-wrap gap-2 mb-6 print:hidden">
    <a href="/vehicleFuelLogs" class="inline-flex items-center gap-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200 rounded-lg px-3 py-1.5 text-sm font-medium">
      &#9981; Fuel Logs
    </a>
    <a href="/vehicleMileageLogs" class="inline-flex items-center gap-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200 rounded-lg px-3 py-1.5 text-sm font-medium">
      &#128663; Mileage Logs
    </a>
    <a href="/vehicleServices" class="inline-flex items-center gap-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200 rounded-lg px-3 py-1.5 text-sm font-medium">
      &#128295; Service History
    </a>
    <a href="/vehicleFuelLog/create" class="inline-flex items-center gap-1 bg-green-50 dark:bg-green-900/20 border border-green-300 dark:border-green-700 hover:bg-green-100 dark:hover:bg-green-800/30 text-green-700 dark:text-green-400 rounded-lg px-3 py-1.5 text-sm font-medium">
      + Log Fuel
    </a>
    <a href="/vehicleMileageLog/create" class="inline-flex items-center gap-1 bg-blue-50 dark:bg-blue-900/20 border border-blue-300 dark:border-blue-700 hover:bg-blue-100 dark:hover:bg-blue-800/30 text-blue-700 dark:text-blue-400 rounded-lg px-3 py-1.5 text-sm font-medium">
      + Log Trip
    </a>
    <a href="/vehicleService/create" class="inline-flex items-center gap-1 bg-purple-50 dark:bg-purple-900/20 border border-purple-300 dark:border-purple-700 hover:bg-purple-100 dark:hover:bg-purple-800/30 text-purple-700 dark:text-purple-400 rounded-lg px-3 py-1.5 text-sm font-medium">
      + Log Service
    </a>
  </div>

  <!-- Summary Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 xl:grid-cols-6 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Total Vehicles</p>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= totalCount %></p>
    </div>
    <% const statusColors = {
      'Available': 'text-green-600',
      'In Use': 'text-blue-600',
      'Under Maintenance': 'text-yellow-600',
      'Out of Service': 'text-red-600',
      'Disposed': 'text-gray-400'
    }; %>
    <% for (const [status, count] of Object.entries(availabilityCounts)) { %>
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-1"><%= status %></p>
        <p class="text-3xl font-bold <%= statusColors[status] || 'text-gray-900 dark:text-gray-100' %>"><%= count %></p>
      </div>
    <% } %>
  </div>

  <!-- Expired (past-due) alerts -->
  <% const expiredSections = [
    { items: expiredMot, label: 'Expired MOT', field: 'motExpiryDate', color: 'red' },
    { items: expiredInsurance, label: 'Expired Insurance', field: 'insuranceExpiryDate', color: 'red' },
    { items: expiredRoadTax, label: 'Expired Road Tax', field: 'roadTaxExpiryDate', color: 'red' }
  ].filter(s => s.items.length > 0); %>

  <% if (expiredSections.length > 0) { %>
    <div class="mb-8 border border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-900/20 rounded-2xl p-4">
      <h2 class="text-xl font-bold text-red-700 dark:text-red-400 mb-4">&#9888; Expired Compliance</h2>
      <% for (const section of expiredSections) { %>
        <h3 class="text-base font-semibold text-red-600 dark:text-red-400 mb-1 mt-3 first:mt-0"><%= section.label %> (<%= section.items.length %>)</h3>
        <ul class="divide-y divide-red-200 dark:divide-red-800 mb-2">
          <% for (const v of section.items) { %>
          <li class="flex items-center justify-between py-1.5 text-sm">
            <div>
              <a href="/vehicle/update/<%= v.uuid %>" class="font-mono font-bold text-blue-600 hover:underline"><%= v.registrationNumber %></a>
              <span class="ml-2 text-gray-700 dark:text-gray-300"><%= v.make %> <%= v.model %></span>
            </div>
            <span class="text-red-600 text-xs font-semibold"><%= slimDateTime(v[section.field]) %></span>
          </li>
          <% } %>
        </ul>
      <% } %>
    </div>
  <% } %>

  <!-- Expiring Soon -->
  <% const expiringSections = [
    { items: expiringMot, label: 'MOT Expiring Soon', field: 'motExpiryDate' },
    { items: expiringInsurance, label: 'Insurance Expiring Soon', field: 'insuranceExpiryDate' },
    { items: expiringRoadTax, label: 'Road Tax Expiring Soon', field: 'roadTaxExpiryDate' }
  ].filter(s => s.items.length > 0); %>

  <% if (expiringSections.length > 0) { %>
    <div class="mb-8 border border-yellow-300 dark:border-yellow-700 bg-yellow-50 dark:bg-yellow-900/20 rounded-2xl p-4">
      <h2 class="text-xl font-bold text-yellow-700 dark:text-yellow-400 mb-4">&#9888; Expiring Within <%= expiryDays %> Days</h2>
      <% for (const section of expiringSections) { %>
        <h3 class="text-base font-semibold text-yellow-600 dark:text-yellow-400 mb-1 mt-3 first:mt-0"><%= section.label %> (<%= section.items.length %>)</h3>
        <ul class="divide-y divide-yellow-200 dark:divide-yellow-800 mb-2">
          <% for (const v of section.items) {
            const daysLeft = Math.ceil((new Date(v[section.field]) - new Date()) / (1000 * 60 * 60 * 24));
          %>
          <li class="flex items-center justify-between py-1.5 text-sm">
            <div>
              <a href="/vehicle/update/<%= v.uuid %>" class="font-mono font-bold text-blue-600 hover:underline"><%= v.registrationNumber %></a>
              <span class="ml-2 text-gray-700 dark:text-gray-300"><%= v.make %> <%= v.model %></span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-gray-500 text-xs"><%= slimDateTime(v[section.field]) %></span>
              <span class="font-semibold text-xs <%= daysLeft <= 7 ? 'text-red-600' : 'text-yellow-600' %>"><%= daysLeft %>d</span>
            </div>
          </li>
          <% } %>
        </ul>
      <% } %>
    </div>
  <% } %>

  <!-- Service Due Soon -->
  <% if (serviceDueSoon.length > 0) { %>
    <div class="mb-8 border border-blue-300 dark:border-blue-700 bg-blue-50 dark:bg-blue-900/20 rounded-2xl p-4">
      <h2 class="text-xl font-bold text-blue-700 dark:text-blue-400 mb-3">&#128295; Service Due Within <%= expiryDays %> Days (<%= serviceDueSoon.length %>)</h2>
      <ul class="divide-y divide-blue-200 dark:divide-blue-800">
        <% for (const v of serviceDueSoon) { %>
        <li class="flex items-center justify-between py-1.5 text-sm">
          <div>
            <a href="/vehicle/read/<%= v.uuid %>" class="font-mono font-bold text-blue-600 hover:underline"><%= v.registrationNumber %></a>
            <span class="ml-2 text-gray-700 dark:text-gray-300"><%= v.make %> <%= v.model %></span>
          </div>
          <span class="text-gray-500 dark:text-gray-400 text-xs"><%= slimDateTime(v.nextServiceDueDate) %></span>
        </li>
        <% } %>
      </ul>
    </div>
  <% } %>

  <!-- Current Assignments -->
  <div class="mb-8">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Current Assignments (<%= assignedVehicles.length %>)</h2>
      <a href="/vehicles" class="text-sm text-blue-600 hover:underline">View all vehicles &rarr;</a>
    </div>
    <% if (assignedVehicles.length > 0) { %>
      <ul class="divide-y divide-gray-200 dark:divide-gray-700">
        <% for (const v of assignedVehicles) { %>
        <li class="flex items-center justify-between py-1.5 text-sm">
          <div>
            <a href="/vehicle/read/<%= v.uuid %>" class="font-mono font-bold text-blue-600 hover:underline"><%= v.registrationNumber %></a>
            <span class="ml-2 text-gray-700 dark:text-gray-300"><%= v.make %> <%= v.model %></span>
          </div>
          <div class="flex items-center gap-2">
            <% if (v._assigneeUuid) { %>
              <a href="/<%= v._assigneeType === 'employee' ? 'employee' : 'supplier' %>/read/<%= v._assigneeUuid %>" class="text-blue-600 hover:underline text-xs"><%= v._assigneeName %></a>
            <% } else { %>
              <span class="text-gray-500 text-xs"><%= v._assigneeName %></span>
            <% } %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= v._assigneeType === 'employee' ? 'bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400' : 'bg-purple-100 text-purple-800 dark:bg-purple-800/20 dark:text-purple-400' %>">
              <%= v._assigneeType === 'employee' ? 'Employee' : 'Subcontractor' %>
            </span>
          </div>
        </li>
        <% } %>
      </ul>
    <% } else { %>
      <p class="text-gray-500 dark:text-gray-400">No vehicles currently assigned.</p>
    <% } %>
  </div>

  <!-- Unassigned & Available -->
  <div class="mb-8">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Unassigned &amp; Available (<%= unassigned.length %>)</h2>
      <a href="/vehicles" class="text-sm text-blue-600 hover:underline">View all vehicles &rarr;</a>
    </div>
    <% if (unassigned.length > 0) { %>
      <div class="flex flex-wrap gap-2">
        <% for (const v of unassigned) { %>
          <a href="/vehicle/read/<%= v.uuid %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 font-mono">
            <%= v.registrationNumber %>
            <span class="text-xs text-gray-400 font-sans"><%= v.make %> <%= v.model %></span>
          </a>
        <% } %>
      </div>
    <% } else { %>
      <p class="text-gray-500 dark:text-gray-400">All vehicles are currently assigned or unavailable.</p>
    <% } %>
  </div>

</div>
