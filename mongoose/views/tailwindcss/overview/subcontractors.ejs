<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">

  <!-- Header -->
  <div class="flex justify-between items-center mb-6 print:hidden">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Subcontractors Overview</h1>
    <div class="flex gap-2">
      <a href="/suppliers" class="inline-flex items-center gap-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">All Suppliers</a>
      <a href="/subcontractor/assign" class="inline-flex items-center gap-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">Edit CIS Details</a>
    </div>
  </div>

  <!-- Summary Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Total Suppliers</p>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= totalCount %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">CIS Applicable</p>
      <p class="text-3xl font-bold text-blue-600"><%= cisApplicable %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Non-CIS</p>
      <p class="text-3xl font-bold text-gray-400"><%= nonCIS %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Portal Users</p>
      <p class="text-3xl font-bold text-indigo-600"><%= subcontractorUsers.length %></p>
    </div>
  </div>

  <!-- CIS Rate Breakdown -->
  <div class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4">CIS Rate Breakdown</h2>
    <% const cisColour = { '0%': 'bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400', '20%': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-800/20 dark:text-yellow-400', '30%': 'bg-red-100 text-red-800 dark:bg-red-800/20 dark:text-red-400', 'Not Set': 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400' }; %>
    <div class="flex flex-wrap gap-4">
      <% for (const [rate, count] of Object.entries(cisRateCounts)) { %>
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow p-4 text-center min-w-24">
        <p class="text-sm font-medium mb-1 <%= cisColour[rate] ? cisColour[rate].split(' ')[1] + ' ' + cisColour[rate].split(' ')[3] : 'text-gray-600' %>"><%= rate %></p>
        <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= count %></p>
      </div>
      <% } %>
    </div>
  </div>

  <!-- IR35 Linked Employees -->
  <% if (ir35Linked.length > 0) { %>
  <div class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-3">IR35 Off-Payroll Subcontractors (<%= ir35Linked.length %>)</h2>
    <ul class="divide-y divide-gray-200 dark:divide-gray-700">
      <% for (const s of ir35Linked) { %>
      <li class="flex items-center justify-between py-1.5 text-sm">
        <div>
          <a href="/supplier/read/<%= s.uuid %>" class="font-medium text-blue-600 hover:underline"><%= s.Name %></a>
          <span class="ml-2 font-mono text-xs text-gray-500"><%= s.CISNumber || '' %></span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-gray-500 text-xs"><%= s.CISRate != null ? (s.CISRate * 100) + '%' : '' %></span>
          <% if (s._employee) { %>
            <a href="/employee/read/<%= s._employee.uuid %>" class="text-blue-600 hover:underline text-xs"><%= s._employee.name %></a>
          <% } %>
        </div>
      </li>
      <% } %>
    </ul>
  </div>
  <% } %>

  <!-- Subcontractor Portal Users -->
  <% if (subcontractorUsers.length > 0) { %>
  <div class="mb-8">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Portal Users (<%= subcontractorUsers.length %>)</h2>
      <a href="/users" class="text-sm text-blue-600 hover:underline">View all users &rarr;</a>
    </div>
    <ul class="divide-y divide-gray-200 dark:divide-gray-700">
      <% for (const u of subcontractorUsers) { %>
      <li class="flex items-center justify-between py-1.5 text-sm">
        <div>
          <a href="/user/update/<%= u.uuid %>" class="font-medium text-blue-600 hover:underline"><%= u.username %></a>
          <span class="ml-2 text-gray-500 dark:text-gray-400"><%= u.email %></span>
          <% if (!u.emailVerified) { %><span class="ml-2 text-xs text-yellow-600">Unverified</span><% } %>
        </div>
        <div class="flex items-center gap-3">
          <% if (u._supplierUuid) { %>
            <a href="/supplier/read/<%= u._supplierUuid %>" class="text-xs text-blue-600 hover:underline"><%= u._supplierName %></a>
          <% } else { %>
            <span class="text-xs text-gray-400">No supplier linked</span>
          <% } %>
        </div>
      </li>
      <% } %>
    </ul>
  </div>
  <% } %>

  <!-- Recently Updated Suppliers -->
  <% if (recentSuppliers.length > 0) { %>
  <div class="mb-8">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Recently Updated</h2>
      <a href="/suppliers" class="text-sm text-blue-600 hover:underline">View all suppliers &rarr;</a>
    </div>
    <ul class="divide-y divide-gray-200 dark:divide-gray-700">
      <% for (const s of recentSuppliers) { %>
      <li class="flex items-center justify-between py-1.5 text-sm">
        <div>
          <a href="/supplier/read/<%= s.uuid %>" class="font-medium text-blue-600 hover:underline"><%= s.Name %></a>
          <% if (s.ApplyWithholdingTax) { %>
            <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-800/20 dark:text-blue-400">CIS</span>
            <span class="ml-1 text-xs text-gray-500"><%= s.CISRate != null ? (s.CISRate * 100) + '%' : 'Rate not set' %></span>
          <% } %>
        </div>
        <span class="text-gray-400 text-xs"><%= slimDateTime(s.updatedAt) %></span>
      </li>
      <% } %>
    </ul>
  </div>
  <% } %>

</div>
