<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">

  <!-- Header -->
  <div class="flex justify-between items-center mb-6 print:hidden">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Policies Overview</h1>
    <div class="flex gap-2">
      <a href="/company-docs/policy/create" class="inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">
        + New Policy
      </a>
      <a href="/company-docs/policies" class="inline-flex items-center gap-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">
        All Policies
      </a>
    </div>
  </div>

  <!-- Sub-model navigation -->
  <div class="flex flex-wrap gap-2 mb-6 print:hidden">
    <a href="/company-docs/policies" class="inline-flex items-center gap-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200 rounded-lg px-3 py-1.5 text-sm font-medium">
      &#128196; All Policies
    </a>
    <a href="/company-docs/letterhead" class="inline-flex items-center gap-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200 rounded-lg px-3 py-1.5 text-sm font-medium">
      &#127981; Letterhead
    </a>
    <a href="/company-docs/policy/create" class="inline-flex items-center gap-1 bg-green-50 dark:bg-green-900/20 border border-green-300 dark:border-green-700 hover:bg-green-100 dark:hover:bg-green-800/30 text-green-700 dark:text-green-400 rounded-lg px-3 py-1.5 text-sm font-medium">
      + New Policy
    </a>
  </div>

  <!-- Summary Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 xl:grid-cols-5 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Total Policies</p>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= totalCount %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Published</p>
      <p class="text-3xl font-bold text-green-600"><%= publishedCount %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Draft</p>
      <p class="text-3xl font-bold <%= draftCount > 0 ? 'text-yellow-600' : 'text-gray-400' %>"><%= draftCount %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Stale (&gt;<%= staleDays %>d)</p>
      <p class="text-3xl font-bold <%= stalePolicies.length > 0 ? 'text-orange-500' : 'text-gray-400' %>"><%= stalePolicies.length %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Updated (30d)</p>
      <p class="text-3xl font-bold text-blue-600"><%= recentlyUpdated.length %></p>
    </div>
  </div>

  <!-- Draft policies -->
  <% if (draftPolicies.length > 0) { %>
    <div class="mb-8 border border-yellow-300 dark:border-yellow-700 bg-yellow-50 dark:bg-yellow-900/20 rounded-2xl p-4">
      <h2 class="text-xl font-bold text-yellow-700 dark:text-yellow-400 mb-4">&#9888; Unpublished Drafts (<%= draftPolicies.length %>)</h2>
      <ul class="divide-y divide-yellow-200 dark:divide-yellow-800">
        <% for (const p of draftPolicies) { %>
        <li class="flex items-center justify-between py-1.5 text-sm">
          <div>
            <a href="/company-docs/policy/update/<%= p.uuid %>" class="font-medium text-blue-600 hover:underline"><%= p.title %></a>
            <span class="ml-2 text-xs text-gray-500 dark:text-gray-400">v<%= p.version %></span>
          </div>
          <div class="flex items-center gap-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-800/20 dark:text-yellow-400"><%= p.category %></span>
            <span class="text-gray-400 text-xs"><%= slimDateTime(p.updatedAt) %></span>
          </div>
        </li>
        <% } %>
      </ul>
    </div>
  <% } %>

  <!-- Stale policies -->
  <% if (stalePolicies.length > 0) { %>
    <div class="mb-8 border border-orange-300 dark:border-orange-700 bg-orange-50 dark:bg-orange-900/20 rounded-2xl p-4">
      <h2 class="text-xl font-bold text-orange-700 dark:text-orange-400 mb-4">&#128336; Not Updated in <%= staleDays %> Days (<%= stalePolicies.length %>)</h2>
      <ul class="divide-y divide-orange-200 dark:divide-orange-800">
        <% for (const p of stalePolicies) { %>
        <li class="flex items-center justify-between py-1.5 text-sm">
          <div>
            <a href="/company-docs/policy/update/<%= p.uuid %>" class="font-medium text-blue-600 hover:underline"><%= p.title %></a>
            <span class="ml-2 text-xs text-gray-500 dark:text-gray-400">v<%= p.version %></span>
          </div>
          <div class="flex items-center gap-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-orange-100 text-orange-800 dark:bg-orange-800/20 dark:text-orange-400"><%= p.category %></span>
            <% const daysStale = Math.floor((new Date() - new Date(p.updatedAt)) / (1000 * 60 * 60 * 24)); %>
            <span class="text-orange-600 text-xs font-semibold"><%= daysStale %>d ago</span>
          </div>
        </li>
        <% } %>
      </ul>
    </div>
  <% } %>

  <!-- By category -->
  <div class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-3">By Category</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-3">
      <% const categoryColors = {
        'HR':              'text-blue-600',
        'Health & Safety': 'text-green-600',
        'GDPR':            'text-purple-600',
        'Finance':         'text-emerald-600',
        'Operations':      'text-orange-500',
        'General':         'text-gray-600'
      }; %>
      <% for (const [cat, count] of Object.entries(byCategory)) { %>
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-3 text-center">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-1"><%= cat %></p>
          <p class="text-2xl font-bold <%= categoryColors[cat] || 'text-gray-900 dark:text-gray-100' %>"><%= count %></p>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Recently updated -->
  <div class="mb-8">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Recently Updated (<%= recentlyUpdated.length %>)</h2>
      <a href="/company-docs/policies" class="text-sm text-blue-600 hover:underline">View all policies &rarr;</a>
    </div>
    <% if (recentlyUpdated.length > 0) { %>
      <ul class="divide-y divide-gray-200 dark:divide-gray-700">
        <% for (const p of recentlyUpdated) { %>
        <li class="flex items-center justify-between py-1.5 text-sm">
          <div>
            <a href="/company-docs/policy/update/<%= p.uuid %>" class="font-medium text-blue-600 hover:underline"><%= p.title %></a>
            <span class="ml-2 text-xs text-gray-500 dark:text-gray-400">v<%= p.version %></span>
          </div>
          <div class="flex items-center gap-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <%= p.isPublished
                ? 'bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400'
                : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400' %>">
              <%= p.isPublished ? 'Published' : 'Draft' %>
            </span>
            <span class="text-gray-400 text-xs"><%= slimDateTime(p.updatedAt) %></span>
          </div>
        </li>
        <% } %>
      </ul>
    <% } else { %>
      <p class="text-gray-500 dark:text-gray-400">No policies updated in the last 30 days.</p>
    <% } %>
  </div>

</div>
