<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">

  <!-- Header -->
  <div class="flex justify-between items-center mb-6 print:hidden">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Projects Overview</h1>
    <div class="flex gap-2">
      <a href="/contracts" class="inline-flex items-center gap-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">All Contracts</a>
      <a href="/assignments" class="inline-flex items-center gap-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">All Assignments</a>
      <a href="/contract/create" class="inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">+ New Contract</a>
    </div>
  </div>

  <!-- Contract Summary Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Total Contracts</p>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= totalContracts %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">In Progress</p>
      <p class="text-3xl font-bold text-blue-600"><%= contractByStatus['In Progress'] || 0 %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Planned</p>
      <p class="text-3xl font-bold text-yellow-600"><%= contractByStatus['Planned'] || 0 %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Completed</p>
      <p class="text-3xl font-bold text-green-600"><%= contractByStatus['Completed'] || 0 %></p>
    </div>
  </div>

  <!-- Overdue Contracts -->
  <% if (overdueContracts.length > 0) { %>
  <div class="mb-8 border border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-900/20 rounded-2xl p-4">
    <h2 class="text-xl font-bold text-red-700 dark:text-red-400 mb-3">&#9888; Overdue Contracts (<%= overdueContracts.length %>)</h2>
    <ul class="divide-y divide-red-200 dark:divide-red-800">
      <% for (const c of overdueContracts) { %>
      <li class="flex items-center justify-between py-1.5 text-sm">
        <div>
          <a href="/contract/read/<%= c.uuid %>" class="font-medium text-blue-600 hover:underline"><%= c.title %></a>
          <span class="ml-2 text-gray-500 dark:text-gray-400"><%= c.location || '' %></span>
        </div>
        <div class="flex items-center gap-3">
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-800/20 dark:text-yellow-400"><%= c.status %></span>
          <span class="text-red-600 text-xs font-semibold"><%= slimDateTime(c.endDate) %></span>
          <a href="/contract/update/<%= c.uuid %>" class="text-blue-600 hover:underline text-xs">Update</a>
        </div>
      </li>
      <% } %>
    </ul>
  </div>
  <% } %>

  <!-- Contracts Ending Soon -->
  <% if (contractsEndingSoon.length > 0) { %>
  <div class="mb-8 border border-yellow-300 dark:border-yellow-700 bg-yellow-50 dark:bg-yellow-900/20 rounded-2xl p-4">
    <h2 class="text-xl font-bold text-yellow-700 dark:text-yellow-400 mb-3">&#9888; Ending Within 30 Days (<%= contractsEndingSoon.length %>)</h2>
    <ul class="divide-y divide-yellow-200 dark:divide-yellow-800">
      <% for (const c of contractsEndingSoon) {
        const daysLeft = Math.ceil((new Date(c.endDate) - new Date()) / (1000 * 60 * 60 * 24));
      %>
      <li class="flex items-center justify-between py-1.5 text-sm">
        <div>
          <a href="/contract/read/<%= c.uuid %>" class="font-medium text-blue-600 hover:underline"><%= c.title %></a>
          <span class="ml-2 text-gray-500 dark:text-gray-400"><%= c.location || '' %></span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-gray-500 text-xs"><%= slimDateTime(c.endDate) %></span>
          <span class="font-semibold text-xs <%= daysLeft <= 7 ? 'text-red-600' : 'text-yellow-600' %>"><%= daysLeft %>d</span>
        </div>
      </li>
      <% } %>
    </ul>
  </div>
  <% } %>

  <!-- Active Contracts Without Assignments -->
  <% if (contractsWithoutAssignments.length > 0) { %>
  <div class="mb-8 border border-orange-300 dark:border-orange-700 bg-orange-50 dark:bg-orange-900/20 rounded-2xl p-4">
    <h2 class="text-xl font-bold text-orange-700 dark:text-orange-400 mb-3">&#9888; In Progress — No Active Assignments (<%= contractsWithoutAssignments.length %>)</h2>
    <ul class="divide-y divide-orange-200 dark:divide-orange-800">
      <% for (const c of contractsWithoutAssignments) { %>
      <li class="flex items-center justify-between py-1.5 text-sm">
        <div>
          <a href="/contract/read/<%= c.uuid %>" class="font-medium text-blue-600 hover:underline"><%= c.title %></a>
          <span class="ml-2 text-gray-500 dark:text-gray-400"><%= c.location || '' %></span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-gray-500 text-xs"><%= slimDateTime(c.startDate) %></span>
          <a href="/assignment/create" class="text-blue-600 hover:underline text-xs">+ Assign</a>
        </div>
      </li>
      <% } %>
    </ul>
  </div>
  <% } %>

  <!-- Active Contracts -->
  <div class="mb-8">
    <div class="flex justify-between items-center">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Active Contracts (<%= activeContracts.length %>)</h2>
      <a href="/contracts" class="text-sm text-blue-600 hover:underline">View all contracts &rarr;</a>
    </div>
  </div>

  <!-- Recent Assignments -->
  <div class="mb-8">
    <div class="flex justify-between items-center">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Recent Assignments</h2>
      <a href="/assignments" class="text-sm text-blue-600 hover:underline">View all assignments &rarr;</a>
    </div>
  </div>

  <!-- KashFlow Projects -->
  <% if (restProjects.length > 0) { %>
  <div class="mb-8">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">KashFlow Projects (<%= restProjects.length %>)</h2>
      <a href="/projects" class="text-sm text-blue-600 hover:underline">View all projects &rarr;</a>
    </div>
    <% if (Object.keys(restProjectByStatus).length > 0) { %>
    <div class="flex flex-wrap gap-3">
      <% for (const [s, c] of Object.entries(restProjectByStatus)) { %>
        <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300">
          <%= s %>: <strong class="ml-1"><%= c %></strong>
        </span>
      <% } %>
    </div>
    <% } %>
  </div>
  <% } %>

</div>
