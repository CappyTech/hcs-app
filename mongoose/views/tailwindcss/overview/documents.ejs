<%
const fmt = (d) => d ? new Date(d).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—';
const plUrl = (id) => `https://docs.heroncs.co.uk/documents/${id}`;
// Permalinks from KashFlow are API-relative paths (/v2/documents/...) — never render them raw.
// Prefer the KashFlow UI purchase page; fall back to the API-hosted PDF link.
const kfUrl = (d) => d.kashflowPurchaseNumber
  ? `https://app.kashflow.com/#purchases/${d.kashflowPurchaseNumber}`
  : (d.kashflowPermalink ? (d.kashflowPermalink.startsWith('/') ? `https://api.kashflow.com${d.kashflowPermalink}` : d.kashflowPermalink) : null);
%>
<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">

  <!-- Header -->
  <div class="flex justify-between items-center mb-6 print:hidden">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Documents Overview</h1>
    <div class="flex gap-2">
      <a href="/paperless/ocr" class="inline-flex items-center gap-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">Manage Documents</a>
      <a href="/ocrDocuments" class="inline-flex items-center gap-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">All OCR Docs</a>
    </div>
  </div>

  <!-- Summary Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 xl:grid-cols-6 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Total Docs</p>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= totalDocs %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">KF Linked</p>
      <p class="text-3xl font-bold text-green-600"><%= linkedDocs %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border <%- orphanedDocs > 0 ? 'border-orange-400 dark:border-orange-600' : 'border-gray-200 dark:border-gray-700' %> rounded-2xl shadow-lg p-4 text-center" title="OcrDocuments whose linked KashFlow purchase has been deleted or is no longer active">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Stale Links</p>
      <p class="text-3xl font-bold <%- orphanedDocs > 0 ? 'text-orange-600' : 'text-gray-400' %>"><%= orphanedDocs %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center" title="Purchases with no KashFlow link<%= unlinkedExcluded > 0 ? ` — excludes ${unlinkedExcluded} statements/subcontractor docs/credits/original-pdf-tagged docs` : '' %>">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Unlinked</p>
      <p class="text-3xl font-bold text-yellow-600"><%= unlinkedDocs %></p>
      <% if (unlinkedExcluded > 0) { %><p class="text-[10px] text-gray-400">+<%= unlinkedExcluded %> excluded</p><% } %>
    </div>
    <div class="bg-white dark:bg-gray-900 border <%- driftedDocs > 0 ? 'border-purple-400 dark:border-purple-600' : 'border-gray-200 dark:border-gray-700' %> rounded-2xl shadow-lg p-4 text-center" title="Documents where MongoDB and Paperless-ngx disagree on the KashFlow link">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Custom Field Drift</p>
      <p class="text-3xl font-bold <%- driftedDocs > 0 ? 'text-purple-600' : 'text-gray-400' %>"><%= driftedDocs %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Errors</p>
      <p class="text-3xl font-bold <%= errorDocs > 0 ? 'text-red-600' : 'text-gray-400' %>"><%= errorDocs %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center" title="Purchases never sent to KashFlow<%= neverSentExcluded > 0 ? ` — excludes ${neverSentExcluded} statements/subcontractor docs/credits/original-pdf-tagged docs` : '' %>">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Never Sent</p>
      <p class="text-3xl font-bold text-gray-600 dark:text-gray-300"><%= neverSentEligible %></p>
      <% if (neverSentExcluded > 0) { %><p class="text-[10px] text-gray-400">+<%= neverSentExcluded %> excluded</p><% } %>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Ingest Errors</p>
      <p class="text-3xl font-bold <%= ingestStats.error > 0 ? 'text-red-600' : 'text-gray-400' %>"><%= ingestStats.error || 0 %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border <%- addedNoKfNumber > 0 ? 'border-amber-400 dark:border-amber-600' : 'border-gray-200 dark:border-gray-700' %> rounded-2xl shadow-lg p-4 text-center" title="Tagged 'added' in Paperless but no KashFlow purchase number recorded">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Missing KF Link</p>
      <p class="text-3xl font-bold <%- addedNoKfNumber > 0 ? 'text-amber-600' : 'text-gray-400' %>"><%= addedNoKfNumber %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border <%- possibleReuploadCount > 0 ? 'border-blue-400 dark:border-blue-600' : 'border-gray-200 dark:border-gray-700' %> rounded-2xl shadow-lg p-4 text-center" title="Deleted Paperless documents with a matching content hash in a live document — likely re-uploads">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Possible Re-uploads</p>
      <p class="text-3xl font-bold <%- possibleReuploadCount > 0 ? 'text-blue-600' : 'text-gray-400' %>"><%= possibleReuploadCount %></p>
    </div>
  </div>

  <!-- Send Mode pills -->
  <div class="mb-6 flex flex-wrap gap-3">
    <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400">
      Direct: <strong class="ml-1"><%= sentDirect %></strong>
    </span>
    <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-800/20 dark:text-blue-400">
      Webhook: <strong class="ml-1"><%= sentWebhook %></strong>
    </span>
    <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300">
      Never Sent: <strong class="ml-1"><%= neverSent %></strong>
    </span>
    <% if (sentButUnlinked > 0) { %>
    <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-800/20 dark:text-yellow-400" title="Sent to KashFlow but KashFlow purchase ID was not saved back to MongoDB">
      Sent but Unlinked: <strong class="ml-1"><%= sentButUnlinked %></strong>
    </span>
    <% } %>
    <% if (hasNumberNoId > 0) { %>
    <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-orange-100 text-orange-800 dark:bg-orange-800/20 dark:text-orange-400" title="Unlinked but have a KashFlow purchase number — can be auto-resolved">
      Has KF# (no ID): <strong class="ml-1"><%= hasNumberNoId %></strong>
    </span>
    <% } %>
    <% if (ingestStats.total > 0) { %>
    <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-800/20 dark:text-indigo-400">
      Ingest Records: <strong class="ml-1"><%= ingestStats.total %></strong>
    </span>
    <% } %>
  </div>

  <!-- By Document Type -->
  <% if (byDocType.length > 0) { %>
  <div class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4">By Document Type</h2>
    <div class="flex flex-wrap gap-3">
      <% for (const dt of byDocType) { %>
        <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300">
          <%= dt._id || 'Uncategorised' %>: <strong class="ml-1"><%= dt.count %></strong>
        </span>
      <% } %>
    </div>
  </div>
  <% } %>

  <!-- ── CF Drift ──────────────────────────────────────────────────────────── -->
  <% if (driftedDocs > 0) { %>
  <details class="mb-6 group border border-purple-300 dark:border-purple-700 bg-purple-50 dark:bg-purple-900/20 rounded-2xl" <%= driftedDocs <= 10 ? 'open' : '' %>>
    <summary class="flex items-center justify-between gap-4 p-4 cursor-pointer list-none">
      <div class="flex items-center gap-3 min-w-0 flex-1">
        <span class="text-lg font-bold text-purple-700 dark:text-purple-400">&#9888; Custom Field Drift (<%= driftedDocs %>)</span>
        <span class="text-sm text-purple-600 dark:text-purple-300 hidden sm:block">MongoDB / Paperless custom field mismatch</span>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <form method="POST" action="/paperless/repair-drift" data-submit-once>
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          <button type="submit" data-submit-once-text="Running…" class="inline-flex items-center gap-1 bg-purple-600 hover:bg-purple-700 text-white rounded-lg px-3 py-1.5 text-sm font-medium transition shadow-sm">Fix All</button>
        </form>
        <span class="text-purple-400 text-sm group-open:hidden">▼</span>
        <span class="text-purple-400 text-sm hidden group-open:inline">▲</span>
      </div>
    </summary>
    <div class="overflow-x-auto px-4 pb-4">
      <table class="min-w-full text-sm">
        <thead><tr class="text-left text-xs text-purple-600 dark:text-purple-400 border-b border-purple-200 dark:border-purple-800">
          <th class="pb-1 pr-3 font-medium">ID</th><th class="pb-1 pr-3 font-medium">Title</th><th class="pb-1 pr-3 font-medium">Type</th><th class="pb-1 pr-3 font-medium">MongoDB KF ID</th><th class="pb-1 pr-3 font-medium">Paperless Custom Field</th><th class="pb-1 font-medium">Links</th>
        </tr></thead>
        <tbody class="divide-y divide-purple-100 dark:divide-purple-900">
          <% for (const d of driftedDocsList) { %>
          <tr>
            <td class="py-1.5 pr-3 font-mono text-xs text-gray-500"><%= d.paperlessId %></td>
            <td class="py-1.5 pr-3 max-w-xs truncate"><a href="/paperless/ocr/<%= d.paperlessId %>" class="text-purple-700 dark:text-purple-300 hover:underline font-medium"><%= d.title || '—' %></a></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500"><%= d.documentType?.name || '—' %></td>
            <td class="py-1.5 pr-3 font-mono text-xs <%= d.kashflowPurchaseId ? 'text-green-700 dark:text-green-400' : 'text-red-500' %>"><%= d.kashflowPurchaseId ?? '—' %></td>
            <td class="py-1.5 pr-3 font-mono text-xs <%= d._cfKfId ? 'text-green-700 dark:text-green-400' : 'text-red-500' %>"><%= d._cfKfId ?? '—' %></td>
            <td class="py-1.5 whitespace-nowrap text-xs">
              <a href="<%= plUrl(d.paperlessId) %>" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-green-600 mr-2">Paperless ↗</a>
              <% if (kfUrl(d)) { %><a href="<%= kfUrl(d) %>" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-blue-600">KashFlow ↗</a><% } %>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% if (driftedDocs > driftedDocsList.length) { %><p class="text-xs text-purple-500 mt-2">Showing <%= driftedDocsList.length %> of <%= driftedDocs %></p><% } %>
    </div>
  </details>
  <% } %>

  <!-- ── Deleted in Paperless ─────────────────────────────────────────────── -->
  <% if (deletedInPaperless > 0) { %>
  <details class="mb-6 group border border-rose-300 dark:border-rose-700 bg-rose-50 dark:bg-rose-900/20 rounded-2xl" <%= deletedInPaperless <= 10 ? 'open' : '' %>>
    <summary class="flex items-center justify-between gap-4 p-4 cursor-pointer list-none">
      <div class="flex items-center gap-3 min-w-0 flex-1">
        <div class="min-w-0">
          <span class="text-lg font-bold text-rose-700 dark:text-rose-400">&#9888; Deleted in Paperless (<%= deletedInPaperless %>)</span>
          <span class="text-sm text-rose-600 dark:text-rose-300 hidden sm:inline ml-2">Still in MongoDB but no longer exist in Paperless</span>
        </div>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <span class="text-rose-400 text-sm group-open:hidden">&#9660;</span><span class="text-rose-400 text-sm hidden group-open:inline">&#9650;</span>
      </div>
    </summary>
    <div class="overflow-x-auto px-4 pb-4">
      <p class="text-xs text-rose-600 dark:text-rose-300 mb-2">These documents were removed from Paperless after ingestion. If one was linked to a KashFlow purchase, check whether a re-uploaded replacement should carry the link before removing. Remove deletes the MongoDB copy and its ingest record.</p>
      <table class="min-w-full text-sm">
        <thead><tr class="text-left text-xs text-rose-600 dark:text-rose-400 border-b border-rose-200 dark:border-rose-800">
          <th class="pb-1 pr-3 font-medium">ID</th><th class="pb-1 pr-3 font-medium">Title</th><th class="pb-1 pr-3 font-medium">Type</th><th class="pb-1 pr-3 font-medium">KF Link</th><th class="pb-1 pr-3 font-medium">Noticed</th><th class="pb-1 font-medium">Actions</th>
        </tr></thead>
        <tbody class="divide-y divide-rose-100 dark:divide-rose-900">
          <% for (const d of deletedInPaperlessList) { %>
          <tr>
            <td class="py-1.5 pr-3 font-mono text-xs text-gray-500"><%= d.paperlessId %></td>
            <td class="py-1.5 pr-3 max-w-xs truncate"><a href="/paperless/ocr/<%= d.paperlessId %>" class="text-rose-700 dark:text-rose-300 hover:underline font-medium"><%= d.title || '—' %></a></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500"><%= d.documentType?.name || '—' %></td>
            <td class="py-1.5 pr-3 font-mono text-xs <%= d.kashflowPurchaseId ? 'text-amber-600 dark:text-amber-400' : 'text-gray-400' %>"><%= d.kashflowPurchaseId ? ('#' + (d.kashflowPurchaseNumber ?? d.kashflowPurchaseId)) : '—' %></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500"><%= d.deletedInPaperlessAt ? fmtDate(d.deletedInPaperlessAt, 'dd/MM/yyyy HH:mm') : '—' %></td>
            <td class="py-1.5 whitespace-nowrap text-xs">
              <form method="POST" action="/paperless/ocr/<%= d.paperlessId %>/remove" data-submit-once class="inline">
                <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
                <button type="submit" data-submit-once-text="Removing…" class="inline-flex items-center gap-1 bg-rose-600 hover:bg-rose-700 text-white rounded px-2 py-1 text-xs font-medium transition shadow-sm" onclick="return confirm('Remove the MongoDB copy of document #<%= d.paperlessId %>? This cannot be undone.')">Remove</button>
              </form>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% if (deletedInPaperless > deletedInPaperlessList.length) { %><p class="text-xs text-rose-500 mt-2">Showing <%= deletedInPaperlessList.length %> of <%= deletedInPaperless %></p><% } %>
    </div>
  </details>
  <% } %>

  <!-- ── Missing KashFlow Link ────────────────────────────────────────────── -->
  <% if (addedNoKfNumber > 0) { %>
  <div class="mb-8 border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 rounded-2xl p-4">
    <h2 class="text-xl font-bold text-amber-700 dark:text-amber-400 mb-2">&#9888; Missing KashFlow Link (<%= addedNoKfNumber %>)</h2>
    <p class="text-sm text-amber-800 dark:text-amber-300">
      <%= addedNoKfNumber %> document<%= addedNoKfNumber !== 1 ? 's are' : ' is' %> tagged <strong>added</strong> in Paperless but have no KashFlow Purchase Number recorded.
      They may have been sent outside this system. Open each document in
      <a href="https://docs.heroncs.co.uk" target="_blank" rel="noopener noreferrer" class="underline font-medium">docs.heroncs.co.uk</a>,
      enter the <strong>KashFlow Purchase Number</strong> custom field, then re-fetch the document to link it automatically.
    </p>
    <div class="mt-2">
      <a href="/paperless/ocr?tag=added&noKfNumber=1" class="inline-flex items-center gap-1.5 bg-amber-600 hover:bg-amber-700 text-white rounded-lg px-4 py-2 text-sm font-medium transition shadow-sm">View affected documents &rarr;</a>
    </div>
  </div>
  <% } %>

  <!-- ── Possible Re-uploads ──────────────────────────────────────────────── -->
  <% if (possibleReuploadCount > 0) { %>
  <details class="mb-6 group border border-blue-300 dark:border-blue-700 bg-blue-50 dark:bg-blue-900/20 rounded-2xl" open>
    <summary class="flex items-center justify-between gap-4 p-4 cursor-pointer list-none">
      <div class="flex items-center gap-3 min-w-0 flex-1">
        <span class="text-lg font-bold text-blue-700 dark:text-blue-400">&#8635; Possible Re-uploads (<%= possibleReuploadCount %>)</span>
        <span class="text-sm text-blue-600 dark:text-blue-300 hidden sm:block">Deleted documents with a matching content hash in a live document</span>
      </div>
      <span class="text-blue-400 text-sm group-open:hidden">&#9660;</span>
      <span class="text-blue-400 text-sm hidden group-open:inline">&#9650;</span>
    </summary>
    <div class="overflow-x-auto px-4 pb-4">
      <table class="min-w-full text-sm">
        <thead><tr class="text-left text-xs text-blue-600 dark:text-blue-400 border-b border-blue-200 dark:border-blue-800">
          <th class="pb-1 pr-3 font-medium">Deleted ID</th>
          <th class="pb-1 pr-3 font-medium">Deleted Title</th>
          <th class="pb-1 pr-3 font-medium">Surviving ID</th>
          <th class="pb-1 font-medium">Surviving Title</th>
        </tr></thead>
        <tbody class="divide-y divide-blue-100 dark:divide-blue-900">
          <% for (const r of possibleReuploadList) { %>
          <tr>
            <td class="py-1.5 pr-3 font-mono text-xs text-gray-500"><a href="/paperless/ocr/<%= r.deletedId %>" class="hover:underline"><%= r.deletedId %></a></td>
            <td class="py-1.5 pr-3 max-w-xs truncate text-gray-500"><%= r.deletedDoc?.title || '—' %></td>
            <td class="py-1.5 pr-3 font-mono text-xs"><a href="/paperless/ocr/<%= r.survivingId %>" class="text-blue-700 dark:text-blue-300 hover:underline font-medium"><%= r.survivingId %></a></td>
            <td class="py-1.5 max-w-xs truncate"><a href="/paperless/ocr/<%= r.survivingId %>" class="text-blue-700 dark:text-blue-300 hover:underline"><%= r.survivingDoc?.title || '—' %></a></td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% if (possibleReuploadCount > possibleReuploadList.length) { %><p class="text-xs text-blue-500 mt-2">Showing <%= possibleReuploadList.length %> of <%= possibleReuploadCount %></p><% } %>
    </div>
  </details>
  <% } %>

  <!-- ── Document Errors ───────────────────────────────────────────────────── -->
  <% if (errorDocsList.length > 0) { %>
  <details class="mb-6 group border border-red-300 dark:border-red-700 bg-red-50 dark:bg-red-900/20 rounded-2xl" open>
    <summary class="flex items-center justify-between gap-4 p-4 cursor-pointer list-none">
      <span class="text-lg font-bold text-red-700 dark:text-red-400">&#9888; Document Errors (<%= errorDocs %>)</span>
      <span class="text-red-400 text-sm group-open:hidden">▼</span><span class="text-red-400 text-sm hidden group-open:inline">▲</span>
    </summary>
    <div class="overflow-x-auto px-4 pb-4">
      <table class="min-w-full text-sm">
        <thead><tr class="text-left text-xs text-red-600 dark:text-red-400 border-b border-red-200 dark:border-red-800">
          <th class="pb-1 pr-3 font-medium">ID</th><th class="pb-1 pr-3 font-medium">Title</th><th class="pb-1 pr-3 font-medium">Type</th><th class="pb-1 pr-3 font-medium">Error</th><th class="pb-1 pr-3 font-medium">Fetched</th><th class="pb-1 font-medium">Links</th>
        </tr></thead>
        <tbody class="divide-y divide-red-100 dark:divide-red-900">
          <% for (const d of errorDocsList) { %>
          <tr>
            <td class="py-1.5 pr-3 font-mono text-xs text-gray-500"><%= d.paperlessId %></td>
            <td class="py-1.5 pr-3 max-w-xs truncate"><a href="/paperless/ocr/<%= d.paperlessId %>" class="text-red-700 dark:text-red-300 hover:underline font-medium"><%= d.title || '—' %></a></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500"><%= d.documentType?.name || '—' %></td>
            <td class="py-1.5 pr-3 text-xs text-red-600 max-w-xs truncate" title="<%= d.error %>"><%= d.error %></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500 whitespace-nowrap"><%= fmt(d.fetchedAt) %></td>
            <td class="py-1.5 whitespace-nowrap text-xs"><a href="<%= plUrl(d.paperlessId) %>" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-green-600">Paperless ↗</a></td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% if (errorDocs > errorDocsList.length) { %><p class="text-xs text-red-500 mt-2">Showing <%= errorDocsList.length %> of <%= errorDocs %></p><% } %>
    </div>
  </details>
  <% } %>

  <!-- ── Never Sent ────────────────────────────────────────────────────────── -->
  <% if (neverSentList.length > 0) { %>
  <details class="mb-6 group border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800/50 rounded-2xl">
    <summary class="flex items-center justify-between gap-4 p-4 cursor-pointer list-none">
      <div class="min-w-0">
        <span class="text-lg font-bold text-gray-700 dark:text-gray-300">Never Sent to KashFlow (<%= neverSentEligible %>)</span>
        <% if (neverSentExcluded > 0) { %><span class="block text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= neverSentExcluded %> statements, subcontractor docs, credits/refunds, reference originals and manually-added-to-KashFlow docs are excluded — the app never sends them.</span><% } %>
      </div>
      <span class="text-gray-400 text-sm group-open:hidden">▼</span><span class="text-gray-400 text-sm hidden group-open:inline">▲</span>
    </summary>
    <div class="overflow-x-auto px-4 pb-4">
      <table class="min-w-full text-sm">
        <thead><tr class="text-left text-xs text-gray-500 border-b border-gray-200 dark:border-gray-700">
          <th class="pb-1 pr-3 font-medium">ID</th><th class="pb-1 pr-3 font-medium">Title</th><th class="pb-1 pr-3 font-medium">Type</th><th class="pb-1 pr-3 font-medium">Added</th><th class="pb-1 font-medium">Links</th>
        </tr></thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          <% for (const d of neverSentList) { %>
          <tr>
            <td class="py-1.5 pr-3 font-mono text-xs text-gray-500"><%= d.paperlessId %></td>
            <td class="py-1.5 pr-3 max-w-xs truncate"><a href="/paperless/ocr/<%= d.paperlessId %>" class="text-gray-800 dark:text-gray-200 hover:underline font-medium"><%= d.title || '—' %></a></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500"><%= d.documentType?.name || '—' %></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500 whitespace-nowrap"><%= fmt(d.added) %></td>
            <td class="py-1.5 whitespace-nowrap text-xs"><a href="<%= plUrl(d.paperlessId) %>" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-green-600">Paperless ↗</a></td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% if (neverSent > neverSentList.length) { %><p class="text-xs text-gray-500 mt-2">Showing <%= neverSentList.length %> of <%= neverSent %></p><% } %>
    </div>
  </details>
  <% } %>

  <!-- ── Ingest Errors ─────────────────────────────────────────────────────── -->
  <% if (ingestErrorsList.length > 0) { %>
  <details class="mb-6 group border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/10 rounded-2xl" open>
    <summary class="flex items-center justify-between gap-4 p-4 cursor-pointer list-none">
      <span class="text-lg font-bold text-red-600 dark:text-red-400">&#9888; Ingest Errors (<%= ingestStats.error %>)</span>
      <span class="text-red-400 text-sm group-open:hidden">▼</span><span class="text-red-400 text-sm hidden group-open:inline">▲</span>
    </summary>
    <div class="overflow-x-auto px-4 pb-4">
      <table class="min-w-full text-sm">
        <thead><tr class="text-left text-xs text-red-500 border-b border-red-200 dark:border-red-800">
          <th class="pb-1 pr-3 font-medium">Paperless ID</th><th class="pb-1 pr-3 font-medium">Error</th><th class="pb-1 pr-3 font-medium">Last Attempt</th><th class="pb-1 font-medium">Links</th>
        </tr></thead>
        <tbody class="divide-y divide-red-100 dark:divide-red-900">
          <% for (const d of ingestErrorsList) { %>
          <tr>
            <td class="py-1.5 pr-3 font-mono text-xs text-gray-500"><%= d.paperlessId %></td>
            <td class="py-1.5 pr-3 text-xs text-red-600 max-w-sm truncate" title="<%= d.error %>"><%= d.error %></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500 whitespace-nowrap"><%= fmt(d.lastFetchedAt) %></td>
            <td class="py-1.5 whitespace-nowrap text-xs">
              <a href="/paperless/ocr/<%= d.paperlessId %>" class="text-gray-500 hover:text-purple-600 mr-2">App ↗</a>
              <a href="<%= plUrl(d.paperlessId) %>" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-green-600">Paperless ↗</a>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% if (ingestStats.error > ingestErrorsList.length) { %><p class="text-xs text-red-500 mt-2">Showing <%= ingestErrorsList.length %> of <%= ingestStats.error %></p><% } %>
    </div>
  </details>
  <% } %>

  <!-- ── Stale Links ───────────────────────────────────────────────────────── -->
  <% if (staleLinkedList.length > 0) { %>
  <details class="mb-6 group border border-orange-300 dark:border-orange-700 bg-orange-50 dark:bg-orange-900/20 rounded-2xl">
    <summary class="flex items-center justify-between gap-4 p-4 cursor-pointer list-none">
      <div class="min-w-0">
        <span class="text-lg font-bold text-orange-700 dark:text-orange-400">&#9888; Stale KashFlow Links (<%= orphanedDocs %>)</span>
        <span class="block text-xs text-orange-600 dark:text-orange-300 mt-0.5">KashFlow purchase no longer exists. Use Clear Now to remove the stale links. Documents sent within the last 48 hours are held (marked below) to allow hcs-sync time to pick up the new purchase.</span>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <form method="POST" action="/paperless/clear-orphans" data-submit-once>
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          <button type="submit" data-submit-once-text="Running…" class="inline-flex items-center gap-1 bg-orange-600 hover:bg-orange-700 text-white rounded-lg px-3 py-1.5 text-sm font-medium transition shadow-sm">Clear Now</button>
        </form>
        <span class="text-orange-400 text-sm shrink-0 group-open:hidden">▼</span><span class="text-orange-400 text-sm shrink-0 hidden group-open:inline">▲</span>
      </div>
    </summary>
    <div class="overflow-x-auto px-4 pb-4">
      <table class="min-w-full text-sm">
        <thead><tr class="text-left text-xs text-orange-600 dark:text-orange-400 border-b border-orange-200 dark:border-orange-800">
          <th class="pb-1 pr-3 font-medium">ID</th><th class="pb-1 pr-3 font-medium">Title</th><th class="pb-1 pr-3 font-medium">Type</th><th class="pb-1 pr-3 font-medium">KF Purchase #</th><th class="pb-1 pr-3 font-medium">Last Sent</th><th class="pb-1 font-medium">Links</th>
        </tr></thead>
        <tbody class="divide-y divide-orange-100 dark:divide-orange-900">
          <% for (const d of staleLinkedList) { %>
          <tr>
            <td class="py-1.5 pr-3 font-mono text-xs text-gray-500"><%= d.paperlessId %></td>
            <td class="py-1.5 pr-3 max-w-xs truncate"><a href="/paperless/ocr/<%= d.paperlessId %>" class="text-orange-700 dark:text-orange-300 hover:underline font-medium"><%= d.title || '—' %></a></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500"><%= d.documentType?.name || '—' %></td>
            <td class="py-1.5 pr-3 font-mono text-xs text-gray-600 dark:text-gray-400"><%= d.kashflowPurchaseNumber ?? '—' %></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500 whitespace-nowrap">
              <%= fmt(d.lastSentAt) %>
              <% if (d.lastSentAt && (Date.now() - new Date(d.lastSentAt).getTime()) < 48 * 60 * 60 * 1000) { %>
                <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-orange-200 text-orange-800 dark:bg-orange-800/40 dark:text-orange-300" title="Sent within the last 48 h — held until hcs-sync has had time to pick up the new purchase">held</span>
              <% } %>
            </td>
            <td class="py-1.5 whitespace-nowrap text-xs">
              <a href="<%= plUrl(d.paperlessId) %>" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-green-600 mr-2">Paperless ↗</a>
              <% if (kfUrl(d)) { %><a href="<%= kfUrl(d) %>" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-blue-600">KashFlow ↗</a><% } %>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% if (orphanedDocs > staleLinkedList.length) { %><p class="text-xs text-orange-500 mt-2">Showing <%= staleLinkedList.length %> of <%= orphanedDocs %></p><% } %>
    </div>
  </details>
  <% } %>

  <!-- ── Unlinked ──────────────────────────────────────────────────────────── -->
  <% if (unlinkedDocsList.length > 0) { %>
  <details class="mb-6 group border border-yellow-300 dark:border-yellow-700 bg-yellow-50 dark:bg-yellow-900/20 rounded-2xl">
    <summary class="flex items-center justify-between gap-4 p-4 cursor-pointer list-none">
      <div class="flex items-center gap-3 min-w-0 flex-1">
        <div class="min-w-0">
          <span class="text-lg font-bold text-yellow-700 dark:text-yellow-400">Unlinked Documents (<%= unlinkedDocs %>)</span>
          <% if (hasNumberNoId > 0) { %><span class="text-sm text-orange-600 dark:text-orange-400 hidden sm:inline ml-2"><%= hasNumberNoId %> have a KF number — resolvable</span><% } %>
          <% if (unlinkedExcluded > 0) { %><span class="block text-xs text-yellow-600 dark:text-yellow-500 mt-0.5"><%= unlinkedExcluded %> statements, subcontractor docs, credits/refunds and reference originals ("original/multiple invoice one pdf") are excluded — they are never entered into KashFlow.</span><% } %>
        </div>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <% if (hasNumberNoId > 0) { %>
        <form method="POST" action="/paperless/resolve-numbers" data-submit-once>
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          <button type="submit" data-submit-once-text="Running…" class="inline-flex items-center gap-1 bg-orange-600 hover:bg-orange-700 text-white rounded-lg px-3 py-1.5 text-sm font-medium transition shadow-sm">Resolve Numbers</button>
        </form>
        <% } %>
        <form method="POST" action="/paperless/match-references" data-submit-once title="Cross-check unlinked documents against synced KashFlow purchases by supplier reference (invoice number), validated by amount or supplier name">
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          <button type="submit" data-submit-once-text="Running…" class="inline-flex items-center gap-1 bg-amber-600 hover:bg-amber-700 text-white rounded-lg px-3 py-1.5 text-sm font-medium transition shadow-sm">Match References</button>
        </form>
        <span class="text-yellow-400 text-sm group-open:hidden">▼</span><span class="text-yellow-400 text-sm hidden group-open:inline">▲</span>
      </div>
    </summary>
    <div class="overflow-x-auto px-4 pb-4">
      <table class="min-w-full text-sm">
        <thead><tr class="text-left text-xs text-yellow-600 dark:text-yellow-400 border-b border-yellow-200 dark:border-yellow-800">
          <th class="pb-1 pr-3 font-medium">ID</th><th class="pb-1 pr-3 font-medium">Title</th><th class="pb-1 pr-3 font-medium">Type</th><th class="pb-1 pr-3 font-medium">KF#</th><th class="pb-1 pr-3 font-medium">Send Mode</th><th class="pb-1 pr-3 font-medium">Status</th><th class="pb-1 pr-3 font-medium">Added</th><th class="pb-1 font-medium">Links</th>
        </tr></thead>
        <tbody class="divide-y divide-yellow-100 dark:divide-yellow-900">
          <% for (const d of unlinkedDocsList) { %>
          <tr>
            <td class="py-1.5 pr-3 font-mono text-xs text-gray-500"><%= d.paperlessId %></td>
            <td class="py-1.5 pr-3 max-w-xs truncate"><a href="/paperless/ocr/<%= d.paperlessId %>" class="text-yellow-700 dark:text-yellow-300 hover:underline font-medium"><%= d.title || '—' %></a></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500"><%= d.documentType?.name || '—' %></td>
            <td class="py-1.5 pr-3 font-mono text-xs">
              <% if (d.kashflowPurchaseNumber) { %><span class="text-orange-600 dark:text-orange-400 font-semibold">#<%= d.kashflowPurchaseNumber %></span><% } else { %><span class="text-gray-400">—</span><% } %>
            </td>
            <td class="py-1.5 pr-3 text-xs">
              <% if (d.lastSendMode === 'direct') { %><span class="text-green-600">direct</span>
              <% } else if (d.lastSendMode === 'webhook') { %><span class="text-blue-600">webhook</span>
              <% } else if (d.lastSentAt) { %><span class="text-gray-500">sent</span>
              <% } else { %><span class="text-gray-400">—</span><% } %>
            </td>
            <td class="py-1.5 pr-3 font-mono text-xs text-gray-500"><%= d.lastSendStatus ?? '—' %></td>
            <td class="py-1.5 pr-3 text-xs text-gray-500 whitespace-nowrap"><%= fmt(d.added) %></td>
            <td class="py-1.5 whitespace-nowrap text-xs"><a href="<%= plUrl(d.paperlessId) %>" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-green-600">Paperless ↗</a></td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% if (unlinkedDocs > unlinkedDocsList.length) { %><p class="text-xs text-yellow-600 mt-2">Showing <%= unlinkedDocsList.length %> of <%= unlinkedDocs %> — <a href="/paperless/ocr?unlinked=1" class="underline">view all in Manage Documents</a></p><% } %>
    </div>
  </details>
  <% } %>

  <!-- Recently Added -->
  <div class="mb-8">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Recently Added (<%= recentLimit %>)</h2>
      <a href="/ocrDocuments" class="text-sm text-blue-600 hover:underline">View all documents &rarr;</a>
    </div>
    <div class="flex flex-wrap gap-2">
      <% for (const d of recentDocs) { %>
        <a href="/paperless/ocr/<%= d.paperlessId %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 max-w-xs truncate">
          <%= d.title || '—' %>
          <% if (d.kashflowPurchaseNumber) { %><span class="text-xs text-green-600">#<%= d.kashflowPurchaseNumber %></span><% } %>
        </a>
      <% } %>
    </div>
  </div>

</div>
