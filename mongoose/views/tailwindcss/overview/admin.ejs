<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">

  <!-- Header -->
  <div class="flex justify-between items-center mb-6 print:hidden">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Admin Overview</h1>
    <div class="flex gap-2">
      <a href="/users" class="inline-flex items-center gap-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">All Users</a>
      <a href="/user/create" class="inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition shadow-sm">+ Add User</a>
    </div>
  </div>

  <!-- Summary Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 xl:grid-cols-5 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Total Users</p>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= totalUsers %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Active Sessions</p>
      <p class="text-3xl font-bold text-blue-600"><%= activeSessionCount %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">2FA Enabled</p>
      <p class="text-3xl font-bold text-green-600"><%= with2FA %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">No 2FA</p>
      <p class="text-3xl font-bold <%= without2FA.length > 0 ? 'text-yellow-600' : 'text-gray-400' %>"><%= without2FA.length %></p>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg p-4 text-center">
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Pending Role</p>
      <p class="text-3xl font-bold <%= pendingRoleUsers.length > 0 ? 'text-orange-600' : 'text-gray-400' %>"><%= pendingRoleUsers.length %></p>
    </div>
  </div>

  <!-- Role Breakdown -->
  <div class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4">Users by Role</h2>
    <% const roleColour = { admin: 'bg-red-100 text-red-800 dark:bg-red-800/20 dark:text-red-400', accountant: 'bg-blue-100 text-blue-800 dark:bg-blue-800/20 dark:text-blue-400', employee: 'bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400', subcontractor: 'bg-purple-100 text-purple-800 dark:bg-purple-800/20 dark:text-purple-400', client: 'bg-indigo-100 text-indigo-800 dark:bg-indigo-800/20 dark:text-indigo-400', hmrc: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-800/20 dark:text-yellow-400', none: 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400' }; %>
    <div class="flex flex-wrap gap-3">
      <% for (const [role, count] of Object.entries(byRole)) { %>
        <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium capitalize <%= roleColour[role] || 'bg-gray-100 text-gray-700' %>">
          <%= role %>: <strong class="ml-1"><%= count %></strong>
        </span>
      <% } %>
    </div>
  </div>

  <!-- Pending Role Assignment -->
  <% if (pendingRoleUsers.length > 0) { %>
  <div class="mb-8 border border-orange-300 dark:border-orange-700 bg-orange-50 dark:bg-orange-900/20 rounded-2xl p-4">
    <h2 class="text-xl font-bold text-orange-700 dark:text-orange-400 mb-3">&#9203; Awaiting Role Assignment (<%= pendingRoleUsers.length %>)</h2>
    <ul class="divide-y divide-orange-200 dark:divide-orange-800">
      <% for (const u of pendingRoleUsers) { %>
      <li class="flex items-center justify-between py-1.5 text-sm">
        <div>
          <a href="/user/update/<%= u.uuid %>" class="font-medium text-blue-600 hover:underline"><%= u.username %></a>
          <span class="ml-2 text-gray-500 dark:text-gray-400"><%= u.email %></span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-gray-400 text-xs"><%= slimDateTime(u.createdAt) %></span>
          <a href="/user/update/<%= u.uuid %>" class="text-blue-600 hover:underline text-xs">Assign Role</a>
        </div>
      </li>
      <% } %>
    </ul>
  </div>
  <% } %>

  <!-- Email Unverified -->
  <% if (unverifiedUsers.length > 0) { %>
  <div class="mb-8 border border-yellow-300 dark:border-yellow-700 bg-yellow-50 dark:bg-yellow-900/20 rounded-2xl p-4">
    <h2 class="text-xl font-bold text-yellow-700 dark:text-yellow-400 mb-3">&#9888; Email Not Verified (<%= unverifiedUsers.length %>)</h2>
    <ul class="divide-y divide-yellow-200 dark:divide-yellow-800">
      <% for (const u of unverifiedUsers) { %>
      <li class="flex items-center justify-between py-1.5 text-sm">
        <div>
          <span class="font-medium text-gray-900 dark:text-gray-100"><%= u.username %></span>
          <span class="ml-2 text-gray-500 dark:text-gray-400"><%= u.email %></span>
          <span class="ml-2 capitalize text-gray-400 text-xs"><%= u.role %></span>
        </div>
        <a href="/user/update/<%= u.uuid %>" class="text-blue-600 hover:underline text-xs">View</a>
      </li>
      <% } %>
    </ul>
  </div>
  <% } %>

  <!-- No 2FA -->
  <% if (without2FA.length > 0) { %>
  <div class="mb-8">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-3">&#128274; No 2FA Setup (<%= without2FA.length %>)</h2>
    <div class="flex flex-wrap gap-2">
      <% for (const u of without2FA) { %>
        <a href="/user/update/<%= u.uuid %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
          <%= u.username %><span class="text-xs capitalize text-gray-400 ml-1"><%= u.role %></span>
        </a>
      <% } %>
    </div>
  </div>
  <% } %>

  <!-- Recent Registrations -->
  <% if (recentUsers.length > 0) { %>
  <div class="mb-8">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">&#127381; Recent Registrations (last <%= recentDays %> days) (<%= recentUsers.length %>)</h2>
      <a href="/users" class="text-sm text-blue-600 hover:underline">View all users &rarr;</a>
    </div>
    <div class="flex flex-wrap gap-2">
      <% for (const u of recentUsers) { %>
        <a href="/user/update/<%= u.uuid %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
          <%= u.username %>
          <span class="text-xs text-gray-400"><%= slimDateTime(u.createdAt) %></span>
          <% if (u.totpSecret) { %><span class="text-xs text-green-600">2FA</span><% } %>
        </a>
      <% } %>
    </div>
  </div>
  <% } %>

</div>
