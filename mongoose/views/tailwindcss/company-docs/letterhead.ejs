<div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-8">

  <div class="flex items-center gap-3 mb-6">
    <a href="/company-docs" class="text-sm text-green-700 dark:text-green-400 hover:underline">← Company Documents</a>
    <span class="text-gray-400">/</span>
    <h1 class="text-xl font-bold">Letterhead Settings</h1>
  </div>

  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm p-6">
    <form method="POST" action="/company-docs/letterhead" enctype="multipart/form-data" class="space-y-6">
      <%- include('../partials/csrfHidden') %>

      <!-- Company identity -->
      <div>
        <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-4">Company Identity</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Company Name</label>
            <input type="text" name="companyName" value="<%= letterhead.companyName || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tagline</label>
            <input type="text" name="tagline" value="<%= letterhead.tagline || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Company Registration No.</label>
            <input type="text" name="registrationNumber" value="<%= letterhead.registrationNumber || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">VAT Registration No.</label>
            <input type="text" name="vatNumber" value="<%= letterhead.vatNumber || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
        </div>
      </div>

      <!-- Address -->
      <div>
        <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-4">Address</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Address Line 1</label>
            <input type="text" name="addressLine1" value="<%= letterhead.addressLine1 || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Address Line 2</label>
            <input type="text" name="addressLine2" value="<%= letterhead.addressLine2 || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Town / City</label>
            <input type="text" name="town" value="<%= letterhead.town || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">County</label>
            <input type="text" name="county" value="<%= letterhead.county || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Postcode</label>
            <input type="text" name="postcode" value="<%= letterhead.postcode || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-4">Contact Details</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Phone</label>
            <input type="tel" name="phone" value="<%= letterhead.phone || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email</label>
            <input type="email" name="email" value="<%= letterhead.email || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Website</label>
            <input type="url" name="website" value="<%= letterhead.website || '' %>"
              class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
          </div>
        </div>
      </div>

      <!-- Logo -->
      <div>
        <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-4">Logo</h2>
        <% if (letterhead.logoPath) { %>
          <div class="mb-3 flex items-center gap-3">
            <img src="<%= letterhead.logoPath %>" alt="Current logo" class="h-16 object-contain border border-gray-200 dark:border-gray-700 rounded-lg p-1 bg-white">
            <span class="text-xs text-gray-500 dark:text-gray-400">Current logo</span>
          </div>
        <% } %>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
          <%= letterhead.logoPath ? 'Replace logo' : 'Upload logo' %> <span class="text-gray-400">(JPEG, PNG, SVG — max 2 MB)</span>
        </label>
        <input type="file" name="logo" accept="image/*"
          class="block text-sm text-gray-700 dark:text-gray-300 file:mr-4 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-green-50 file:text-green-700 dark:file:bg-green-900/30 dark:file:text-green-300 hover:file:bg-green-100 dark:hover:file:bg-green-900/50">
      </div>

      <!-- Footer text -->
      <div>
        <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-4">Document Footer</h2>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
          Footer text <span class="text-gray-400">(e.g. registered address, small print)</span>
        </label>
        <textarea name="footerText" rows="2"
          class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500"><%= letterhead.footerText || '' %></textarea>
      </div>

      <div class="flex justify-end pt-2">
        <button type="submit"
          class="inline-flex items-center gap-2 px-5 py-2 rounded-lg bg-green-600 hover:bg-green-700 text-white text-sm font-medium transition">
          <i class="bi bi-check-lg"></i> Save Letterhead
        </button>
      </div>
    </form>
  </div>

</div>
