<div class="max-w-5xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">

  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
    <div class="flex items-center gap-3">
      <a href="/company-docs" class="text-sm text-green-700 dark:text-green-400 hover:underline">← Company Documents</a>
      <span class="text-gray-400">/</span>
      <h1 class="text-xl font-bold">Policies</h1>
    </div>
    <a href="/company-docs/policies/create"
       class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-green-600 hover:bg-green-700 text-white text-sm font-medium transition">
      <i class="bi bi-plus-lg"></i> New Policy
    </a>
  </div>

  <% if (policies.length > 0) { %>
    <div class="flex items-center gap-2 text-sm">
      <span class="text-gray-500 dark:text-gray-400">Group by</span>
      <div class="inline-flex rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
        <% groupOptions.forEach((opt, i) => { %>
          <a href="?groupBy=<%= opt.value %>"
             class="px-3 py-1.5 text-xs font-medium transition <%= i > 0 ? 'border-l border-gray-200 dark:border-gray-700' : '' %> <%= groupBy === opt.value ? 'bg-green-600 text-white' : 'bg-white dark:bg-gray-900 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800' %>">
            <%= opt.label %>
          </a>
        <% }) %>
      </div>
    </div>
  <% } %>

  <% if (policies.length === 0) { %>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm p-12 text-center">
      <i class="bi bi-journal-x text-4xl text-gray-300 dark:text-gray-600 mb-3 block"></i>
      <p class="text-gray-500 dark:text-gray-400 text-sm">No policies yet. Create your first one.</p>
      <a href="/company-docs/policies/create"
         class="mt-4 inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-green-600 hover:bg-green-700 text-white text-sm font-medium transition">
        <i class="bi bi-plus-lg"></i> New Policy
      </a>
    </div>
  <% } else { %>
    <% groups.forEach(group => { %>
      <section class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
        <% const toneDot = { danger: 'bg-red-500', warning: 'bg-amber-500', success: 'bg-green-500' }[group.tone]; %>
        <div class="flex items-center justify-between gap-3 px-4 py-3 bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
          <h2 class="flex items-center gap-2 font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">
            <% if (toneDot) { %><span class="inline-block w-2 h-2 rounded-full <%= toneDot %>"></span><% } %>
            <%= group.label %>
          </h2>
          <span class="text-xs text-gray-400 dark:text-gray-500"><%= group.policies.length %> <%= group.policies.length === 1 ? 'policy' : 'policies' %></span>
        </div>
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
          <thead class="bg-white dark:bg-gray-900">
            <tr>
              <th class="px-4 py-3 text-left font-semibold uppercase tracking-wide text-xs text-gray-500 dark:text-gray-400">Title</th>
              <th class="px-4 py-3 text-left font-semibold uppercase tracking-wide text-xs text-gray-500 dark:text-gray-400 hidden md:table-cell">Version</th>
              <th class="px-4 py-3 text-left font-semibold uppercase tracking-wide text-xs text-gray-500 dark:text-gray-400 hidden md:table-cell">Review</th>
              <th class="px-4 py-3 text-left font-semibold uppercase tracking-wide text-xs text-gray-500 dark:text-gray-400 hidden sm:table-cell">Status</th>
              <th class="px-4 py-3 text-right font-semibold uppercase tracking-wide text-xs text-gray-500 dark:text-gray-400">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <% group.policies.forEach(policy => { %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition">
                <td class="px-4 py-3">
                  <a href="/company-docs/policies/<%= policy.uuid %>/print"
                     class="font-medium text-green-700 dark:text-green-400 hover:underline">
                    <%= policy.title %>
                  </a>
                  <% if (policy.employee && policy.employee.name) { %>
                    <span class="ml-2 inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300">
                      <i class="bi bi-person"></i> <%= policy.employee.name %>
                    </span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-gray-500 dark:text-gray-400 hidden md:table-cell">v<%= policy.version %></td>
                <td class="px-4 py-3 hidden md:table-cell">
                  <% if (policy.effectiveReviewDate) { %>
                    <% const reviewTone = policy.reviewState === 'expired'
                         ? 'bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300'
                         : policy.reviewState === 'due'
                         ? 'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300'
                         : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300'; %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium <%= reviewTone %>"
                          title="<%= policy.reviewState === 'expired' ? 'Out of date' : policy.reviewState === 'due' ? 'Due soon' : 'Up to date' %>">
                      <% if (policy.reviewState === 'expired') { %><i class="bi bi-exclamation-triangle-fill"></i><% } else if (policy.reviewState === 'due') { %><i class="bi bi-clock-history"></i><% } %>
                      <%= policy.effectiveReviewDate %>
                    </span>
                  <% } else { %>
                    <span class="text-xs text-gray-400 dark:text-gray-500">—</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell">
                  <% if (policy.isPublished) { %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300">
                      <i class="bi bi-check-circle-fill"></i> Published
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
                      <i class="bi bi-dash-circle"></i> Draft
                    </span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <a href="/company-docs/policies/<%= policy.uuid %>/print"
                       class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition">
                      <i class="bi bi-eye"></i> View
                    </a>
                    <a href="/company-docs/policies/<%= policy.uuid %>/edit"
                       class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition">
                      <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form method="POST" action="/company-docs/policies/<%= policy.uuid %>/delete"
                          data-confirm="Delete '<%= policy.title %>'? This cannot be undone.">
                      <%- include('../partials/csrfHidden') %>
                      <button type="submit"
                        class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/30 transition">
                        <i class="bi bi-trash"></i> Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    <% }) %>
  <% } %>

</div>
