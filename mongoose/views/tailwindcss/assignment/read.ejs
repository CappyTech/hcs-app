<%
  // Streamlined assignment detail view. Resolved refs (contract, employees,
  // subcontractors) are provided by the assignment config's readLocals.
  const _status = item.status || 'Planned';
  const _emps = (typeof employees !== 'undefined' && Array.isArray(employees)) ? employees : [];
  const _subs = (typeof subcontractors !== 'undefined' && Array.isArray(subcontractors)) ? subcontractors : [];
  const _contract = (typeof contract !== 'undefined') ? contract : null;
%>
<div class="max-w-3xl mx-auto py-8 px-4 sm:px-6 lg:px-8 space-y-5">
  <a href="/assignments" class="inline-flex items-center gap-1.5 text-sm text-green-600 dark:text-green-400 hover:underline font-medium"><i class="bi bi-arrow-left"></i> Go Back</a>

  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <div class="p-6 sm:p-8 space-y-6">

      <!-- Header: title + status, contract subtitle, actions -->
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 break-words"><%= item.title %></h1>
            <%- include('../partials/_status-badge', { status: _status }) %>
          </div>
          <% if (_contract) { %>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
              <i class="bi bi-folder2-open mr-1"></i>
              <a href="/contract/read/<%= _contract.uuid %>" class="text-green-600 dark:text-green-400 hover:underline"><%= _contract.name %></a>
            </p>
          <% } %>
        </div>
        <%- include('../partials/_detail-actions', { basePath: 'assignment', item }) %>
      </div>

      <!-- Meta grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Week Start</div>
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= item.weekStart ? slimDateTime(item.weekStart, ['displayFormat']) : '—' %></div>
        </div>
        <% if (item.estimatedHours != null && item.estimatedHours !== '') { %>
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Estimated Hours</div>
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= item.estimatedHours %></div>
        </div>
        <% } %>
        <% if (item.createdAt) { %>
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Created</div>
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= slimDateTime(item.createdAt, ['displayFormat']) %></div>
        </div>
        <% } %>
      </div>

      <!-- People -->
      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <h2 class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-2"><i class="bi bi-people mr-1"></i>Assigned Employees</h2>
          <% if (_emps.length) { %>
            <div class="flex flex-wrap gap-1.5">
              <% _emps.forEach(e => { %>
                <a href="/employee/read/<%= e.uuid %>" class="inline-flex items-center gap-1.5 rounded-full bg-green-100 dark:bg-green-800/20 text-green-800 dark:text-green-400 px-3 py-1 text-sm font-medium hover:underline">
                  <i class="bi bi-person-fill"></i><%= e.name %>
                </a>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-sm text-gray-400 dark:text-gray-500 italic">None assigned.</p>
          <% } %>
        </div>
        <div>
          <h2 class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-2"><i class="bi bi-person-badge mr-1"></i>Assigned Subcontractors</h2>
          <% if (_subs.length) { %>
            <div class="flex flex-wrap gap-1.5">
              <% _subs.forEach(s => { %>
                <a href="/supplier/read/<%= s.uuid %>" class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 dark:bg-blue-800/20 text-blue-800 dark:text-blue-400 px-3 py-1 text-sm font-medium hover:underline">
                  <i class="bi bi-person-badge-fill"></i><%= s.name %>
                </a>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-sm text-gray-400 dark:text-gray-500 italic">None assigned.</p>
          <% } %>
        </div>
      </div>

      <!-- Description -->
      <% if (item.description && String(item.description).trim()) { %>
        <div>
          <h2 class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1"><i class="bi bi-card-text mr-1"></i>Description</h2>
          <p class="text-sm text-gray-800 dark:text-gray-200 whitespace-pre-line leading-relaxed"><%= item.description %></p>
        </div>
      <% } %>

    </div>
  </div>
</div>
