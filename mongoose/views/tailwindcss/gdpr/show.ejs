<div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">

  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm">
    <div class="p-6 sm:p-8 space-y-4">

      <div>
        <a href="/gdpr/requests" class="text-sm text-green-700 dark:text-green-400 hover:underline">
          &larr; Back to My Requests
        </a>
        <div class="mt-2 flex items-center gap-3 flex-wrap">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= title %></h1>
          <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold <%= STATUS_CLASSES[request.status] || '' %>">
            <%= request.status.replace('_', ' ') %>
          </span>
        </div>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          <%= TYPE_LABELS[request.type] || request.type %>
        </p>
      </div>

      <!-- Details grid -->
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm pt-2 border-t border-gray-100 dark:border-gray-800">
        <div>
          <dt class="text-gray-400 dark:text-gray-500 uppercase text-xs tracking-wide">Submitted</dt>
          <dd class="mt-0.5 text-gray-900 dark:text-gray-100 font-medium">
            <%= new Date(request.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
          </dd>
        </div>
        <div>
          <dt class="text-gray-400 dark:text-gray-500 uppercase text-xs tracking-wide">Response Deadline</dt>
          <dd class="mt-0.5 font-medium
            <% const dl = request.deadline ? new Date(request.deadline) : null; %>
            <% const overdue = dl && dl < new Date() && !['completed','rejected','withdrawn'].includes(request.status); %>
            <%= overdue ? 'text-red-600' : 'text-gray-900 dark:text-gray-100' %>">
            <% if (dl) { %><%= dl.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %><% } else { %>—<% } %>
            <% if (overdue) { %><span class="ml-1 text-xs">(overdue)</span><% } %>
          </dd>
        </div>
        <% if (request.reviewedAt) { %>
          <div>
            <dt class="text-gray-400 dark:text-gray-500 uppercase text-xs tracking-wide">Reviewed</dt>
            <dd class="mt-0.5 text-gray-900 dark:text-gray-100 font-medium">
              <%= new Date(request.reviewedAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            </dd>
          </div>
        <% } %>
        <% if (request.completedAt) { %>
          <div>
            <dt class="text-gray-400 dark:text-gray-500 uppercase text-xs tracking-wide">Completed</dt>
            <dd class="mt-0.5 text-gray-900 dark:text-gray-100 font-medium">
              <%= new Date(request.completedAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            </dd>
          </div>
        <% } %>
      </dl>

      <!-- Description -->
      <% if (request.description) { %>
        <div class="pt-2 border-t border-gray-100 dark:border-gray-800">
          <p class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 mb-1">Your Description</p>
          <p class="text-sm text-gray-700 dark:text-gray-300 whitespace-pre-wrap"><%= request.description %></p>
        </div>
      <% } %>

      <!-- Admin notes — only shown once request has been reviewed -->
      <% if (request.adminNotes && ['approved','rejected','completed','under_review'].includes(request.status)) { %>
        <div class="rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 px-4 py-3">
          <p class="text-xs uppercase tracking-wide text-blue-500 dark:text-blue-400 mb-1">Administrator Notes</p>
          <p class="text-sm text-blue-800 dark:text-blue-200 whitespace-pre-wrap"><%= request.adminNotes %></p>
        </div>
      <% } %>

      <!-- Withdraw (data subject, pending only) -->
      <% if (!isAdmin && request.status === 'pending') { %>
        <div class="pt-2 border-t border-gray-100 dark:border-gray-800">
          <form method="POST" action="/gdpr/requests/<%= request.uuid %>/withdraw">
            <%- include('../partials/csrfHidden') %>
            <button type="submit"
                    class="text-sm text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-200 font-medium">
              Withdraw this request
            </button>
          </form>
        </div>
      <% } %>

    </div>
  </div>

  <!-- Admin review panel -->
  <% if (isAdmin) { %>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm">
      <div class="p-6 sm:p-8 space-y-4">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Admin Review</h2>

        <% if (!canReview) { %>
          <div class="rounded-lg bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 px-4 py-3 text-sm text-amber-700 dark:text-amber-300">
            <i class="bi bi-shield-exclamation mr-1"></i>
            You submitted this request and cannot review it. Another administrator must action it.
          </div>
        <% } else if (['completed', 'rejected', 'withdrawn'].includes(request.status)) { %>
          <p class="text-sm text-gray-500 dark:text-gray-400">This request is closed (<strong><%= request.status %></strong>) and cannot be updated.</p>
        <% } else { %>
          <form method="POST" action="/admin/gdpr/requests/<%= request.uuid %>/review" class="space-y-4">
            <%- include('../partials/csrfHidden') %>

            <div>
              <label for="status" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                Update Status <span class="text-red-500">*</span>
              </label>
              <select id="status" name="status" required
                      class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500">
                <option value="" disabled selected>— Select new status —</option>
                <option value="under_review"  <%= request.status === 'under_review'  ? 'selected' : '' %>>Under Review</option>
                <option value="approved"      <%= request.status === 'approved'      ? 'selected' : '' %>>Approved</option>
                <option value="rejected"      <%= request.status === 'rejected'      ? 'selected' : '' %>>Rejected</option>
                <option value="completed"     <%= request.status === 'completed'     ? 'selected' : '' %>>Completed</option>
              </select>
            </div>

            <div>
              <label for="adminNotes" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                Admin Notes
                <span class="text-gray-400 font-normal">(will be shown to the requester when the request is reviewed)</span>
              </label>
              <textarea id="adminNotes" name="adminNotes" rows="4" maxlength="2000"
                        class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500"><%= request.adminNotes || '' %></textarea>
            </div>

            <button type="submit"
                    class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition shadow-sm">
              Save Review
            </button>
          </form>
        <% } %>
      </div>
    </div>

    <!-- Audit trail -->
    <% if (request.evidenceLog && request.evidenceLog.length > 0) { %>
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
        <div class="p-6 sm:p-8 space-y-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Audit Trail</h2>
          <ol class="relative border-l border-gray-200 dark:border-gray-700 ml-2 space-y-4">
            <% request.evidenceLog.forEach(function(entry) { %>
              <li class="ml-4">
                <div class="absolute -left-1.5 mt-1.5 h-3 w-3 rounded-full border-2 border-white dark:border-gray-900 bg-gray-400 dark:bg-gray-500"></div>
                <p class="text-sm font-medium text-gray-800 dark:text-gray-200"><%= entry.action.replace(/_/g, ' ') %></p>
                <% if (entry.notes) { %>
                  <p class="text-xs text-gray-500 dark:text-gray-400"><%= entry.notes %></p>
                <% } %>
                <p class="text-xs text-gray-400 dark:text-gray-500">
                  <%= new Date(entry.at).toLocaleString('en-GB') %>
                </p>
              </li>
            <% }); %>
          </ol>
        </div>
      </div>
    <% } %>
  <% } %>

</div>
