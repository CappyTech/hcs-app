<div class="max-w-5xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm">
    <div class="p-6 sm:p-8 space-y-6">

      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= title %></h1>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Your data subject rights requests under UK GDPR.
          </p>
        </div>
        <a href="/gdpr/requests/new"
           class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition shadow-sm">
          <i class="bi bi-plus-lg"></i> New Request
        </a>
      </div>

      <% if (requests.length === 0) { %>
        <div class="rounded-xl border border-dashed border-gray-300 dark:border-gray-600 p-10 text-center">
          <p class="text-gray-500 dark:text-gray-400 text-sm">You have not submitted any GDPR requests yet.</p>
          <a href="/gdpr/requests/new"
             class="mt-4 inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition">
            Submit a Request
          </a>
        </div>
      <% } else { %>
        <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
          <table class="min-w-full text-sm divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800 text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
              <tr>
                <th class="px-4 py-3 text-left">Type</th>
                <th class="px-4 py-3 text-left">Status</th>
                <th class="px-4 py-3 text-left">Submitted</th>
                <th class="px-4 py-3 text-left">Deadline</th>
                <th class="px-4 py-3 text-left"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-800 bg-white dark:bg-gray-900">
              <% requests.forEach(function(r) { %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                  <td class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100">
                    <%= TYPE_LABELS[r.type] || r.type %>
                  </td>
                  <td class="px-4 py-3">
                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold <%= STATUS_CLASSES[r.status] || '' %>">
                      <%= r.status.replace('_', ' ') %>
                    </span>
                  </td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-400">
                    <%= new Date(r.createdAt).toLocaleDateString('en-GB') %>
                  </td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-400">
                    <% const dl = r.deadline ? new Date(r.deadline) : null; %>
                    <% const overdue = dl && dl < new Date() && !['completed','rejected','withdrawn'].includes(r.status); %>
                    <% if (dl) { %>
                      <span class="<%= overdue ? 'text-red-600 font-semibold' : '' %>">
                        <%= dl.toLocaleDateString('en-GB') %>
                        <% if (overdue) { %><i class="bi bi-exclamation-triangle-fill ml-1"></i><% } %>
                      </span>
                    <% } else { %>—<% } %>
                  </td>
                  <td class="px-4 py-3 text-right">
                    <a href="/gdpr/requests/<%= r.uuid %>"
                       class="text-green-700 dark:text-green-400 hover:underline text-xs font-medium">
                      View
                    </a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>

      <p class="text-xs text-gray-400 dark:text-gray-500">
        Under UK GDPR, we must respond to most requests within 30 calendar days. For help, contact your system administrator.
      </p>

    </div>
  </div>
</div>
