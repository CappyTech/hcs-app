<%
  // Streamlined contract detail view. Resolved refs (project, location, quote) and
  // the related assignments list are provided by the contract config's readLocals.
  const _status = item.status || 'Planned';
  const _project = (typeof project !== 'undefined') ? project : null;
  const _location = (typeof location !== 'undefined') ? location : null;
  const _quote = (typeof quote !== 'undefined') ? quote : null;
  const _asgs = (typeof assignments !== 'undefined' && Array.isArray(assignments)) ? assignments : [];
  const _canUpdate = typeof canUpdate !== 'undefined' ? canUpdate : isAdmin;

  // Duration in days (inclusive) when both dates are present.
  let _durationDays = null;
  if (item.startDate && item.endDate) {
    const ms = new Date(item.endDate).getTime() - new Date(item.startDate).getTime();
    if (!Number.isNaN(ms) && ms >= 0) _durationDays = Math.round(ms / 86400000) + 1;
  }
%>
<div class="max-w-5xl mx-auto py-8 px-4 sm:px-6 lg:px-8 space-y-5">
  <a href="/contracts" class="inline-flex items-center gap-1.5 text-sm text-green-600 dark:text-green-400 hover:underline font-medium"><i class="bi bi-arrow-left"></i> Go Back</a>

  <!-- Main card -->
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <div class="p-6 sm:p-8 space-y-6">

      <!-- Header -->
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 break-words"><%= item.title %></h1>
            <%- include('../partials/_status-badge', { status: _status }) %>
          </div>
          <% if (item.location) { %>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><i class="bi bi-geo-alt mr-1"></i><%= item.location %></p>
          <% } %>
        </div>
        <%- include('../partials/_detail-actions', { basePath: 'contract', item }) %>
      </div>

      <!-- Meta grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Start Date</div>
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= item.startDate ? slimDateTime(item.startDate, ['displayFormat']) : '—' %></div>
        </div>
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">End Date</div>
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= item.endDate ? slimDateTime(item.endDate, ['displayFormat']) : '—' %></div>
        </div>
        <% if (_durationDays != null) { %>
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Duration</div>
          <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= _durationDays %> day<%= _durationDays === 1 ? '' : 's' %></div>
        </div>
        <% } %>
        <% if (_project) { %>
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Project</div>
          <div class="text-sm font-medium"><a href="/project/read/<%= _project.uuid %>" class="text-green-600 dark:text-green-400 hover:underline"><%= _project.name %></a></div>
        </div>
        <% } %>
        <% if (_location) { %>
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Location</div>
          <div class="text-sm font-medium"><a href="/location/read/<%= _location.uuid %>" class="text-green-600 dark:text-green-400 hover:underline"><%= _location.name %></a></div>
        </div>
        <% } %>
        <% if (_quote) { %>
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-xl">
          <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Quote</div>
          <div class="text-sm font-medium"><a href="/quote/read/<%= _quote.uuid %>" class="text-green-600 dark:text-green-400 hover:underline"><%= _quote.label %></a></div>
        </div>
        <% } %>
      </div>

      <!-- Notes -->
      <% if (item.notes && String(item.notes).trim()) { %>
        <div>
          <h2 class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1"><i class="bi bi-card-text mr-1"></i>Notes</h2>
          <p class="text-sm text-gray-800 dark:text-gray-200 whitespace-pre-line leading-relaxed"><%= item.notes %></p>
        </div>
      <% } %>

    </div>
  </div>

  <!-- Assignments under this contract -->
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-blue-500 to-blue-400"></div>
    <div class="p-6 sm:p-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100"><i class="bi bi-calendar-week mr-2 text-blue-500"></i>Assignments<% if (_asgs.length) { %> <span class="text-sm font-normal text-gray-400">(<%= _asgs.length %>)</span><% } %></h2>
        <% if (isAuthenticated && _canUpdate) { %>
          <a href="/assignment/create" class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-blue-700 transition shadow-sm"><i class="bi bi-plus-lg"></i><span class="hidden sm:inline">New</span></a>
        <% } %>
      </div>
      <% if (_asgs.length) { %>
        <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
            <thead class="bg-gray-50 dark:bg-gray-800 text-gray-500 dark:text-gray-300">
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wider">Title</th>
                <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wider">Week Start</th>
                <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wider">Status</th>
                <th class="px-4 py-2 text-right text-xs font-medium uppercase tracking-wider">Employees</th>
                <th class="px-4 py-2 text-right text-xs font-medium uppercase tracking-wider">Subs</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
              <% _asgs.forEach(a => { %>
                <tr>
                  <td class="px-4 py-2"><a href="/assignment/read/<%= a.uuid %>" class="text-green-600 dark:text-green-400 hover:underline font-medium"><%= a.title %></a></td>
                  <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><%= a.weekStart ? slimDateTime(a.weekStart, ['displayFormat']) : '—' %></td>
                  <td class="px-4 py-2"><%- include('../partials/_status-badge', { status: a.status || 'Planned' }) %></td>
                  <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= a.empCount %></td>
                  <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= a.subCount %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-sm text-gray-500 dark:text-gray-400 italic">No assignments for this contract yet.</p>
      <% } %>
    </div>
  </div>
</div>
