
  <div class="text-center mb-4">
    <h1 class="text-2xl font-bold gap-2">
      <i class="bi bi-terminal"></i> Application Logs
    </h1>
  </div>

  <!-- Tabs -->
<div class="border-b text-center mb-4" id="log-tabs">
<% ['info', 'debug', 'warn', 'error'].forEach((level) => {
  const colorMap = {
    info: {
      text: 'text-blue-600 dark:text-blue-400 blind:text-blue-600',
      hover: 'hover:text-blue-100 dark:hover:text-blue-800 blind:hover:text-blue-100'
    },
    debug: {
      text: 'text-amber-600 dark:text-yellow-400 blind:text-cyan-600',
      hover: 'hover:text-amber-100 dark:hover:text-yellow-800 blind:hover:text-cyan-100'
    },
    warn: {
      text: 'text-yellow-600 dark:text-yellow-400 blind:text-orange-600',
      hover: 'hover:text-yellow-100 dark:hover:text-yellow-800 blind:hover:text-orange-100'
    },
    error: {
      text: 'text-red-600 dark:text-red-400 blind:text-rose-600',
      hover: 'hover:text-red-100 dark:hover:text-red-800 blind:hover:text-rose-100'
    }
  };
%>
  <button
    class="
      tab-btn
      px-4
      py-2
      border-b-2
      text-sm
      font-medium
      transition-all
      <%= colorMap[level].text %>
      <%= colorMap[level].hover %>
    "
    data-target="log-<%= level %>"
  >
    <%= level.charAt(0).toUpperCase() + level.slice(1) %>
    <span class="ml-1 text-xs bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 px-2 py-1 rounded-full">
      <%= logsByLevel[level].length %>
    </span>
  </button>
<% }) %>
</div>


  <!-- Tab Panels -->
  <div id="log-panels">
    <% ['info', 'debug' , 'warn' , 'error' ].forEach((level, i)=> { %>
      <div id="log-<%= level %>" class="tab-panel flex flex-col-reverse <%= i !== 0 ? 'hidden' : '' %>">
        <% if (logsByLevel[level].length> 0) { %>
          <% logsByLevel[level].slice().sort((b, a) => new Date(a.timestamp) - new Date(b.timestamp)).forEach(entry => { %>
            <div class="border p-3 rounded bg-white dark:bg-gray-800 shadow-sm">
              <div class="flex justify-between text-xs text-gray-500 mb-1">
                <span>
                  <%= entry.timestamp %>
                </span>
                <span
                  class="uppercase font-bold
                  <%= level === 'info' ? 'text-blue-600' : level === 'debug' ? 'text-gray-500' : level === 'warn' ? 'text-yellow-600' : 'text-red-600' %>">
                  <%= level %>
                </span>
              </div>
              <div class="font-medium">
                <%= entry.message %>
              </div>
              <% if (entry.user) { %>
                <div class="text-xs text-gray-600">User: <%= entry.user.username %> (ID: <%= entry.user.id %>)</div>
                <% } %>
                  <% if (entry.route) { %>
                    <div class="text-xs text-gray-600">Route: <%= entry.route %>
                    </div>
                    <% } %>
            </div>
            <% }) %>
              <% } else { %>
                <div class="text-sm text-gray-500">No <%= level %> logs available.</div>
                <% } %>
      </div>
      <% }) %>
  </div>


<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.tab-panel');

    const storageKey = 'activeLogTab';

    // Helper to activate a tab by ID
    function activateTab(targetId) {
      tabs.forEach(t => {
        t.classList.remove('border-blue-600', 'text-blue-600', 'text-gray-500', 'hover:text-gray-800', 'hover:border-gray-300', 'border-transparent');
        t.classList.add('text-gray-500', 'hover:text-gray-800', 'hover:border-gray-300', 'border-transparent');
      });

      panels.forEach(p => p.classList.add('hidden'));

      const activeTab = [...tabs].find(t => t.dataset.target === targetId);
      const activePanel = document.getElementById(targetId);

      if (activeTab && activePanel) {
        activeTab.classList.remove('text-gray-500', 'hover:text-gray-800', 'hover:border-gray-300', 'border-transparent');
        activeTab.classList.add('border-blue-600', 'text-blue-600');
        activePanel.classList.remove('hidden');
      }
    }

    // Restore last active tab from localStorage (or fallback to first)
    const lastActive = localStorage.getItem(storageKey) || tabs[0].dataset.target;
    activateTab(lastActive);

    // Add click listeners
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetId = tab.dataset.target;
        localStorage.setItem(storageKey, targetId);
        activateTab(targetId);
      });
    });
  });
</script>
<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io({
    transports: ['websocket'], // Force WS
  });

  socket.on('connect', () => {
    console.log('✅ WebSocket connected');
  });

  socket.on('logs:init', (data) => {
    console.log('ℹ️ Initial log message:', data.message);
  });

  socket.on('logs:update', (data) => {
    const { level } = data;
    // Defensive fallback:
    const entry = data.entry || data; // accept either full entry or nested entry

    const { message, timestamp, user, route } = entry || {};

    if (!message) {
      console.warn('Received logs:update event missing message:', data);
      return;
    }

    const panel = document.getElementById(`log-${level}`);
    if (!panel) {
      console.warn(`⚠️ No panel found for level: ${level}`);
      return;
    }

    const div = document.createElement('div');
    div.className = 'border p-3 rounded bg-white dark:bg-gray-800 shadow-sm mb-2';
    div.innerHTML = `
    <div class="flex justify-between text-xs text-gray-500 mb-1">
      <span>${timestamp}</span>
      <span class="uppercase font-bold ${level === 'info' ? 'text-blue-600' :
        level === 'debug' ? 'text-gray-500' :
          level === 'warn' ? 'text-yellow-600' : 'text-red-600'
      }">${level}</span>
    </div>
    <div class="font-medium">${message}</div>
    ${user ? `<div class="text-xs text-gray-600">User: ${user.username} (ID: ${user.id})</div>` : ''}
    ${route ? `<div class="text-xs text-gray-600">Route: ${route}</div>` : ''}
  `;
  console.log('Appending log entry for level:', level);
  console.log('Target panel:', panel);
  panel.prepend(div);
  });
</script>