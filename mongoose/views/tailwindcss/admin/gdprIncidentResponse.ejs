<div class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">

  <!-- Header -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
    
    <div class="p-6 sm:p-8">
      <a href="/admin/gdpr" class="text-sm text-green-700 dark:text-green-400 hover:underline">&larr; Back to GDPR Overview</a>
      <h1 class="mt-2 text-2xl font-bold text-gray-900 dark:text-gray-100"><%= title %></h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        Operational process for identifying, containing, assessing, and reporting personal data incidents.
      </p>
    </div>
  </div>

  <!-- Roles -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Roles</h2>
    </div>
    <div class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div class="rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-4 py-3">
        <p class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500">Incident Lead</p>
        <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200 font-medium">Engineering lead on-call</p>
      </div>
      <div class="rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-4 py-3">
        <p class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500">Privacy Owner</p>
        <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200 font-medium">DPO or nominated privacy contact</p>
      </div>
      <div class="rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-4 py-3">
        <p class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500">Security Owner</p>
        <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200 font-medium">Infrastructure / security lead</p>
      </div>
      <div class="rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-4 py-3">
        <p class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500">Business Owner</p>
        <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200 font-medium">Department lead for impacted process</p>
      </div>
    </div>
  </div>

  <!-- Severity -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Severity Levels</h2>
    </div>
    <div class="p-6 space-y-3">
      <div class="flex items-start gap-3 rounded-lg border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/20 px-4 py-3">
        <span class="shrink-0 mt-0.5 inline-block text-xs font-bold text-red-700 dark:text-red-300 bg-red-100 dark:bg-red-900/40 px-2 py-0.5 rounded">SEV1</span>
        <p class="text-sm text-red-800 dark:text-red-200">Confirmed breach with likely risk to individuals' rights or freedoms. ICO notification likely required.</p>
      </div>
      <div class="flex items-start gap-3 rounded-lg border border-orange-200 dark:border-orange-800 bg-orange-50 dark:bg-orange-900/20 px-4 py-3">
        <span class="shrink-0 mt-0.5 inline-block text-xs font-bold text-orange-700 dark:text-orange-300 bg-orange-100 dark:bg-orange-900/40 px-2 py-0.5 rounded">SEV2</span>
        <p class="text-sm text-orange-800 dark:text-orange-200">Confirmed unauthorised access with limited personal data scope. Assess notification requirement.</p>
      </div>
      <div class="flex items-start gap-3 rounded-lg border border-yellow-200 dark:border-yellow-800 bg-yellow-50 dark:bg-yellow-900/20 px-4 py-3">
        <span class="shrink-0 mt-0.5 inline-block text-xs font-bold text-yellow-700 dark:text-yellow-300 bg-yellow-100 dark:bg-yellow-900/40 px-2 py-0.5 rounded">SEV3</span>
        <p class="text-sm text-yellow-800 dark:text-yellow-200">Security event without confirmed personal data impact. Monitor and document.</p>
      </div>
    </div>
  </div>

  <!-- Timeline -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Response Timeline</h2>
    </div>
    <div class="p-6 space-y-5">

      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block text-xs font-bold text-white bg-red-600 px-2 py-0.5 rounded">First 60 Minutes</span>
        </div>
        <ol class="list-decimal list-inside space-y-1 text-sm text-gray-700 dark:text-gray-300 ml-1">
          <li>Open incident record with timestamp, reporter, and affected systems.</li>
          <li>Contain exposure: revoke credentials, rotate keys, block endpoints, isolate hosts.</li>
          <li>Preserve evidence: logs, request IDs, deployment hashes, and DB snapshots.</li>
          <li>Start impact triage: data categories affected, record count, potential recipients.</li>
        </ol>
      </div>

      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block text-xs font-bold text-white bg-orange-600 px-2 py-0.5 rounded">24 Hours</span>
        </div>
        <ol class="list-decimal list-inside space-y-1 text-sm text-gray-700 dark:text-gray-300 ml-1">
          <li>Confirm root cause and blast radius.</li>
          <li>Validate data categories and subject groups impacted.</li>
          <li>Assess harm likelihood and severity.</li>
          <li>Decide whether ICO notification is required.</li>
        </ol>
      </div>

      <div class="rounded-lg border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 px-4 py-3">
        <div class="flex items-center gap-2 mb-1">
          <span class="inline-block text-xs font-bold text-amber-700 dark:text-amber-300 bg-amber-100 dark:bg-amber-900/40 px-2 py-0.5 rounded">72-Hour Rule — UK GDPR Art. 33</span>
        </div>
        <p class="text-sm text-amber-800 dark:text-amber-200 mb-2">If reportable, submit ICO notification within 72 hours of becoming aware of the breach.</p>
        <p class="text-xs text-amber-700 dark:text-amber-300 font-medium mb-1">Notification package must include:</p>
        <ul class="list-disc list-inside text-xs text-amber-700 dark:text-amber-300 space-y-0.5">
          <li>Incident nature and timeline</li>
          <li>Data categories and approximate volume</li>
          <li>Affected subject categories</li>
          <li>Likely consequences</li>
          <li>Containment and remediation actions taken</li>
          <li>Contact details for follow-up queries</li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Data Subject Notification -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Data Subject Notification (Art. 34)</h2>
    </div>
    <div class="p-6 space-y-3">
      <p class="text-sm text-gray-600 dark:text-gray-400">Notify affected individuals without undue delay when a high risk to their rights or freedoms is likely.</p>
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Each notification must include:</p>
      <ul class="list-disc list-inside text-sm text-gray-700 dark:text-gray-300 space-y-1 ml-1">
        <li>What happened and when</li>
        <li>Which data may have been affected</li>
        <li>Actions already taken to mitigate</li>
        <li>What the individual should do next</li>
        <li>A support contact channel</li>
      </ul>
    </div>
  </div>

  <!-- Evidence Checklist -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Evidence Checklist</h2>
    </div>
    <div class="p-6">
      <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
        <% [
          'Incident UUID and full chronology',
          'Query extracts and affected record counts',
          'Relevant application and infrastructure logs',
          'Access audit trail and auth / session indicators',
          'Changes applied (commits, config, infrastructure updates)',
        ].forEach(function(item) { %>
          <li class="flex items-start gap-2">
            <i class="bi bi-check-square text-emerald-600 dark:text-emerald-400 mt-0.5 shrink-0"></i>
            <%= item %>
          </li>
        <% }); %>
      </ul>
    </div>
  </div>

  <!-- Post-Incident Review -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Post-Incident Review <span class="text-xs font-normal text-gray-400">(within 5 business days)</span></h2>
    </div>
    <div class="p-6">
      <ol class="list-decimal list-inside space-y-1.5 text-sm text-gray-700 dark:text-gray-300 ml-1">
        <li>Complete root cause analysis.</li>
        <li>Record corrective and preventive actions.</li>
        <li>Update RoPA, DPIA, and security controls where required.</li>
        <li>Validate closure with the privacy owner.</li>
      </ol>
    </div>
  </div>

</div>
