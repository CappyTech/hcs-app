<div class="max-w-5xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-8">

  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
        <i class="bi bi-plug-fill text-indigo-500"></i> External Connections
      </h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        Configure credentials for external services. Changes are saved to <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded text-xs">config/app-config.json</code>
        and applied immediately to the running process.
      </p>
    </div>
    <a href="/admin" class="text-indigo-600 hover:underline dark:text-indigo-400 text-sm whitespace-nowrap">← Admin</a>
  </div>

  <!-- Info banner -->
  <div class="rounded-xl border border-amber-200 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-700 p-4 flex gap-3">
    <i class="bi bi-info-circle-fill text-amber-500 mt-0.5 flex-shrink-0"></i>
    <div class="text-sm text-amber-800 dark:text-amber-200 space-y-1">
      <p><strong>Environment variables take priority</strong> and cannot be overridden here while the container is running.
        Fields showing <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 dark:bg-amber-800 text-amber-800 dark:text-amber-100"><i class="bi bi-lock-fill"></i> Env</span>
        are locked to their startup values.</p>
      <p>Values saved here persist across restarts via <code class="bg-amber-100 dark:bg-amber-800 px-1 rounded text-xs">app-config.json</code>
        and are applied for any key <em>not</em> set by docker-compose at startup.</p>
    </div>
  </div>

  <!-- Connection cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

    <!-- KashFlow -->
    <a href="/admin/connections/kashflow"
       class="group bg-white dark:bg-gray-900 rounded-2xl shadow border border-gray-200 dark:border-gray-700 p-6 hover:border-indigo-400 dark:hover:border-indigo-500 transition">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center">
            <i class="bi bi-bank2 text-indigo-600 dark:text-indigo-400 text-lg"></i>
          </div>
          <div>
            <div class="font-semibold text-gray-900 dark:text-gray-100">KashFlow API</div>
            <div class="text-xs text-gray-500 dark:text-gray-400">Accounting & sync</div>
          </div>
        </div>
        <% if (kashflowOk) { %>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300">
            <i class="bi bi-check-circle-fill"></i> Configured
          </span>
        <% } else { %>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
            <i class="bi bi-dash-circle"></i> Not set
          </span>
        <% } %>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400">API credentials, memorable word, session token, and debug flags.</p>
      <div class="mt-4 text-xs text-indigo-600 dark:text-indigo-400 group-hover:underline">Configure →</div>
    </a>

    <!-- SMTP -->
    <a href="/admin/connections/smtp"
       class="group bg-white dark:bg-gray-900 rounded-2xl shadow border border-gray-200 dark:border-gray-700 p-6 hover:border-indigo-400 dark:hover:border-indigo-500 transition">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center">
            <i class="bi bi-envelope-fill text-blue-600 dark:text-blue-400 text-lg"></i>
          </div>
          <div>
            <div class="font-semibold text-gray-900 dark:text-gray-100">Email (SMTP)</div>
            <div class="text-xs text-gray-500 dark:text-gray-400">Outbound mail relay</div>
          </div>
        </div>
        <% if (smtpOk) { %>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300">
            <i class="bi bi-check-circle-fill"></i> Configured
          </span>
        <% } else { %>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
            <i class="bi bi-dash-circle"></i> Not set
          </span>
        <% } %>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400">SMTP host, port, credentials, from address, and application base URL.</p>
      <div class="mt-4 text-xs text-indigo-600 dark:text-indigo-400 group-hover:underline">Configure →</div>
    </a>

    <!-- Paperless -->
    <a href="/admin/connections/paperless"
       class="group bg-white dark:bg-gray-900 rounded-2xl shadow border border-gray-200 dark:border-gray-700 p-6 hover:border-indigo-400 dark:hover:border-indigo-500 transition">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-900/50 flex items-center justify-center">
            <i class="bi bi-file-earmark-text-fill text-emerald-600 dark:text-emerald-400 text-lg"></i>
          </div>
          <div>
            <div class="font-semibold text-gray-900 dark:text-gray-100">Paperless-ngx</div>
            <div class="text-xs text-gray-500 dark:text-gray-400">OCR document store</div>
          </div>
        </div>
        <% if (paperlessOk) { %>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300">
            <i class="bi bi-check-circle-fill"></i> Configured
          </span>
        <% } else { %>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
            <i class="bi bi-dash-circle"></i> Not set
          </span>
        <% } %>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400">Base URL, API token, SSH tunnel toggle, and ingestion options.</p>
      <div class="mt-4 text-xs text-indigo-600 dark:text-indigo-400 group-hover:underline">Configure →</div>
    </a>

    <!-- SMS (Twilio) -->
    <a href="/admin/connections/sms"
       class="group bg-white dark:bg-gray-900 rounded-2xl shadow border border-gray-200 dark:border-gray-700 p-6 hover:border-violet-400 dark:hover:border-violet-500 transition">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-violet-100 dark:bg-violet-900/50 flex items-center justify-center">
            <i class="bi bi-phone-fill text-violet-600 dark:text-violet-400 text-lg"></i>
          </div>
          <div>
            <div class="font-semibold text-gray-900 dark:text-gray-100">SMS (Twilio)</div>
            <div class="text-xs text-gray-500 dark:text-gray-400">Password reset codes</div>
          </div>
        </div>
        <% if (smsOk) { %>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300">
            <i class="bi bi-check-circle-fill"></i> Configured
          </span>
        <% } else { %>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
            <i class="bi bi-dash-circle"></i> Not set
          </span>
        <% } %>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400">Twilio Account SID, Auth Token, and sender phone number for SMS OTP delivery.</p>
      <div class="mt-4 text-xs text-violet-600 dark:text-violet-400 group-hover:underline">Configure →</div>
    </a>

  </div>

  <!-- MongoDB (read-only) -->
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="h-1 bg-gradient-to-r from-gray-400 to-gray-500"></div>
    <div class="p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-9 h-9 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
          <i class="bi bi-database-fill text-gray-600 dark:text-gray-400"></i>
        </div>
        <div>
          <div class="font-semibold text-gray-900 dark:text-gray-100">MongoDB</div>
          <div class="text-xs text-gray-500 dark:text-gray-400">Read-only — changing the database connection requires redeployment</div>
        </div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        <% mongo.forEach(m => { %>
          <div class="rounded-lg bg-gray-50 dark:bg-gray-800 px-3 py-2">
            <div class="flex items-center gap-1 mb-0.5">
              <span class="text-xs font-mono text-gray-500 dark:text-gray-400 truncate"><%= m.key %></span>
              <% if (m.fromEnv) { %>
                <span class="ml-auto flex-shrink-0 inline-flex items-center gap-0.5 px-1 py-0.5 rounded text-xs font-medium bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300">
                  <i class="bi bi-lock-fill text-xs"></i> Env
                </span>
              <% } %>
            </div>
            <div class="text-sm font-medium text-gray-800 dark:text-gray-200 truncate"><%= m.display %></div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

</div>
