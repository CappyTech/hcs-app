<div class="max-w-6xl mx-auto my-6 px-4">

  <div class="flex flex-col sm:flex-row items-center justify-between mb-6 gap-3">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
      <i class="bi bi-trash3"></i> Deleted Items
    </h1>
    <span class="text-sm text-gray-500 dark:text-gray-400">
      <%= rows.length %> record<%= rows.length !== 1 ? 's' : '' %> soft-deleted across all models
    </span>
  </div>

  <% if (rows.length === 0) { %>
    <div class="rounded-lg border border-green-200 bg-green-50 dark:bg-green-900/20 dark:border-green-800 p-6 text-center text-green-700 dark:text-green-300">
      <i class="bi bi-check-circle text-2xl mb-2 block"></i>
      No soft-deleted records found.
    </div>
  <% } else { %>

    <!-- Search filter -->
    <div class="mb-4">
      <input id="row-search" type="text" placeholder="Filter by model or label…"
        class="w-full sm:w-80 px-3 py-1.5 text-sm rounded border border-gray-300 dark:border-gray-600
               bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100
               focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" />
    </div>

    <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700 shadow-sm">
      <table class="w-full text-sm text-left" id="deleted-table">
        <thead class="bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 uppercase text-xs tracking-wide">
          <tr>
            <th class="px-4 py-3 font-semibold">Model</th>
            <th class="px-4 py-3 font-semibold">Record</th>
            <th class="px-4 py-3 font-semibold whitespace-nowrap">Deleted At</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
          <% rows.forEach(row => { %>
            <tr class="bg-white dark:bg-gray-900 hover:bg-red-50 dark:hover:bg-red-900/10 transition deleted-row">
              <td class="px-4 py-3 text-gray-500 dark:text-gray-400 whitespace-nowrap row-model">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-medium
                  bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
                  <%= row.model %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-900 dark:text-gray-100 row-label">
                <%= row.label %>
              </td>
              <td class="px-4 py-3 text-red-600 dark:text-red-400 whitespace-nowrap font-mono text-xs">
                <%= new Date(row.deletedAt).toLocaleString('en-GB', { timeZone: 'Europe/London' }) %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <script>
      document.getElementById('row-search').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#deleted-table .deleted-row').forEach(tr => {
          const model = tr.querySelector('.row-model').textContent.toLowerCase();
          const label = tr.querySelector('.row-label').textContent.toLowerCase();
          tr.style.display = (model.includes(q) || label.includes(q)) ? '' : 'none';
        });
      });
    </script>

  <% } %>
</div>
