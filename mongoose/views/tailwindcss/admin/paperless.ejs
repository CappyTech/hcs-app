<%
function srcBadge(f) {
  if (f.fromEnv) return '<span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 dark:bg-amber-800 text-amber-800 dark:text-amber-100"><i class="bi bi-lock-fill"></i> Env</span>';
  if (f.isSet)  return '<span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs font-medium bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300"><i class="bi bi-check-circle-fill"></i> Set</span>';
  return '<span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">Not set</span>';
}
%>

<div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-emerald-500 to-teal-500"></div>
    <div class="p-6 sm:p-8">

      <div class="flex justify-between items-center mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
            <i class="bi bi-file-earmark-text-fill text-emerald-500"></i> Paperless-ngx &amp; Other
          </h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
            Paperless-ngx OCR document ingestion and optional People's Pension API key.
          </p>
        </div>
        <a href="/admin/connections" class="text-indigo-600 hover:underline dark:text-indigo-400 text-sm whitespace-nowrap">← Connections</a>
      </div>

      <form method="POST" action="/admin/connections/paperless">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

        <p class="text-xs text-gray-500 dark:text-gray-400 mb-5 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-4 py-3">
          <i class="bi bi-info-circle"></i>
          Leave any field <strong>blank</strong> to keep the existing value.
          Fields marked <span class="inline-flex items-center gap-0.5 px-1 rounded text-xs font-medium bg-amber-100 dark:bg-amber-800 text-amber-800 dark:text-amber-100"><i class="bi bi-lock-fill"></i> Env</span>
          are locked to their startup values for this container session.
        </p>

        <!-- Paperless connection -->
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-3">Paperless-ngx Connection</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
          <div class="sm:col-span-2">
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">PAPERLESS_BASE_URL</label>
              <%- srcBadge(fields.PAPERLESS_BASE_URL) %>
            </div>
            <input type="url" name="PAPERLESS_BASE_URL"
              placeholder="<%= fields.PAPERLESS_BASE_URL.display || 'http://paperless:8000/api' %>"
              <% if (fields.PAPERLESS_BASE_URL.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">PAPERLESS_PORT</label>
              <%- srcBadge(fields.PAPERLESS_PORT) %>
            </div>
            <input type="number" name="PAPERLESS_PORT" min="1" max="65535"
              placeholder="<%= fields.PAPERLESS_PORT.display || '8000' %>"
              <% if (fields.PAPERLESS_PORT.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
          </div>
        </div>
        <div class="mb-6">
          <div class="flex items-center justify-between mb-1">
            <label class="text-sm font-medium text-gray-700 dark:text-gray-300">PAPERLESS_TOKEN</label>
            <%- srcBadge(fields.PAPERLESS_TOKEN) %>
          </div>
          <input type="password" name="PAPERLESS_TOKEN" autocomplete="new-password"
            placeholder="<%= fields.PAPERLESS_TOKEN.isSet ? '••••••••' : 'Paperless-ngx API token' %>"
            <% if (fields.PAPERLESS_TOKEN.fromEnv) { %>disabled<% } %>
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
        </div>

        <!-- SSH Tunnel -->
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-3">SSH Tunnel</h2>
        <div class="mb-6">
          <div class="flex items-center justify-between mb-1">
            <label class="text-sm font-medium text-gray-700 dark:text-gray-300">PAPERLESS_SSH_TUNNEL_ENABLED</label>
            <%- srcBadge(fields.PAPERLESS_SSH_TUNNEL_ENABLED) %>
          </div>
          <select name="PAPERLESS_SSH_TUNNEL_ENABLED"
            <% if (fields.PAPERLESS_SSH_TUNNEL_ENABLED.fromEnv) { %>disabled<% } %>
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
            <option value="">— keep existing (<%= fields.PAPERLESS_SSH_TUNNEL_ENABLED.display || 'false' %>) —</option>
            <option value="true">true (use SSH tunnel to reach Paperless)</option>
            <option value="false">false (direct connection)</option>
          </select>
          <p class="text-xs text-gray-400 mt-1">
            When true, hcs-app opens an SSH tunnel before connecting to Paperless.
            Requires SSH_HOST, SSH_USER, and SSH_KEY_PATH to be set in the container environment.
          </p>
        </div>

        <!-- Ingestion options -->
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-3">Ingestion Options</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">PAPERLESS_PAGE_SIZE</label>
              <%- srcBadge(fields.PAPERLESS_PAGE_SIZE) %>
            </div>
            <input type="number" name="PAPERLESS_PAGE_SIZE" min="1" max="1000"
              placeholder="<%= fields.PAPERLESS_PAGE_SIZE.display || '50' %>"
              <% if (fields.PAPERLESS_PAGE_SIZE.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">PAPERLESS_CONCURRENCY</label>
              <%- srcBadge(fields.PAPERLESS_CONCURRENCY) %>
            </div>
            <input type="number" name="PAPERLESS_CONCURRENCY" min="1" max="20"
              placeholder="<%= fields.PAPERLESS_CONCURRENCY.display || '5' %>"
              <% if (fields.PAPERLESS_CONCURRENCY.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">PAPERLESS_ACCEPT</label>
              <%- srcBadge(fields.PAPERLESS_ACCEPT) %>
            </div>
            <input type="text" name="PAPERLESS_ACCEPT"
              placeholder="<%= fields.PAPERLESS_ACCEPT.display || 'application/json; version=6' %>"
              <% if (fields.PAPERLESS_ACCEPT.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">PAPERLESS_TIMEOUT_MS</label>
              <%- srcBadge(fields.PAPERLESS_TIMEOUT_MS) %>
            </div>
            <input type="number" name="PAPERLESS_TIMEOUT_MS" min="5000" step="1000"
              placeholder="<%= fields.PAPERLESS_TIMEOUT_MS.display || '60000' %>"
              <% if (fields.PAPERLESS_TIMEOUT_MS.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
            <p class="text-xs text-gray-400 mt-1">HTTP request timeout in milliseconds (default 60000). Increase if Paperless tag/field updates are timing out.</p>
          </div>
        </div>

        <!-- People's Pension -->
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-3">People's Pension API</h2>
        <div class="mb-8">
          <div class="flex items-center justify-between mb-1">
            <label class="text-sm font-medium text-gray-700 dark:text-gray-300">PEOPLES_PENSION_API_KEY</label>
            <%- srcBadge(fields.PEOPLES_PENSION_API_KEY) %>
          </div>
          <input type="password" name="PEOPLES_PENSION_API_KEY" autocomplete="new-password"
            placeholder="<%= fields.PEOPLES_PENSION_API_KEY.isSet ? '••••••••' : 'API key from People\'s Pension portal' %>"
            <% if (fields.PEOPLES_PENSION_API_KEY.fromEnv) { %>disabled<% } %>
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
          <p class="text-xs text-gray-400 mt-1">
            Required to enable direct contribution uploads. CSV export works without this key.
          </p>
        </div>

        <div class="flex justify-end gap-3">
          <a href="/admin/connections" class="px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 transition">Cancel</a>
          <button type="submit" class="px-5 py-2 rounded-lg text-sm font-medium bg-emerald-600 hover:bg-emerald-700 text-white transition">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>
