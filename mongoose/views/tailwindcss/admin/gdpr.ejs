<div class="max-w-6xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm">
    <div class="p-6 sm:p-8 space-y-6">
      <div>
        <a href="/admin" class="text-sm text-green-700 dark:text-green-400 hover:underline">Back to Admin</a>
        <h1 class="text-2xl font-bold mt-1 text-gray-900 dark:text-gray-100"><%= title %></h1>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
          Central access point for GDPR governance artifacts and evidence used during internal audits.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 p-4">
          <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">RoPA Version</p>
          <p class="mt-1 text-lg font-semibold text-gray-900 dark:text-gray-100"><%= ropaVersion %></p>
        </div>
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 p-4">
          <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">Last Updated</p>
          <p class="mt-1 text-lg font-semibold text-gray-900 dark:text-gray-100"><%= ropaLastUpdated %></p>
        </div>
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 p-4">
          <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">Registered Activities</p>
          <p class="mt-1 text-lg font-semibold text-gray-900 dark:text-gray-100"><%= activityCount %></p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/admin/gdpr/ropa" class="rounded-xl border border-green-300 dark:border-green-700 bg-green-50 dark:bg-green-900/20 p-4 hover:shadow-sm transition">
          <h2 class="font-semibold text-green-800 dark:text-green-300">RoPA JSON</h2>
          <p class="text-sm mt-1 text-green-700 dark:text-green-400">Open machine-readable record of processing activities.</p>
        </a>

        <a href="/admin/gdpr/incident-response" class="rounded-xl border border-blue-300 dark:border-blue-700 bg-blue-50 dark:bg-blue-900/20 p-4 hover:shadow-sm transition">
          <h2 class="font-semibold text-blue-800 dark:text-blue-300">Incident Response</h2>
          <p class="text-sm mt-1 text-blue-700 dark:text-blue-400">Review breach triage, notification, and evidence workflow.</p>
        </a>

        <a href="/admin/gdpr/dpia-template" class="rounded-xl border border-violet-300 dark:border-violet-700 bg-violet-50 dark:bg-violet-900/20 p-4 hover:shadow-sm transition">
          <h2 class="font-semibold text-violet-800 dark:text-violet-300">DPIA Template</h2>
          <p class="text-sm mt-1 text-violet-700 dark:text-violet-400">Use for high-risk feature assessments and mitigations.</p>
        </a>

        <a href="/admin/gdpr/requests" class="rounded-xl border border-blue-300 dark:border-blue-700 bg-blue-50 dark:bg-blue-900/20 p-4 hover:shadow-sm transition">
          <h2 class="font-semibold text-blue-800 dark:text-blue-300">DSR Requests</h2>
          <p class="text-sm mt-1 text-blue-700 dark:text-blue-400">Review and action data subject rights requests from users.</p>
        </a>
      </div>

      <div class="rounded-xl border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 p-4">
        <h3 class="font-semibold text-amber-800 dark:text-amber-300">Processor Coverage</h3>
        <p class="text-sm mt-1 text-amber-700 dark:text-amber-400">
          Processors listed in RoPA: <strong><%= processorCount %></strong>. Ensure each processor has DPA and transfer assessment evidence on file.
        </p>
      </div>
    </div>
  </div>
</div>
