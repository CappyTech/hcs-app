<%
function srcBadge(f) {
  if (f.fromEnv) return '<span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 dark:bg-amber-800 text-amber-800 dark:text-amber-100"><i class="bi bi-lock-fill"></i> Env</span>';
  if (f.isSet)  return '<span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs font-medium bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300"><i class="bi bi-check-circle-fill"></i> Set</span>';
  return '<span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">Not set</span>';
}
%>

<div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-blue-500 to-sky-500"></div>
    <div class="p-6 sm:p-8">

      <div class="flex justify-between items-center mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
            <i class="bi bi-envelope-fill text-blue-500"></i> Email (SMTP)
          </h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
            Outbound email relay for user verification, password resets, and notifications.
          </p>
        </div>
        <a href="/admin/connections" class="text-indigo-600 hover:underline dark:text-indigo-400 text-sm whitespace-nowrap">← Connections</a>
      </div>

      <form method="POST" action="/admin/connections/test/smtp" class="mb-4">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button type="submit" class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-lg text-blue-700 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-700 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition">
          <i class="bi bi-lightning-charge"></i> Test connection with saved credentials
        </button>
      </form>

      <form method="POST" action="/admin/connections/smtp">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

        <p class="text-xs text-gray-500 dark:text-gray-400 mb-5 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-4 py-3">
          <i class="bi bi-info-circle"></i>
          Leave any field <strong>blank</strong> to keep the existing value. If SMTP is not configured,
          emails are logged to the console only (suitable for development).
        </p>

        <!-- Server -->
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-3">Mail Server</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
          <div class="sm:col-span-2">
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">SMTP_HOST</label>
              <%- srcBadge(fields.SMTP_HOST) %>
            </div>
            <input type="text" name="SMTP_HOST"
              placeholder="<%= fields.SMTP_HOST.display || 'smtp.example.com' %>"
              <% if (fields.SMTP_HOST.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">SMTP_PORT</label>
              <%- srcBadge(fields.SMTP_PORT) %>
            </div>
            <input type="number" name="SMTP_PORT" min="1" max="65535"
              placeholder="<%= fields.SMTP_PORT.display || '587' %>"
              <% if (fields.SMTP_PORT.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
          </div>
        </div>

        <!-- Credentials -->
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-3">Credentials</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">SMTP_USER</label>
              <%- srcBadge(fields.SMTP_USER) %>
            </div>
            <input type="text" name="SMTP_USER" autocomplete="off"
              placeholder="<%= fields.SMTP_USER.display || 'smtp-user@example.com' %>"
              <% if (fields.SMTP_USER.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">SMTP_PASS</label>
              <%- srcBadge(fields.SMTP_PASS) %>
            </div>
            <input type="password" name="SMTP_PASS" autocomplete="new-password"
              placeholder="<%= fields.SMTP_PASS.isSet ? '••••••••' : 'SMTP password' %>"
              <% if (fields.SMTP_PASS.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
          </div>
        </div>

        <!-- Identity -->
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-3">Identity</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">SMTP_FROM</label>
              <%- srcBadge(fields.SMTP_FROM) %>
            </div>
            <input type="email" name="SMTP_FROM"
              placeholder="<%= fields.SMTP_FROM.display || 'noreply@heroncs.co.uk' %>"
              <% if (fields.SMTP_FROM.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
            <p class="text-xs text-gray-400 mt-1">Sender address on outbound emails.</p>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-sm font-medium text-gray-700 dark:text-gray-300">BASE_URL</label>
              <%- srcBadge(fields.BASE_URL) %>
            </div>
            <input type="url" name="BASE_URL"
              placeholder="<%= fields.BASE_URL.display || 'https://hcs.heroncs.co.uk' %>"
              <% if (fields.BASE_URL.fromEnv) { %>disabled<% } %>
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 disabled:opacity-50 disabled:cursor-not-allowed">
            <p class="text-xs text-gray-400 mt-1">Used in email links (e.g. verify email, password reset).</p>
          </div>
        </div>

        <div class="flex justify-end gap-3">
          <a href="/admin/connections" class="px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 transition">Cancel</a>
          <button type="submit" class="px-5 py-2 rounded-lg text-sm font-medium bg-blue-600 hover:bg-blue-700 text-white transition">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>
