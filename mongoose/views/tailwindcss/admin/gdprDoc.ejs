<div class="max-w-6xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-slate-700 to-slate-500"></div>
    <div class="p-6 sm:p-8 space-y-4">
      <div>
        <a href="/admin/gdpr" class="text-sm text-green-700 dark:text-green-400 hover:underline">Back to GDPR Compliance</a>
        <h1 class="text-2xl font-bold mt-1 text-gray-900 dark:text-gray-100"><%= title %></h1>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-300"><%= description %></p>
      </div>

      <pre class="text-xs whitespace-pre-wrap break-words rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 p-4 text-gray-800 dark:text-gray-200"><%= body %></pre>
    </div>
  </div>
</div>
