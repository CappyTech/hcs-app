<div class="max-w-6xl mx-auto py-10 px-4">
  <div class="bg-gray-100 dark:bg-gray-800 rounded-xl p-6 shadow">
    <h1 class="text-3xl font-bold text-center mb-6">
      <%= typeof title !== 'undefined' ? title : '' %>
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-4">
      <!-- Card 1 -->
      <div class="flex flex-col bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow p-4">
        <div class="flex-grow">
          <h5 class="text-xl font-semibold mb-2">CIS Dashboard</h5>
          <p class="text-sm text-gray-600 dark:text-gray-300">
            View monthly return status and receipts.
          </p>
        </div>
        <a href="/CIS"
           class="mt-4 inline-block bg-green-700 text-white text-sm px-5 py-2 rounded hover:bg-green-800 transition">
          CIS Dashboard
        </a>
      </div>

      <!-- Card 2 -->
      <div class="flex flex-col bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow p-4">
        <div class="flex-grow">
          <h5 class="text-xl font-semibold mb-2">Monthly Returns</h5>
          <p class="text-sm text-gray-600 dark:text-gray-300">
            Submit your CIS returns for each period.
          </p>
        </div>
        <a href="/monthly/returns/form"
           class="mt-4 inline-block bg-green-700 text-white text-sm px-5 py-2 rounded hover:bg-green-800 transition">
          Monthly Returns
        </a>
      </div>

      <!-- Card 3 -->
      <div class="flex flex-col bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow p-4">
        <div class="flex-grow">
          <h5 class="text-xl font-semibold mb-2">Suppliers</h5>
          <p class="text-sm text-gray-600 dark:text-gray-300">
            Manage CIS registered suppliers.
          </p>
        </div>
        <a href="/suppliers"
           class="mt-4 inline-block bg-green-700 text-white text-sm px-5 py-2 rounded hover:bg-green-800 transition">
          Suppliers
        </a>
      </div>
    </div>
  </div>
</div>
