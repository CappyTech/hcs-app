    </div><!-- /p-8 -->
  </div><!-- /card -->

  <div class="mt-6 w-full max-w-lg text-xs text-gray-400 dark:text-gray-500 text-center space-y-3">

    <p>
      <span class="inline-flex items-center gap-1">
        <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        <strong class="text-gray-500 dark:text-gray-400">Your progress is saved automatically</strong> after each step.
      </span>
      Passwords are never saved.
    </p>

    <p>
      If you close the browser or the server restarts, your answers will be restored when you return.
    </p>

    <p>
      <button type="button" id="clearDraftBtn"
        class="inline-flex items-center gap-1 text-red-400 dark:text-red-500 hover:text-red-600 dark:hover:text-red-400 hover:underline transition">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Clear saved progress
      </button>
      &mdash; start the wizard from scratch.
    </p>

  </div>

  <script>
  document.getElementById('clearDraftBtn').addEventListener('click', clearWizardDraft);
  function clearWizardDraft() {
    ['hcs_setup_step1','hcs_setup_step2','hcs_setup_step3'].forEach(k => localStorage.removeItem(k));
    fetch('/setup/clear-draft', { method: 'POST' }).finally(() => location.reload());
  }
  </script>

</body>
</html>
