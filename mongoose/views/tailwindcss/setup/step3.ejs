<%- include('./_header.ejs') %>

<% if (error) { %>
  <div class="mb-4 p-3 rounded-xl bg-red-50 dark:bg-red-900/30 text-red-800 dark:text-red-300 text-sm border border-red-200 dark:border-red-700">
    <%= error %>
  </div>
<% } %>

<p class="text-sm text-gray-600 dark:text-gray-400 mb-6">
  Create the first administrator account. This user will have full access to all
  departments and models. Additional users can be created from the admin panel after login.
</p>

<form action="/setup/complete" method="POST" class="space-y-5">

  <!-- Username -->
  <div>
    <label class="block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300">
      Username <span class="text-red-500">*</span>
    </label>
    <input type="text" name="adminUsername" required
      placeholder="admin" value="<%= values.adminUsername || '' %>"
      autocomplete="username"
      class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-green-500 bg-gray-50 dark:bg-gray-900 text-sm">
    <p class="mt-1 text-xs text-gray-400">Lowercase, no spaces (e.g. <code>john.smith</code>).</p>
  </div>

  <!-- Email -->
  <div>
    <label class="block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300">Email</label>
    <input type="email" name="adminEmail"
      placeholder="admin@example.com" value="<%= values.adminEmail || '' %>"
      autocomplete="email"
      class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-green-500 bg-gray-50 dark:bg-gray-900 text-sm">
  </div>

  <!-- Password -->
  <div>
    <label class="block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300">
      Password <span class="text-red-500">*</span>
    </label>
    <input type="password" name="adminPassword" required minlength="8"
      autocomplete="new-password"
      class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-green-500 bg-gray-50 dark:bg-gray-900 text-sm">
    <p class="mt-1 text-xs text-gray-400">Minimum 8 characters.</p>
  </div>

  <!-- Confirm Password -->
  <div>
    <label class="block mb-1 text-sm font-medium text-gray-700 dark:text-gray-300">
      Confirm Password <span class="text-red-500">*</span>
    </label>
    <input type="password" name="adminPasswordConfirm" required
      autocomplete="new-password"
      class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-green-500 bg-gray-50 dark:bg-gray-900 text-sm">
  </div>

  <div class="pt-2 flex justify-between items-center">
    <a href="/setup/step2" class="text-sm text-gray-500 dark:text-gray-400 hover:underline">← Back</a>
    <button type="submit"
      class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg text-sm font-medium bg-green-600 text-white hover:bg-green-700 transition shadow-sm">
      Finish Setup
    </button>
  </div>
</form>

<%- include('./_footer.ejs') %>
