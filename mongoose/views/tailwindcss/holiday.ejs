<%- include('./partials/successAlert.ejs') %>
<%- include('./partials/errorAlert.ejs') %>

<div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <div class="p-10 text-center">
    <h1 class="text-4xl font-extrabold text-hcs-green mb-8 flex items-center justify-center gap-3">
      <i class="bi bi-calendar-x"></i>
      <% if (isAuthenticated) { %>
        You’re meant to be on Holiday! <br> What are you doing here?
      <% } else { %>
        We’re on Holiday!
      <% } %>
    </h1>
    <p class="text-lg text-gray-600 max-w-xl mx-auto mb-8">
      <% if (isAuthenticated) { %>
        Certain functionalities are temporarily unavailable during the holiday period. Please check back later or reach out if needed.
      <% } else { %>
        Our services are currently unavailable as we are observing a holiday.
      <% } %>
    </p>
    <hr class="border-t border-gray-300 my-8 max-w-xl mx-auto" />
    <p class="text-xl font-semibold mb-4">
      <span class="font-light block">Reason:</span>
      <%= reason %>
    </p>
    <p class="text-xl font-semibold mb-6">
      <span class="font-light block">Period:</span>
      <% if (startDate === endDate) { %>
        <span class="text-blue-600"><%= slimDateTime(startDate) %></span>
      <% } else { %>
        from <span class="text-blue-600"><%= slimDateTime(startDate, ['includeTime']) %></span><br />
        to <span class="text-blue-600"><%= slimDateTime(endDate, ['includeTime']) %></span>
      <% } %>
    </p>
    <p class="text-gray-600 text-lg">
      <% if (startDate === endDate) { %>
        We’ll be back on <span class="text-green-600 font-bold"><%= moment(endDate).add(1, 'day').format('DD/MM/YYYY') %></span>. Thank you for your patience!
      <% } else { %>
        We’ll be back after <span class="text-green-600 font-bold"><%= slimDateTime(endDate) %></span>. Thank you for your patience!
      <% } %>
    </p>

    <% if (isAuthenticated) { %>
      <button id="dismissHolidayBtn" class="inline-flex items-center gap-1.5 bg-green-600 text-white text-lg px-6 py-3 rounded-lg mt-4 hover:bg-green-700 transition shadow-sm font-medium">Dismiss Holiday Notice</button>
    <% } else { %>
      <a href="/user/login" class="inline-flex items-center gap-1.5 bg-green-600 text-white text-lg px-6 py-3 rounded-lg mt-4 hover:bg-green-700 transition shadow-sm font-medium">
        Log In
      </a>
    <% } %>

  </div>
  </div>
</div>

<script>
  document.getElementById('dismissHolidayBtn').addEventListener('click', async () => {
    try {
      const res = await fetch('/holiday/dismiss', { method: 'POST', credentials: 'same-origin' });
      if (res.ok) {
        alert('Holiday dismissed. You will no longer see this notice.');
        window.location.reload();
      } else {
        const data = await res.json();
        alert('Error: ' + (data.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Failed to dismiss holiday: ' + err.message);
    }
  });
</script>
