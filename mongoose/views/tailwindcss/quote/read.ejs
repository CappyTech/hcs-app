<%
  // Compact quote detail view. relatedCustomer is provided by the quote
  // config's readLocals; quotes are synced read-only from KashFlow.
  const _customer = (typeof relatedCustomer !== 'undefined') ? relatedCustomer : null;
  const _money = (v) => { const n = Number(v); return Number.isFinite(n) ? formatCurrency(n) : null; };
  const _date  = (v) => v ? slimDateTime(v) : null;
  const _category = item.Category && item.Category.Name ? item.Category.Name : null;
%>
<div class="max-w-5xl mx-auto py-8 px-4 sm:px-6 lg:px-8 space-y-5">
  <a href="/quotes" class="inline-flex items-center gap-1.5 text-sm text-green-600 dark:text-green-400 hover:underline font-medium"><i class="bi bi-arrow-left"></i> Go Back</a>

  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <div class="p-6 sm:p-8 space-y-6">

      <!-- Header: number + status, customer subtitle, KashFlow link -->
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Quote #<%= item.Number %></h1>
            <%- include('../partials/_status-badge', { status: item.Status }) %>
            <% if (_category) { %>
              <span class="text-[11px] px-2 py-0.5 rounded-full bg-blue-100 text-blue-800 border border-blue-200 dark:bg-blue-900/40 dark:text-blue-300 dark:border-blue-700"><%= _category %></span>
            <% } %>
          </div>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            <i class="bi bi-building mr-1"></i>
            <% if (_customer) { %>
              <a href="/customer/read/<%= _customer.uuid %>" class="text-green-600 dark:text-green-400 hover:underline"><%= _customer.Name %></a>
            <% } else { %>
              <%= item.CustomerName || '—' %>
            <% } %>
            <% if (item.CustomerReference) { %><span class="ml-2 text-xs font-mono text-gray-400">Ref <%= item.CustomerReference %></span><% } %>
          </p>
        </div>
        <a href="https://app.kashflow.com/#quotes/<%= item.Number %>" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-1.5 rounded-lg border border-gray-200 dark:border-gray-700 px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition shrink-0">
          <i class="bi bi-box-arrow-up-right"></i><span class="hidden sm:inline">Open in KashFlow</span>
        </a>
      </div>

      <!-- Amounts + date -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <%- include('../partials/_meta-tile', { label: 'Net',   value: _money(item.NetAmount) }) %>
        <%- include('../partials/_meta-tile', { label: 'VAT',   value: _money(item.VATAmount) }) %>
        <%- include('../partials/_meta-tile', { label: 'Gross', value: _money(item.GrossAmount) }) %>
        <%- include('../partials/_meta-tile', { label: 'Date',  value: _date(item.Date) }) %>
      </div>

    </div>
  </div>

  <!-- Items -->
  <%- include('../partials/read/_lineitems-card', { lineItems: item.LineItems }) %>
</div>
