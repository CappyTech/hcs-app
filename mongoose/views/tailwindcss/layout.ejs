<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= typeof title !=='undefined' ? title : 'Subcontractor Management System' %>
  </title>

  <link rel="icon" href="/resources/images/favicon.ico" type="image/x-icon">
  <link rel="manifest" href="/resources/manifest/manifest.json">

  <!-- Prevent theme flash: set initial theme class and base background before CSS loads -->
  <script>
    (function () {
      try {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        var enableDark = stored ? (stored === 'dark') : prefersDark;
        var root = document.documentElement;
        if (enableDark) {
          root.classList.add('dark');
        } else {
          root.classList.remove('dark');
        }
      } catch (e) {
        // noop
      }
    })();
  </script>
  <style>
    /* Base background to avoid white flash before Tailwind loads */
    html { background-color: #f9fafb; }
    html.dark { background-color: #374151; }
  </style>

  <!-- Tailwind CSS (pinned version + plugins). For production consider compiling locally instead of CDN. -->
  <script src="https://cdn.tailwindcss.com/3.4.9?plugins=forms,typography"></script>

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

  <script>
    // Tailwind runtime config (only effective with CDN build)
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            brand: {
              DEFAULT: '#047857', // emerald-700
              light: '#10b981',   // emerald-500
              dark: '#065f46'     // emerald-900
            }
          }
        }
      }
    };
  </script>
</head>

<body class="bg-gray-50 text-gray-900 dark:bg-gray-700 dark:text-gray-100 min-h-screen flex flex-col">

  <% if (isAuthenticated) { %>
    <!-- Top Nav -->
    <nav class="fixed top-0 w-full bg-gray-100 dark:bg-gray-800 shadow-sm z-50 print:hidden">
      <div class="flex justify-around text-center py-2">
        <a href="/construction-industry-scheme" class="text-sm hover:text-green-600">
          <i class="bi bi-building fs-5"></i><br>
          <small>Construction Industry Scheme</small>
        </a>
        <a href="/management" class="text-sm hover:text-green-600">
          <i class="bi bi-folder2-open fs-5"></i><br>
          <small>Management</small>
        </a>
        <a href="/payroll" class="text-sm hover:text-green-600">
          <i class="bi bi-cash-coin fs-5"></i><br>
          <small>Payroll</small>
        </a>
        <% if (isAdmin) { %>
          <a href="/human-resources" class="text-sm hover:text-green-600">
            <i class="bi bi-people fs-5"></i><br>
            <small>Human Resources</small>
          </a>
          <a href="/paperless" class="text-sm hover:text-green-600">
            <i class="bi bi-file-earmark-text fs-5"></i><br>
            <small>Documents</small>
          </a>
          <% } %>
            <a href="/kashflow" class="text-sm hover:text-green-600">
              <i class="bi bi-graph-up fs-5"></i><br>
              <small>Kashflow</small>
            </a>
            <a href="/create" class="text-sm text-green-600 hover:text-green-800">
              <i class="bi bi-plus fs-5"></i><br>
              <small>Create</small>
            </a>
      </div>
    </nav>
    <% } %>

      <main id="main-content" class="flex-grow container mx-auto pt-24 pb-24 px-4">
        <%- include('./partials/successAlert.ejs') %>
        <%- include('./partials/errorAlert.ejs') %>
        <%- body %>
      </main>

      <% if (isAuthenticated) { %>
        <!-- Bottom Nav -->
        <nav class="fixed bottom-0 w-full bg-gray-100 dark:bg-gray-800 shadow-sm z-50 print:hidden">
          <div class="flex justify-around text-center py-2">
            <a id="theme-toggle" class="text-sm hover:text-green-600">
              <i id="theme-icon" class="bi bi-moon-stars fs-5"></i><br>
              <small>Theme</small>
            </a>
            <a href="/user/profile" class="text-sm hover:text-green-600">
              <i class="bi bi-person fs-5"></i><br>
              <small>Profile</small>
            </a>
            <% if (isAdmin) { %>
            <a href="/logs" class="text-sm hover:text-green-600">
              <i class="bi bi-journal-text fs-5"></i><br>
              <small>Logs</small>
            </a>
            <% } %>
            <a href="/user/account" class="text-sm hover:text-green-600">
              <i class="bi bi-sliders fs-5"></i><br>
              <small>Settings</small>
            </a>
            <a href="/user/logout" class="text-sm text-red-500 hover:text-red-600">
              <i class="bi bi-box-arrow-right fs-5"></i><br>
              <small>Logout</small>
            </a>
          </div>
          <%- include('./partials/footer.ejs') %>
        </nav>
        <% } else { %>
          <!-- Bottom Nav -->
          <nav class="fixed bottom-0 w-full bg-gray-100 dark:bg-gray-800 shadow-sm z-50 print:hidden">
            <div class="flex justify-around text-center py-2">
              <a id="theme-toggle" class="text-sm hover:text-green-600">
                <i id="theme-icon" class="bi bi-moon-stars fs-5"></i><br>
                <small>Theme</small>
              </a>
            </div>
            <%- include('./partials/footer.ejs') %>
          </nav>
        <% } %>

          <!-- JS: Theme Toggle (replace data-bs-theme logic if needed) -->
          <!-- Dark Mode Toggle with Tailwind -->
          <script src="/resources/js/theme-toggle.js" defer></script>
          <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/alpine-csp.min.js"></script>


          <!-- JS: Service Worker -->
          <script defer>
            if ('serviceWorker' in navigator) {
              window.addEventListener('load', () => {
                navigator.serviceWorker.register('/resources/js/service-worker.js').catch(console.error);
              });
            }
          </script>
</body>

</html>