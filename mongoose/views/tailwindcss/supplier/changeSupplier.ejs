<div class="max-w-xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <h2 class="text-2xl font-semibold mb-6 text-gray-900 dark:text-gray-100">Edit CIS Details — <%= supplier.Name %></h2>
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
  <form action="/supplier/change/<%= supplier.uuid %>" method="POST" novalidate class="p-6 sm:p-8">
    <%- include('../partials/csrfHidden.ejs') %>

    <div class="mb-6 text-sm text-gray-500 dark:text-gray-400">
      Edit CIS withholding tax rate and HMRC references for this supplier. A valid Verification Number is required for a supplier to appear on CIS reports.
    </div>

    <!-- Withholding Tax Fields -->
    <div class="space-y-6">
      <div>
  <label for="withholdingTaxRate" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">Withholding Tax Rate</label>
  <% const whtRate = supplier.WithholdingTaxRate != null ? Number(supplier.WithholdingTaxRate) : -1; %>
  <select id="withholdingTaxRate" name="withholdingTaxRate" class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500">
          <option value="-1" <%= whtRate < 0 || isNaN(whtRate) ? 'selected' : '' %>>Not a subcontractor</option>
          <option value="0" <%= whtRate === 0 ? 'selected' : '' %>>0% (Gross)</option>
          <option value="20" <%= whtRate === 20 ? 'selected' : '' %>>20% (Standard)</option>
          <option value="30" <%= whtRate === 30 ? 'selected' : '' %>>30% (Higher)</option>
        </select>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-300">
          0% = Gross payment status, 20% = standard rate, 30% = unverified subcontractor.
        </p>
      </div>

      <% const _refs = Array.isArray(supplier.WithholdingTaxReferences) ? supplier.WithholdingTaxReferences : []; %>
      <% const _refNames = ['Verification Number', 'UTR Number', 'NI Number']; %>
      <fieldset class="space-y-3">
        <legend class="block mb-1 font-medium text-gray-700 dark:text-gray-200">Withholding Tax References</legend>
        <% _refNames.forEach((refName, i) => { %>
          <% const existing = _refs.find(r => r && r.Name === refName); %>
          <div>
            <label for="whtRef_<%= i %>" class="block text-sm text-gray-600 dark:text-gray-300"><%= refName %></label>
            <input type="hidden" name="whtRefName_<%= i %>" value="<%= refName %>">
            <input 
              type="text" 
              id="whtRef_<%= i %>" 
              name="whtRefValue_<%= i %>" 
              value="<%= existing ? existing.Value : '' %>" 
              placeholder="<%= refName === 'Verification Number' ? 'V1234567890' : refName === 'UTR Number' ? '1234567890' : 'AB123456C' %>"
              class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500"
            >
          </div>
        <% }); %>
      </fieldset>
    </div>

    <button type="submit" class="mt-6 inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white font-medium px-6 py-2.5 rounded-lg transition shadow-sm">
      Save Changes
    </button>
  </form>
  </div>
</div>

