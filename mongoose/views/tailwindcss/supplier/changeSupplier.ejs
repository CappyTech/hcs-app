<div class="container mx-auto mt-10 max-w-xl px-4">
  <h2 class="text-2xl font-semibold mb-6 text-gray-900 dark:text-gray-100">Change <%= supplier.Name %> Details</h2>
  <form action="/supplier/change/<%= supplier.uuid %>" method="POST" novalidate class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded p-4">
    <%- include('../partials/csrfHidden.ejs') %>

    <!-- OLD: Subcontractor checkbox — no longer needed; WithholdingTaxRate >= 0 implies subcontractor -->
    <!--
    <div class="mb-6 flex items-start space-x-3">
      <input type="checkbox" id="subcontractor" name="subcontractor"
        class="mt-1 h-5 w-5 rounded border-gray-300 text-green-600 focus:ring-bg-green-600"
        <%%= supplier.Subcontractor ? 'checked' : '' %>>
      <label for="subcontractor" class="select-none text-gray-700 dark:text-gray-200">
        Is this supplier a subcontractor under CIS?
      </label>
    </div>
    -->
    <div class="mb-6 text-sm text-gray-500 dark:text-gray-300">
      Subcontractors have a Withholding Tax Rate of 0%, 20%, or 30% based on HMRC verification. Set to -1 to remove subcontractor status.
    </div>

    <!-- Withholding Tax Fields -->
    <div class="space-y-6">
      <div>
  <label for="withholdingTaxRate" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">Withholding Tax Rate</label>
  <% const whtRate = supplier.WithholdingTaxRate != null ? Number(supplier.WithholdingTaxRate) : -1; %>
  <select id="withholdingTaxRate" name="withholdingTaxRate" class="w-full rounded border border-gray-300 dark:border-gray-600 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-600 dark:bg-gray-800 dark:text-white">
          <option value="-1" <%= whtRate < 0 || isNaN(whtRate) ? 'selected' : '' %>>Not a subcontractor</option>
          <option value="0" <%= whtRate === 0 ? 'selected' : '' %>>0% (Gross)</option>
          <option value="0.2" <%= whtRate === 0.2 ? 'selected' : '' %>>20% (Standard)</option>
          <option value="0.3" <%= whtRate === 0.3 ? 'selected' : '' %>>30% (Higher)</option>
        </select>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-300">
          0% = Gross payment status, 20% = standard rate, 30% = unverified subcontractor.
        </p>
      </div>

      <% const _refs = Array.isArray(supplier.WithholdingTaxReferences) ? supplier.WithholdingTaxReferences : []; %>
      <% const _refNames = ['Verification Number', 'UTR Number', 'NI Number']; %>
      <fieldset class="space-y-3">
        <legend class="block mb-1 font-medium text-gray-700 dark:text-gray-200">Withholding Tax References</legend>
        <% _refNames.forEach((refName, i) => { %>
          <% const existing = _refs.find(r => r && r.Name === refName); %>
          <div>
            <label for="whtRef_<%= i %>" class="block text-sm text-gray-600 dark:text-gray-300"><%= refName %></label>
            <input type="hidden" name="whtRefName_<%= i %>" value="<%= refName %>">
            <input 
              type="text" 
              id="whtRef_<%= i %>" 
              name="whtRefValue_<%= i %>" 
              value="<%= existing ? existing.Value : '' %>" 
              placeholder="<%= refName === 'Verification Number' ? 'V1234567890' : refName === 'UTR Number' ? '1234567890' : 'AB123456C' %>"
              class="w-full rounded border border-gray-300 dark:border-gray-600 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-600 dark:bg-gray-800 dark:text-white"
            >
          </div>
        <% }); %>
      </fieldset>
    </div>

    <button type="submit" class="mt-6 inline-block bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-2 rounded transition">
      Save Changes
    </button>
  </form>
</div>

