<div class="max-w-xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <h2 class="text-2xl font-semibold mb-6 text-gray-900 dark:text-gray-100">Edit CIS Details</h2>

  <% if (suppliers.length === 0) { %>
    <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
      <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
      <div class="p-8 text-center">
      <p class="text-gray-500 dark:text-gray-400 mb-4">No suppliers found.</p>
      <a href="/supplier" class="inline-flex items-center gap-1.5 text-green-600 hover:text-green-700 dark:text-green-400 dark:hover:text-green-300 font-medium">
        &larr; Back to Suppliers
      </a>
      </div>
    </div>
  <% } else { %>
    <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
      <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <form action="/subcontractor/assign" method="POST" novalidate class="p-6 sm:p-8">
      <%- include('../partials/csrfHidden.ejs') %>

      <div class="mb-6">
        <label for="supplierUuid" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">Select a Supplier</label>
        <select id="supplierUuid" name="supplierUuid" required
          class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500">
          <option value="">-- Choose a supplier --</option>
          <% suppliers.forEach(function(s) { %>
            <option value="<%= s.uuid %>">
              <%= s.Name %><% if (s.Code) { %> (<%= s.Code %>)<% } %><% if (s.WithholdingTaxRate != null && s.WithholdingTaxRate >= 0) { %> — CIS <%= s.WithholdingTaxRate %>%<% } %>
            </option>
          <% }); %>
        </select>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          Pick a supplier to edit their CIS withholding tax rate and references.
        </p>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white font-medium px-6 py-2.5 rounded-lg transition shadow-sm">
          Continue
        </button>
        <a href="/supplier" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 text-sm">Cancel</a>
      </div>
    </form>
    </div>
  <% } %>
</div>
