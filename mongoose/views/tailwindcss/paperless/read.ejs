<div class="w-full my-10">
  <a href="/paperless/ocr" class="text-sm text-green-700 dark:text-green-400 hover:underline">← Back to list</a>
  <h1 class="text-2xl font-bold mt-2 mb-4"><%= title %></h1>

  <div class="grid md:grid-cols-2 gap-4">
    <div class="border rounded-xl p-4">
      <h2 class="font-semibold mb-2">Document</h2>
      <div class="text-sm space-y-1">
        <div><span class="font-medium">Paperless ID:</span> #<%= doc.paperlessId %></div>
        <div><span class="font-medium">Correspondent:</span> <%= doc.correspondent?.name || '-' %></div>
        <div><span class="font-medium">Type:</span> <%= doc.documentType?.name || '-' %></div>
        <div><span class="font-medium">Created:</span> <%= doc.created ? new Date(doc.created).toLocaleString() : '-' %></div>
        <div><span class="font-medium">Modified:</span> <%= doc.modified ? new Date(doc.modified).toLocaleString() : '-' %></div>
        <div><span class="font-medium">Files:</span> <%= doc.originalFileName || doc.archivedFileName || '-' %></div>
        <div><span class="font-medium">Tags:</span> <%= (doc.tags||[]).map(t=>t.name).join(', ') || '-' %></div>
        <% if (doc.kashflowPurchaseNumber || doc.kashflowPermalink) { %>
          <div class="mt-2 p-2 rounded bg-green-50 text-green-800">
            <div class="font-medium">Linked KashFlow Purchase</div>
            <div class="text-sm">
              <% if (doc.kashflowPurchaseNumber) { %>Number: <%= doc.kashflowPurchaseNumber %><% } %>
              <% if (doc.kashflowPurchaseId) { %><span class="ml-2">Id: <%= doc.kashflowPurchaseId %></span><% } %>
              <% if (doc.kashflowPermalink) { %>
                <span class="ml-2"><a href="<%= doc.kashflowPermalink %>" target="_blank" class="underline hover:no-underline">Open in KashFlow</a></span>
              <% } %>
            </div>
            <% if (doc.lastSentAt) { %>
              <div class="text-xs text-green-700 mt-1">Last sent: <%= new Date(doc.lastSentAt).toLocaleString() %> via <%= doc.lastSendMode || '-' %> (status <%= doc.lastSendStatus ?? '-' %>)</div>
            <% } %>
          </div>
        <% } %>
      </div>
      <div class="mt-4">
        <a href="/paperless/ocr/<%= doc.paperlessId %>/draft" class="inline-flex items-center px-3 py-1.5 rounded-md bg-green-700 hover:bg-green-800 text-white text-sm">
          Open Purchase Draft
        </a>
      </div>
    </div>

    <div class="border rounded-xl p-4">
      <h2 class="font-semibold mb-2">Ingest</h2>
      <% if (ingest) { %>
        <div class="text-sm space-y-1">
          <div><span class="font-medium">Status:</span> <%= ingest.status %></div>
          <div><span class="font-medium">Last Modified:</span> <%= ingest.lastModified ? new Date(ingest.lastModified).toLocaleString() : '-' %></div>
          <div><span class="font-medium">Last Fetched At:</span> <%= ingest.lastFetchedAt ? new Date(ingest.lastFetchedAt).toLocaleString() : '-' %></div>
          <div><span class="font-medium">Hash:</span> <code class="break-all"><%= ingest.lastContentHash %></code></div>
          <% if (ingest.error) { %>
            <div class="text-red-600">Error: <%= ingest.error %></div>
          <% } %>
        </div>
      <% } else { %>
        <div class="text-sm">No ingest record yet.</div>
      <% } %>
    </div>
  </div>

  <div class="border rounded-xl p-4 mt-4">
    <h2 class="font-semibold mb-2">OCR Text</h2>
    <pre class="whitespace-pre-wrap text-sm max-h-[60vh] overflow-auto p-3 bg-gray-50 dark:bg-gray-900 rounded-md"><%= (doc.ocrText||'').trim() %></pre>
  </div>

  <div class="border rounded-xl p-4 mt-4">
    <h2 class="font-semibold mb-2">Custom Fields</h2>
    <% const _cfs = Array.isArray(doc.customFields) ? doc.customFields : []; %>
    <% if (_cfs.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left border-b">
              <th class="p-2">Field</th>
              <th class="p-2">Value</th>
            </tr>
          </thead>
          <tbody>
            <% _cfs.forEach(cf => { %>
              <tr class="border-b last:border-0 align-top">
                <td class="p-2 font-medium"><%= cf.fieldName || '-' %></td>
                <td class="p-2">
                  <div class="whitespace-pre-wrap break-words max-w-full">
                    <%= (typeof cf.value === 'object') ? JSON.stringify(cf.value, null, 2) : (cf.value ?? '') %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-sm text-slate-600 dark:text-slate-300">No custom fields found.</div>
    <% } %>
  </div>
</div>
