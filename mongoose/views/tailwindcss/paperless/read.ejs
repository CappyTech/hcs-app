<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <a href="/paperless/ocr" class="text-sm text-green-700 dark:text-green-400 hover:underline">← Back to list</a>
  <h1 class="text-2xl font-bold mt-2 mb-4"><%= title %></h1>

  <div class="grid md:grid-cols-2 gap-4">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
      <h2 class="font-semibold mb-2">Document</h2>
      <div class="text-sm space-y-1">
        <div><span class="font-medium">Paperless ID:</span> #<%= doc.paperlessId %></div>
        <div><span class="font-medium">Correspondent:</span> <%= doc.correspondent?.name || '-' %></div>
        <div><span class="font-medium">Type:</span> <%= doc.documentType?.name || '-' %></div>
        <div><span class="font-medium">Created:</span> <%= doc.created ? new Date(doc.created).toLocaleString() : '-' %></div>
        <div><span class="font-medium">Modified:</span> <%= doc.modified ? new Date(doc.modified).toLocaleString() : '-' %></div>
        <div><span class="font-medium">Files:</span> <%= doc.originalFileName || doc.archivedFileName || '-' %></div>
        <div><span class="font-medium">Tags:</span> <%= (doc.tags||[]).map(t=>t.name).join(', ') || '-' %></div>
        <% const _hasAddedTag = (doc.tags||[]).some(t => (t.name||'').toLowerCase() === 'added'); %>
        <% if (_hasAddedTag && !doc.kashflowPurchaseNumber && !doc.kashflowPermalink) { %>
          <div class="mt-2 p-2 rounded bg-amber-50 border border-amber-200 text-amber-800 text-sm">
            <div class="font-medium flex items-center gap-1"><i class="bi bi-exclamation-triangle-fill"></i> KashFlow linkage missing</div>
            <div class="mt-1">This document is tagged <strong>added</strong> but has no KashFlow Purchase Number recorded. It may have been sent outside this system.</div>
            <div class="mt-1">Enter the KashFlow Purchase Number in the <strong>"KashFlow Purchase Number"</strong> custom field at
              <a href="https://docs.heroncs.co.uk/documents/<%= doc.paperlessId %>" target="_blank" rel="noopener noreferrer" class="underline hover:no-underline font-medium">docs.heroncs.co.uk/documents/<%= doc.paperlessId %></a>,
              then re-fetch this document to link it automatically.
            </div>
          </div>
        <% } %>
        <% if (doc.kashflowPurchaseNumber || doc.kashflowPermalink) { %>
          <div class="mt-2 p-2 rounded bg-green-50 text-green-800">
            <div class="font-medium">Linked KashFlow Purchase</div>
            <div class="text-sm">
              <% if (doc.kashflowPurchaseNumber) { %>Number: <%= doc.kashflowPurchaseNumber %><% } %>
              <% if (doc.kashflowPurchaseId) { %><span class="ml-2">Id: <%= doc.kashflowPurchaseId %></span><% } %>
              <% if (doc.kashflowPurchaseNumber) { %>
                <span class="ml-2"><a href="https://app.kashflow.com/#purchases/<%= doc.kashflowPurchaseNumber %>" target="_blank" class="underline hover:no-underline">Open in KashFlow</a></span>
              <% } else if (doc.kashflowPermalink) { %>
                <span class="ml-2"><a href="https://app.kashflow.com/#purchases" target="_blank" class="underline hover:no-underline">Open in KashFlow</a></span>
              <% } %>
            </div>
            <% if (doc.lastSentAt) { %>
              <% const _modifiedAfterSent = doc.modified && doc.modifiedAtLastSend && new Date(doc.modified) > new Date(doc.modifiedAtLastSend); %>
              <div class="text-xs text-green-700 mt-1">Last sent: <%= new Date(doc.lastSentAt).toLocaleString() %> via <%= doc.lastSendMode || '-' %> (status <%= doc.lastSendStatus ?? '-' %>)</div>
              <% if (_modifiedAfterSent) { %>
                <div class="mt-1 flex items-center gap-1 text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded px-2 py-1">
                  <i class="bi bi-exclamation-triangle-fill"></i>
                  Document modified after last send — KashFlow purchase may be out of date
                </div>
              <% } %>
            <% } %>
          </div>
        <% } %>
        <% if (hasDrift) { %>
          <div class="mt-2 p-2 rounded bg-amber-50 border border-amber-300 text-amber-800 text-sm">
            <div class="font-semibold mb-1">⚠ Custom field out of sync</div>
            <div>
              MongoDB <code>kashflowPurchaseId</code>: <strong><%= doc.kashflowPurchaseId ?? '(none)' %></strong>
            </div>
            <div>
              Paperless cached field: <strong><%= cfKashflowPurchaseId ?? '(none)' %></strong>
            </div>
            <% if (doc.kashflowPurchaseId != null) { %>
              <div class="mt-2 text-xs text-amber-700">The KashFlow Purchase Id was not written back to Paperless. Use the button below to sync it.</div>
              <form method="POST" action="/paperless/repair-drift" class="mt-2">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <button type="submit" class="px-3 py-1 rounded bg-amber-600 hover:bg-amber-700 text-white text-xs font-medium">Sync Paperless custom fields</button>
              </form>
            <% } else { %>
              <div class="mt-2 text-xs text-amber-700">Paperless has a KashFlow id but MongoDB does not. Re-ingest or check send logs.</div>
              <form method="POST" action="/paperless/ocr/<%= doc.paperlessId %>/ingest" class="mt-2">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <button type="submit" class="px-3 py-1 rounded bg-amber-600 hover:bg-amber-700 text-white text-xs font-medium">Re-ingest document</button>
              </form>
            <% } %>
          </div>
        <% } %>
      </div>
      <div class="mt-4">
        <a href="/paperless/ocr/<%= doc.paperlessId %>/draft" class="inline-flex items-center px-3 py-1.5 rounded-lg bg-green-600 hover:bg-green-700 text-white text-sm font-medium transition shadow-sm">
          <%= /subcontract/i.test(doc.documentType?.name || '') ? 'Open Subcontractor Invoice Draft' : 'Open Purchase Draft' %>
        </a>
        <div class="m-2 flex flex-wrap items-center gap-3">
          <a href="https://docs.heroncs.co.uk/documents/<%= doc.paperlessId %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-md text-sm font-medium bg-slate-100 text-slate-700 hover:bg-green-50 hover:text-green-700 border border-slate-200 dark:bg-slate-800 dark:text-slate-200 dark:border-slate-700 dark:hover:bg-green-900/30 focus:outline-none focus:ring-2 focus:ring-green-600">
            <i class="bi bi-box-arrow-up-right text-xs"></i>
            <span>View Document</span>
          </a>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
      <h2 class="font-semibold mb-2">Ingest</h2>
      <% if (ingest) { %>
        <div class="text-sm space-y-1">
          <div><span class="font-medium">Status:</span> <%= ingest.status %></div>
          <div><span class="font-medium">Last Modified:</span> <%= ingest.lastModified ? new Date(ingest.lastModified).toLocaleString() : '-' %></div>
          <div><span class="font-medium">Last Fetched At:</span> <%= ingest.lastFetchedAt ? new Date(ingest.lastFetchedAt).toLocaleString() : '-' %></div>
          <div><span class="font-medium">Hash:</span> <code class="break-all"><%= ingest.lastContentHash %></code></div>
          <% if (ingest.error) { %>
            <div class="text-red-600">Error: <%= ingest.error %></div>
          <% } %>
        </div>
        <% if (hashDuplicate) { %>
          <div class="mt-3 p-2 rounded bg-blue-50 border border-blue-200 text-blue-800 text-sm">
            <strong>Possible re-upload detected.</strong>
            A document with the same content hash already exists as
            <a href="/paperless/ocr/<%= hashDuplicate.paperlessId %>" class="underline font-medium">Document #<%= hashDuplicate.paperlessId %></a>.
            If this is a re-upload, you can send that document to KashFlow instead.
          </div>
        <% } %>
      <% } else { %>
        <div class="text-sm">No ingest record yet.</div>
      <% } %>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4 mt-4">
    <h2 class="font-semibold mb-2">OCR Text</h2>
    <pre class="whitespace-pre-wrap text-sm max-h-[60vh] overflow-auto p-3 bg-gray-50 dark:bg-gray-900 rounded-md"><%= (doc.ocrText||'').trim() %></pre>
  </div>

  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4 mt-4">
    <h2 class="font-semibold mb-2">Custom Fields</h2>
    <% const _cfs = Array.isArray(doc.customFields) ? doc.customFields : []; %>
    <% if (_cfs.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left border-b">
              <th class="p-2">Field</th>
              <th class="p-2">Value</th>
            </tr>
          </thead>
          <tbody>
            <% _cfs.forEach(cf => { %>
              <tr class="border-b last:border-0 align-top">
                <td class="p-2 font-medium"><%= cf.fieldName || '-' %></td>
                <td class="p-2">
                  <div class="whitespace-pre-wrap break-words max-w-full">
                    <%= (typeof cf.value === 'object') ? JSON.stringify(cf.value, null, 2) : (cf.value ?? '') %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-sm text-slate-600 dark:text-slate-300">No custom fields found.</div>
    <% } %>
  </div>
</div>
