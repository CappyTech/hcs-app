<div class="w-full py-4 px-4">
	<a href="/paperless/ocr/<%= paperlessId %>" class="text-sm text-green-700 dark:text-green-400 hover:underline">← Back to document</a>
	<h1 class="text-2xl font-bold mt-2 mb-6"><%= title %></h1>
	<div class="m-2 flex flex-wrap items-center gap-3">
		<a href="https://docs.heroncs.co.uk/documents/<%= paperlessId %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-50 text-gray-700 hover:bg-green-50 hover:text-green-700 border border-gray-200 dark:bg-gray-800 dark:text-gray-200 dark:border-gray-700 dark:hover:bg-green-900/30 focus:outline-none focus:ring-2 focus:ring-green-600">
			<i class="bi bi-box-arrow-up-right text-xs"></i>
			<span>View Document</span>
		</a>
	</div>
	<% /* Derived checks and helper values */ %>
	<% const hasSupplier = !!(selectedSupplier || draft.SupplierId || draft.SupplierName); %>
	<% const supplierDefaultNominal = (selectedSupplier && typeof selectedSupplier.DefaultNominalCode === 'number') ? selectedSupplier.DefaultNominalCode : (typeof draft.DefaultNominalCode === 'number' ? draft.DefaultNominalCode : null); %>
	<% const lineItems = Array.isArray(draft.LineItems) ? draft.LineItems : []; %>
	<% const hasLineItems = lineItems.length > 0; %>
	<% const hasNominalPerLine = hasLineItems && (lineItems.every(li => typeof li.NominalCode === 'number') || typeof supplierDefaultNominal === 'number'); %>
	<% /* Coerce numeric strings to numbers for robust calculations (handles 0.5, 1.5, etc.) */ %>
	<% const toNum = (v) => { if (v == null || v === '') return null; const n = (typeof v === 'number') ? v : parseFloat(String(v).replace(',', '.')); return Number.isFinite(n) ? n : null; }; %>
	<% const net = draft.NetAmount, vat = draft.VATAmount, gross = draft.GrossAmount; %>
	<% /* Use numeric-coerced copies for arithmetic consistency checks */ %>
	<% const _netH = toNum(draft.NetAmount), _vatH = toNum(draft.VATAmount), _grossH = toNum(draft.GrossAmount); %>
	<% const totalsConsistent = (_netH != null && _vatH != null && _grossH != null) ? Math.abs((_netH + _vatH) - _grossH) < 0.01 : true; %>
	<% const hasCurrency = !!draft.Currency; %>
	<% const hasSupplierRef = !!draft.SupplierReference; %>
	<% const hasIssuedDate = !!draft.IssuedDate; %>
	<%
	  // canSend and alreadySentLock are computed in getPurchaseDraft controller and passed as template vars
	%>
	<% const usedCustomFieldLines = (draft.Debug && Array.isArray(draft.Debug.EnumeratedLineItems) && draft.Debug.EnumeratedLineItems.length > 0); %>
	<% const sumNet = +lineItems.reduce((a,li)=>{ const n = toNum(li.NetAmount); return a + (n ?? 0); }, 0).toFixed(2); %>
	<% const sumVAT = +lineItems.reduce((a,li)=>{ const n = toNum(li.VATAmount); return a + (n ?? 0); }, 0).toFixed(2); %>
	<% const sumGross = +lineItems.reduce((a,li)=>{ const n = toNum(li.GrossAmount); return a + (n ?? 0); }, 0).toFixed(2); %>
	<% const sumGrossDerived = +((sumNet + sumVAT)).toFixed(2); %>
	<% const headerVsLinesNetOk = (_netH == null) || Math.abs(_netH - sumNet) < 0.01; %>
	<% const headerVsLinesVatOk = (_vatH == null) || Math.abs(_vatH - sumVAT) < 0.01; %>
	<% const headerVsLinesGrossOk = (_grossH == null) || Math.abs(_grossH - sumGrossDerived) < 0.01; %>

	<%
	// Subcontractor mode — detect sub-contractor and materials nominal codes from the nominal map
	let _subcontrNomCode = null, _materialsNomCode = null;
	if (isSubcontractor && nominalMap) {
		Object.keys(nominalMap).forEach(function(_c) {
			const _i = nominalMap[_c] || {};
			const _n = (_i.Name || _i.Description || '').toLowerCase();
			if (!_subcontrNomCode && /subcontract|sub.?contr/.test(_n)) _subcontrNomCode = parseInt(_c, 10);
			if (!_materialsNomCode && /material/.test(_n)) _materialsNomCode = parseInt(_c, 10);
		});
	}
	// For subcontractor: if only the single fallback line, expand to labour + materials rows
	const _fallbackExpanded = isSubcontractor && lineItems.length === 1 && !usedCustomFieldLines;
	let displayLineItems = lineItems;
	if (_fallbackExpanded) {
		displayLineItems = [
			Object.assign({}, lineItems[0], {
				Description: lineItems[0].Description || 'Sub-contractor Labour',
				NominalCode: lineItems[0].NominalCode != null ? lineItems[0].NominalCode : (_subcontrNomCode != null ? _subcontrNomCode : undefined)
			}),
			{ Description: 'Materials', NetAmount: null, VATAmount: null, GrossAmount: null, Quantity: 1, UnitPrice: null, NominalCode: _materialsNomCode != null ? _materialsNomCode : undefined }
		];
	}
	%>

	<div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6">
		<!-- Left: Purchase / Subcontractor Invoice -->
		<div class="space-y-4 min-w-0">
			<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
				<h2 class="font-semibold mb-2"><%= isSubcontractor ? 'Subcontractor Invoice' : 'Purchase Invoice' %></h2>
				<div class="text-sm space-y-1">
					<div><span class="font-medium">Supplier Name:</span> <span id="supplier-name-display"><%= draft.SupplierName || (selectedSupplier && selectedSupplier.Name) || '-' %></span></div>
					<div><span class="font-medium">Supplier Code:</span> <span id="supplier-code-display"><%= draft.SupplierCode || (selectedSupplier && selectedSupplier.Code) || '-' %></span></div>
					<div><span class="font-medium">Supplier Reference:</span> <%= draft.SupplierReference || '-' %>
						<% if (sources && sources.SupplierReferenceSource) { %>
							<span class="text-xs text-slate-500">(from <%= sources.SupplierReferenceSource %>)</span>
						<% } %>
					</div>
					<div><span class="font-medium">Issued Date:</span> <%= draft.IssuedDate ? new Date(draft.IssuedDate).toLocaleDateString() : '-' %>
						<% if (sources && sources.IssuedDateSource) { %>
							<span class="text-xs text-slate-500">(from <%= sources.IssuedDateSource %>)</span>
						<% } %>
					</div>
					<div><span class="font-medium">Due Date:</span> <%= draft.DueDate ? new Date(draft.DueDate).toLocaleDateString() : '-' %>
						<% if (sources && sources.DueDateSource) { %>
							<span class="text-xs text-slate-500">(from <%= sources.DueDateSource %>)</span>
						<% } %>
					</div>
					<div><span class="font-medium">Currency:</span> <%= draft.Currency || '-' %></div>
				</div>
			</div>

			<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
				<h2 class="font-semibold mb-2">Amounts</h2>
				<div class="text-sm space-y-1">
					<div><span class="font-medium">Net:</span> <%= (draft.NetAmount ?? '-') %>
						<% if (sources && sources.NetAmountSource) { %>
							<span class="text-xs text-slate-500">(from <%= sources.NetAmountSource %>)</span>
						<% } %>
					</div>
					<div><span class="font-medium">VAT:</span> <%= (draft.VATAmount ?? '-') %>
						<% if (sources && sources.VATAmountSource) { %>
							<span class="text-xs text-slate-500">(from <%= sources.VATAmountSource %>)</span>
						<% } %>
					</div>
					<div><span class="font-medium">Gross:</span> <%= (draft.GrossAmount ?? '-') %>
						<% if (sources && sources.GrossAmountSource) { %>
							<span class="text-xs text-slate-500">(from <%= sources.GrossAmountSource %>)</span>
						<% } %>
					</div>
					<% if (net != null && vat != null && gross != null) { %>
						<div class="text-xs <%= totalsConsistent ? 'text-green-600' : 'text-red-600' %>">
							<i class="bi <%= totalsConsistent ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill' %>"></i>
							<%= totalsConsistent ? 'Totals look consistent' : 'Net + VAT does not equal Gross' %>
						</div>
					<% } %>
					
				</div>
			</div>

			<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
				<h2 class="font-semibold mb-2 flex items-center gap-2">Line Items
					<% if (usedCustomFieldLines) { %>
						<span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300">Source: Custom fields</span>
					<% } else { %>
						<span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-700 dark:bg-slate-900/40 dark:text-slate-300">Source: Amounts</span>
					<% } %>
				</h2>
				<div class="overflow-x-auto">
					<table class="w-full text-sm">
						<thead>
							<tr class="text-left border-b">
								<th class="p-2">#</th>
								<th class="p-2">Description</th>
								<th class="p-2">Qty</th>
								<th class="p-2">Unit Price</th>
								<th class="p-2">Net</th>
								<th class="p-2">VAT</th>
								<th class="p-2">Gross</th>
								<th class="p-2">Project</th>
								<th class="p-2">Nominal</th>
							</tr>
						</thead>
						<tbody>
						<% displayLineItems.forEach((li, idx) => { %>
								<tr class="border-b last:border-0">
									<td class="p-2"><%= idx + 1 %></td>
									<% const __rowCode = (typeof li.NominalCode === 'number') ? li.NominalCode : (isSubcontractor ? (idx === 0 ? _subcontrNomCode : (idx === 1 ? _materialsNomCode : null)) ?? supplierDefaultNominal ?? null : supplierDefaultNominal ?? null); %>
									<% const __nomInfo = (__rowCode != null && nominalMap) ? nominalMap[__rowCode] : null; %>
									<% const __descFromNominal = __nomInfo ? (__nomInfo.Description || __nomInfo.Name || null) : null; %>
									<td class="p-2 desc-cell" data-has-desc="<%= (li.Description && String(li.Description).trim() !== '') ? 'true' : 'false' %>"><%= li.Description || __descFromNominal || '-' %></td>
									<td class="p-2"><% const __qty = toNum(li.Quantity); %><%= (__qty != null ? __qty : (li.Quantity ?? 1)) %></td>
									<td class="p-2"><% const __unit = toNum(li.UnitPrice) ?? toNum(li.Rate); %><%= (__unit != null ? __unit.toFixed(2) : (li.UnitPrice ?? '-')) %></td>
									<td class="p-2"><% const __net = toNum(li.NetAmount); %>
										<%= (__net != null ? __net.toFixed(2) : (li.NetAmount ?? '-')) %>
										<% if (__net != null && __qty != null && __unit != null) { const __netExp = +(__qty * __unit).toFixed(2); if (Math.abs(__net - __netExp) >= 0.01) { %>
											<span class="ml-1 text-[10px] text-red-600" title="Expected Qty × Unit Price">exp <%= __netExp.toFixed(2) %></span>
										<% } } %>
									</td>
									<td class="p-2"><% const __vatCell = toNum(li.VATAmount); %><%= (__vatCell != null ? __vatCell.toFixed(2) : (li.VATAmount ?? '-')) %></td>
									<% 
									  const __rate = toNum(li.UnitPrice) ?? toNum(li.Rate);
									  const __vat = toNum(li.VATAmount);
									  const __gross = toNum(li.GrossAmount);
									  const __netExpected = (__qty!=null && __rate!=null) ? +(__qty * __rate).toFixed(2) : null;
									  const __netOk = (__netExpected==null || __net==null) ? true : Math.abs(__net - __netExpected) < 0.01;
									  // If VAT is provided as a percent (e.g., 20 for 20%), convert to a monetary value for consistency checks
									  let __vatForCheck = __vat;
									  const __looksLikePercent = (__vat!=null && __vat >= 0 && __vat <= 100 && Number.isInteger(__vat));
									  if (__net!=null && __looksLikePercent) {
									    const __vatFromPercent = +(__net * (__vat/100)).toFixed(2);
									    if (__gross!=null) {
									      // Prefer the interpretation that best matches the provided gross
									      const diffMonetary = Math.abs((__net + (__vat||0)) - __gross);
									      const diffPercent = Math.abs((__net + __vatFromPercent) - __gross);
									      if (diffPercent + 1e-9 < diffMonetary) {
									        __vatForCheck = __vatFromPercent;
									      }
									    } else {
									      __vatForCheck = __vatFromPercent;
									    }
									  }
									  const __grossExpected = (__net!=null && __vatForCheck!=null) ? +(__net + __vatForCheck).toFixed(2) : null;
									  // Display gross as derived when provided gross is missing or inconsistent
									  const __useDerivedGross = (__grossExpected!=null) && (__gross==null || Math.abs(__gross - __grossExpected) >= 0.01);
									  const __grossDisplay = __useDerivedGross ? __grossExpected : __gross;
									  const __grossOk = (__grossExpected==null || __grossDisplay==null) ? true : Math.abs(__grossDisplay - __grossExpected) < 0.01;
									  const __rowOk = __netOk && __grossOk;
									%>
									<td class="p-2">
										<%= (__grossDisplay!=null ? __grossDisplay.toFixed(2) : '-') %>
										<% if (__useDerivedGross) { %>
											<span class="text-[10px] text-slate-500" title="Derived from Net + VAT">(calc)</span>
										<% } %>
										<i title="Row consistency" class="bi <%= __rowOk ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-red-600' %>"></i>
									</td>								<td class="p-2 project-cell">
									<% const __rowProject = li.ProjectNumber != null ? li.ProjectNumber : null; %>
									<select class="project-select w-full rounded-xl border-gray-200 dark:border-gray-700 px-2 py-1.5 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-green-500 focus:border-green-500 dark:focus:ring-green-500 dark:focus:border-green-500">
										<option value="">— None —</option>
										<% (activeProjects || []).forEach(function(proj) { %>
											<option value="<%= proj.Number %>" <%= (__rowProject != null && __rowProject === proj.Number) ? 'selected' : '' %>><%= proj.Number %> — <%= proj.Name || '(unnamed)' %><% if (proj.Status) { %> (<%= proj.Status %>)<% } %></option>
										<% }); %>
									</select>
								</td>									<td class="p-2 nominal-cell" data-explicit="<%= (typeof li.NominalCode === 'number') ? 'true' : 'false' %>">
										<select class="nominal-select w-full rounded-xl border-gray-200 dark:border-gray-700 px-2 py-1.5 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-green-500 focus:border-green-500 dark:focus:ring-green-500 dark:focus:border-green-500">
											<option value="">— Choose nominal —</option>
											<%
											  const __codes = Object.keys(nominalMap || {}).sort((a,b)=>Number(a)-Number(b));
										  const __currentNominal = __rowCode != null ? String(__rowCode) : '';
											  __codes.forEach(code => {
											    const info = nominalMap[code] || {};
											%>
											  <option value="<%= code %>" <%= (__currentNominal && __currentNominal==String(code)) ? 'selected' : '' %>><%= code %><%= info.Name ? ' — ' + info.Name : (info.Description ? ' — ' + info.Description : '') %></option>
											<% }); %>
										</select>
									</td>
								</tr>
							<% }) %>
						</tbody>
					</table>
						<tfoot>
							<tr class="border-t font-medium">
								<td class="p-2 text-right text-slate-500" colspan="4">Totals</td>
								<td class="p-2">
									<%= sumNet.toFixed(2) %>
									<i class="bi <%= headerVsLinesNetOk ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-red-600' %>"></i>
									<% if (!headerVsLinesNetOk && draft.NetAmount != null) { %>
										<span class="text-red-600">(Δ <%= (draft.NetAmount - sumNet).toFixed(2) %>)</span>
									<% } %>
								</td>
								<td class="p-2">
									<%= sumVAT.toFixed(2) %>
									<i class="bi <%= headerVsLinesVatOk ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-red-600' %>"></i>
									<% if (!headerVsLinesVatOk && draft.VATAmount != null) { %>
										<span class="text-red-600">(Δ <%= (draft.VATAmount - sumVAT).toFixed(2) %>)</span>
									<% } %>
								</td>
								<td class="p-2">
									<%= sumGrossDerived.toFixed(2) %>
									<i class="bi <%= headerVsLinesGrossOk ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-red-600' %>"></i>
									<% if (!headerVsLinesGrossOk && draft.GrossAmount != null) { %>
										<span class="text-red-600">(Δ <%= (draft.GrossAmount - sumGrossDerived).toFixed(2) %>)</span>
									<% } %>
								</td>
								<td class="p-2" colspan="2"></td>
							</tr>
						</tfoot>
				</div>
			</div>

			<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
				<h2 class="font-semibold mb-2">Notes</h2>
				<div class="text-sm whitespace-pre-wrap"><%= isSubcontractor ? 'This subcontractor invoice was created automatically, with manual oversight and checks.' : 'This purchase invoice was created automatically, with manual oversight and checks.' %></div>
			</div>

			<form id="send-form" method="post" action="/paperless/ocr/<%= paperlessId %>/send" class="mt-2 space-y-3">
				<input type="hidden" name="_csrf" value="<%= csrfToken %>">
				<!-- Hidden supplier value populated by the selector on the right -->
				<input type="hidden" id="supplier-uuid" name="supplierUuid" value="<%= selectedSupplier ? selectedSupplier.uuid : '' %>">
				<label class="inline-flex items-center gap-2 text-sm">
					<input type="checkbox" name="dryRun" value="true" checked class="rounded border-gray-200 dark:border-gray-700 accent-green-600 dark:bg-gray-800">
					Dry run (don’t send – just log)
				</label>
				<div>
						<button id="send-button" type="submit" class="inline-flex items-center px-4 py-2 rounded-lg text-white disabled:opacity-50 disabled:cursor-not-allowed bg-green-600 hover:bg-green-700 shadow-sm font-medium transition" <%= canSend ? '' : 'disabled' %>>
							<%= isSubcontractor ? 'Send to KashFlow (Create a Subcontractor Invoice)' : 'Send to KashFlow (Create a Purchase Invoice)' %>
						</button>
						<% if (isSubcontractor) { %>
							<div class="mt-3 p-3 rounded-lg bg-amber-50 border border-amber-200 dark:bg-amber-900/20 dark:border-amber-700 text-sm text-amber-800 dark:text-amber-300">
								<i class="bi bi-exclamation-triangle-fill mr-1"></i>
								<strong>CIS Reminder:</strong> After creating this purchase in KashFlow, go to KashFlow and add any CIS deductions needed against this invoice.
							</div>
						<% } %>
						<% if (!canSend) { %>
							<% if (alreadySentLock) { %>
								<div class="text-xs text-slate-700 dark:text-slate-300 mt-1">
									Sending is disabled because this document appears already sent to KashFlow (Purchase Number: <%= (doc && doc.kashflowPurchaseNumber != null) ? doc.kashflowPurchaseNumber : '-' %>, status 201) and only the 'added' tag is present. This prevents duplicate purchases.
								</div>
								<div class="text-xs text-slate-500 mt-1">
									If this is incorrect, remove the 'added' tag or clear the existing KashFlow linkage on the document, then refresh this page.
								</div>
							<% } else { %>
								<div class="text-xs text-red-600 mt-1">Complete the items on the right to enable sending.</div>
							<% } %>
						<% } %>
					<div class="text-xs text-slate-500 mt-1">
						<% if (sendDirectEnabled) { %>
							Current mode: Direct to KashFlow (KfToken). Uncheck “Dry run” to send to <%= kashflowApiBaseUrl %>/purchases.
						<% } else if (sendWebhookEnabled) { %>
							Current mode: Webhook. Uncheck “Dry run” to send via KASHFLOW_CREATOR_WEBHOOK_URL.
						<% } else { %>
							No sender is configured. Even if you uncheck “Dry run”, nothing will be sent. Configure either session-based direct auth (KASHFLOW_API_USERNAME/PASSWORD + KASHFLOW_MEMORABLE, or KASHFLOW_EXTERNAL_TOKEN) or set KASHFLOW_CREATOR_WEBHOOK_URL.
						<% } %>
					</div>
				</div>
			</form>
		</div>

		<!-- Right: Required info and setup -->
		<div class="space-y-4 w-full lg:w-[360px] lg:max-w-[420px] lg:justify-self-end">
			<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
				<h2 class="font-semibold mb-2">Before sending</h2>
				<ul class="text-sm space-y-2">
					<li class="flex items-start gap-2">
						<i class="bi <%= hasSupplier ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-red-600' %>"></i>
						<span>Supplier selected or present (<%= hasSupplier ? 'OK' : 'Select a supplier' %>)</span>
					</li>
					<li class="flex items-start gap-2">
						<i class="bi <%= hasLineItems ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-red-600' %>"></i>
						<span>At least one line item</span>
					</li>
					<li class="flex items-start gap-2" id="check-nominal">
						<i id="check-nominal-icon" class="bi <%= hasNominalPerLine ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-red-600' %>"></i>
						<span id="check-nominal-text">Nominal code for items (<%= hasNominalPerLine ? (supplierDefaultNominal ? 'from supplier default if missing' : 'set per line') : 'set per line or choose supplier with default' %>)</span>
					</li>
					<li class="flex items-start gap-2">
						<i class="bi <%= hasCurrency ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-red-600' %>"></i>
						<span>Currency <%= hasCurrency ? '(' + draft.Currency + ')' : '' %></span>
					</li>
					<li class="flex items-start gap-2">
						<i class="bi <%= totalsConsistent ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-red-600' %>"></i>
						<span>Net + VAT equals Gross</span>
					</li>
					<li class="flex items-start gap-2">
						<i class="bi <%= hasSupplierRef ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-yellow-500' %>"></i>
						<span>Supplier reference <%= hasSupplierRef ? '' : '(recommended)' %></span>
					</li>
					<li class="flex items-start gap-2">
						<i class="bi <%= hasIssuedDate ? 'bi-check-circle-fill text-green-600' : 'bi-exclamation-triangle-fill text-yellow-500' %>"></i>
						<span>Issued date <%= hasIssuedDate ? '' : '(recommended)' %></span>
					</li>
				</ul>
			</div>

			<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
				<h2 class="font-semibold mb-2">Supplier</h2>
				<div class="text-sm space-y-2">
					<div>
						<label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Search supplier</label>
						<input id="supplier-search" type="text" placeholder="Type name or code..." class="w-full rounded-xl border-gray-200 dark:border-gray-700 px-3 py-2 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:ring-2 focus:ring-green-500 focus:border-green-500 dark:focus:ring-green-500 dark:focus:border-green-500" />
					</div>
					<div>
						<label class="block text-xs text-slate-600 dark:text-slate-300 mb-1">Select supplier</label>
						<select id="supplier-select" class="w-full rounded-xl border-gray-200 dark:border-gray-700 px-3 py-2 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-green-500 focus:border-green-500 dark:focus:ring-green-500 dark:focus:border-green-500">
							<option value="">— Not selected —</option>
							<% (suppliers || []).forEach(s => { %>
								<option value="<%= s.uuid %>" data-name="<%= s.Name || '' %>" data-code="<%= s.Code || '' %>" data-default-nominal="<%= (s.DefaultNominalCode!=null && s.DefaultNominalCode!=='') ? s.DefaultNominalCode : '' %>" <%= (selectedSupplier && selectedSupplier.uuid===s.uuid)?'selected':'' %>>
									<%= s.Name || '(no name)' %><% if (s.Code) { %> — <%= s.Code %><% } %>
								</option>
							<% }) %>
						</select>
						<div class="text-xs text-slate-500 mt-1">Auto-match tries to use the document’s correspondent or draft SupplierName. You can override it here.</div>
						<div class="text-xs text-slate-500 mt-1">Default nominal code: <span id="supplier-default-nominal" class="font-semibold"><%= supplierDefaultNominal != null ? supplierDefaultNominal : '-' %></span></div>
					</div>
				</div>
			</div>

			<details class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
				<summary class="cursor-pointer font-semibold">Legend & troubleshooting</summary>
				<div class="mt-2 text-sm space-y-4">
					<div>
						<div class="font-medium mb-1">Status icons</div>
						<ul class="list-disc pl-5 space-y-1">
							<li><i class="bi bi-check-circle-fill text-green-600"></i> Green check = OK, consistent, or complete.</li>
							<li><i class="bi bi-exclamation-triangle-fill text-red-600"></i> Red triangle = required item missing or inconsistent. Fix before sending.</li>
							<li><i class="bi bi-exclamation-triangle-fill text-yellow-500"></i> Yellow triangle = recommended but optional (e.g., Supplier reference, Issued date).</li>
						</ul>
					</div>

					<div>
						<div class="font-medium mb-1">Line items source badge</div>
						<ul class="list-disc pl-5 space-y-1">
							<li><span class="px-2 py-0.5 rounded-full bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300 text-xs">Source: Custom fields</span> Lines were built from fields like Description_Line1, Qty_Line1, Price/UnitPrice_Line1, Net_Line1, VAT_Line1, Gross_Line1, Nominal_Line1.</li>
							<li><span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-700 dark:bg-slate-900/40 dark:text-slate-300 text-xs">Source: Amounts</span> No enumerated fields found; a single line is created from Net/VAT/Gross.</li>
						</ul>
						<div class="text-xs text-slate-500 mt-1">Fix at source: in Paperless, add/rename custom fields using any of these patterns: “Description_Line1”, “Description 1”, “Line1_Description”, “1_Description”, etc. See “Parsed line items (debug)” to verify detection.</div>
					</div>

					<div>
						<div class="font-medium mb-1">Amounts consistency</div>
						<ul class="list-disc pl-5 space-y-1">
							<li>Header check: “Net + VAT equals Gross” should show a green check.</li>
							<li>Lines total vs header: the “Lines total” section shows sums of Net/VAT/Gross across all lines with a check/delta. If you see a red delta, the header values differ from the sum of the lines.</li>
						</ul>
						<div class="text-xs text-slate-500 mt-1">How to fix: update the Net/VAT/Gross custom fields on the document or correct the per-line values (Qty/Price/Net/VAT/Gross). Removing a conflicting number lets the system derive it from the others.</div>
					</div>

					<div>
						<div class="font-medium mb-1">Row consistency (per line)</div>
						<ul class="list-disc pl-5 space-y-1">
							<li>Each line shows a small icon in the Gross column. It turns red if either check fails: Net ≈ Qty × Unit Price, or Gross ≈ Net + VAT.</li>
						</ul>
						<div class="text-xs text-slate-500 mt-1">How to fix: edit the specific LineN fields (e.g., Qty_LineN, Price/UnitPrice_LineN, Net_LineN, VAT_LineN, Gross_LineN). Prefer providing two of the three and let the third be derived.</div>
					</div>

					<div>
						<div class="font-medium mb-1">Nominal coverage</div>
						<ul class="list-disc pl-5 space-y-1">
							<li>Green = every line has a NominalCode or a supplier with a default nominal is selected.</li>
							<li>Red = set Nominal_LineN on each line or choose a supplier that has a DefaultNominalCode.</li>
						</ul>
						<div class="text-xs text-slate-500 mt-1">Where to fix: pick a supplier on the right (to apply a default) or add Nominal_LineN in Paperless custom fields. To change the description shown, provide Description_LineN or adjust the nominal in your chart of accounts.</div>
					</div>

					<div>
						<div class="font-medium mb-1">Recommended fields</div>
						<ul class="list-disc pl-5 space-y-1">
							<li>Supplier reference (Invoice Number) and Issued date are recommended. If missing, they show a yellow triangle.</li>
						</ul>
						<div class="text-xs text-slate-500 mt-1">Where to fix: add custom fields named like “Invoice Number” and “Invoice Date” (or the mapped variants) in Paperless.</div>
					</div>
				</div>
			</details>

			<details class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
				<summary class="cursor-pointer font-semibold">KashFlow payload (debug)</summary>
				<pre class="mt-2 text-xs bg-neutral-50 dark:bg-neutral-900 p-3 rounded overflow-auto"><%= JSON.stringify(payloadPreview || { error: 'payload build failed' }, null, 2) %></pre>
			</details>

			<details class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
				<summary class="cursor-pointer font-semibold">Parsed line items (debug)</summary>
				<div class="mt-2 grid md:grid-cols-2 gap-3">
					<div>
						<div class="text-xs font-medium mb-1">From custom fields (_LineN)</div>
						<pre class="text-xs bg-neutral-50 dark:bg-neutral-900 p-3 rounded overflow-auto"><%= JSON.stringify((draft.Debug && draft.Debug.EnumeratedLineItems) ? draft.Debug.EnumeratedLineItems : [], null, 2) %></pre>
					</div>
					<div>
						<div class="text-xs font-medium mb-1">Final LineItems (used)</div>
						<pre class="text-xs bg-neutral-50 dark:bg-neutral-900 p-3 rounded overflow-auto"><%= JSON.stringify(draft.LineItems || [], null, 2) %></pre>
					</div>
				</div>
			</details>

			<details class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm p-4">
				<summary class="cursor-pointer font-semibold">Raw draft (debug)</summary>
				<pre class="mt-2 text-xs bg-neutral-50 dark:bg-neutral-900 p-3 rounded overflow-auto"><%= JSON.stringify(draft, null, 2) %></pre>
			</details>
		</div>
	</div>

	<script>
	(function(){
	  const $search = document.getElementById('supplier-search');
	  const $select = document.getElementById('supplier-select');
			const $hidden = document.getElementById('supplier-uuid');
			const $defNom = document.getElementById('supplier-default-nominal');
			const $nameDisp = document.getElementById('supplier-name-display');
			const $codeDisp = document.getElementById('supplier-code-display');
			const $sendBtn = document.getElementById('send-button');
			const $nominalIcon = document.getElementById('check-nominal-icon');
			const $nominalText = document.getElementById('check-nominal-text');

			// Server-evaluated lock: keep disabled client-side if already sent
			const ALREADY_SENT_LOCK = <%= alreadySentLock ? 'true' : 'false' %>;

			// Nominal map for client-side fallback of descriptions when supplier default applies
			let nominalMap = {};
			try {
				const txt = document.getElementById('nominal-map-json')?.textContent || '{}';
				nominalMap = JSON.parse(txt);
			} catch(_) { nominalMap = {}; }

			function getSelectedDefaultNominal() {
				if (!$select) return '';
				const opt = $select.selectedOptions && $select.selectedOptions[0];
				return opt ? (opt.getAttribute('data-default-nominal') || '').trim() : '';
			}

			function updateNominalChecklist() {
				const defAttr = getSelectedDefaultNominal();
				const hasDef = defAttr !== '' && defAttr != null;
				// if def present, nominal coverage is satisfied; otherwise all lines must be explicit
				let allExplicit = true;
				document.querySelectorAll('td.nominal-cell').forEach(td => {
					const isExplicit = (td.getAttribute('data-explicit') || '').toLowerCase() === 'true';
					if (!isExplicit) allExplicit = false;
				});
				const ok = hasDef || allExplicit;
				if ($nominalIcon) {
					$nominalIcon.classList.remove('bi-check-circle-fill','text-green-600','bi-exclamation-triangle-fill','text-red-600');
					if (ok) {
						$nominalIcon.classList.add('bi-check-circle-fill','text-green-600');
					} else {
						$nominalIcon.classList.add('bi-exclamation-triangle-fill','text-red-600');
					}
				}
				if ($nominalText) {
					$nominalText.textContent = `Nominal code for items (${ok ? (hasDef ? 'from supplier default if missing' : 'set per line') : 'set per line or choose supplier with default'})`;
				}
				return ok;
			}

			function recomputeCanSend() {
				const hasSupplier = !!(($hidden && $hidden.value) || ($nameDisp && ($nameDisp.textContent || '').trim() !== '-'));
				const hasLineItems = document.querySelectorAll('tbody tr').length > 0;
				const hasCurrency = true; // currency doesn't change client-side
				const totalsConsistent = true; // totals unchanged by supplier nominal
				const hasNominalPerLine = updateNominalChecklist();
				const canSend = hasSupplier && hasLineItems && hasNominalPerLine && hasCurrency && totalsConsistent && !ALREADY_SENT_LOCK;
				if ($sendBtn) {
					$sendBtn.disabled = !canSend;
				}
				return canSend;
			}
			if ($select && $hidden) {
				$select.addEventListener('change', () => {
					$hidden.value = $select.value || '';
					const opt = $select.selectedOptions && $select.selectedOptions[0];
					const defAttr = opt ? (opt.getAttribute('data-default-nominal') || '').trim() : '';
					const hasDef = defAttr !== '' && defAttr != null;
					if ($defNom) {
						$defNom.textContent = hasDef ? defAttr : '-';
					}
					// Update displayed supplier name/code on the left
					if (opt) {
						const nm = opt.getAttribute('data-name') || '';
						const cd = opt.getAttribute('data-code') || '';
						if ($nameDisp) $nameDisp.textContent = nm || '-';
						if ($codeDisp) $codeDisp.textContent = cd || '-';
					}
						// If we have a default nominal, populate any non-explicit nominal selects to reflect fallback
					const rows = document.querySelectorAll('tbody tr');
					rows.forEach(tr => {
						const tdNom = tr.querySelector('td.nominal-cell');
						if (!tdNom) return;
						const isExplicit = (tdNom.getAttribute('data-explicit') || '').toLowerCase() === 'true';
						const sel = tdNom.querySelector('select.nominal-select');
						let codeText = (sel && sel.value) ? sel.value.trim() : '';
						if (!isExplicit && defAttr && sel) {
							codeText = defAttr;
							sel.value = defAttr;
						}
						// Update description from nominal map if we have a code
						const tdDesc = tr.querySelector('td.desc-cell');
						const hasExplicitDesc = (tdDesc && (tdDesc.getAttribute('data-has-desc') || '').toLowerCase() === 'true');
						if (tdDesc && codeText && !hasExplicitDesc) {
							const info = nominalMap && (nominalMap[codeText] || nominalMap[String(codeText)] || nominalMap[Number(codeText)]) || null;
							if (info) tdDesc.textContent = info.Description || info.Name || tdDesc.textContent || '-';
						}
					});
					recomputeCanSend();
				});
	  }

		  // Update checklist and description when a nominal is manually changed
		  document.querySelectorAll('select.nominal-select').forEach(sel => {
		  	sel.addEventListener('change', (e) => {
		  		const tr = sel.closest('tr');
		  		const tdDesc = tr && tr.querySelector('td.desc-cell');
		  		const hasExplicitDesc = tdDesc && (tdDesc.getAttribute('data-has-desc') || '').toLowerCase() === 'true';
		  		const code = sel.value;
		  		if (tdDesc && code && !hasExplicitDesc) {
		  			const info = nominalMap && (nominalMap[code] || nominalMap[String(code)] || nominalMap[Number(code)]) || null;
		  			if (info) tdDesc.textContent = info.Description || info.Name || tdDesc.textContent || '-';
		  		}
		  		updateNominalChecklist();
		  	});
		  });

		  // On submit, copy selected nominal codes and project numbers into hidden inputs inside the form
		  const $form = document.getElementById('send-form');
		  if ($form) {
		  	$form.addEventListener('submit', () => {
		  		// remove previous hidden inputs
		  		$form.querySelectorAll('input[name="nominalCodes[]"]').forEach(n => n.remove());
		  		$form.querySelectorAll('input[name="projectNumbers[]"]').forEach(n => n.remove());
		  		const rows = document.querySelectorAll('tbody tr');
		  		rows.forEach((tr) => {
		  			const sel = tr.querySelector('select.nominal-select');
		  			const val = sel ? (sel.value || '').trim() : '';
		  			const hid = document.createElement('input');
		  			hid.type = 'hidden';
		  			hid.name = 'nominalCodes[]';
		  			hid.value = val;
		  			$form.appendChild(hid);

		  			const projSel = tr.querySelector('select.project-select');
		  			const projVal = projSel ? (projSel.value || '').trim() : '';
		  			const projHid = document.createElement('input');
		  			projHid.type = 'hidden';
		  			projHid.name = 'projectNumbers[]';
		  			projHid.value = projVal;
		  			$form.appendChild(projHid);
		  		});
		  	});
		  }
	  if ($search && $select && $hidden) {
		let timer = null;
		$search.addEventListener('input', () => {
		  const q = $search.value.trim();
		  clearTimeout(timer);
		  timer = setTimeout(async () => {
			try {
			  const res = await fetch(`/paperless/suppliers?q=${encodeURIComponent(q)}`);
			  if (!res.ok) return;
			  const data = await res.json();
			  const items = Array.isArray(data.items) ? data.items : [];
			  // Rebuild options; preserve current selection if still present
			  const current = $hidden.value;
			  const opts = [new Option('— Not selected —', '')];
							for (const s of items) {
				const label = `${s.Name || '(no name)'}${s.Code ? ' — ' + s.Code : ''}`;
								const opt = new Option(label, s.uuid, false, s.uuid === current);
								if (s.Name) opt.setAttribute('data-name', s.Name);
								if (s.Code) opt.setAttribute('data-code', s.Code);
								if (s.DefaultNominalCode != null && s.DefaultNominalCode !== '') {
									opt.setAttribute('data-default-nominal', s.DefaultNominalCode);
								}
				opts.push(opt);
			  }
			  // Replace existing options
			  $select.innerHTML = '';
			  for (const opt of opts) $select.add(opt);
			} catch (_) { /* ignore */ }
		  }, 250);
		});
	  }
	})();
	</script>
	<script type="application/json" id="nominal-map-json"><%= JSON.stringify(nominalMap || {}) %></script>
</div>
