<div class="w-full my-10">
  <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 lg:gap-6 mb-6">
    <h1 class="text-2xl font-bold text-center lg:text-left"><%= title %></h1>
    <div class="flex items-center gap-3">
      <a href="/paperless/ingest" class="text-sm text-green-700 dark:text-green-400 hover:underline">Ingest tracker</a>
    </div>
  </div>

  <form method="get" class="mb-4 flex flex-wrap gap-3 items-center" id="list-controls">
    <input name="q" value="<%= q %>" placeholder="Search title/OCR/correspondent/type"
           class="text-sm border rounded px-3 py-1 w-64 bg-white dark:bg-gray-800 dark:text-white dark:border-gray-600" />
    <label class="inline-flex items-center gap-2 text-sm">
      <input type="checkbox" name="done" value="1" <%= done ? 'checked' : '' %> class="rounded border-slate-300 dark:border-gray-600 dark:bg-gray-800 accent-green-600" />
      Only data-entry-done
    </label>
    <button class="text-sm bg-green-700 text-white px-4 py-1 rounded hover:bg-green-800 transition">Search</button>
  </form>

  <div class="text-sm text-gray-600 dark:text-gray-300 mb-2">Total: <%= total %></div>

  <div class="overflow-x-auto border rounded-xl">
    <table class="min-w-full text-sm border border-gray-300 dark:border-gray-600">
      <thead class="bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200">
        <tr>
          <th class="px-3 py-2 text-xs border-b dark:border-gray-600 text-left font-medium">Paperless ID</th>
          <th class="px-3 py-2 text-xs border-b dark:border-gray-600 text-left font-medium">Title</th>
          <th class="px-3 py-2 text-xs border-b dark:border-gray-600 text-left font-medium">Correspondent</th>
          <th class="px-3 py-2 text-xs border-b dark:border-gray-600 text-left font-medium">Type</th>
          <th class="px-3 py-2 text-xs border-b dark:border-gray-600 text-left font-medium">Kashflow</th>
          <th class="px-3 py-2 text-xs border-b dark:border-gray-600 text-left font-medium">Tags</th>
          <th class="px-3 py-2 text-xs border-b dark:border-gray-600 text-left font-medium">Modified</th>
          <th class="px-3 py-2 text-xs border-b dark:border-gray-600 text-left font-medium">Details</th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100">
        <% items.forEach(it => { %>
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
            <td class="px-3 py-2 border-b dark:border-gray-700"><a class="text-green-600 dark:text-green-400 hover:underline" target="_blank" href="/paperless/ocr/<%= it.paperlessId %>">#<%= it.paperlessId %></a></td>
            <td class="px-3 py-2 border-b dark:border-gray-700"><%= it.title || '-' %></td>
            <td class="px-3 py-2 border-b dark:border-gray-700"><%= it.correspondent?.name || '-' %></td>
            <td class="px-3 py-2 border-b dark:border-gray-700"><%= it.documentType?.name || '-' %></td>
            <td class="px-3 py-2 border-b dark:border-gray-700">
              <% if (typeof it.kashflowPurchaseNumber === 'number') { %>
                <a href="https://app.kashflow.com/#purchases/<%= it.kashflowPurchaseNumber %>" target="_blank" class="text-green-600 dark:text-green-400 hover:underline">#<%= it.kashflowPurchaseNumber %></a>
              <% } else { %>
                <span class="text-slate-400">-</span>
              <% } %>
            </td>
            <td class="px-3 py-2 border-b dark:border-gray-700">
              <% const _tags = Array.isArray(it.tags) ? it.tags : []; const _tagNames = _tags.map(t => (t && (t.name || t.Name)) || (typeof t === 'string' ? t : null)).filter(Boolean); %>
              <% if (_tagNames.length === 0) { %>
                <span class="text-slate-400">-</span>
              <% } else { %>
                <div class="flex flex-wrap gap-1">
                  <% _tagNames.forEach(n => { %>
                    <span class="text-[11px] px-2 py-0.5 rounded-full bg-slate-100 text-slate-700 border border-slate-200 dark:bg-slate-900/40 dark:text-slate-300 dark:border-slate-700"><%= n %></span>
                  <% }) %>
                </div>
              <% } %>
            </td>
            <td class="px-3 py-2 border-b dark:border-gray-700"><%= it.modified ? new Date(it.modified).toLocaleString() : '-' %></td>
            <td class="px-3 py-2 border-b dark:border-gray-700">
              <a href="https://docs.heroncs.co.uk/documents/<%= it.paperlessId %>/details" target="_blank" class="text-green-600 dark:text-green-400 hover:underline" target="_blank">View Details</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="flex items-center justify-between mt-4 text-sm">
    <div>Page <%= page %> of <%= pages %></div>
    <div class="flex gap-2">
      <% if (page > 1) { %>
        <a class="px-3 py-1 rounded border text-xs bg-white dark:bg-gray-800 dark:text-white border-gray-300 dark:border-gray-600 hover:bg-green-600 hover:text-white dark:hover:bg-green-700 transition" href="?q=<%= encodeURIComponent(q) %>&page=<%= page-1 %>&pageSize=<%= pageSize %><%= done ? '&done=1' : '' %>">Prev</a>
      <% } %>
      <% if (page < pages) { %>
        <a class="px-3 py-1 rounded border text-xs bg-white dark:bg-gray-800 dark:text-white border-gray-300 dark:border-gray-600 hover:bg-green-600 hover:text-white dark:hover:bg-green-700 transition" href="?q=<%= encodeURIComponent(q) %>&page=<%= page+1 %>&pageSize=<%= pageSize %><%= done ? '&done=1' : '' %>">Next</a>
      <% } %>
    </div>
  </div>

  <script>
    (function(){
      // Only poll if the server actually started a background ingest
      const started = <%= startedBgIngest ? 'true' : 'false' %>;
      if (!started) return;
      let attempts = 0;
      const maxAttempts = 60; // ~2 minutes
      const timer = setInterval(async () => {
        attempts++;
        try {
          const res = await fetch('/paperless/ingest?json=1');
          if (!res.ok) throw new Error('status fetch failed');
          const data = await res.json();
          if (!data.running) {
            clearInterval(timer);
            // Reload once, with autoIngest disabled to avoid loops
            const url = new URL(window.location.href);
            url.searchParams.set('autoIngest', '0');
            window.location.replace(url.toString());
          } else if (attempts >= maxAttempts) {
            clearInterval(timer);
          }
        } catch (_) {
          if (attempts >= maxAttempts) clearInterval(timer);
        }
      }, 2000);
    })();
  </script>
</div>
