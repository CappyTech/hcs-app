<div class="p-4 max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-4">
    <h1 class="text-2xl font-semibold"><%= title %></h1>
    <a href="/paperless/ocr" class="underline">OCR documents</a>
  </div>

  <form method="get" class="mb-4 flex gap-2 items-end">
    <div>
      <label class="block text-sm mb-1">Status</label>
      <select name="status" class="rounded-md border px-3 py-2 dark:bg-neutral-900">
        <option value="" <%= !status ? 'selected' : '' %>>All</option>
        <option value="fetched" <%= status==='fetched'?'selected':'' %>>Fetched</option>
        <option value="skipped" <%= status==='skipped'?'selected':'' %>>Skipped</option>
        <option value="error" <%= status==='error'?'selected':'' %>>Error</option>
      </select>
    </div>
    <button class="h-[38px] rounded-md px-4 py-2 border hover:bg-neutral-50 dark:hover:bg-neutral-800">Filter</button>
  </form>

  <form method="post" action="/paperless/ingest/trigger" class="mb-6 border rounded-xl p-4">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <h2 class="font-semibold mb-2">Trigger grab</h2>
    <div class="grid md:grid-cols-4 gap-3">
      <div>
        <label class="block text-sm mb-1">Since (ISO-8601)</label>
        <input name="since" placeholder="2025-01-01T00:00:00Z" class="w-full rounded-md border px-3 py-2 dark:bg-neutral-900"/>
      </div>
      <div>
        <label class="block text-sm mb-1">Query (Paperless search)</label>
        <input name="query" placeholder="document_type:Invoice" class="w-full rounded-md border px-3 py-2 dark:bg-neutral-900"/>
      </div>
      <div>
        <label class="block text-sm mb-1">Page size</label>
        <input name="pageSize" type="number" min="1" max="500" value="50" class="w-full rounded-md border px-3 py-2 dark:bg-neutral-900"/>
      </div>
      <div>
        <label class="block text-sm mb-1">Concurrency</label>
        <input name="concurrency" type="number" min="1" max="20" value="5" class="w-full rounded-md border px-3 py-2 dark:bg-neutral-900"/>
      </div>
    </div>
    <div class="mt-3">
      <button class="rounded-md px-4 py-2 border hover:bg-neutral-50 dark:hover:bg-neutral-800">Run grab</button>
    </div>
  </form>

  <div class="text-sm text-neutral-600 dark:text-neutral-400 mb-2">Total: <%= total %></div>

  <div class="overflow-x-auto border rounded-xl">
    <table class="min-w-full text-sm">
      <thead class="bg-neutral-50 dark:bg-neutral-900">
        <tr>
          <th class="text-left p-3">Paperless ID</th>
          <th class="text-left p-3">Status</th>
          <th class="text-left p-3">Last Modified</th>
          <th class="text-left p-3">Last Fetched</th>
          <th class="text-left p-3">Hash</th>
          <th class="text-left p-3">Open</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach(it => { %>
          <tr class="border-t hover:bg-neutral-50 dark:hover:bg-neutral-900">
            <td class="p-3">#<%= it.paperlessId %></td>
            <td class="p-3"><%= it.status %></td>
            <td class="p-3"><%= it.lastModified ? new Date(it.lastModified).toLocaleString() : '-' %></td>
            <td class="p-3"><%= it.lastFetchedAt ? new Date(it.lastFetchedAt).toLocaleString() : '-' %></td>
            <td class="p-3 max-w-[220px]"><code class="break-all"><%= it.lastContentHash %></code></td>
            <td class="p-3"><a class="text-blue-600 underline" href="/paperless/ocr/<%= it.paperlessId %>">Open</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="flex items-center justify-between mt-4 text-sm">
    <div>Page <%= page %> of <%= pages %></div>
    <div class="flex gap-2">
      <% if (page > 1) { %>
        <a class="px-3 py-1 border rounded" href="?status=<%= encodeURIComponent(status) %>&page=<%= page-1 %>&pageSize=<%= pageSize %>">Prev</a>
      <% } %>
      <% if (page < pages) { %>
        <a class="px-3 py-1 border rounded" href="?status=<%= encodeURIComponent(status) %>&page=<%= page+1 %>&pageSize=<%= pageSize %>">Next</a>
      <% } %>
    </div>
  </div>
</div>