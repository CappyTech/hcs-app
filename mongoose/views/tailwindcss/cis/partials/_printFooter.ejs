<%
  const _cssLine = (footerTitle || '')
    .replace(/&mdash;/g, '\u2014')
    .replace(/&bull;/g, '\u2022')
    .replace(/&amp;/g, '&')
    .replace(/\\/g, '\\\\')
    .replace(/"/g, '\\"');
  const _cssFooter = _cssLine + ' \u2022 Heron Constructive Solutions LTD \u2022 103 Herondale Road, Mossley Hill, Liverpool, L18 1JZ \u2022 admin@heroncs.co.uk';
%>
<style nonce="<%= locals.cspNonce %>">:root { --hcs-footer: "<%- _cssFooter %>"; }</style>
