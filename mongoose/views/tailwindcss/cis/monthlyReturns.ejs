<div class="text-center mt-4">
  <div class="mb-6 text-gray-700 text-sm">
    <%= supplier.Name %> | Heron Constructive Solutions LTD | <%= year %> Monthly Returns
  </div>

  <h1 class="mb-6 text-5xl font-bold"><%= year %> Monthly Returns</h1>

  <div class="flex flex-wrap justify-center gap-8 mb-8">
    <div class="w-full md:w-1/2 text-center">
      <p class="text-3xl font-semibold mb-2">Subcontractor</p>
      <p><%= supplier.Name %></p>
      <!-- OLD: supplier.CISNumber -->
      <% const whtRefs = Array.isArray(supplier.WithholdingTaxReferences) ? supplier.WithholdingTaxReferences : []; %>
      <% whtRefs.forEach(ref => { %>
        <% if (ref && ref.Value) { %><p><%= ref.Name %>: <%= ref.Value %></p><% } %>
      <% }); %>
      <% if (supplier.VATNumber) { %><p>VAT: <%= supplier.VATNumber %></p><% } %>
      <address class="not-italic mt-2 leading-relaxed">
        <% if (supplier.Address1) { %><%= supplier.Address1 %>, <br><% } %>
        <% if (supplier.Address2) { %><%= supplier.Address2 %>, <br><% } %>
        <% if (supplier.Address3) { %><%= supplier.Address3 %>, <br><% } %>
        <% if (supplier.PostCode) { %><%= supplier.PostCode %>.<% } %>
      </address>
    </div>

    <div class="w-full md:w-1/2 text-center">
      <p class="text-3xl font-semibold mb-2">Contractor</p>
      <p>Heron Constructive Solutions LTD</p>
      <p>Company: 09276951</p>
      <p>VAT: 252295994</p>
      <address class="not-italic mt-2 leading-relaxed">
        103 Herondale Road, <br>
        Mossley Hill, <br>
        Liverpool, <br>
        Merseyside, <br>
        L18 1JZ.
      </address>
    </div>
  </div>

  <% for (let monthIndex = 1; monthIndex <= 12; monthIndex++) { %>
    <% 
      const monthKey = monthIndex.toString(); 
  let receipts = receiptsByMonth[monthKey] || []; 
  receipts = receipts.sort((a, b) => new Date(a.PayDate) - new Date(b.PayDate));
  const hasReceipts = receipts.length > 0; 
    %>
    <% if (hasReceipts) { %>
      <table class="min-w-full border-collapse border border-gray-300 mb-10 print:table <%= pageBreakMonths.includes(monthIndex) ? 'print:break-after-page' : '' %>">
        <caption class="text-center text-lg font-semibold mb-4">
          Month <%= monthKey %> (<%= monthNames[monthIndex - 1] %> <%= monthIndex >= 10 ? year + 1 : year %>)
        </caption>
        <thead class="bg-gray-100">
          <tr>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">#</th>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">KF #</th>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">Invoiced</th>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">Paid</th>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">Gross</th>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">Labour</th>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">Material</th>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">
              <% const cisRateVal = typeof supplier.WithholdingTaxRate === 'number' ? supplier.WithholdingTaxRate : (supplier.WithholdingTaxRate != null && supplier.WithholdingTaxRate !== '' ? +supplier.WithholdingTaxRate : null); %>
              <% const cisRateNorm = cisRateVal != null && cisRateVal > 1 ? cisRateVal / 100 : cisRateVal; %>
              CIS @ <%= cisRateNorm === 0 ? '0%' : cisRateNorm === 0.2 ? '20%' : cisRateNorm === 0.3 ? '30%' : 'Unknown' %>
            </th>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">Net</th>
            <% if (supplier.isReverseCharge) { %>
              <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">RC</th>
            <% } %>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">Month</th>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">Year</th>
            <th class="border border-gray-300 px-3 py-1 text-center text-xs md:text-sm">Submission</th>
          </tr>
        </thead>
        <tbody>
          <% 
            let totalGross = 0, totalLabour = 0, totalMaterial = 0, totalCIS = 0, totalNet = 0;
            receipts.forEach(receipt => { 
          %>
          <tr class="even:bg-gray-50">
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= receipt.InvoiceNumber || receipt.Number %></td>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= receipt.KashflowNumber || receipt.Number %></td>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= slimDateTime(receipt.InvoiceDate || receipt.IssuedDate) %></td>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= slimDateTime(receipt.PayDate) %></td>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= formatCurrency(receipt.Gross) %></td>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= formatCurrency(receipt.Labour) %></td>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= formatCurrency(receipt.Material) %></td>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= formatCurrency(receipt.CIS) %></td>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= formatCurrency(receipt.Net) %></td>
            <% if (supplier.isReverseCharge) { %>
              <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= formatCurrency(receipt.ReverseCharge) %></td>
            <% } %>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= receipt.TaxMonth %></td>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= receipt.TaxYear %></td>
            <td class="border border-gray-300 px-3 py-1 text-center text-sm"><%= slimDateTime(receipt.SubmissionDate) %></td>
          </tr>
          <% 
            totalGross += receipt.Gross;
            totalLabour += receipt.Labour;
            totalMaterial += receipt.Material;
            totalCIS += receipt.CIS;
            totalNet += receipt.Net;
          }); %>
          <tr class="font-bold bg-gray-200">
            <td colspan="4" class="border border-gray-300 px-3 py-1 text-left">Total for Month <%= monthKey %>:</td>
            <td class="border border-gray-300 px-3 py-1 text-center"><%= formatCurrency(totalGross) %></td>
            <td class="border border-gray-300 px-3 py-1 text-center"><%= formatCurrency(totalLabour) %></td>
            <td class="border border-gray-300 px-3 py-1 text-center"><%= formatCurrency(totalMaterial) %></td>
            <td class="border border-gray-300 px-3 py-1 text-center"><%= formatCurrency(totalCIS) %></td>
            <td class="border border-gray-300 px-3 py-1 text-center"><%= formatCurrency(totalNet) %></td>
            <% if (supplier.isReverseCharge) { %>
              <td></td>
            <% } %>
            <td></td>
            <td></td>
            <td></td>
          </tr>
        </tbody>
      </table>
    <% } %>
  <% } %>
</div>
