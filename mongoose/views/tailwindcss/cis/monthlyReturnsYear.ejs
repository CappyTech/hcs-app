<div class="text-center mt-4 space-y-8">
  <h1 class="mb-4 text-4xl font-bold">Year <%= year %> Report</h1>

  <% subcontractors.forEach(subcontractor => { %>
    <div class="space-y-2">
      <div class="text-lg font-semibold">
        <%= subcontractor.name %> | <%= subcontractor.company %> @ 
        <% if (subcontractor.deduction === 0.0) { %>0%<% } else if (subcontractor.deduction === 0.2) { %>20%<% } else if (subcontractor.deduction === 0.3) { %>30%<% } %>
        <% if (subcontractor.isGross) { %> GROSS<% } %>
      </div>
      <div class="text-sm text-gray-600">
        <%= subcontractor.utrNumber %> | <%= subcontractor.cisNumber %>
      </div>

      <div class="max-w-full overflow-x-auto">
        <% const hasInvoices = subcontractor.invoices.length > 0; %>
        <% if (hasInvoices) { %>
          <table class="min-w-full border border-gray-300 rounded-lg overflow-hidden text-left text-sm">
            <caption class="text-left font-semibold p-2 text-gray-700">Year <%= year %></caption>
            <thead class="bg-gray-100">
              <tr>
                <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Invoice</th>
                <th class="px-3 py-2 border border-gray-300 md:hidden">Inv</th>

                <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Kashflow</th>
                <th class="px-3 py-2 border border-gray-300 md:hidden">KF</th>

                <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Invoiced</th>
                <th class="px-3 py-2 border border-gray-300 md:hidden">Invoiced</th>

                <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Paid</th>
                <th class="px-3 py-2 border border-gray-300 md:hidden">Paid</th>

                <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Gross</th>
                <th class="px-3 py-2 border border-gray-300 md:hidden">Gross</th>

                <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Labour</th>
                <th class="px-3 py-2 border border-gray-300 md:hidden">Labour</th>

                <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Material</th>
                <th class="px-3 py-2 border border-gray-300 md:hidden">Material</th>

                <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">
                  CIS @
                  <% if (subcontractor.deduction === 0.0) { %>0%<% } else if (subcontractor.deduction === 0.2) { %>20%<% } else if (subcontractor.deduction === 0.3) { %>30%<% } %>
                </th>
                <th class="px-3 py-2 border border-gray-300 md:hidden">CIS</th>

                <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Net</th>
                <th class="px-3 py-2 border border-gray-300 md:hidden">Net</th>

                <% if (subcontractor.isReverseCharge) { %>
                  <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Reverse Charge</th>
                  <th class="px-3 py-2 border border-gray-300 md:hidden">RC</th>
                <% } %>

                <th class="px-3 py-2 border border-gray-300 text-center">Month</th>
                <th class="px-3 py-2 border border-gray-300 text-center">Year</th>

                <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Submission Date</th>
                <th class="px-3 py-2 border border-gray-300 md:hidden">Submission</th>
              </tr>
            </thead>
            <tbody>
              <% 
                let totalGross = 0;
                let totalLabourCost = 0;
                let totalMaterialCost = 0;
                let totalCISAmount = 0;
                let totalNetAmount = 0;
                let totalReverseCharge = 0;
                subcontractor.invoices.forEach(invoice => { 
              %>
              <tr class="even:bg-gray-50">
                <td class="border border-gray-300 px-3 py-1"><%= invoice.invoiceNumber %></td>
                <td class="border border-gray-300 px-3 py-1"><%= invoice.kashflowNumber %></td>
                <td class="border border-gray-300 px-3 py-1"><%= slimDateTime(invoice.invoiceDate) %></td>
                <td class="border border-gray-300 px-3 py-1"><%= slimDateTime(invoice.remittanceDate) %></td>
                <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(invoice.grossAmount) %></td>
                <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(invoice.labourCost) %></td>
                <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(invoice.materialCost) %></td>
                <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(invoice.cisAmount) %></td>
                <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(invoice.netAmount) %></td>
                <% if (subcontractor.isReverseCharge) { %>
                  <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(invoice.reverseCharge) %></td>
                <% } %>
                <td class="border border-gray-300 px-3 py-1 text-center"><%= invoice.month %></td>
                <td class="border border-gray-300 px-3 py-1 text-center"><%= invoice.year %></td>
                <td class="border border-gray-300 px-3 py-1"><%= slimDateTime(invoice.submissionDate) %></td>
              </tr>
              <% 
                totalGross += invoice.grossAmount;
                totalLabourCost += invoice.labourCost;
                totalMaterialCost += invoice.materialCost;
                totalCISAmount += invoice.cisAmount;
                totalNetAmount += invoice.netAmount;
                totalReverseCharge += invoice.reverseCharge;
              %>
              <% }); %>
              <tr class="font-semibold bg-gray-200">
                <td colspan="2" class="border border-gray-300 px-3 py-1">Total:</td>
                <td class="border border-gray-300 px-3 py-1"></td>
                <td class="border border-gray-300 px-3 py-1"></td>
                <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalGross) %></td>
                <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalLabourCost) %></td>
                <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalMaterialCost) %></td>
                <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalCISAmount) %></td>
                <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalNetAmount) %></td>
                <td class="border border-gray-300 px-3 py-1"></td>
                <% if (subcontractor.isReverseCharge) { %>
                  <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalReverseCharge) %></td>
                <% } %>
                <td class="border border-gray-300 px-3 py-1"></td>
                <td class="border border-gray-300 px-3 py-1"></td>
                <td class="border border-gray-300 px-3 py-1"></td>
              </tr>
              <!-- Optional: Add another total table for submission input values -->
            </tbody>
          </table>
        <% } else { %>
          <p class="text-center text-gray-500">No invoices available for the selected month and year.</p>
        <% } %>
      </div>
    <% }); %>
</div>
