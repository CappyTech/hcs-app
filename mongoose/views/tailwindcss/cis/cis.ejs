<div class="container mx-auto py-10 max-w-7xl px-4">
  <div class="mb-8 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg">
    <div class="py-12 px-4">
      <!-- Navigation -->
      <div class="flex justify-between items-center mb-4">
        <a href="/CIS/Dashboard/<%= previousYear %>/<%= previousMonth %>" 
           class="inline-block bg-green-600 hover:bg-green-700 text-white px-4 py-3 rounded text-center text-sm leading-tight">
          <i class="bi bi-chevron-left"></i> Previous<br> <h3 class="text-2xl"><%= previousMonth %>, <%= previousYear %></h3>
        </a>
        <h1 class="text-4xl font-semibold text-center flex-1 mx-4">
          <%= specifiedMonth %>, <%= specifiedYear %>
        </h1>
        <h2 class="text-xl font-semibold text-center flex-1 mx-4">
          <%= slimDateTime(currentMonthlyReturn.periodStart, ['displayFormat']) %> - <%= slimDateTime(currentMonthlyReturn.periodEnd, ['displayFormat']) %>
        </h2>
        <a href="/CIS/Dashboard/<%= nextYear %>/<%= nextMonth %>" 
           class="inline-block bg-green-600 hover:bg-green-700 text-white px-4 py-3 rounded text-center text-sm leading-tight">
          Next <i class="bi bi-chevron-right"></i><br><h3 class="text-2xl"><%= nextMonth %>, <%= nextYear %></h3>
        </a>
      </div>

      <!-- Summary Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white dark:bg-gray-900 border dark:border-gray-700 rounded shadow p-6 text-center">
          <h4 class="text-lg font-semibold mb-2">Total Suppliers</h4>
          <p class="text-3xl font-bold"><%= supplierCount %></p>
        </div>
        <div class="bg-white dark:bg-gray-900 border dark:border-gray-700 rounded shadow p-6 text-center">
          <h4 class="text-lg font-semibold mb-2">Total Purchases</h4>
          <p class="text-3xl font-bold"><%= purchaseCount %></p>
        </div>
      </div>

      <% if (!allPurchasesSubmitted || purchases.length === 0) { %>
      <div class="mb-6 bg-yellow-300 dark:bg-yellow-800 text-yellow-900 dark:text-yellow-100 rounded text-center p-4 font-semibold">
        This month should be submitted between <span class="font-bold"><%= slimDateTime(submissionStartDate, ['displayFormat']) %></span> and <span class="font-bold"><%= slimDateTime(submissionEndDate, ['displayFormat']) %></span>.
      </div>
      <% } else if (submissionDate) { %>
      <div class="mb-6 bg-green-600 dark:bg-green-700 text-white rounded text-center p-6">
        <h4 class="text-xl font-semibold mb-2">Submitted On:</h4>
        <p class="text-2xl font-semibold"><%= slimDateTime(submissionDate, ['displayFormat']) %></p>
      </div>
      <% } %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
          <div class="bg-white dark:bg-gray-900 border dark:border-gray-700 rounded shadow p-6 mb-6">
            <h4 class="text-lg font-semibold mb-1">
              Tax Year
            </h4>  
            <p>
              <%= slimDateTime(taxYear.start, ['displayFormat']) %> - <%= slimDateTime(taxYear.end, ['displayFormat']) %>
            </p>
            <small>
              <a href="/CIS/returns/all/<%= specifiedYear %>" class="text-green-600 hover:underline">
                Print-out of this Year's returns
              </a>
            </small>
          </div>
          <div class="bg-white dark:bg-gray-900 border dark:border-gray-700 rounded shadow p-6">
            <h4 class="text-lg font-semibold mb-1">Submission Deadline</h4>
            <p><%= slimDateTime(currentMonthlyReturn.submissionDeadline, ['displayFormat']) %> (<%= currentMonthlyReturn.submissionDeadlineInDays %> days left)</p>
          </div>
        </div>
        <div>
          <div class="bg-white dark:bg-gray-900 border dark:border-gray-700 rounded shadow p-6 mb-6">
            <h4 class="text-lg font-semibold mb-1">
              Monthly Return
            </h4>
            <p>
              <%= slimDateTime(currentMonthlyReturn.periodStart, ['displayFormat']) %> - <%= slimDateTime(currentMonthlyReturn.periodEnd, ['displayFormat']) %>
            </p>
            <small>
              <a href="/CIS/returns/all/<%= specifiedYear %>/<%= specifiedMonth %>" class="text-green-600 hover:underline">
                Print-out of this Month's Returns
              </a>
            </small>
          </div>
          <div class="bg-white dark:bg-gray-900 border dark:border-gray-700 rounded shadow p-6">
            <h4 class="text-lg font-semibold mb-1">HMRC Update Date</h4>
            <p><%= slimDateTime(currentMonthlyReturn.hmrcUpdateDate, ['displayFormat']) %> (<%= currentMonthlyReturn.hmrcUpdateDateInDays %> days left)</p>
          </div>
        </div>
      </div>

      <!-- Subcontractors Table -->

      <% if (typeof debug !== 'undefined' && debug) { %>
      <div class="mb-8 p-4 bg-gray-900 text-green-300 rounded-lg font-mono text-xs overflow-x-auto">
        <h4 class="text-sm font-bold text-yellow-300 mb-2">Debug Output (?debug=1)</h4>
        <pre><%= JSON.stringify(debug, null, 2) %></pre>
      </div>
      <% } %>
      <div class="mb-12">
        <h3 class="text-center text-2xl font-bold mb-6">Subcontractors</h3>
        <div class="overflow-x-auto">
          <table class="min-w-full border-collapse border border-gray-300 dark:border-gray-700">
            <thead class="bg-gray-200 dark:bg-gray-800 text-gray-800 dark:text-gray-200">
              <tr>
                <th class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-left">Name</th>
                <th class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right">Gross</th>
                <th class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right">Labour</th>
                <th class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right">Materials</th>
                <th class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right">CIS</th>
                <th class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right">Reverse Charge</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100">
              <% if (suppliers.length === 0) { %>
              <tr>
                <td colspan="6" class="border border-gray-300 dark:border-gray-700 text-center py-6">No purchases that cover <%= slimDateTime(currentMonthlyReturn.periodStart, ['displayFormat']) %> - <%= slimDateTime(currentMonthlyReturn.periodEnd, ['displayFormat']) %>.</td>
              </tr>
              <% } else { %>
                <% suppliers.forEach(supplier => { %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
                  <td class="border border-gray-300 dark:border-gray-700 px-4 py-2">
                    <a href="/supplier/read/<%= supplier.uuid %>" class="text-green-600 dark:text-green-400 hover:underline"><%= supplier.Name %></a>
                  </td>
                  <% if (supplierTotals[String(supplier.Id)]) { %>
                  <td class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right font-bold"><%= formatCurrency(supplierTotals[String(supplier.Id)].grossAmount) %></td>
                  <td class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right"><%= formatCurrency(supplierTotals[String(supplier.Id)].labourCost) %></td>
                  <td class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right font-bold"><%= formatCurrency(supplierTotals[String(supplier.Id)].materialsCost) %></td>
                  <% const st = supplierTotals[String(supplier.Id)]; %>
                  <td class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right font-bold"><%= formatCurrency((st.cisDeductions && st.cisDeductions !== 0) ? st.cisDeductions : st.calculatedCISDeduction) %></td>
                  <td class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right"><%= formatCurrency(supplierTotals[String(supplier.Id)].reverseChargeVAT) %></td>
                  <% } else { %>
                  <td colspan="6" class="border border-gray-300 dark:border-gray-700 text-center py-6">No Data</td>
                  <% } %>
                </tr>
                <% }); %>
              <% } %>
            </tbody>
            <tfoot class="bg-gray-50 dark:bg-gray-800 text-gray-800 dark:text-gray-200 font-semibold">
              <%
                let totGross = 0, totLabour = 0, totMaterials = 0, totCIS = 0, totRC = 0;
                suppliers.forEach(s => {
                  const st = supplierTotals[String(s.Id)];
                  if (!st) return;
                  totGross += st.grossAmount || 0;
                  totLabour += st.labourCost || 0;
                  totMaterials += st.materialsCost || 0;
                  totCIS += (st.cisDeductions && st.cisDeductions !== 0) ? st.cisDeductions : (st.calculatedCISDeduction || 0);
                  totRC += st.reverseChargeVAT || 0;
                });
              %>
              <tr>
                <td class="border border-gray-300 dark:border-gray-700 px-4 py-2">Totals</td>
                <td class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right font-bold"><%= formatCurrency(totGross) %></td>
                <td class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right"><%= formatCurrency(totLabour) %></td>
                <td class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right font-bold"><%= formatCurrency(totMaterials) %></td>
                <td class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right font-bold"><%= formatCurrency(totCIS) %></td>
                <td class="border border-gray-300 dark:border-gray-700 px-4 py-2 text-right"><%= formatCurrency(totRC) %></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>

      <!-- Purchase Lists -->
      <% if (suppliers.length === 0) { %><% } else { %>
        <div class="mb-12">
          <% const midIndex = Math.ceil(purchases.length / 2); %>
          <h3 class="text-center text-2xl font-bold mb-6">Purchases</h3>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <% [purchases.slice(0, midIndex), purchases.slice(midIndex)].forEach((group) => { %>
              <ul class="border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm overflow-hidden bg-white dark:bg-gray-900">
                <% group.forEach(purchase => { %>
                  <li>
                    <a href="/purchase/read/<%= purchase.uuid %>"
                      class="flex justify-between items-center px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-700 dark:text-gray-200 border-b border-gray-200 dark:border-gray-700">
                      <span class="flex items-center gap-2 text-sm">
                        <i class="bi bi-pencil-square text-gray-500 dark:text-gray-400"></i>
                        <% if (purchase.SubmissionDate) { %>
                          <i class="bi bi-check text-green-600"></i>
                        <% } else { %>
                          <i class="bi bi-x text-red-600"></i>
                        <% } %>
                      </span>
                      <span class="text-sm text-right">
                        <div><%= purchase.Number %> | <%= purchase.SupplierName %> | <%= purchase.SupplierReference %></div>
                        <small class="block text-xs text-gray-500 dark:text-gray-400">
                          <%= purchase.displayDateLabel %>: <%= purchase.displayDate %> (<%= purchase.timeZoneTag %>)
                          <% if (!purchase.isPaid && purchase.dueDateStr) { %>
                            &nbsp;• Due: <%= purchase.dueDateStr %>
                          <% } %>
                        </small>
                      </span>
                    </a>
                  </li>
                <% }); %>
              </ul>
            <% }); %>
          </div>
        </div>
      <% } %>
      <% if (purchases.length > 0) { %>
      <hr class="my-8 border-gray-300 dark:border-gray-600">
      <div class="mb-8">
        <% if (allPurchasesSubmitted) { %>
        <div class="mb-4 text-center">
          <span class="inline-block bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 text-sm font-medium px-3 py-1 rounded-full">
            <i class="bi bi-check-circle"></i> All Purchases Submitted
          </span>
        </div>
        <% } %>
        <!-- Change All Submissions quick action -->
        <div class="max-w-xl mx-auto mb-6">
          <form action="/purchase/change" method="POST" class="flex flex-col sm:flex-row items-end gap-3">
            <%- include('../partials/csrfHidden.ejs') %>
            <input type="hidden" name="redirectPath" value="/CIS/Dashboard/<%= specifiedYear %>/<%= specifiedMonth %>">
            <% purchases.forEach(purchase => { %>
              <input type="hidden" name="uuids" value="<%= purchase.uuid %>">
            <% }); %>
            <div class="flex-1 w-full">
              <label for="submissionDateAll" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">Change all submissions to Date:</label>
              <input type="date" id="submissionDateAll" name="submissionDate" required
                class="w-full rounded border border-gray-300 dark:border-gray-600 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-hcs-green bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
            </div>
            <button type="submit" class="w-full sm:w-auto bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-2 rounded transition">
              Update All
            </button>
          </form>
        </div>

        <hr class="my-6 border-gray-200 dark:border-gray-700">

        <h4 class="text-center text-lg font-semibold mb-4">Update Submission Date for Selected Purchases</h4>
        <form action="/purchase/change" method="POST" class="max-w-xl mx-auto">
          <%- include('../partials/csrfHidden.ejs') %>
          <input type="hidden" name="redirectPath" value="/CIS/Dashboard/<%= specifiedYear %>/<%= specifiedMonth %>">
          <div class="mb-4">
            <label for="submissionDate" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">Submission Date</label>
            <input type="date" id="submissionDate" name="submissionDate" required
              class="w-full rounded border border-gray-300 dark:border-gray-600 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-hcs-green bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <!-- Select all toggle for purchases -->
          <div class="mb-2 flex items-center justify-end">
            <input type="checkbox" id="select-all-purchases" class="h-4 w-4 rounded border-gray-300 dark:border-gray-600 text-hcs-green focus:ring-hcs-green">
            <label for="select-all-purchases" class="ml-2 text-sm text-gray-700 dark:text-gray-200 cursor-pointer">Select all</label>
          </div>
          <fieldset class="purchase-scroll mb-6 max-h-96 overflow-y-auto border rounded border-gray-300 dark:border-gray-600 p-4 pr-2">
            <legend class="font-semibold mb-2 text-gray-800 dark:text-gray-200">Select Purchases</legend>
            <% purchases.forEach(purchase => { %>
            <div class="mb-2 flex items-center space-x-3">
              <input type="checkbox" id="purchase-<%= purchase.uuid %>" name="uuids" value="<%= purchase.uuid %>" 
                     class="h-4 w-4 rounded border-gray-300 dark:border-gray-600 text-hcs-green focus:ring-hcs-green">
              <label for="purchase-<%= purchase.uuid %>" class="text-gray-700 dark:text-gray-200 cursor-pointer">
                <%= purchase.Number %> | <%= purchase.SupplierName %>
              </label>
            </div>
            <% }); %>
          </fieldset>
          <script>
            (function () {
              const master = document.getElementById('select-all-purchases');
              if (!master) return;
              const scope = document.querySelector('fieldset.purchase-scroll');
              if (!scope) return;
              const getBoxes = () => Array.from(scope.querySelectorAll('input[type="checkbox"][name="uuids"]'));
              const refreshMaster = () => {
                const boxes = getBoxes();
                const total = boxes.length;
                const checked = boxes.filter(cb => cb.checked).length;
                master.indeterminate = checked > 0 && checked < total;
                master.checked = total > 0 && checked === total;
              };
              master.addEventListener('change', () => {
                const boxes = getBoxes();
                boxes.forEach(cb => { cb.checked = master.checked; });
                refreshMaster();
              });
              getBoxes().forEach(cb => cb.addEventListener('change', refreshMaster));
              refreshMaster();
            })();
          </script>
          <button type="submit" class="w-full bg-yellow-400 hover:bg-yellow-500 text-black dark:text-white font-semibold py-3 rounded transition">
            Update Selected Purchases
          </button>
        </form>
      </div>
      <% } %>
    </div>

<div class="p-6 mx-auto max-w-3xl">
  <div class="bg-green-50 dark:bg-green-900 border-l-4 border-green-400 dark:border-green-600 text-green-800 dark:text-green-100 rounded-lg shadow-sm p-5">
    <div class="flex flex-row mb-2">
      <h2 class="text-lg font-semibold"><i class="bi bi-info-circle text-xl mt-0.5"></i> Reminder</h2>
    </div>
    <div class="flex flex-col divide-y divide-gray-200 dark:divide-gray-700">
      <div>
        <p>
          This dashboard shows <span class="font-medium">paid purchases only</span>. Please ensure that
          <span class="font-medium">Paid Dates</span> are correctly set for all purchases you expect to appear here.
        </p>
      </div>
      <div class="text-center">
        <p class="text-sm">
          This helps maintain accurate CIS reporting and payment timelines.
        </p>
        <p class="text-sm">
          If you need to update the <span class="font-medium">Submission Date</span> for any purchases, please use the form above.
        </p>
      </div>
    </div>
  </div>
</div>


  </div>
</div>
