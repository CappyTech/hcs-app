<div class="container mx-auto py-10 max-w-7xl px-4">
  <div class="mb-8 bg-gray-100 rounded-lg">
    <div class="py-12 px-4">
      <!-- Navigation -->
      <div class="flex justify-between items-center mb-4">
        <a href="/CIS/<%= previousYear %>/<%= previousMonth %>" 
           class="inline-block bg-green-600 hover:bg-green-700 text-white px-4 py-3 rounded text-center text-sm leading-tight">
          &laquo; Previous<br> Month <%= previousMonth %>, <%= previousYear %>
        </a>
        <h1 class="text-2xl font-semibold text-center flex-1 mx-4">
          Month <%= specifiedMonth %> | <%= currentMonthlyReturn.periodStartDisplay %> - <%= currentMonthlyReturn.periodEndDisplay %>
        </h1>
        <a href="/CIS/<%= nextYear %>/<%= nextMonth %>" 
           class="inline-block bg-green-600 hover:bg-green-700 text-white px-4 py-3 rounded text-center text-sm leading-tight">
          Next &raquo;<br> Month <%= nextMonth %>, <%= nextYear %>
        </a>
      </div>

      <!-- Summary Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white rounded shadow p-6 text-center">
          <h4 class="text-lg font-semibold mb-2">Total Suppliers</h4>
          <p class="text-4xl font-bold"><%= supplierCount %></p>
        </div>
        <div class="bg-white rounded shadow p-6 text-center">
          <h4 class="text-lg font-semibold mb-2">Total Receipts</h4>
          <p class="text-4xl font-bold"><%= receiptCount %></p>
        </div>
      </div>

      <% if (!allReceiptsSubmitted || receipts.length === 0) { %>
      <div class="mb-6 bg-yellow-300 text-yellow-900 rounded text-center p-4 font-semibold">
        This month should be submitted between <span class="font-bold"><%= submissionStartDate %></span> and <span class="font-bold"><%= submissionEndDate %></span>.
      </div>
      <% } else if (submissionDate) { %>
      <div class="mb-6 bg-green-600 text-white rounded text-center p-6">
        <h4 class="text-xl font-semibold mb-2">Submitted On:</h4>
        <p class="text-2xl font-semibold"><%= slimDateTime(submissionDate) %></p>
      </div>
      <% } %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
          <div class="bg-white rounded shadow p-6 mb-6">
            <h4 class="text-lg font-semibold mb-1">Tax Year</h4>
            <p><%= taxYear.start %> - <%= taxYear.end %></p>
          </div>
          <div class="bg-white rounded shadow p-6">
            <h4 class="text-lg font-semibold mb-1">Monthly Return</h4>
            <p><%= currentMonthlyReturn.periodStartDisplay %> - <%= currentMonthlyReturn.periodEndDisplay %></p>
          </div>
        </div>
        <div>
          <div class="bg-white rounded shadow p-6 mb-6">
            <h4 class="text-lg font-semibold mb-1">Submission Deadline</h4>
            <p><%= currentMonthlyReturn.submissionDeadline %> (<%= currentMonthlyReturn.submissionDeadlineInDays %> days left)</p>
          </div>
          <div class="bg-white rounded shadow p-6">
            <h4 class="text-lg font-semibold mb-1">HMRC Update Date</h4>
            <p><%= currentMonthlyReturn.hmrcUpdateDate %> (<%= currentMonthlyReturn.hmrcUpdateDateInDays %> days left)</p>
          </div>
        </div>
      </div>

      <!-- Suppliers Table -->
      <div class="mb-8">
        <h3 class="text-center text-xl font-semibold mb-4">Suppliers</h3>
        <div class="overflow-x-auto">
          <table class="min-w-full border-collapse border border-gray-300">
            <thead>
              <tr class="bg-gray-200">
                <th class="border border-gray-300 px-4 py-2 text-left">Supplier</th>
                <th class="border border-gray-300 px-4 py-2 text-right">Gross Total</th>
                <th class="border border-gray-300 px-4 py-2 text-right">Labour Total</th>
                <th class="border border-gray-300 px-4 py-2 text-right">Materials Total</th>
                <th class="border border-gray-300 px-4 py-2 text-right">CIS Total</th>
                <th class="border border-gray-300 px-4 py-2 text-right">Reverse Charge Total</th>
              </tr>
            </thead>
            <tbody>
              <% if (suppliers.length === 0) { %>
              <tr>
                <td colspan="6" class="border border-gray-300 text-center py-6">No receipts that cover this period.</td>
              </tr>
              <% } else { %>
                <% suppliers.forEach(supplier => { %>
                <tr class="hover:bg-gray-50">
                  <td class="border border-gray-300 px-4 py-2">
                    <a href="/supplier/read/<%= supplier.uuid %>" class="text-blue-600 hover:underline"><%= supplier.Name %></a>
                  </td>
                  <% if (supplierTotals[String(supplier.SupplierID)]) { %>
                  <td class="border border-gray-300 px-4 py-2 text-right"><%= formatCurrency(supplierTotals[String(supplier.SupplierID)].grossAmount) %></td>
                  <td class="border border-gray-300 px-4 py-2 text-right"><%= formatCurrency(supplierTotals[String(supplier.SupplierID)].labourCost) %></td>
                  <td class="border border-gray-300 px-4 py-2 text-right"><%= formatCurrency(supplierTotals[String(supplier.SupplierID)].materialsCost) %></td>
                  <td class="border border-gray-300 px-4 py-2 text-right"><%= formatCurrency(supplierTotals[String(supplier.SupplierID)].cisDeductions) %></td>
                  <td class="border border-gray-300 px-4 py-2 text-right"><%= formatCurrency(supplierTotals[String(supplier.SupplierID)].reverseChargeVAT) %></td>
                  <% } else { %>
                  <td colspan="6" class="border border-gray-300 text-center py-6">No Data</td>
                  <% } %>
                </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Receipts Lists -->
      <div class="mb-8">
        <% const midIndex = Math.ceil(receipts.length / 2); %>
        <h3 class="text-center text-xl font-semibold mb-4">Receipts</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <ul class="divide-y divide-gray-300 border rounded shadow overflow-hidden">
            <% receipts.slice(0, midIndex).forEach(receipt => { %>
            <li>
              <a href="/receipt/read/<%= receipt.uuid %>" 
                 class="block px-4 py-3 hover:bg-gray-50 flex items-center justify-between text-gray-700">
                <span>
                  <%= receipt.InvoiceNumber %> | <%= receipt.CustomerName %> | <%= receipt.CustomerReference %>
                </span>
                <span class="flex items-center space-x-2 text-sm">
                  <i class="bi bi-pencil-square text-gray-500"></i>
                  <% if (receipt.SubmissionDate) { %>
                    <i class="bi bi-check text-hcs-green"></i>
                  <% } else { %>
                    <i class="bi bi-x text-hcs-red"></i>
                  <% } %>
                </span>
              </a>
            </li>
            <% }); %>
          </ul>
          <ul class="divide-y divide-gray-300 border rounded shadow overflow-hidden">
            <% receipts.slice(midIndex).forEach(receipt => { %>
            <li>
              <a href="/receipt/read/<%= receipt.uuid %>" 
                 class="block px-4 py-3 hover:bg-gray-50 flex items-center justify-between text-gray-700">
                <span>
                  <%= receipt.InvoiceNumber %> | <%= receipt.CustomerName %> | <%= receipt.CustomerReference %>
                </span>
                <span class="flex items-center space-x-2 text-sm">
                  <i class="bi bi-pencil-square text-gray-500"></i>
                  <% if (receipt.SubmissionDate) { %>
                    <i class="bi bi-check text-hcs-green"></i>
                  <% } else { %>
                    <i class="bi bi-x text-hcs-red"></i>
                  <% } %>
                </span>
              </a>
            </li>
            <% }); %>
          </ul>
        </div>
      </div>

      <% if (!allReceiptsSubmitted || receipts.length === 0) { %>
      <hr class="my-8 border-gray-300">
      <div class="mb-8">
        <h4 class="text-center text-lg font-semibold mb-4">Update Submission Date for Selected Receipts</h4>
        <form action="/receipt/change" method="POST" class="max-w-xl mx-auto">
          <input type="hidden" name="redirectPath" value="/mdb/CIS/<%= specifiedYear %>/<%= specifiedMonth %>">
          <div class="mb-4">
            <label for="submissionDate" class="block mb-1 font-medium text-gray-700">Submission Date</label>
            <input type="date" id="submissionDate" name="submissionDate" required
              class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-hcs-green">
          </div>
          <fieldset class="mb-6 max-h-96 overflow-auto border rounded border-gray-300 p-4">
            <legend class="font-semibold mb-2">Select Receipts</legend>
            <% receipts.forEach(receipt => { %>
            <div class="mb-2 flex items-center space-x-3">
              <input type="checkbox" id="receipt-<%= receipt.uuid %>" name="uuids" value="<%= receipt.uuid %>" 
                     class="h-4 w-4 rounded border-gray-300 text-hcs-green focus:ring-hcs-green">
              <label for="receipt-<%= receipt.uuid %>" class="text-gray-700 cursor-pointer">
                <%= receipt.InvoiceNumber %> | <%= receipt.CustomerName %>
              </label>
            </div>
            <% }); %>
          </fieldset>
          <button type="submit" class="w-full bg-yellow-400 hover:bg-yellow-500 text-gray-900 font-semibold py-3 rounded transition">
            Update Selected Receipts
          </button>
        </form>
      </div>
      <% } else { %>
      <hr class="my-8 border-gray-300">
      <div>
        <h4 class="text-center text-lg font-semibold">All Receipts Submitted</h4>
      </div>
      <% } %>
    </div>
  </div>
</div>
