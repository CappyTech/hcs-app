<div class="text-center mt-10 max-w-5xl mx-auto px-4">
  <h1 class="text-3xl font-semibold mb-6">Month <%= month %> Report</h1>

  <% subcontractors.forEach(subcontractor => { %>
    <div class="mb-10">
      <div class="mb-2 text-lg font-medium">
        <%= subcontractor.name %> | <%= subcontractor.company %> @
        <% if (subcontractor.deduction === 0.0) { %>0%<% } else if (subcontractor.deduction === 0.2) { %>20%<% } else if (subcontractor.deduction === 0.3) { %>30%<% } %>
        <% if (subcontractor.isGross) { %> GROSS <% } %>
      </div>
      <div class="mb-4 text-sm text-gray-600">
        <%= subcontractor.utrNumber %> | <%= subcontractor.cisNumber %>
      </div>

      <% const hasInvoices = subcontractor.invoices.length > 0; %>
      <% if (hasInvoices) { %>
        <div class="overflow-x-auto">
          <table class="min-w-full border-collapse border border-gray-300 text-sm">
            <caption class="caption-top text-left mb-2 font-semibold">
              Month <%= month %>
            </caption>
            <thead class="bg-gray-100 border-b border-gray-300">
              <tr>
                <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">Invoice</th>
                <th class="border border-gray-300 px-2 py-1 md:hidden">Inv</th>

                <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">Kashflow</th>
                <th class="border border-gray-300 px-2 py-1 md:hidden">KF</th>

                <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">Invoiced</th>
                <th class="border border-gray-300 px-2 py-1 md:hidden">Invoiced</th>

                <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">Paid</th>
                <th class="border border-gray-300 px-2 py-1 md:hidden">Paid</th>

                <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">Gross</th>
                <th class="border border-gray-300 px-2 py-1 md:hidden">Gross</th>

                <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">Labour</th>
                <th class="border border-gray-300 px-2 py-1 md:hidden">Labour</th>

                <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">Material</th>
                <th class="border border-gray-300 px-2 py-1 md:hidden">Material</th>

                <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">
                  CIS @
                  <% if (subcontractor.deduction === 0.0) { %>0%<% } else if (subcontractor.deduction === 0.2) { %>20%<% } else if (subcontractor.deduction === 0.3) { %>30%<% } %>
                </th>
                <th class="border border-gray-300 px-2 py-1 md:hidden">CIS</th>

                <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">Net</th>
                <th class="border border-gray-300 px-2 py-1 md:hidden">Net</th>

                <% if (subcontractor.isReverseCharge) { %>
                  <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">Reverse Charge</th>
                  <th class="border border-gray-300 px-2 py-1 md:hidden">RC</th>
                <% } %>

                <th class="border border-gray-300 px-2 py-1">Month</th>
                <th class="border border-gray-300 px-2 py-1">Year</th>

                <th class="border border-gray-300 px-2 py-1 hidden md:table-cell">Submission Date</th>
                <th class="border border-gray-300 px-2 py-1 md:hidden">Submission</th>
              </tr>
            </thead>
            <tbody>
              <% 
                let totalGross = 0;
                let totalLabourCost = 0;
                let totalMaterialCost = 0;
                let totalCISAmount = 0;
                let totalNetAmount = 0;
                let totalReverseCharge = 0;
                subcontractor.invoices.forEach(invoice => { 
              %>
                <tr class="border-b border-gray-300 hover:bg-gray-50">
                  <td class="border border-gray-300 px-2 py-1"><%= invoice.invoiceNumber %></td>
                  <td class="border border-gray-300 px-2 py-1"><%= invoice.kashflowNumber %></td>
                  <td class="border border-gray-300 px-2 py-1"><%= slimDateTime(invoice.invoiceDate) %></td>
                  <td class="border border-gray-300 px-2 py-1"><%= slimDateTime(invoice.remittanceDate) %></td>
                  <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(invoice.grossAmount) %></td>
                  <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(invoice.labourCost) %></td>
                  <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(invoice.materialCost) %></td>
                  <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(invoice.cisAmount) %></td>
                  <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(invoice.netAmount) %></td>
                  <% if (subcontractor.isReverseCharge) { %>
                    <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(invoice.reverseCharge) %></td>
                  <% } %>
                  <td class="border border-gray-300 px-2 py-1 text-center"><%= invoice.month %></td>
                  <td class="border border-gray-300 px-2 py-1 text-center"><%= invoice.year %></td>
                  <td class="border border-gray-300 px-2 py-1"><%= slimDateTime(invoice.submissionDate) %></td>
                </tr>
                <% 
                  totalGross += invoice.grossAmount;
                  totalLabourCost += invoice.labourCost;
                  totalMaterialCost += invoice.materialCost;
                  totalCISAmount += invoice.cisAmount;
                  totalNetAmount += invoice.netAmount;
                  totalReverseCharge += invoice.reverseCharge || 0;
                %>
              <% }); %>
              <tr class="bg-gray-200 font-semibold">
                <td colspan="2" class="border border-gray-300 px-2 py-1">Total:</td>
                <td class="border border-gray-300 px-2 py-1"></td>
                <td class="border border-gray-300 px-2 py-1"></td>
                <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(totalGross) %></td>
                <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(totalLabourCost) %></td>
                <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(totalMaterialCost) %></td>
                <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(totalCISAmount) %></td>
                <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(totalNetAmount) %></td>
                <td class="border border-gray-300 px-2 py-1"></td>
                <% if (subcontractor.isReverseCharge) { %>
                  <td class="border border-gray-300 px-2 py-1 text-right"><%= formatCurrency(totalReverseCharge) %></td>
                <% } %>
                <td class="border border-gray-300 px-2 py-1"></td>
                <td class="border border-gray-300 px-2 py-1"></td>
                <td class="border border-gray-300 px-2 py-1"></td>
              </tr>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-gray-500 italic text-center">No invoices available for the selected month and year.</p>
      <% } %>
    </div>
  <% }); %>
</div>
