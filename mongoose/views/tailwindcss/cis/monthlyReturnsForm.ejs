<div class="max-w-6xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <div class="p-6 sm:p-8">
    <h1 class="text-2xl font-bold mb-6 text-gray-900 dark:text-gray-100">Monthly Returns</h1>

    <% if (suppliersWithMonths.length===0) { %>
      <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 text-amber-800 dark:text-amber-200 px-4 py-3 rounded-xl mb-6" role="alert">
        No subcontractor return data found.
      </div>
      <% } %>

        <div id="suppliersAccordion" class="space-y-4">
          <% suppliersWithMonths.forEach((data, index)=> {
            const supplier = data.supplier;
            const years = data.years;
            const receiptsByYear = data.receiptsByYear;
            %>
            <div class="border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm overflow-hidden">
              <h2>
                <button type="button"
                  class="accordion-toggle w-full px-4 py-3 text-left flex justify-between items-center focus:outline-none focus:ring focus:ring-green-500"
                  aria-expanded="false" aria-controls="collapse-<%= supplier.uuid %>"
                  id="heading-<%= supplier.uuid %>">
                  <span class="font-semibold text-lg text-gray-900 dark:text-gray-100">
                    <%= supplier.Name %>
                      <span class="inline-block bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-100 text-xs font-medium ml-2 px-2.5 py-1 rounded-full">
                        <%= years.length %>
                          <%= years.length===1 ? 'Year' : 'Years' %>
                      </span>
                      <% const rateLabel = whtRateLabel(supplier.WithholdingTaxRate); %>
                      <% if (rateLabel) { %>
                      <span class="inline-block bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-100 text-xs font-medium ml-2 px-2.5 py-1 rounded-full">
                        <%= rateLabel %>
                      </span>
                      <% } %>
                  </span>
                  <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 transition-transform duration-200"
                    xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                    aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
              </h2>

              <div id="collapse-<%= supplier.uuid %>" role="region" aria-labelledby="heading-<%= supplier.uuid %>"
                class="hidden px-4 pb-4 mt-2">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                  <% years.forEach(year=> { %>
                    <div class="bg-gray-50 dark:bg-gray-800 p-4 rounded-xl h-full flex flex-col">
                      <h3 class="text-2xl font-semibold mb-2">
                        <%= year %>-<%= (Number(year) + 1).toString().slice(-2) %>
                      </h3>
                      <ul class="flex flex-col space-y-1 flex-grow">
                        <li class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2 shadow-sm hover:bg-green-50 dark:hover:bg-green-900/20 relative">
                          <a href="/CIS/returns/<%= supplier.uuid %>/yearly/<%= year %>" class="block w-full h-full">
                            Yearly Report
                          </a>
                        </li>
                        <% receiptsByYear[year].forEach(month=> { %>
                          <li class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl px-3 py-2 shadow-sm hover:bg-green-50 dark:hover:bg-green-900/20 relative">
                            <a href="/CIS/returns/<%= supplier.uuid %>/<%= year %>/<%= month %>"
                              class="block w-full h-full">
                              <%= monthNames[month - 1] %> <%= month >= 10 ? Number(year) + 1 : year %>
                            </a>
                          </li>
                          <% }) %>
                      </ul>
                    </div>
                    <% }) %>
                </div>
              </div>
            </div>
            <% }); %>
        </div>
    </div>
  </div>
</div>

<script src="/resources/js/toggleAccordion.js"></script>