<div class="">
  <h1 class="mb-4 text-center font-extrabold">
    <%= year %>-<%= (parseInt(year) + 1).toString().slice(-2) %> Construction Industry Scheme Returns
  </h1>

  <div class="grid grid-cols-1 md:grid-cols-2 print:grid-cols-2 gap-8 text-center">
    <div>
      <p class="font-semibold mb-2">Subcontractor</p>
      <p>
        <%= supplier.Name %><br><br>
        <% 
          // Address is consistently shaped as:
          // { Line1, Line2, Line3, Line4, PostCode, CountryName, CountryCode, CountryId }
          const A = supplier.Address || {};
          const line1 = (A.Line1 || '').trim();
          const line2 = (A.Line2 || '').trim();
          const line3 = (A.Line3 || '').trim();
          const line4 = (A.Line4 || '').trim();
          const postCode = (A.PostCode || '').trim();
          const slots = [line1, line2, line3, line4, postCode];
        %>
        <% if (typeof debug !== 'undefined' && debug) { %>
          <details class="mt-2 mb-2 p-2 border border-yellow-300 bg-yellow-50 text-xs rounded print:hidden">
            <summary class="cursor-pointer font-semibold">Debug: address slots</summary>
            <div class="mt-2">
              <div><span class="font-medium">typeof supplier.Address:</span> <%= typeof supplier.Address %></div>
              <div class="mt-1"><span class="font-medium">Raw supplier.Address:</span></div>
              <pre class="whitespace-pre-wrap break-words"><%- JSON.stringify(supplier.Address, null, 2) %></pre>
              <div class="mt-1"><span class="font-medium">Computed slots:</span></div>
              <pre class="whitespace-pre-wrap break-words"><%- JSON.stringify(slots, null, 2) %></pre>
            </div>
          </details>
        <% } %>
        <% 
          const nonEmptyIdx = slots.map((s,i)=> (s && s.trim()) ? i : -1).filter(i=>i!==-1);
          const lastIdx = nonEmptyIdx.length ? nonEmptyIdx[nonEmptyIdx.length-1] : -1;
          for (let i = 0; i < slots.length; i++) {
            const raw = slots[i] || '';
            const trimmed = raw.trim();
            const isEmpty = !trimmed;
            const isLast = i === lastIdx;
        %>
          <span>
            <% if (!isEmpty) { 
                 const endsWithPunct = /[.,]$/.test(trimmed);
                 let out = trimmed;
                 if (!endsWithPunct) {
                   out = trimmed + (isLast ? '.' : ',');
                 }
            %>
              <%= out %>
            <% } else { %>
              <%- '&nbsp;' %>
            <% } %>
          </span><br>
        <% } %>
      </p>
    </div>
    <div>
      <p class="font-semibold mb-2">Contractor</p>
      <p>
        Heron Constructive Solutions LTD<br><br>
        103 Herondale Road,<br>
        Mossley Hill,<br>
        Liverpool,<br>
        Merseyside,<br>
        L18 1JZ.
      </p>
    </div>
  </div>
</div>

<div class="page-break"></div>

<% for (let monthIndex = 1; monthIndex <= 12; monthIndex++) { %>
  <% const monthKey = monthIndex.toString(); %>
  <% let receipts = receiptsByMonth[monthKey] || []; %>
  <% receipts = receipts.sort((a, b) => new Date(a.PayDate) - new Date(b.PayDate)); %>
  <% const hasReceipts = receipts.length > 0; %>
  <% if (hasReceipts) { %>
  <% const tableClasses = pageBreakMonths.includes(monthIndex) ? 'page-break d-print-table' : 'd-print-table'; %>
  <div class="avoid-page-break">
  <table class="min-w-full border border-gray-300 rounded-lg overflow-hidden text-left text-xs leading-tight mb-4 condensed-table <%= tableClasses %>">
      <caption class="text-center font-semibold p-2 text-gray-700">Month <%= monthKey %> (<%= monthNames[monthIndex - 1] %> <%= monthIndex >= 10 ? year + 1 : year %>)</caption>
      <thead class="bg-gray-100">
        <tr>
          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Invoice</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Inv</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Kashflow</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">KF</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Invoiced</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Invoiced</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Paid</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Paid</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Gross</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Gross</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Labour</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Labour</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Material</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Material</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">
            CIS @ 
            <% const cisRateNum = typeof supplier.CISRate === 'number' ? supplier.CISRate : (supplier.CISRate != null && supplier.CISRate !== '' ? +supplier.CISRate : null); %>
            <%= cisRateNum === 0 ? '0%' : cisRateNum === 0.2 ? '20%' : cisRateNum === 0.3 ? '30%' : 'Unknown' %>
          </th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">CIS</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Net</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Net</th>

          <% if (supplier.isReverseCharge) { %>
            <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Reverse Charge</th>
            <th class="px-3 py-2 border border-gray-300 md:hidden">RC</th>
          <% } %>

          <th class="px-3 py-2 border border-gray-300 text-center">Submission Date</th>
        </tr>
      </thead>
      <tbody>
        <% let totalGross=0, totalLabour=0, totalMaterial=0, totalCIS=0, totalNet=0, totalRC=0; %>
        <% receipts.forEach(receipt => { %>
          <tr class="even:bg-gray-50">
            <td class="border border-gray-300 px-3 py-1"><%= receipt.InvoiceNumber %></td>
            <td class="border border-gray-300 px-3 py-1"><%= receipt.KashflowNumber %></td>
            <td class="border border-gray-300 px-3 py-1"><%= slimDateTime(receipt.InvoiceDate) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= slimDateTime(receipt.PayDate) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.Gross) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.Labour) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.Material) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.CIS) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.Net) %></td>
            <% if (supplier.isReverseCharge) { %>
              <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.ReverseCharge) %></td>
            <% } %>
            <td class="border border-gray-300 px-3 py-1"><%= slimDateTime(receipt.SubmissionDate) %></td>
          </tr>
          <% 
            totalGross += receipt.Gross;
            totalLabour += receipt.Labour;
            totalMaterial += receipt.Material;
            totalCIS += receipt.CIS;
            totalNet += receipt.Net;
            totalRC += receipt.ReverseCharge || 0;
          %>
        <% }) %>
        <tr class="font-semibold bg-gray-200">
          <td colspan="4" class="border border-gray-300 px-3 py-1">Totals for Month <%= monthKey %>:</td>
          <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalGross) %></td>
          <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalLabour) %></td>
          <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalMaterial) %></td>
          <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalCIS) %></td>
          <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalNet) %></td>
          <% if (supplier.isReverseCharge) { %>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalRC) %></td>
          <% } %>
          <td class="border border-gray-300 px-3 py-1"></td>
        </tr>
      </tbody>
  </table>
  </div>
  <% } %>
<% } %>


<style>
  @media print {
    /* Preserve colors for header rows, etc. */
    body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    /* Hide UI-only elements */
    .print\:hidden { display: none !important; }

    /* Make tables paginate cleanly */
    table { page-break-inside: auto; border-collapse: collapse; }
    tr { page-break-inside: avoid; page-break-after: auto; }
    thead { display: table-header-group; }
    tfoot { display: table-footer-group; }
    caption { caption-side: top; }

    /* Keep each table together on one page when possible */
  .avoid-page-break { page-break-inside: avoid; break-inside: avoid; }
  .avoid-page-break table { page-break-inside: avoid !important; break-inside: avoid !important; }

    /* Utility classes used in template */
    .page-break { page-break-before: always; break-before: page; }
    .d-print-table { display: table !important; width: 100% !important; }
    .d-print-table th, .d-print-table td { padding: 6px 8px !important; }
  }
  /* Ensure borders render crisply both on screen and print */
  .d-print-table, .d-print-table th, .d-print-table td { border-color: #d1d5db; }
</style>

<style>
  /* Condensed table utility for yearly returns */
  .condensed-table { font-size: 0.75rem; line-height: 1.2; }
  .condensed-table th, .condensed-table td { padding: 2px 4px; }
  .condensed-table caption { padding: 4px 0; }

  @media print {
    .condensed-table { font-size: 10px !important; }
    /* Override earlier print padding rules to be tighter */
    .condensed-table.d-print-table th, .condensed-table.d-print-table td { padding: 2px 4px !important; }
    .condensed-table caption { padding: 2px 0 !important; }
  }
</style>


