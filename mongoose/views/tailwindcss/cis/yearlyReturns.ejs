<div class="flex flex-wrap gap-2 print:hidden p-4 border-b border-gray-200">
  <!-- PDF Button -->
  <button class="btn-hcs-green px-4 py-2 rounded disabled:opacity-50 disabled:cursor-not-allowed" data-bs-toggle="modal" data-bs-target="#pdfModal" disabled>
    Download as PDF
  </button>

  <!-- CSV Button -->
  <form action="/kashflow/yearly/download-csv" method="POST" class="m-0">
    <input type="hidden" name="year" value="<%= year %>">
    <input type="hidden" name="uuid" value="<%= supplier.uuid %>">
    <input type="hidden" name="filename"
      value="<%= supplier.Name.replace(/\\s+/g, '_') %>_<%= year %>-<%= (parseInt(year) + 1).toString().slice(-2) %>_CIS_Returns.csv">
    <button type="submit" class="btn-hcs-green px-4 py-2 rounded disabled:opacity-50 disabled:cursor-not-allowed" disabled>
      Download as CSV
    </button>
  </form>

  <!-- XLSX Button -->
  <form action="/kashflow/yearly/download-xlsx" method="POST" class="m-0">
    <input type="hidden" name="year" value="<%= year %>">
    <input type="hidden" name="uuid" value="<%= supplier.uuid %>">
    <input type="hidden" name="filename"
      value="<%= supplier.Name.replace(/\\s+/g, '_') %>_<%= year %>-<%= (parseInt(year) + 1).toString().slice(-2) %>_CIS_Returns.xlsx">
    <button type="submit" class="btn-hcs-green px-4 py-2 rounded">
      Download as Excel
    </button>
  </form>
</div>

<div class="page-number py-3 text-center text-gray-600 font-semibold">
  <%= supplier.Name %> | Heron Constructive Solutions LTD | <%= year %>-<%= (parseInt(year) + 1).toString().slice(-2) %> CIS Returns
</div>

<div class="mt-4">
  <h1 class="mb-4 text-center text-4xl font-extrabold">
    <%= year %>-<%= (parseInt(year) + 1).toString().slice(-2) %> Returns
  </h1>

  <div class="flex flex-wrap justify-evenly gap-8 text-center">
    <div class="w-full md:w-1/2">
      <p class="text-3xl font-semibold mb-2">Subcontractor</p>
      <p>
        <%= supplier.Name %><br>
        <%= [supplier.Address1, supplier.Address2, supplier.Address3, supplier.Address4, supplier.PostCode].filter(Boolean).join(', ') %>
      </p>
    </div>
    <div class="w-full md:w-1/2">
      <p class="text-3xl font-semibold mb-2">Contractor</p>
      <p>
        Heron Constructive Solutions LTD<br>
        103 Herondale Road,<br>
        Mossley Hill,<br>
        Liverpool,<br>
        Merseyside,<br>
        L18 1JZ.
      </p>
    </div>
  </div>
</div>

<% for (let monthIndex = 1; monthIndex <= 12; monthIndex++) { %>
  <% const monthKey = monthIndex.toString(); %>
  <% let receipts = receiptsByMonth[monthKey] || []; %>
  <% receipts = receipts.sort((a, b) => new Date(a.PayDate) - new Date(b.PayDate)); %>
  <% const hasReceipts = receipts.length > 0; %>
  <% if (hasReceipts) { %>
    <% const tableClasses = pageBreakMonths.includes(monthIndex) ? 'page-break d-print-table' : 'd-print-table'; %>
    <table class="min-w-full border border-gray-300 rounded-lg overflow-hidden text-left text-sm mb-6 <%= tableClasses %>">
      <caption class="text-center font-semibold p-2 text-gray-700">Month <%= monthKey %> (<%= monthNames[monthIndex - 1] %> <%= year %>)</caption>
      <thead class="bg-gray-100">
        <tr>
          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Invoice</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Inv</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Kashflow</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">KF</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Invoiced</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Invoiced</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Paid</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Paid</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Gross</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Gross</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Labour</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Labour</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Material</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Material</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">
            CIS @ 
            <% if (supplier.CISRate===' 0') { %>0%<% } else if (supplier.CISRate==='0.2') { %>20%<% } else if (supplier.CISRate==='0.3') { %>30%<% } %>
          </th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">CIS</th>

          <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Net</th>
          <th class="px-3 py-2 border border-gray-300 md:hidden">Net</th>

          <% if (supplier.isReverseCharge) { %>
            <th class="px-3 py-2 border border-gray-300 hidden md:table-cell">Reverse Charge</th>
            <th class="px-3 py-2 border border-gray-300 md:hidden">RC</th>
          <% } %>

          <th class="px-3 py-2 border border-gray-300 text-center">Submission Date</th>
        </tr>
      </thead>
      <tbody>
        <% let totalGross=0, totalLabour=0, totalMaterial=0, totalCIS=0, totalNet=0; %>
        <% receipts.forEach(receipt => { %>
          <tr class="even:bg-gray-50">
            <td class="border border-gray-300 px-3 py-1"><%= receipt.InvoiceNumber %></td>
            <td class="border border-gray-300 px-3 py-1"><%= receipt.KashflowNumber %></td>
            <td class="border border-gray-300 px-3 py-1"><%= slimDateTime(receipt.InvoiceDate) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= slimDateTime(receipt.PayDate) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.GrossAmount) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.LabourCost) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.MaterialCost) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.CISAmount) %></td>
            <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.NetAmount) %></td>
            <% if (supplier.isReverseCharge) { %>
              <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(receipt.ReverseCharge) %></td>
            <% } %>
            <td class="border border-gray-300 px-3 py-1"><%= slimDateTime(receipt.SubmissionDate) %></td>
          </tr>
          <% 
            totalGross += receipt.GrossAmount;
            totalLabour += receipt.LabourCost;
            totalMaterial += receipt.MaterialCost;
            totalCIS += receipt.CISAmount;
            totalNet += receipt.NetAmount;
          %>
        <% }) %>
        <tr class="font-semibold bg-gray-200">
          <td colspan="4" class="border border-gray-300 px-3 py-1">Total for Month <%= monthKey %>:</td>
          <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalGross) %></td>
          <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalLabour) %></td>
          <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalMaterial) %></td>
          <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalCIS) %></td>
          <td class="border border-gray-300 px-3 py-1"><%= formatCurrency(totalNet) %></td>
          <td class="border border-gray-300 px-3 py-1"></td>
        </tr>
      </tbody>
    </table>
  <% } %>
<% } %>

<!-- PDF Options Modal -->
<div class="modal fade" id="pdfModal" tabindex="-1" aria-labelledby="pdfModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <form action="/kashflow/yearly/download-pdf" method="POST" class="bg-white rounded shadow p-6">
      <input type="hidden" name="year" value="<%= year %>">
      <input type="hidden" name="uuid" value="<%= supplier.uuid %>">
      <input type="hidden" name="pageBreakMonths" value="<%= pageBreakMonths.join(',') %>">

      <div class="modal-content">
        <div class="modal-header flex justify-between items-center border-b border-gray-200 pb-2">
          <h5 class="modal-title text-lg font-semibold">PDF Options</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body grid grid-cols-1 md:grid-cols-3 gap-4 pt-4">
          <div class="col-span-3">
            <label class="block mb-1 font-medium" for="filename">Filename</label>
            <input
              type="text"
              name="filename"
              id="filename"
              class="w-full border border-gray-300 rounded px-3 py-2"
              placeholder="<%= supplier.Name %> | Heron Constructive Solutions LTD | <%= year %>-<%= (parseInt(year) + 1).toString().slice(-2) %> CIS Returns"
              value="<%= supplier.Name %> | Heron Constructive Solutions LTD | <%= year %>-<%= (parseInt(year) + 1).toString().slice(-2) %> CIS Returns"
              required
            />
          </div>

          <div>
            <label class="block mb-1 font-medium" for="format">Format</label>
            <select name="format" id="format" class="form-select w-full border border-gray-300 rounded px-3 py-2">
              <option>A4</option>
              <option>Letter</option>
              <option>A3</option>
              <option>A5</option>
              <option>Legal</option>
            </select>
          </div>

          <div>
            <label class="block mb-1 font-medium" for="width">Width (if custom)</label>
            <input
              type="text"
              class="form-control w-full border border-gray-300 rounded px-3 py-2"
              name="width"
              id="width"
              placeholder="e.g., 8.5in"
            />
          </div>

          <div>
            <label class="block mb-1 font-medium" for="height">Height (if custom)</label>
            <input
              type="text"
              class="form-control w-full border border-gray-300 rounded px-3 py-2"
              name="height"
              id="height"
              placeholder="e.g., 11in"
            />
          </div>

          <div>
            <label class="block mb-1 font-medium" for="landscape">Orientation</label>
            <select name="landscape" id="landscape" class="form-select w-full border border-gray-300 rounded px-3 py-2">
              <option value="0">Portrait</option>
              <option value="1">Landscape</option>
            </select>
          </div>

          <div>
            <label class="block mb-1 font-medium" for="scale">Scale (0.1 - 2.0)</label>
            <input
              type="number"
              step="0.1"
              min="0.1"
              max="2.0"
              name="scale"
              id="scale"
              class="form-control w-full border border-gray-300 rounded px-3 py-2"
              value="1"
            />
          </div>

          <div>
            <label class="block mb-1 font-medium" for="pageRanges">Page Ranges</label>
            <input
              type="text"
              name="pageRanges"
              id="pageRanges"
              class="form-control w-full border border-gray-300 rounded px-3 py-2"
              placeholder="e.g., 1-3,5"
            />
          </div>

          <div>
            <label class="block mb-1 font-medium" for="marginTop">Top Margin</label>
            <input
              type="text"
              name="marginTop"
              id="marginTop"
              class="form-control w-full border border-gray-300 rounded px-3 py-2"
              value="20mm"
            />
          </div>

          <div>
            <label class="block mb-1 font-medium" for="marginBottom">Bottom Margin</label>
            <input
              type="text"
              name="marginBottom"
              id="marginBottom"
              class="form-control w-full border border-gray-300 rounded px-3 py-2"
              value="20mm"
            />
          </div>

          <div>
            <label class="block mb-1 font-medium" for="marginLeft">Left Margin</label>
            <input
              type="text"
              name="marginLeft"
              id="marginLeft"
              class="form-control w-full border border-gray-300 rounded px-3 py-2"
              value="15mm"
            />
          </div>

          <div>
            <label class="block mb-1 font-medium" for="marginRight">Right Margin</label>
            <input
              type="text"
              name="marginRight"
              id="marginRight"
              class="form-control w-full border border-gray-300 rounded px-3 py-2"
              value="15mm"
            />
          </div>

          <div class="col-span-1 md:col-span-3 flex items-center mt-3">
            <input
              class="form-check-input mr-2"
              type="checkbox"
              name="printBackground"
              id="printBackground"
            />
            <label class="form-check-label" for="printBackground">Print Background</label>
          </div>

          <div class="col-span-1 md:col-span-3 flex items-center mt-3">
            <input
              class="form-check-input mr-2"
              type="checkbox"
              name="preferCSSPageSize"
              id="preferCSSPageSize"
            />
            <label class="form-check-label" for="preferCSSPageSize">Prefer CSS Page Size</label>
          </div>

          <div class="col-span-1 md:col-span-3 flex items-center mt-3">
            <input
              class="form-check-input mr-2"
              type="checkbox"
              name="displayHeaderFooter"
              id="displayHeaderFooter"
            />
            <label class="form-check-label" for="displayHeaderFooter">Display Header/Footer</label>
          </div>

          <div class="col-span-1 md:col-span-3 mt-3">
            <label class="block mb-1 font-medium" for="headerTemplate">Header HTML</label>
            <textarea
              class="w-full border border-gray-300 rounded px-3 py-2"
              name="headerTemplate"
              id="headerTemplate"
              rows="2"
              placeholder="Optional: custom HTML for header..."
            ></textarea>
          </div>

          <div class="col-span-1 md:col-span-3 mt-3">
            <label class="block mb-1 font-medium" for="footerTemplate">Footer HTML</label>
            <textarea
              class="w-full border border-gray-300 rounded px-3 py-2"
              name="footerTemplate"
              id="footerTemplate"
              rows="2"
              placeholder="Optional: custom HTML for footer..."
            ></textarea>
          </div>
        </div>

        <div class="modal-footer mt-4 flex justify-end border-t border-gray-200 pt-3">
          <button type="submit" class="btn-hcs-green px-6 py-2 rounded font-semibold">Generate PDF</button>
        </div>
      </div>
    </form>
  </div>
</div>
