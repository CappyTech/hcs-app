<%
  // -- Compute shared values once --
  const cisRateNum = typeof supplier.WithholdingTaxRate === 'number'
    ? supplier.WithholdingTaxRate
    : (supplier.WithholdingTaxRate != null && supplier.WithholdingTaxRate !== '' ? +supplier.WithholdingTaxRate : null);
  const cisRateNorm = cisRateNum != null && cisRateNum > 1 ? cisRateNum / 100 : cisRateNum;
  const cisRateLabel = cisRateNorm === 0 ? '0% (Gross)' : cisRateNorm === 0.2 ? '20%' : cisRateNorm === 0.3 ? '30%' : '—';
  const refs = Array.isArray(supplier.WithholdingTaxReferences) ? supplier.WithholdingTaxReferences : [];
  const verificationRef = refs.find(r => r && r.Name === 'Verification Number');
  const utrRef = refs.find(r => r && r.Name === 'UTR Number');
  const niRef = refs.find(r => r && r.Name === 'NI Number');
  const A = supplier.Address || {};
  const addrParts = [A.Line1, A.Line2, A.Line3, A.Line4, A.PostCode].map(s => (s || '').trim()).filter(Boolean);

  // Compute annual totals across all months
  let annualGross = 0, annualLabour = 0, annualMaterial = 0, annualCIS = 0, annualNet = 0, annualRC = 0, annualCount = 0;
  for (let mi = 1; mi <= 12; mi++) {
    const recs = receiptsByMonth[mi.toString()] || [];
    recs.forEach(r => {
      annualGross += r.Gross || 0;
      annualLabour += r.Labour || 0;
      annualMaterial += r.Material || 0;
      annualCIS += r.CIS || 0;
      annualNet += r.Net || 0;
      annualRC += r.ReverseCharge || 0;
      annualCount++;
    });
  }
%>

<!-- ===== COVER / HEADER PAGE ===== -->
<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-center border-b-2 border-black pb-2 mb-6">
    Construction Industry Scheme — Yearly Return<br>
    Tax Year <%= year %>/<%= (parseInt(year) + 1).toString().slice(-2) %>
  </h1>

  <div class="flex justify-between text-sm mb-6">
    <!-- Subcontractor -->
    <div class="w-1/2 pr-4">
      <table class="w-full text-sm">
        <tr><td colspan="2" class="font-bold border-b border-black pb-1 mb-1">Subcontractor</td></tr>
        <tr><td class="py-0.5 pr-2 font-semibold align-top w-28">Name</td><td class="py-0.5"><%= supplier.Name %></td></tr>
        <% if (supplier.Code) { %>
        <tr><td class="py-0.5 pr-2 font-semibold align-top">Code</td><td class="py-0.5"><%= supplier.Code %></td></tr>
        <% } %>
        <% if (addrParts.length) { %>
        <tr><td class="py-0.5 pr-2 font-semibold align-top">Address</td><td class="py-0.5"><%= addrParts.join(', ') %></td></tr>
        <% } %>
        <% if (verificationRef && verificationRef.Value) { %>
        <tr><td class="py-0.5 pr-2 font-semibold align-top">Verification No.</td><td class="py-0.5 font-mono"><%= verificationRef.Value %></td></tr>
        <% } %>
        <% if (utrRef && utrRef.Value) { %>
        <tr><td class="py-0.5 pr-2 font-semibold align-top">UTR</td><td class="py-0.5 font-mono"><%= utrRef.Value %></td></tr>
        <% } %>
        <% if (niRef && niRef.Value) { %>
        <tr><td class="py-0.5 pr-2 font-semibold align-top">NI Number</td><td class="py-0.5 font-mono"><%= niRef.Value %></td></tr>
        <% } %>
        <tr><td class="py-0.5 pr-2 font-semibold align-top">Deduction Rate</td><td class="py-0.5"><%= cisRateLabel %></td></tr>
      </table>
    </div>
    <!-- Contractor -->
    <div class="w-1/2 pl-4">
      <table class="w-full text-sm">
        <tr><td colspan="2" class="font-bold border-b border-black pb-1 mb-1">Contractor</td></tr>
        <tr><td class="py-0.5 pr-2 font-semibold align-top w-28">Name</td><td class="py-0.5">Heron Constructive Solutions LTD</td></tr>
        <tr><td class="py-0.5 pr-2 font-semibold align-top">Address</td><td class="py-0.5">103 Herondale Road, Mossley Hill, Liverpool, Merseyside, L18 1JZ</td></tr>
      </table>
    </div>
  </div>

  <!-- Annual Summary -->
  <table class="w-full text-sm border-collapse border border-black mb-6">
    <caption class="text-left font-bold text-base mb-1">Annual Summary</caption>
    <thead>
      <tr>
        <th class="border border-black px-2 py-1 text-left">Invoices</th>
        <th class="border border-black px-2 py-1 text-right">Gross</th>
        <th class="border border-black px-2 py-1 text-right">Labour</th>
        <th class="border border-black px-2 py-1 text-right">Materials</th>
        <th class="border border-black px-2 py-1 text-right">CIS Deducted</th>
        <th class="border border-black px-2 py-1 text-right">Net Paid</th>
        <% if (annualRC > 0) { %>
        <th class="border border-black px-2 py-1 text-right">Reverse Charge</th>
        <% } %>
      </tr>
    </thead>
    <tbody>
      <tr class="font-semibold">
        <td class="border border-black px-2 py-1"><%= annualCount %></td>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualGross) %></td>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualLabour) %></td>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualMaterial) %></td>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualCIS) %></td>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualNet) %></td>
        <% if (annualRC > 0) { %>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualRC) %></td>
        <% } %>
      </tr>
    </tbody>
  </table>

  <% if (typeof debug !== 'undefined' && debug) { %>
  <details class="mb-4 p-2 border border-gray-400 text-xs print:hidden">
    <summary class="cursor-pointer font-semibold">Debug: supplier object</summary>
    <pre class="whitespace-pre-wrap break-words mt-2"><%- JSON.stringify(supplier, null, 2) %></pre>
  </details>
  <% } %>

  <button id="printBtn" type="button" class="print:hidden mb-4 border border-black px-4 py-1 text-sm hover:bg-gray-100 cursor-pointer">
    Print Report
  </button>
</div>

<div class="page-break"></div>

<!-- ===== MONTHLY DETAIL TABLES ===== -->
<div class="max-w-4xl mx-auto">
<% for (let monthIndex = 1; monthIndex <= 12; monthIndex++) { %>
  <% const monthKey = monthIndex.toString(); %>
  <% let receipts = receiptsByMonth[monthKey] || []; %>
  <% receipts = receipts.sort((a, b) => new Date(a.PayDate) - new Date(b.PayDate)); %>
  <% if (receipts.length > 0) { %>
  <div class="avoid-page-break mb-6">
    <table class="w-full text-xs border-collapse border border-black cis-table">
      <caption class="text-left font-bold text-sm pb-1">
        Month <%= monthKey %>: <%= monthNames[monthIndex - 1] %> <%= monthIndex >= 10 ? parseInt(year) + 1 : year %>
      </caption>
      <thead>
        <tr>
          <th class="border border-black px-1 py-0.5 text-left">Invoice</th>
          <th class="border border-black px-1 py-0.5 text-left">KF No.</th>
          <th class="border border-black px-1 py-0.5 text-left">Invoiced</th>
          <th class="border border-black px-1 py-0.5 text-left">Paid</th>
          <th class="border border-black px-1 py-0.5 text-right">Gross</th>
          <th class="border border-black px-1 py-0.5 text-right">Labour</th>
          <th class="border border-black px-1 py-0.5 text-right">Material</th>
          <th class="border border-black px-1 py-0.5 text-right">CIS @ <%= cisRateLabel %></th>
          <th class="border border-black px-1 py-0.5 text-right">Net</th>
          <% if (annualRC > 0) { %>
          <th class="border border-black px-1 py-0.5 text-right">RC</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% let mGross=0, mLabour=0, mMaterial=0, mCIS=0, mNet=0, mRC=0; %>
        <% receipts.forEach(receipt => { %>
        <tr>
          <td class="border border-black px-1 py-0.5"><%= receipt.InvoiceNumber %></td>
          <td class="border border-black px-1 py-0.5"><%= receipt.KashflowNumber %></td>
          <td class="border border-black px-1 py-0.5"><%= slimDateTime(receipt.InvoiceDate) %></td>
          <td class="border border-black px-1 py-0.5"><%= slimDateTime(receipt.PayDate) %></td>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(receipt.Gross) %></td>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(receipt.Labour) %></td>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(receipt.Material) %></td>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(receipt.CIS) %></td>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(receipt.Net) %></td>
          <% if (annualRC > 0) { %>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(receipt.ReverseCharge) %></td>
          <% } %>
        </tr>
        <%
          mGross += receipt.Gross || 0;
          mLabour += receipt.Labour || 0;
          mMaterial += receipt.Material || 0;
          mCIS += receipt.CIS || 0;
          mNet += receipt.Net || 0;
          mRC += receipt.ReverseCharge || 0;
        %>
        <% }); %>
      </tbody>
      <tfoot>
        <tr class="font-bold">
          <td colspan="4" class="border border-black px-1 py-0.5">Month Total (<%= receipts.length %> invoice<%= receipts.length !== 1 ? 's' : '' %>)</td>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(mGross) %></td>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(mLabour) %></td>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(mMaterial) %></td>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(mCIS) %></td>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(mNet) %></td>
          <% if (annualRC > 0) { %>
          <td class="border border-black px-1 py-0.5 text-right"><%= formatCurrency(mRC) %></td>
          <% } %>
        </tr>
      </tfoot>
    </table>
  </div>
  <% } %>
<% } %>

<!-- Annual Totals (repeated at end for easy reference) -->
<div class="avoid-page-break mt-4 border-t-2 border-black pt-2">
  <table class="w-full text-sm border-collapse border border-black">
    <caption class="text-left font-bold text-base mb-1">Annual Total — Tax Year <%= year %>/<%= (parseInt(year) + 1).toString().slice(-2) %></caption>
    <thead>
      <tr>
        <th class="border border-black px-2 py-1 text-left">Invoices</th>
        <th class="border border-black px-2 py-1 text-right">Gross</th>
        <th class="border border-black px-2 py-1 text-right">Labour</th>
        <th class="border border-black px-2 py-1 text-right">Materials</th>
        <th class="border border-black px-2 py-1 text-right">CIS Deducted</th>
        <th class="border border-black px-2 py-1 text-right">Net Paid</th>
        <% if (annualRC > 0) { %>
        <th class="border border-black px-2 py-1 text-right">Reverse Charge</th>
        <% } %>
      </tr>
    </thead>
    <tbody>
      <tr class="font-bold">
        <td class="border border-black px-2 py-1"><%= annualCount %></td>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualGross) %></td>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualLabour) %></td>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualMaterial) %></td>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualCIS) %></td>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualNet) %></td>
        <% if (annualRC > 0) { %>
        <td class="border border-black px-2 py-1 text-right"><%= formatCurrency(annualRC) %></td>
        <% } %>
      </tr>
    </tbody>
  </table>
</div>
</div>

<style>
  @media print {
    body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .print\:hidden { display: none !important; }
    table { page-break-inside: auto; border-collapse: collapse; }
    tr { page-break-inside: avoid; }
    thead { display: table-header-group; }
    tfoot { display: table-footer-group; }
    .avoid-page-break { page-break-inside: avoid; break-inside: avoid; }
    .page-break { page-break-before: always; break-before: page; }
    .cis-table { font-size: 9px !important; }
    .cis-table th, .cis-table td { padding: 1px 3px !important; }
  }
</style>

<script>
  document.getElementById('printBtn').addEventListener('click', function () {
    window.print();
  });
</script>


