<div class="max-w-lg mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <div class="p-6 sm:p-8">

    <h1 class="text-2xl font-bold text-center mb-2 text-gray-900 dark:text-gray-100">
      Submit Attendance
    </h1>
    <p class="text-center text-gray-500 dark:text-gray-400 mb-6">
      Submitting as <strong><%= entityName %></strong> (<%= isEmployee ? 'Employee' : 'Subcontractor' %>)
    </p>

    <form method="POST" action="/attendance/submit" class="space-y-5">
      <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% } %>

      <!-- Date -->
      <div>
        <label for="date" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Date</label>
        <input type="date" id="date" name="date" value="<%= today %>" required
          class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-4 py-3 focus:ring-2 focus:ring-green-500 focus:border-green-500">
      </div>

      <!-- Type -->
      <div>
        <label for="type" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Type</label>
        <select id="type" name="type" required
          class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-4 py-3 focus:ring-2 focus:ring-green-500 focus:border-green-500">
          <option value="work" selected>Work</option>
          <option value="training">Training</option>
          <option value="sick">Sick</option>
          <option value="holiday">Holiday</option>
          <option value="leave">Leave</option>
          <option value="off">Off</option>
        </select>
      </div>

      <!-- Project -->
      <div>
        <label for="projectId" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Project <span class="text-gray-400">(optional)</span></label>
        <select id="projectId" name="projectId"
          class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-4 py-3 focus:ring-2 focus:ring-green-500 focus:border-green-500">
          <option value="">— None —</option>
          <% projects.forEach(p => { %>
            <option value="<%= p._id %>">
              <%= p.Number ? '#' + p.Number + ' – ' : '' %><%= p.Name %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Location -->
      <div>
        <label for="locationId" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Location <span class="text-gray-400">(optional)</span></label>
        <select id="locationId" name="locationId"
          class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-4 py-3 focus:ring-2 focus:ring-green-500 focus:border-green-500">
          <option value="">— None —</option>
          <% locations.forEach(l => { %>
            <option value="<%= l._id %>"><%= l.name %></option>
          <% }) %>
        </select>
      </div>

      <% if (isEmployee) { %>
        <!-- Hours Worked (employees only) -->
        <div>
          <label for="hoursWorked" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Hours Worked</label>
          <input type="number" id="hoursWorked" name="hoursWorked" step="0.25" min="0" max="24" placeholder="8"
            class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-4 py-3 focus:ring-2 focus:ring-green-500 focus:border-green-500">
        </div>
      <% } %>

      <!-- Notes -->
      <div>
        <label for="notes" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes <span class="text-gray-400">(optional)</span></label>
        <textarea id="notes" name="notes" rows="3" maxlength="2000" placeholder="Any additional details..."
          class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-4 py-3 focus:ring-2 focus:ring-green-500 focus:border-green-500 resize-y"></textarea>
      </div>

      <!-- Submit -->
      <div class="flex justify-between items-center pt-2">
        <a href="/daily/<%= today %>" class="text-green-600 dark:text-green-400 hover:underline text-sm">
          <i class="bi bi-arrow-left"></i> Back to Daily View
        </a>
        <button type="submit"
          class="inline-flex items-center gap-1.5 rounded-lg bg-green-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-green-700 transition shadow-sm focus:ring-2 focus:ring-green-500 focus:outline-none">
          <i class="bi bi-send"></i> Submit for Approval
        </button>
      </div>
    </form>
    </div>
  </div>

  <p class="text-center text-xs text-gray-400 dark:text-gray-500 mt-4">
    Your attendance will be set to <strong>Pending</strong> until approved by an administrator.
  </p>
</div>
