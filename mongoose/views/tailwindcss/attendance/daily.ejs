<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <div class="p-6 sm:p-8">

      <h1 class="text-2xl font-bold text-center mb-8 text-gray-900 dark:text-gray-100">
        Daily Attendance for <%= moment(date).format('Do MMMM YYYY') %>
      </h1>

      <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
      <table class="min-w-full table-auto">
        <thead class="bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
          <tr>
            <th class="px-4 py-3 border-r border-gray-200 dark:border-gray-700 text-left text-xs font-medium uppercase tracking-wider">Location / Project</th>
            <th class="px-4 py-3 border-r border-gray-200 dark:border-gray-700 text-left text-xs font-medium uppercase tracking-wider">Person</th>
            <th class="px-4 py-3 border-r border-gray-200 dark:border-gray-700 text-left text-xs font-medium uppercase tracking-wider">Type</th>
            <th class="px-4 py-3 border-r border-gray-200 dark:border-gray-700 text-left text-xs font-medium uppercase tracking-wider">Status</th>
            <th class="px-4 py-3 border-r border-gray-200 dark:border-gray-700 text-left text-xs font-medium uppercase tracking-wider">Hours</th>
            <th class="px-4 py-3 border-r border-gray-200 dark:border-gray-700 text-left text-xs font-medium uppercase tracking-wider">OT</th>
            <th class="px-4 py-3 border-r border-gray-200 dark:border-gray-700 text-left text-xs font-medium uppercase tracking-wider">Notes</th>
            <th class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100">
          <% if (attendance.length > 0) { %>
            <% attendance.forEach(record => { %>
              <tr class="even:bg-white odd:bg-gray-50 dark:even:bg-gray-900 dark:odd:bg-gray-800">
                <td class="px-4 py-2 border-r border-gray-200 dark:border-gray-700">
                  <% if (record.locationId && typeof record.locationId === 'object') { %>
                    <a href="/location/read/<%= record.locationId.uuid %>" class="text-green-700 dark:text-green-400 hover:underline">
                      <%= record.locationId.name || [record.locationId.address, record.locationId.city, record.locationId.postalCode].filter(Boolean).join(', ') %>
                    </a>
                  <% } else if (record.projectId && typeof record.projectId === 'object') { %>
                    <a href="/project/read/<%= record.projectId.uuid %>" class="text-green-700 dark:text-green-400 hover:underline">
                      <%= record.projectId.Name || record.projectId.name || 'Project' %>
                    </a>
                  <% } else { %>
                    <span class="text-gray-400 dark:text-gray-500">&mdash;</span>
                  <% } %>
                </td>
                <td class="px-4 py-2 border-r border-gray-200 dark:border-gray-700">
                  <% if (record.employeeId && typeof record.employeeId === 'object') { %>
                    <a href="/employee/read/<%= record.employeeId.uuid %>" class="text-green-700 dark:text-green-400 hover:underline">
                      <%= record.employeeId.name %>
                    </a>
                  <% } else if (record.subcontractorId && typeof record.subcontractorId === 'object') { %>
                    <a href="/supplier/read/<%= record.subcontractorId.uuid %>" class="text-green-700 dark:text-green-400 hover:underline">
                      <%= record.subcontractorId.Name || record.subcontractorId.name %>
                    </a>
                  <% } else { %>
                    <span class="text-gray-400 dark:text-gray-500">&mdash;</span>
                  <% } %>
                </td>
                <td class="px-4 py-2 border-r border-gray-200 dark:border-gray-700">
                  <span class="capitalize"><%= record.type || 'N/A' %></span>
                </td>
                <td class="px-4 py-2 border-r border-gray-200 dark:border-gray-700">
                  <% const statusColors = { approved: 'bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400', pending: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-800/20 dark:text-yellow-400', rejected: 'bg-red-100 text-red-800 dark:bg-red-800/20 dark:text-red-400' }; %>
                  <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold <%= statusColors[record.status] || statusColors.approved %>">
                    <%= record.status || 'approved' %>
                  </span>
                </td>
                <td class="px-4 py-2 border-r border-gray-200 dark:border-gray-700">
                  <% if (record.hoursWorked) { %>
                    <%= record.hoursWorked %> hrs
                    <% if (record.breakMinutes) { %>
                      <span class="text-xs text-gray-500">(<%= record.breakMinutes %>m break)</span>
                    <% } %>
                  <% } else if (record.dayRate) { %>
                    <span class="text-xs">Day rate</span>
                  <% } else { %>
                    <span class="text-gray-400 dark:text-gray-500">&mdash;</span>
                  <% } %>
                </td>
                <td class="px-4 py-2 border-r border-gray-200 dark:border-gray-700">
                  <% if (record.overtimeHours) { %>
                    <%= record.overtimeHours %> hrs
                  <% } else { %>
                    <span class="text-gray-400 dark:text-gray-500">&mdash;</span>
                  <% } %>
                </td>
                <td class="px-4 py-2 border-r border-gray-200 dark:border-gray-700 max-w-xs truncate" title="<%= record.notes || '' %>">
                  <%= record.notes ? record.notes.substring(0, 50) + (record.notes.length > 50 ? '…' : '') : '' %>
                </td>
                <td class="px-4 py-2 text-center space-x-1">
                  <a href="/attendance/read/<%= record.uuid %>" class="inline-block rounded bg-green-600 hover:bg-green-700 text-white p-1" title="View">
                    <i class="bi bi-eye"></i>
                  </a>
                  <a href="/attendance/update/<%= record.uuid %>" class="inline-block rounded bg-gray-600 hover:bg-gray-700 text-white p-1" title="Edit">
                    <i class="bi bi-pencil-square"></i>
                  </a>
                  <% if (record.status === 'pending') { %>
                    <form method="POST" action="/attendance/<%= record.uuid %>/approve" class="inline">
                      <button type="submit" class="inline-block rounded bg-blue-600 hover:bg-blue-700 text-white p-1" title="Approve">
                        <i class="bi bi-check-lg"></i>
                      </button>
                    </form>
                    <form method="POST" action="/attendance/<%= record.uuid %>/reject" class="inline">
                      <button type="submit" class="inline-block rounded bg-red-600 hover:bg-red-700 text-white p-1" title="Reject">
                        <i class="bi bi-x-lg"></i>
                      </button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="8" class="px-4 py-6 text-center text-gray-500 dark:text-gray-400">No attendance records found for this day.</td>
            </tr>
          <% } %>
          <tr class="font-light">
            <td class="px-4 py-2">
              <a href="/attendance/create?date=<%= date %>" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-green-600 hover:bg-green-700 text-white shadow-sm transition">
                <i class="bi bi-plus-lg"></i>
              </a>
            </td>
            <td colspan="7"></td>
          </tr>
        </tbody>
      </table>
      </div>
    </div>
  </div>
</div>
