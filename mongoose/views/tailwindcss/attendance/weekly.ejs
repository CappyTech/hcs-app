<div class="container mx-auto py-4 px-4">

  <!-- Week Navigation -->
  <div class="flex justify-between items-center mb-4 print:hidden">
    <a href="/<%= isManagementView ? 'weekly-management' : 'weekly' %>/<%= previousYear %>/<%= previousWeek %>"
      class="inline-block bg-green-600 hover:bg-green-700 text-white rounded px-4 py-2">
      &laquo; Previous Week
    </a>
    <div class="text-center flex-grow mx-4">
      <h1 class="text-4xl font-extrabold text-gray-900 dark:text-gray-100">Weekly Attendance</h1>
      <p class="text-lg font-semibold text-gray-700 dark:text-gray-300 mt-1">
        Tax Week <%= taxWeekNumber %> &mdash; <%= taxYear %>/<%= taxYear + 1 %>
      </p>
    </div>
    <a href="/<%= isManagementView ? 'weekly-management' : 'weekly' %>/<%= nextYear %>/<%= nextWeek %>"
      class="inline-block bg-green-600 hover:bg-green-700 text-white rounded px-4 py-2">
      Next Week &raquo;
    </a>
  </div>

  <p class="text-center mb-6 text-gray-700 dark:text-gray-300">
    From <%= moment(startDate).format('Do MMMM YYYY') %> to <%= moment(endDate).format('Do MMMM YYYY') %>
  </p>

  <!-- Stats Grid (admin only) -->
  <% if (!isManagementView) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="bg-white dark:bg-gray-900 border dark:border-gray-700 rounded-lg shadow p-6 text-center">
        <h4 class="text-lg font-semibold mb-2">Total Employee Payment</h4>
        <p class="text-4xl font-bold">&pound;<%= totalEmployeePay != null ? totalEmployeePay.toFixed(2) : '0.00' %> <small class="text-base font-normal">gross</small></p>
      </div>
      <div class="bg-white dark:bg-gray-900 border dark:border-gray-700 rounded-lg shadow p-6 text-center">
        <h4 class="text-lg font-semibold mb-2">Total Subcontractor Payment</h4>
        <p class="text-4xl font-bold">&pound;<%= totalSubcontractorPay != null ? totalSubcontractorPay.toFixed(2) : '0.00' %> <small class="text-base font-normal">net</small></p>
      </div>
      <div class="bg-white dark:bg-gray-900 border dark:border-gray-700 rounded-lg shadow p-6 text-center">
        <h4 class="text-lg font-semibold mb-2">Total Employee Hours Worked</h4>
        <p class="text-4xl font-bold"><%= totalEmployeeHours || '0' %> hours</p>
      </div>
      <div class="bg-white dark:bg-gray-900 border dark:border-gray-700 rounded-lg shadow p-6 text-center">
        <h4 class="text-lg font-semibold mb-2">Total Subcontractor Days Worked</h4>
        <p class="text-4xl font-bold"><%= totalSubcontractorDays || '0' %> days</p>
      </div>
    </div>
  <% } %>

  <!-- Employee Table -->
  <h3 class="mt-5 mb-3 text-center text-2xl font-bold">Employees</h3>
  <div class="overflow-x-auto mb-5">
    <%- include('../partials/weeklyTable', {
      entries: employeeEntries,
      daysOfWeek,
      startDate,
      endDate,
      moment,
      isManagementView
    }) %>
  </div>

  <!-- Subcontractor Table -->
  <h3 class="mt-5 mb-3 text-center text-2xl font-bold">Subcontractors</h3>
  <div class="overflow-x-auto mb-5">
    <%- include('../partials/weeklyTable', {
      entries: subcontractorEntries,
      daysOfWeek,
      startDate,
      endDate,
      moment,
      isManagementView
    }) %>
  </div>

  <% if (activeProjects && activeProjects.length > 0) { %>
    <h3 class="mt-5 mb-3 text-xl font-semibold text-gray-900 dark:text-gray-100">
      Scheduled Projects
      <span class="ml-2 inline-flex items-center justify-center rounded-full bg-gray-200 text-gray-800 dark:bg-gray-700 dark:text-gray-100 px-2 py-0.5 text-xs font-semibold">
        <%= activeProjects.length %>
      </span>
      <span class="ml-2 text-xs text-gray-600 dark:text-gray-300">
        (<%= (projectStatusFilter && projectStatusFilter.length ? projectStatusFilter.join(', ') : 'All') %>)
      </span>
    </h3>
    <ul class="divide-y divide-gray-200 dark:divide-gray-700 mb-5 border dark:border-gray-700 rounded-lg overflow-hidden">
      <% activeProjects.forEach(project => { %>
        <li class="flex justify-between items-center px-4 py-3 bg-white dark:bg-gray-900">
          <a href="/project/read/<%= project.uuid %>" class="text-green-700 dark:text-green-400 hover:underline">
            <%= project.Name %>
          </a>
        </li>
      <% }) %>
    </ul>
  <% } %>

</div>
