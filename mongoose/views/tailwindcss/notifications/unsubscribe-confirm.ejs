<div class="max-w-md mx-auto py-16 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-amber-500 to-orange-500"></div>
    <div class="p-6 sm:p-8 text-center">
      <div class="text-amber-500 text-4xl mb-3"><i class="bi bi-bell-slash"></i></div>
      <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Confirm unsubscribe</h1>

      <% if (mode === 'admin-contact') { %>
        <p class="text-sm text-gray-600 dark:text-gray-300">
          Stop <strong>administrators</strong> from emailing <strong><%= maskedEmail %></strong>?
          Security-critical emails will still be sent.
        </p>
      <% } else { %>
        <p class="text-sm text-gray-600 dark:text-gray-300">
          Unsubscribe <strong><%= maskedEmail %></strong> from
          <strong><%= typeDoc ? typeDoc.label : type %></strong> emails?
        </p>
      <% } %>

      <p class="text-xs text-gray-400 mt-2">Nothing changes until you press the button below.</p>

      <form method="POST" action="/notifications/unsubscribe" class="mt-6">
        <%- include('../partials/csrfHidden.ejs') %>
        <input type="hidden" name="token" value="<%= token %>">
        <input type="hidden" name="mode" value="<%= mode %>">
        <input type="hidden" name="type" value="<%= type %>">
        <button type="submit" class="w-full px-5 py-2.5 rounded-lg text-sm font-medium bg-amber-600 hover:bg-amber-700 text-white transition">
          <%= mode === 'admin-contact' ? 'Stop admin emails' : 'Unsubscribe' %>
        </button>
      </form>

      <p class="text-xs text-gray-400 mt-4">
        Manage all your preferences from your
        <a href="/user/account/settings/notifications" class="text-blue-600 dark:text-blue-400 hover:underline">notification settings</a>
        (sign-in required).
      </p>
    </div>
  </div>
</div>
