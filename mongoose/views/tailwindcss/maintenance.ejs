<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex">
  <title><%= typeof title !== 'undefined' && title ? title : 'Service Unavailable' %></title>
  <meta http-equiv="refresh" content="<%= typeof refreshSeconds !== 'undefined' && refreshSeconds ? refreshSeconds : 10 %>">
  <link rel="stylesheet" href="/resources/css/tailwind.css">
  <script nonce="<%= locals.cspNonce %>">if(localStorage.getItem('theme')==='light')document.documentElement.classList.remove('dark');</script>
</head>
<body class="bg-gray-50 dark:bg-gray-900">
<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8 text-center">
    <div>
      <!-- Status mark -->
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-32 w-32" viewBox="0 0 120 120" aria-hidden="true">
        <circle cx="60" cy="60" r="52" fill="none" stroke="#e5e7eb" stroke-width="4" />
        <circle cx="60" cy="60" r="52" fill="none" stroke="#16a34a" stroke-width="4"
                stroke-linecap="round" stroke-dasharray="82 245" transform="rotate(-90 60 60)">
          <animateTransform attributeName="transform" type="rotate" from="-90 60 60" to="270 60 60" dur="2.5s" repeatCount="indefinite" />
        </circle>
        <!-- Wrench -->
        <g transform="rotate(45 60 60)">
          <rect x="56" y="44" width="8" height="34" rx="3" fill="#6b7280" />
          <path d="M52 38a10 10 0 0 1 16 0v8h-5v-5a3 3 0 0 0-6 0v5h-5z" fill="#6b7280" />
          <circle cx="60" cy="80" r="7" fill="#6b7280" />
          <circle cx="60" cy="80" r="3" fill="#e5e7eb" />
        </g>
      </svg>

      <h1 class="mt-6 text-3xl font-extrabold text-gray-900 dark:text-gray-100">
        <%= typeof heading !== 'undefined' && heading ? heading : 'Service temporarily unavailable' %>
      </h1>
      <p class="mt-3 text-base text-gray-600 dark:text-gray-300">
        <%= typeof message !== 'undefined' && message ? message : 'We are experiencing a temporary issue. This usually resolves within a few seconds.' %>
      </p>

      <!-- Auto-retry indicator -->
      <div class="mt-4">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-green-700 dark:text-green-400">
          <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
          </svg>
          Retrying automatically in <span id="countdown" class="font-mono tabular-nums"><%= typeof refreshSeconds !== 'undefined' && refreshSeconds ? refreshSeconds : 10 %></span>s
        </span>
      </div>
    </div>

    <div class="mt-6 text-sm text-gray-500 dark:text-gray-400">
      If the problem persists, please contact
      <a href="mailto:<%= (typeof contactEmail !== 'undefined' && contactEmail) ? contactEmail : 'admin@heroncs.co.uk' %>" class="text-green-600 dark:text-green-400 hover:underline">
        <%= (typeof contactEmail !== 'undefined' && contactEmail) ? contactEmail : 'admin@heroncs.co.uk' %>
      </a>
    </div>

    <div class="mt-4">
      <a href="/" class="inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-medium rounded-lg text-white bg-green-600 hover:bg-green-700 shadow-sm transition">Retry now</a>
    </div>
  </div>
</div>

<script nonce="<%= locals.cspNonce %>">
  (function () {
    var el = document.getElementById('countdown');
    if (!el) return;
    var s = parseInt(el.textContent, 10) || 10;
    var t = setInterval(function () {
      s--;
      el.textContent = s;
      if (s <= 0) clearInterval(t);
    }, 1000);
  })();
</script>
</body>
</html>
