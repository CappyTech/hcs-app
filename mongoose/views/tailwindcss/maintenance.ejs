<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Getting Dressed...' %></title>
  <meta http-equiv="refresh" content="10">
  <link rel="stylesheet" href="/resources/css/output.css">
  <script>if(localStorage.getItem('theme')==='light')document.documentElement.classList.remove('dark');</script>
</head>
<body class="bg-gray-50 dark:bg-gray-900">
<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8 text-center">
    <div>
      <!-- Heron getting dressed — upside-down with a hard hat -->
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-32 w-32" viewBox="0 0 120 120" aria-hidden="true">
        <!-- Hard hat floating above -->
        <ellipse cx="60" cy="18" rx="18" ry="8" fill="#f59e0b" />
        <rect x="44" y="16" width="32" height="6" rx="2" fill="#d97706" />
        <!-- Body (upside-down heron) -->
        <g transform="rotate(180 60 68)">
          <!-- Body -->
          <ellipse cx="60" cy="60" rx="14" ry="20" fill="#6b7280" />
          <!-- Belly -->
          <ellipse cx="60" cy="64" rx="9" ry="14" fill="#e5e7eb" />
          <!-- Head -->
          <circle cx="60" cy="36" r="10" fill="#6b7280" />
          <!-- Eye -->
          <circle cx="63" cy="34" r="2" fill="white" />
          <circle cx="63.5" cy="34" r="1" fill="#111827" />
          <!-- Beak -->
          <polygon points="70,36 82,34 70,38" fill="#f59e0b" />
          <!-- Legs sticking up -->
          <line x1="54" y1="80" x2="50" y2="98" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" />
          <line x1="66" y1="80" x2="70" y2="98" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" />
          <!-- Feet -->
          <line x1="50" y1="98" x2="44" y2="100" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" />
          <line x1="50" y1="98" x2="50" y2="102" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" />
          <line x1="70" y1="98" x2="76" y2="100" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" />
          <line x1="70" y1="98" x2="70" y2="102" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" />
        </g>
        <!-- Sweat drops -->
        <circle cx="38" cy="55" r="2" fill="#38bdf8" opacity="0.7">
          <animate attributeName="cy" values="55;50;55" dur="1.5s" repeatCount="indefinite" />
        </circle>
        <circle cx="84" cy="60" r="1.5" fill="#38bdf8" opacity="0.7">
          <animate attributeName="cy" values="60;54;60" dur="2s" repeatCount="indefinite" />
        </circle>
      </svg>

      <h1 class="mt-6 text-3xl font-extrabold text-gray-900 dark:text-gray-100">
        You've caught me getting dressed!
      </h1>
      <p class="mt-3 text-base text-gray-600 dark:text-gray-300">
        The application is starting&hellip;
      </p>

      <!-- Countdown timer -->
      <div class="mt-4">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-green-700 dark:text-green-400">
          <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
          </svg>
          Refreshing in <span id="countdown" class="font-mono tabular-nums">10</span>s
        </span>
      </div>
    </div>

    <div class="mt-6 text-sm text-gray-500 dark:text-gray-400">
      If I'm taking too long to get dressed, please contact
      <a href="mailto:<%= (typeof contactEmail !== 'undefined' && contactEmail) ? contactEmail : 'admin@heroncs.co.uk' %>" class="text-green-600 dark:text-green-400 hover:underline">
        <%= (typeof contactEmail !== 'undefined' && contactEmail) ? contactEmail : 'admin@heroncs.co.uk' %>
      </a>
    </div>
    <p class="text-xs text-gray-400 dark:text-gray-500 italic">
      I might have fell over or got stuck &mdash; I am upside down.
    </p>

    <div class="mt-4">
      <a href="/" class="inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-medium rounded-lg text-white bg-green-600 hover:bg-green-700 shadow-sm transition">Try again</a>
    </div>
  </div>
</div>

<script>
  (function () {
    var s = 10, el = document.getElementById('countdown');
    if (!el) return;
    var t = setInterval(function () {
      s--;
      el.textContent = s;
      if (s <= 0) clearInterval(t);
    }, 1000);
  })();
</script>
</body>
</html>
