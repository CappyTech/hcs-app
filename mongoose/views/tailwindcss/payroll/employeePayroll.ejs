<div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-indigo-500 to-purple-500"></div>
    <div class="p-6 sm:p-8">

      <div class="flex justify-between items-center mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Payroll Settings</h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= employee.name || employee.firstName || 'Employee' %></p>
        </div>
        <div class="flex gap-3">
          <a href="/employees/read/<%= employee.uuid %>" class="text-indigo-600 hover:underline dark:text-indigo-400 text-sm">← Employee Record</a>
          <a href="/payroll/dashboard" class="text-gray-500 hover:underline dark:text-gray-400 text-sm">Payroll Dashboard</a>
        </div>
      </div>

      <% if (typeof flash !== 'undefined' && flash?.success) { %>
        <div class="mb-4 p-3 rounded-lg bg-green-50 border border-green-200 text-green-800 dark:bg-green-900/20 dark:border-green-700 dark:text-green-300 text-sm"><%= flash.success %></div>
      <% } %>
      <% if (typeof flash !== 'undefined' && flash?.error) { %>
        <div class="mb-4 p-3 rounded-lg bg-red-50 border border-red-200 text-red-800 dark:bg-red-900/20 dark:border-red-700 dark:text-red-300 text-sm"><%= flash.error %></div>
      <% } %>

      <form method="POST" action="/payroll/employee/<%= employee.uuid %>">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

        <!-- HMRC Identifiers -->
        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3 mt-2">HMRC Identifiers</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">NI Number</label>
            <input type="text" name="niNumber" value="<%= niDisplay %>" placeholder="AB123456C"
              autocomplete="off"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 font-mono tracking-widest"
              title="Leave unchanged to keep existing value. Enter new value to update.">
            <p class="text-xs text-gray-400 mt-1">Stored encrypted. Leave unchanged to keep current value.</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">NI Category</label>
            <select name="niCategory"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
              <% ['A','B','C','H','J','M','Z'].forEach(cat => { %>
                <option value="<%= cat %>" <%= (employee.payroll?.niCategory || 'A') === cat ? 'selected' : '' %>><%= cat %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tax Code</label>
            <input type="text" name="taxCode" value="<%= employee.payroll?.taxCode || '1257L' %>" placeholder="1257L"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 font-mono">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tax Basis</label>
            <select name="taxBasis"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
              <option value="cumulative" <%= (employee.payroll?.taxBasis || 'cumulative') === 'cumulative' ? 'selected' : '' %>>Cumulative</option>
              <option value="week1/month1" <%= employee.payroll?.taxBasis === 'week1/month1' ? 'selected' : '' %>>Week1 / Month1</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">PAYE Start Date</label>
            <input type="date" name="payeStartDate"
              value="<%= employee.payroll?.payeStartDate ? new Date(employee.payroll.payeStartDate).toISOString().split('T')[0] : '' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Payroll ID</label>
            <input type="text" name="payrollId" value="<%= employee.payroll?.payrollId || '' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Starter Declaration</label>
            <select name="starterDeclaration"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
              <option value="" <%= !employee.payroll?.starterDeclaration ? 'selected' : '' %>>— None —</option>
              <option value="A" <%= employee.payroll?.starterDeclaration === 'A' ? 'selected' : '' %>>A — First job since last 6 April</option>
              <option value="B" <%= employee.payroll?.starterDeclaration === 'B' ? 'selected' : '' %>>B — Only job, but had another since last 6 April</option>
              <option value="C" <%= employee.payroll?.starterDeclaration === 'C' ? 'selected' : '' %>>C — Has another job or pension</option>
            </select>
          </div>
        </div>

        <!-- Year-to-Date Carry-Forward -->
        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-1 mt-6">Year-to-Date (carry-forward from prior system)</h2>
        <p class="text-xs text-gray-400 mb-3">These are updated automatically during payroll runs. Only edit when onboarding mid-year.</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
          <% [['ytdGrossPay','Gross Pay'],['ytdTaxPaid','Tax Paid'],['ytdEmployeeNI','Employee NI'],['ytdEmployerNI','Employer NI']].forEach(([field, label]) => { %>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"><%= label %></label>
              <input type="number" step="0.01" min="0" name="<%= field %>"
                value="<%= employee.payroll?.[field] != null ? Number(employee.payroll[field].toString ? employee.payroll[field].toString() : employee.payroll[field]).toFixed(2) : '0.00' %>"
                class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 font-mono text-sm">
            </div>
          <% }); %>
        </div>

        <!-- Student / Postgrad Loans -->
        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3 mt-6">Student &amp; Postgraduate Loans</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Student Loan Plan</label>
            <select name="studentLoanPlan"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
              <% ['none','Plan1','Plan2','Plan4','Postgrad'].forEach(plan => { %>
                <option value="<%= plan %>" <%= (employee.payroll?.studentLoanPlan || 'none') === plan ? 'selected' : '' %>><%= plan === 'none' ? '— None —' : plan %></option>
              <% }); %>
            </select>
          </div>
          <div class="flex items-center gap-3 pt-6">
            <input type="checkbox" name="postgradLoan" id="postgradLoan" value="on"
              <%= employee.payroll?.postgradLoan ? 'checked' : '' %>
              class="h-4 w-4 rounded border-gray-300 text-indigo-600">
            <label for="postgradLoan" class="text-sm font-medium text-gray-700 dark:text-gray-300">Postgraduate Loan</label>
          </div>
        </div>

        <!-- Pension (Auto-enrolment) -->
        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3 mt-6">Pension (Auto-Enrolment)</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          <div class="flex items-center gap-3">
            <input type="checkbox" name="pensionEnrolled" id="pensionEnrolled" value="on"
              <%= employee.payroll?.pensionEnrolled ? 'checked' : '' %>
              class="h-4 w-4 rounded border-gray-300 text-indigo-600">
            <label for="pensionEnrolled" class="text-sm font-medium text-gray-700 dark:text-gray-300">Enrolled in pension scheme</label>
          </div>
          <div class="flex items-center gap-3">
            <input type="checkbox" name="salarySacrifice" id="salarySacrifice" value="on"
              <%= employee.payroll?.salarySacrifice ? 'checked' : '' %>
              class="h-4 w-4 rounded border-gray-300 text-indigo-600">
            <label for="salarySacrifice" class="text-sm font-medium text-gray-700 dark:text-gray-300">Salary sacrifice arrangement</label>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Opt-Out Date</label>
            <input type="date" name="pensionOptOutDate"
              value="<%= employee.payroll?.pensionOptOutDate ? new Date(employee.payroll.pensionOptOutDate).toISOString().split('T')[0] : '' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Employee Rate Override (%)</label>
            <input type="number" step="0.01" min="0" max="100" name="employeePensionRate"
              value="<%= employee.payroll?.employeePensionRate != null ? Number(employee.payroll.employeePensionRate.toString ? employee.payroll.employeePensionRate.toString() : employee.payroll.employeePensionRate).toFixed(2) : '' %>"
              placeholder="Leave blank to use scheme default"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Employer Rate Override (%)</label>
            <input type="number" step="0.01" min="0" max="100" name="employerPensionRate"
              value="<%= employee.payroll?.employerPensionRate != null ? Number(employee.payroll.employerPensionRate.toString ? employee.payroll.employerPensionRate.toString() : employee.payroll.employerPensionRate).toFixed(2) : '' %>"
              placeholder="Leave blank to use scheme default"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
        </div>

        <!-- Submit -->
        <div class="flex justify-end gap-3 pt-4 border-t border-gray-200 dark:border-gray-700">
          <a href="/employees/read/<%= employee.uuid %>"
            class="px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 text-sm">
            Cancel
          </a>
          <button type="submit"
            class="px-6 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white font-medium text-sm">
            Save Payroll Settings
          </button>
        </div>
      </form>

    </div>
  </div>
</div>
