<div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-indigo-500 to-purple-500"></div>
    <div class="p-6 sm:p-8">

      <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= isNew ? 'Add Tax Year Rates' : 'Edit Tax Year Rates — ' + rate.taxYear %></h1>
        <a href="/settings/payroll/tax-rates" class="text-indigo-600 hover:underline dark:text-indigo-400 text-sm">← All Years</a>
      </div>

      <form method="POST" action="/settings/payroll/tax-rates/<%= isNew ? 'new' : encodeURIComponent(rate.taxYear) %>">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

        <!-- Tax Year -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tax Year</label>
          <input type="text" name="taxYear" value="<%= rate.taxYear || '' %>" placeholder="2025/26" required pattern="\d{4}/\d{2}"
            class="w-48 border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100"
            <%= !isNew ? 'readonly' : '' %>>
        </div>

        <% const sections = [
          { title: 'Income Tax', fields: [
            { key: 'personalAllowance',      label: 'Personal Allowance (£)' },
            { key: 'basicRateLimit',         label: 'Basic Rate Limit (£)' },
            { key: 'higherRateThreshold',    label: 'Higher Rate Threshold (£)' },
            { key: 'additionalRateThreshold',label: 'Additional Rate Threshold (£)' },
            { key: 'basicRate',              label: 'Basic Rate (decimal, e.g. 0.20)' },
            { key: 'higherRate',             label: 'Higher Rate (e.g. 0.40)' },
            { key: 'additionalRate',         label: 'Additional Rate (e.g. 0.45)' }
          ]},
          { title: 'Employee National Insurance', fields: [
            { key: 'niLEL', label: 'Lower Earnings Limit (£)' },
            { key: 'niPT',  label: 'Primary Threshold (£)' },
            { key: 'niUEL', label: 'Upper Earnings Limit (£)' },
            { key: 'niEmployeeMain',  label: 'Main Employee Rate (decimal)' },
            { key: 'niEmployeeUpper', label: 'Upper Employee Rate (decimal)' },
            { key: 'niEmployeeReducedRate', label: 'Category B Reduced Rate (decimal, e.g. 0.0185)' }
          ]},
          { title: 'Employer National Insurance', fields: [
            { key: 'niST',          label: 'Secondary Threshold (£)' },
            { key: 'niEmployerRate', label: 'Employer Rate (decimal, e.g. 0.15)' }
          ]},
          { title: 'Pension Auto-Enrolment', fields: [
            { key: 'aeQualifyingLower', label: 'Lower Qualifying Earnings (£)' },
            { key: 'aeQualifyingUpper', label: 'Upper Qualifying Earnings (£)' }
          ]},
          { title: 'Student Loans', fields: [
            { key: 'studentLoanPlan1Threshold',    label: 'Plan 1 Threshold (£)' },
            { key: 'studentLoanPlan2Threshold',    label: 'Plan 2 Threshold (£)' },
            { key: 'studentLoanPlan4Threshold',    label: 'Plan 4 (Scotland) Threshold (£)' },
            { key: 'studentLoanPostgradThreshold', label: 'Postgrad Threshold (£)' },
            { key: 'studentLoanRate',              label: 'Student Loan Rate (decimal, e.g. 0.09)' },
            { key: 'postgradLoanRate',             label: 'Postgrad Rate (decimal, e.g. 0.06)' }
          ]}
        ] %>

        <% sections.forEach(section => { %>
        <h2 class="text-base font-semibold text-gray-800 dark:text-gray-200 mt-6 mb-3 border-b border-gray-200 dark:border-gray-700 pb-2"><%= section.title %></h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-2">
          <% section.fields.forEach(f => { %>
          <div>
            <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1"><%= f.label %></label>
            <input type="number" step="any" name="<%= f.key %>" value="<%= rate[f.key] != null ? rate[f.key] : '' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <% }) %>
        </div>
        <% }) %>

        <div class="flex justify-end gap-3 mt-8">
          <a href="/settings/payroll/tax-rates" class="px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 transition">Cancel</a>
          <button type="submit" class="px-5 py-2 rounded-lg text-sm font-medium bg-indigo-600 hover:bg-indigo-700 text-white transition">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>
