<div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-indigo-500 to-purple-500"></div>
    <div class="p-6 sm:p-8">

      <div class="flex justify-between items-center mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Payroll Settings</h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Company PAYE configuration and KashFlow nominals</p>
        </div>
        <a href="/payroll/dashboard" class="text-indigo-600 hover:underline dark:text-indigo-400 text-sm">← Payroll Dashboard</a>
      </div>

      <form method="POST" action="/settings/payroll">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

        <!-- PAYE / HMRC -->
        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3 mt-2">PAYE / HMRC</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Employer Name</label>
            <input type="text" name="employerName" value="<%= config?.employerName || '' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">PAYE Scheme Reference</label>
            <input type="text" name="payeSchemeReference" value="<%= config?.payeSchemeReference || '' %>" placeholder="123/A12345"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Accounts Office Reference</label>
            <input type="text" name="accountsOfficeRef" value="<%= config?.accountsOfficeRef || '' %>" placeholder="123PA00123456"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Contact Name</label>
            <input type="text" name="contactName" value="<%= config?.contactName || '' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Contact Phone</label>
            <input type="tel" name="contactPhone" value="<%= config?.contactPhone || '' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Contact Email</label>
            <input type="email" name="contactEmail" value="<%= config?.contactEmail || '' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
        </div>

        <!-- Government Gateway -->
        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3">Government Gateway Credentials</h2>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Stored encrypted at rest. Leave blank to keep existing values.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">User ID</label>
            <input type="text" name="gatewayUserId" autocomplete="off"
              placeholder="<%= config?.gatewayUserId || 'Enter to set…' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password</label>
            <input type="password" name="gatewayPassword" autocomplete="new-password"
              placeholder="<%= config?.gatewayPassword || 'Enter to set…' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
        </div>

        <!-- Pension -->
        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3">Pension (Auto-Enrolment)</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Provider</label>
            <input type="text" name="pensionProviderName" value="<%= config?.pensionProviderName || "People's Pension" %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Employer Reference</label>
            <input type="text" name="pensionEmployerRef" value="<%= config?.pensionEmployerRef || '' %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div class="sm:col-span-1"></div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Default Employee Rate (%)</label>
            <input type="number" step="0.1" min="0" max="100" name="defaultEmployeePensionRate"
              value="<%= fmt ? fmt(config?.defaultEmployeePensionRate, 1) : (config?.defaultEmployeePensionRate ?? 5.0) %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Default Employer Rate (%)</label>
            <input type="number" step="0.1" min="0" max="100" name="defaultEmployerPensionRate"
              value="<%= fmt ? fmt(config?.defaultEmployerPensionRate, 1) : (config?.defaultEmployerPensionRate ?? 3.0) %>"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
        </div>

        <!-- KashFlow Nominal Codes -->
        <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3">KashFlow Nominal Codes</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 mb-8">
          <% const nominalFields = [
            { key: 'grossWages',     label: 'Gross Wages' },
            { key: 'employerNI',     label: 'Employer NI Expense' },
            { key: 'employerPension', label: 'Employer Pension Expense' },
            { key: 'payeNiControl',  label: 'PAYE / NI Control' },
            { key: 'netPayControl',  label: 'Net Pay Control' },
            { key: 'pensionControl', label: 'Pension Control' },
            { key: 'bankNominal',    label: 'Bank Account' }
          ] %>
          <% nominalFields.forEach(f => { %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"><%= f.label %></label>
            <input type="number" name="<%= f.key %>" value="<%= config?.kashflowNominals?.[f.key] || '' %>"
              placeholder="e.g. 7000"
              class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
          </div>
          <% }) %>
        </div>

        <div class="flex justify-end gap-3">
          <a href="/payroll/dashboard" class="px-4 py-2 rounded-lg text-sm font-medium bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 transition">Cancel</a>
          <button type="submit" class="px-5 py-2 rounded-lg text-sm font-medium bg-indigo-600 hover:bg-indigo-700 text-white transition">Save Settings</button>
        </div>
      </form>

      <!-- Tax rates link -->
      <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
        <a href="/settings/payroll/tax-rates" class="text-indigo-600 hover:underline dark:text-indigo-400 text-sm">
          <i class="bi bi-table"></i> Manage Tax Rate Tables →
        </a>
      </div>
    </div>
  </div>
</div>
