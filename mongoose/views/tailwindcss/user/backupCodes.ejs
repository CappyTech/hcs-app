<div class="max-w-2xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-8">

  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
      <i class="bi bi-key-fill text-green-600"></i> Your 2FA Backup Codes
    </h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
      Each code can be used <strong>once</strong> in place of an authenticator code if you lose access to your device.
    </p>
  </div>

  <div class="rounded-xl border border-amber-200 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-700 p-4 flex gap-3">
    <i class="bi bi-exclamation-triangle-fill text-amber-500 mt-0.5 flex-shrink-0"></i>
    <p class="text-sm text-amber-800 dark:text-amber-200">
      <strong>This is the only time these codes will be shown.</strong> Store them somewhere safe — a password
      manager or printed copy. Anyone with a code can bypass your authenticator once.
    </p>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow border border-gray-200 dark:border-gray-700 p-6">
    <div class="grid grid-cols-2 gap-3 font-mono text-base text-gray-900 dark:text-gray-100">
      <% codes.forEach((code) => { %>
        <div class="px-3 py-2 rounded-lg bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-center tracking-wider"><%= code %></div>
      <% }) %>
    </div>
  </div>

  <div class="flex gap-3">
    <a href="/user/account" class="inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-medium rounded-lg text-white bg-green-600 hover:bg-green-700 shadow-sm transition">
      I've saved my codes — back to Account Settings
    </a>
  </div>
</div>
