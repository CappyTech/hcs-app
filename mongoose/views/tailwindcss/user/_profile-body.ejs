<%
  /* ── Determine which entity tabs are available ── */
  const hasEmployee = !!(user.employeeId && employee);
  const hasSubcontractor = !!(user.subcontractorId && subcontractor);
  const hasClient = !!(user.clientId && client);
  const hasEntity = hasEmployee || hasSubcontractor || hasClient;

  /* Helper: safely convert Decimal128 / mixed to formatted GBP string.
     Treats 0 / NaN / null / undefined as "no value" → returns null. */
  function formatGBP(val) {
    if (val == null) return null;
    const n = typeof val === 'object' && val.toString ? Number(val.toString()) : Number(val);
    if (isNaN(n) || n === 0) return null;
    return '£' + n.toLocaleString('en-GB', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  /* Helper: humanise an enum slug  e.g. "zero-hours" → "Zero Hours"  */
  function humanise(str) {
    if (!str) return 'N/A';
    return str.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  }
%>

<div class="max-w-6xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-8">

  <!-- ═══════════ PROFILE HEADER CARD ═══════════ -->
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <!-- Green accent bar -->
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>

    <div class="p-6 sm:p-8">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">

        <!-- Avatar -->
        <div class="shrink-0 w-20 h-20 rounded-full bg-green-600 flex items-center justify-center text-white text-3xl font-bold select-none ring-4 ring-green-100 dark:ring-green-900/40">
          <%= user.username.charAt(0).toUpperCase() %>
        </div>

        <!-- Identity block -->
        <div class="flex-1 text-center sm:text-left">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= user.username %></h1>
          <p class="text-gray-500 dark:text-gray-400"><%= user.email %></p>

          <!-- Badges row -->
          <div class="mt-3 flex flex-wrap justify-center sm:justify-start gap-2">
            <!-- Role badge -->
            <% if (permissions.role === 'none') { %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400">
                <i class="bi bi-hourglass-split"></i> Pending Role
              </span>
            <% } else { %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">
                <i class="bi bi-person-check"></i> <%= permissions.role.charAt(0).toUpperCase() + permissions.role.slice(1) %>
              </span>
            <% } %>

            <!-- 2FA badge -->
            <% if (user.totpEnabled) { %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400">
                <i class="bi bi-shield-check"></i> 2FA
              </span>
            <% } else { %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400">
                <i class="bi bi-shield-exclamation"></i> No 2FA
              </span>
            <% } %>

            <!-- Email verified badge -->
            <% if (user.emailVerified) { %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400">
                <i class="bi bi-envelope-check"></i> Verified
              </span>
            <% } else { %>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400">
                <i class="bi bi-envelope-exclamation"></i> Unverified
              </span>
            <% } %>
          </div>
        </div>

        <!-- Meta + action -->
        <div class="shrink-0 text-center sm:text-right space-y-2">
          <% if (isAdminView) { %>
            <div class="flex flex-wrap justify-center sm:justify-end gap-2">
              <a href="/users" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 hover:bg-gray-300 dark:hover:bg-gray-600 transition shadow-sm">
                <i class="bi bi-arrow-left"></i> All Users
              </a>
              <% if (canUpdate) { %>
                <a href="/user/update/<%= user.uuid %>" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium bg-green-600 text-white hover:bg-green-700 transition shadow-sm">
                  <i class="bi bi-pencil"></i> Edit
                </a>
              <% } %>
              <% if (canDelete) { %>
                <form method="POST" action="/user/delete/<%= user.uuid %>" class="inline" onsubmit="return confirm('Permanently delete this user?');">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <button type="submit" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium bg-red-600 text-white hover:bg-red-700 transition shadow-sm">
                    <i class="bi bi-trash"></i> Delete
                  </button>
                </form>
              <% } %>
            </div>
          <% } else { %>
            <a href="/user/account" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium bg-green-600 text-white hover:bg-green-700 transition shadow-sm">
              <i class="bi bi-gear"></i> Manage Account
            </a>
          <% } %>
          <div class="text-xs text-gray-400 dark:text-gray-500 space-y-0.5 mt-2">
            <p><i class="bi bi-calendar-plus"></i> Created <%= slimDateTime(user.createdAt, ['includeTime']) %></p>
            <p><i class="bi bi-clock-history"></i> Last login <%= lastLoginTime ? slimDateTime(lastLoginTime, ['includeTime']) : 'Never' %></p>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ═══════════ ENTITY TABBED SECTION ═══════════ -->
  <% if (hasEntity) { %>
  <div x-data="profileTabs" class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">

    <!-- Tab bar -->
    <div class="border-b border-gray-200 dark:border-gray-700">
      <nav class="flex -mb-px" role="tablist">
        <% if (hasEmployee) { %>
          <button data-tab="employee" x-bind="tab('employee')"
            class="flex-1 sm:flex-none px-6 py-3 text-sm font-medium border-b-2 transition-colors focus:outline-none" role="tab">
            <i class="bi bi-person-badge mr-1"></i> Employee
          </button>
        <% } %>
        <% if (hasSubcontractor) { %>
          <button data-tab="subcontractor" x-bind="tab('subcontractor')"
            class="flex-1 sm:flex-none px-6 py-3 text-sm font-medium border-b-2 transition-colors focus:outline-none" role="tab">
            <i class="bi bi-person-vcard mr-1"></i> Subcontractor
          </button>
        <% } %>
        <% if (hasClient) { %>
          <button data-tab="client" x-bind="tab('client')"
            class="flex-1 sm:flex-none px-6 py-3 text-sm font-medium border-b-2 transition-colors focus:outline-none" role="tab">
            <i class="bi bi-building mr-1"></i> Client
          </button>
        <% } %>
      </nav>
    </div>

    <!-- ── EMPLOYEE TAB ── -->
    <% if (hasEmployee) { %>
    <div x-bind="panel('employee')" class="p-6 sm:p-8 space-y-8">

      <!-- Personal Details -->
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400">
            <i class="bi bi-person"></i>
          </span>
          Personal Details
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Full Name</p>
            <p class="mt-0.5 text-sm font-semibold text-gray-800 dark:text-gray-200"><%= employee.name %></p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Email</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%- employee.email || '<span class="text-gray-400 italic">Not set</span>' %></p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Phone</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%- employee.phoneNumber || '<span class="text-gray-400 italic">Not set</span>' %></p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Position</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%- employee.position || '<span class="text-gray-400 italic">Not set</span>' %></p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Employment Type</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200 capitalize"><%= employee.type || 'N/A' %></p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Status</p>
            <span class="mt-0.5 inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold
              <%= employee.status === 'active'
                ? 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400'
                : 'bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300' %>">
              <i class="bi <%= employee.status === 'active' ? 'bi-check-circle-fill' : 'bi-x-circle-fill' %>"></i>
              <%= employee.status ? employee.status.charAt(0).toUpperCase() + employee.status.slice(1) : 'N/A' %>
            </span>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Hire Date</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= employee.hireDate ? slimDateTime(employee.hireDate) : 'N/A' %></p>
          </div>
          <% if (employee.contactName || employee.contactNumber) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Emergency Contact</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200">
              <%= employee.contactName || '' %><% if (employee.contactName && employee.contactNumber) { %> &middot; <% } %><%= employee.contactNumber || '' %>
            </p>
          </div>
          <% } %>
        </div>
      </section>

      <!-- Contract Details -->
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400">
            <i class="bi bi-file-earmark-text"></i>
          </span>
          Contract
        </h3>
        <% if (employee.contract) { %>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Contract Type</p>
              <p class="mt-0.5 text-sm font-semibold text-gray-800 dark:text-gray-200"><%= humanise(employee.contract.termsType) %></p>
            </div>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Hours / Week</p>
              <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%- employee.contract.hoursPerWeek != null ? employee.contract.hoursPerWeek : '<span class="text-gray-400 italic">Not specified</span>' %></p>
            </div>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Working Days / Week</p>
              <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= employee.contract.workingDaysPerWeek != null ? employee.contract.workingDaysPerWeek : 5 %></p>
            </div>
            <% if (employee.contract.startDate) { %>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Start Date</p>
              <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= slimDateTime(employee.contract.startDate) %></p>
            </div>
            <% } %>
            <% if (employee.contract.endDate) { %>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">End Date</p>
              <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= slimDateTime(employee.contract.endDate) %></p>
            </div>
            <% } %>
            <% if (employee.contract.noticePeriodWeeks) { %>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Notice Period</p>
              <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= employee.contract.noticePeriodWeeks %> week<%= employee.contract.noticePeriodWeeks !== 1 ? 's' : '' %></p>
            </div>
            <% } %>
          </div>
        <% } else { %>
          <p class="text-sm text-gray-400 dark:text-gray-500 italic">No contract details on record.</p>
        <% } %>
      </section>

      <!-- Compensation -->
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400">
            <i class="bi bi-currency-pound"></i>
          </span>
          Compensation
        </h3>
        <%
          const rates = [
            { label: 'Hourly',  key: 'hourly',  value: formatGBP(employee.hourlyRate) },
            { label: 'Daily',   key: 'daily',   value: formatGBP(employee.dailyRate) },
            { label: 'Weekly',  key: 'weekly',  value: formatGBP(employee.weeklyRate) },
            { label: 'Monthly', key: 'monthly', value: formatGBP(employee.monthlyRate) },
            { label: 'Yearly',  key: 'yearly',  value: formatGBP(employee.yearlyRate) },
          ];
          const definedRate = employee.definedRate || 'weekly';
        %>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
          <% rates.forEach(r => { %>
            <div class="relative bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3 <%= r.key === definedRate ? 'ring-2 ring-green-500/60' : '' %>">
              <% if (r.key === definedRate) { %>
                <span class="absolute -top-2 right-2 px-1.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-green-500 text-white">Primary</span>
              <% } %>
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide"><%= r.label %></p>
              <p class="mt-1 text-base font-semibold text-gray-800 dark:text-gray-200"><%- r.value || '<span class="text-gray-400 font-normal">—</span>' %></p>
            </div>
          <% }) %>
        </div>
      </section>

      <!-- Holiday Policy -->
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-sky-100 dark:bg-sky-900/30 text-sky-600 dark:text-sky-400">
            <i class="bi bi-calendar-event"></i>
          </span>
          Holiday Policy
        </h3>
        <% if (employee.holidayPolicy) { %>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Entitlement</p>
              <p class="mt-0.5 text-sm font-semibold text-gray-800 dark:text-gray-200">
                <%= employee.holidayPolicy.entitlementValue %> <%= employee.holidayPolicy.entitlementType === 'hours' ? 'hours' : 'days' %>
              </p>
            </div>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Includes Bank Holidays</p>
              <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200">
                <% if (employee.holidayPolicy.includesBankHolidays) { %>
                  <i class="bi bi-check-circle-fill text-green-500"></i> Yes
                <% } else { %>
                  <i class="bi bi-x-circle-fill text-gray-400"></i> No
                <% } %>
              </p>
            </div>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Accrual Method</p>
              <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200 capitalize"><%= employee.holidayPolicy.accrualMethod || 'Fixed' %></p>
            </div>
            <% if (employee.holidayPolicy.accrualMethod !== 'fixed' && employee.holidayPolicy.accrualPercent) { %>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Accrual %</p>
              <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= employee.holidayPolicy.accrualPercent %>%</p>
            </div>
            <% } %>
            <% if (employee.holidayPolicy.carryOverMaxDays > 0 || employee.holidayPolicy.carryOverMaxHours > 0) { %>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
              <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Carry Over Limit</p>
              <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200">
                <% if (employee.holidayPolicy.entitlementType === 'hours') { %>
                  <%= employee.holidayPolicy.carryOverMaxHours %> hours
                <% } else { %>
                  <%= employee.holidayPolicy.carryOverMaxDays %> days
                <% } %>
              </p>
            </div>
            <% } %>
          </div>
        <% } else { %>
          <p class="text-sm text-gray-400 dark:text-gray-500 italic">No holiday policy configured.</p>
        <% } %>
      </section>

    </div>
    <% } %>

    <!-- ── SUBCONTRACTOR TAB ── -->
    <% if (hasSubcontractor) { %>
    <div x-bind="panel('subcontractor')" class="p-6 sm:p-8 space-y-8">

      <!-- Overview -->
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400">
            <i class="bi bi-person-vcard"></i>
          </span>
          Overview
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Name</p>
            <p class="mt-0.5 text-sm font-semibold text-gray-800 dark:text-gray-200"><%= subcontractor.Name || 'N/A' %></p>
          </div>
          <% if (subcontractor.Code) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Code</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= subcontractor.Code %></p>
          </div>
          <% } %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">VAT Number</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%- subcontractor.VATNumber || subcontractor.VatNumber || '<span class="text-gray-400 italic">Not set</span>' %></p>
          </div>
          <% if (subcontractor.UniqueEntityNumber) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">UTR / Entity Number</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= subcontractor.UniqueEntityNumber %></p>
          </div>
          <% } %>
          <% if (subcontractor.Note) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3 sm:col-span-2">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Notes</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= subcontractor.Note %></p>
          </div>
          <% } %>
        </div>
      </section>

      <!-- CIS Information -->
      <% if (subcontractor.IsSubcontractor || subcontractor.Subcontractor || subcontractor.CISNumber || subcontractor.CISRate != null) { %>
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400">
            <i class="bi bi-clipboard-data"></i>
          </span>
          CIS Details
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">CIS Registered</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200">
              <% if (subcontractor.IsSubcontractor || subcontractor.Subcontractor) { %>
                <i class="bi bi-check-circle-fill text-green-500"></i> Yes
              <% } else { %>
                <i class="bi bi-x-circle-fill text-gray-400"></i> No
              <% } %>
            </p>
          </div>
          <% if (subcontractor.CISNumber) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">CIS Number</p>
            <p class="mt-0.5 text-sm font-mono text-gray-800 dark:text-gray-200"><%= subcontractor.CISNumber %></p>
          </div>
          <% } %>
          <% if (subcontractor.CISRate != null) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">CIS Deduction Rate</p>
            <p class="mt-0.5 text-sm font-semibold text-gray-800 dark:text-gray-200"><%= (subcontractor.CISRate * 100) %>%</p>
          </div>
          <% } %>
        </div>
      </section>
      <% } %>

      <!-- Address -->
      <% if (subcontractor.Address) { %>
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-violet-100 dark:bg-violet-900/30 text-violet-600 dark:text-violet-400">
            <i class="bi bi-geo-alt"></i>
          </span>
          Address
        </h3>
        <%
          const addr = subcontractor.Address;
          const addrParts = [addr.Line1, addr.Line2, addr.City, addr.County, addr.PostalCode, addr.Country].filter(Boolean);
        %>
        <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3 max-w-lg">
          <p class="text-sm text-gray-800 dark:text-gray-200 leading-relaxed"><%- addrParts.join(', ') || '<span class="text-gray-400 italic">No address on file</span>' %></p>
        </div>
      </section>
      <% } %>

      <!-- Contacts -->
      <% if (subcontractor.Contacts && subcontractor.Contacts.length > 0) { %>
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-cyan-100 dark:bg-cyan-900/30 text-cyan-600 dark:text-cyan-400">
            <i class="bi bi-people"></i>
          </span>
          Contacts
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% subcontractor.Contacts.forEach(contact => { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3 space-y-1">
            <% if (contact.Name) { %><p class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= contact.Name %></p><% } %>
            <% if (contact.Email) { %><p class="text-xs text-gray-500 dark:text-gray-400"><i class="bi bi-envelope mr-1"></i><%= contact.Email %></p><% } %>
            <% if (contact.Phone || contact.Telephone) { %><p class="text-xs text-gray-500 dark:text-gray-400"><i class="bi bi-phone mr-1"></i><%= contact.Phone || contact.Telephone %></p><% } %>
            <% if (contact.Mobile) { %><p class="text-xs text-gray-500 dark:text-gray-400"><i class="bi bi-phone-vibrate mr-1"></i><%= contact.Mobile %></p><% } %>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>

      <!-- Financial Summary -->
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400">
            <i class="bi bi-wallet2"></i>
          </span>
          Financial Summary
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Outstanding</p>
            <p class="mt-0.5 text-base font-semibold text-gray-800 dark:text-gray-200"><%= formatGBP(subcontractor.OutstandingBalance) || '£0.00' %></p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Total Paid</p>
            <p class="mt-0.5 text-base font-semibold text-gray-800 dark:text-gray-200"><%= formatGBP(subcontractor.TotalPaidAmount) || '£0.00' %></p>
          </div>
          <% if (subcontractor.Currency && subcontractor.Currency.Code) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Currency</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= subcontractor.Currency.Code %></p>
          </div>
          <% } %>
        </div>
      </section>

    </div>
    <% } %>

    <!-- ── CLIENT TAB ── -->
    <% if (hasClient) { %>
    <div x-bind="panel('client')" class="p-6 sm:p-8 space-y-8">

      <!-- Overview -->
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400">
            <i class="bi bi-building"></i>
          </span>
          Overview
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Name</p>
            <p class="mt-0.5 text-sm font-semibold text-gray-800 dark:text-gray-200"><%= client.Name || client.DisplayName || 'N/A' %></p>
          </div>
          <% if (client.Code) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Code</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= client.Code %></p>
          </div>
          <% } %>
          <% if (client.VATNumber) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">VAT Number</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= client.VATNumber %></p>
          </div>
          <% } %>
          <% if (client.DefaultCustomerReference) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Reference</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= client.DefaultCustomerReference %></p>
          </div>
          <% } %>
          <% if (client.Note) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3 sm:col-span-2">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Notes</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= client.Note %></p>
          </div>
          <% } %>
        </div>
      </section>

      <!-- Contact Details -->
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-cyan-100 dark:bg-cyan-900/30 text-cyan-600 dark:text-cyan-400">
            <i class="bi bi-telephone"></i>
          </span>
          Contact Details
        </h3>
        <%
          const clientContactFields = [
            { label: 'Email', value: client.Email, icon: 'bi-envelope' },
            { label: 'Phone', value: client.TelephoneNumber, icon: 'bi-telephone' },
            { label: 'Mobile', value: client.MobileNumber, icon: 'bi-phone' },
            { label: 'Fax', value: client.FaxNumber, icon: 'bi-printer' },
            { label: 'Website', value: client.Website, icon: 'bi-globe' },
          ].filter(f => f.value);
        %>
        <% if (clientContactFields.length > 0) { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% clientContactFields.forEach(f => { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide"><%= f.label %></p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><i class="bi <%= f.icon %> mr-1 text-gray-400"></i><%= f.value %></p>
          </div>
          <% }) %>
        </div>
        <% } else { %>
          <p class="text-sm text-gray-400 dark:text-gray-500 italic">No contact details on record.</p>
        <% } %>
      </section>

      <!-- Addresses -->
      <% if (client.Addresses && client.Addresses.length > 0) { %>
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-violet-100 dark:bg-violet-900/30 text-violet-600 dark:text-violet-400">
            <i class="bi bi-geo-alt"></i>
          </span>
          Addresses
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% client.Addresses.forEach(a => { %>
          <%
            const cParts = [a.Line1, a.Line2, a.City, a.County, a.PostalCode, a.Country].filter(Boolean);
          %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-sm text-gray-800 dark:text-gray-200 leading-relaxed"><%= cParts.join(', ') %></p>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>

      <!-- Contacts -->
      <% if (client.Contacts && client.Contacts.length > 0) { %>
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-teal-100 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400">
            <i class="bi bi-people"></i>
          </span>
          Contacts
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% client.Contacts.forEach(contact => { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3 space-y-1">
            <% if (contact.Name) { %><p class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= contact.Name %></p><% } %>
            <% if (contact.Email) { %><p class="text-xs text-gray-500 dark:text-gray-400"><i class="bi bi-envelope mr-1"></i><%= contact.Email %></p><% } %>
            <% if (contact.Phone || contact.Telephone) { %><p class="text-xs text-gray-500 dark:text-gray-400"><i class="bi bi-phone mr-1"></i><%= contact.Phone || contact.Telephone %></p><% } %>
            <% if (contact.Mobile) { %><p class="text-xs text-gray-500 dark:text-gray-400"><i class="bi bi-phone-vibrate mr-1"></i><%= contact.Mobile %></p><% } %>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>

      <!-- Financial Summary -->
      <section>
        <h3 class="flex items-center gap-2 text-lg font-semibold text-gray-800 dark:text-gray-200 mb-4">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400">
            <i class="bi bi-wallet2"></i>
          </span>
          Financial Summary
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Outstanding</p>
            <p class="mt-0.5 text-base font-semibold text-gray-800 dark:text-gray-200"><%= formatGBP(client.OutstandingBalance) || '£0.00' %></p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Total Paid</p>
            <p class="mt-0.5 text-base font-semibold text-gray-800 dark:text-gray-200"><%= formatGBP(client.TotalPaidAmount) || '£0.00' %></p>
          </div>
          <% if (client.InvoiceCount != null) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Invoices</p>
            <p class="mt-0.5 text-base font-semibold text-gray-800 dark:text-gray-200"><%= client.InvoiceCount %></p>
          </div>
          <% } %>
          <% if (client.InvoicedNetAmount != null) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Net Invoiced</p>
            <p class="mt-0.5 text-base font-semibold text-gray-800 dark:text-gray-200"><%= formatGBP(client.InvoicedNetAmount) || '£0.00' %></p>
          </div>
          <% } %>
          <% if (client.Currency && client.Currency.Code) { %>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide">Currency</p>
            <p class="mt-0.5 text-sm text-gray-800 dark:text-gray-200"><%= client.Currency.Code %></p>
          </div>
          <% } %>
        </div>
      </section>

    </div>
    <% } %>

  </div>

  <% } else { %>
    <!-- No linked entity -->
    <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl p-8 text-center">
      <i class="bi bi-info-circle text-4xl text-gray-300 dark:text-gray-600"></i>
      <p class="mt-3 text-gray-500 dark:text-gray-400">No linked employee, subcontractor, or client record found for this account.</p>
    </div>
  <% } %>

  <!-- ═══════════ PERMISSIONS SECTION ═══════════ -->
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-indigo-500 to-purple-400"></div>
    <div class="p-6 sm:p-8">
      <h2 class="flex items-center gap-2 text-xl font-bold text-gray-900 dark:text-gray-100 mb-6">
        <i class="bi bi-shield-lock text-indigo-500"></i> Permissions
      </h2>

      <% if (permissions.role === 'none') { %>
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 rounded-xl p-6 text-center">
          <i class="bi bi-hourglass-split text-amber-500 text-4xl"></i>
          <h3 class="mt-3 text-lg font-semibold text-amber-700 dark:text-amber-400">No Permissions Assigned</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            <% if (isAdminView) { %>
              This user has not been assigned a role yet. Edit the user to assign permissions.
            <% } else { %>
              Your account has been created but a role has not been assigned yet.
              Please contact an administrator to activate your account permissions.
            <% } %>
          </p>
        </div>

      <% } else { %>
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Departments -->
          <div>
            <h3 class="text-base font-semibold text-gray-800 dark:text-gray-200 mb-3">
              <i class="bi bi-building mr-1 text-indigo-400"></i> Departments
            </h3>
            <% if (permissions.departments.length > 0) { %>
              <ul class="space-y-2">
                <% permissions.departments.forEach(dept => { %>
                  <li class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                    <i class="bi bi-check-circle-fill text-green-500"></i>
                    <span class="capitalize"><%= dept.replace(/-/g, ' ') %></span>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="text-sm text-gray-400 dark:text-gray-500 italic">No department access.</p>
            <% } %>
          </div>

          <!-- Data Access -->
          <div>
            <h3 class="text-base font-semibold text-gray-800 dark:text-gray-200 mb-3">
              <i class="bi bi-database mr-1 text-indigo-400"></i> Data Access
            </h3>
            <% if (permissions.models.length > 0) { %>
              <div class="space-y-3">
                <% permissions.models.forEach(m => { %>
                  <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-3">
                    <h4 class="text-sm font-medium text-gray-800 dark:text-gray-200"><%= m.model %></h4>
                    <div class="flex flex-wrap gap-1 mt-1.5">
                      <% m.operations.forEach(op => { %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium
                          <%= op.ownOnly ? 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400' : 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400' %>">
                          <%= op.label %><% if (op.ownOnly) { %> <small>(own)</small><% } %>
                        </span>
                      <% }) %>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-sm text-gray-400 dark:text-gray-500 italic">No model access.</p>
            <% } %>
          </div>
        </div>

        <!-- Accessible Pages -->
        <% if (permissions.customRoutes.length > 0) { %>
          <div class="mt-8">
            <h3 class="text-base font-semibold text-gray-800 dark:text-gray-200 mb-3">
              <i class="bi bi-signpost-2 mr-1 text-indigo-400"></i> Accessible Pages
            </h3>
            <div class="flex flex-wrap gap-2">
              <% permissions.customRoutes.forEach(route => { %>
                <a href="<%= route %>" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-indigo-100 dark:hover:bg-indigo-900/30 hover:text-indigo-700 dark:hover:text-indigo-400 transition">
                  <i class="bi bi-link-45deg"></i> <%= route %>
                </a>
              <% }) %>
            </div>
          </div>
        <% } %>

      <% } %>
    </div>
  </div>
</div>
