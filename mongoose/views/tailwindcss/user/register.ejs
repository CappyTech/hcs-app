<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<div class="max-w-2xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <div class="p-8">
    <h1 class="text-3xl font-bold text-center mb-8 text-gray-900 dark:text-gray-100">Create an account</h1>

    <form action="/user/register" method="POST" class="space-y-6">
      <%- include('../partials/csrfHidden.ejs') %>

      <!-- Username -->
      <div>
        <label for="username" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">
          Username:
        </label>
        <input
          type="text"
          id="username"
          name="username"
          required
          class="w-full px-4 py-2.5 rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-green-500 focus:border-green-500"
        >
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">
          Email:
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-2.5 rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-green-500 focus:border-green-500"
        >
      </div>

      <!-- Password -->
      <div>
        <label for="password" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">
          Password:
        </label>
        <input
          type="password"
          id="password"
          name="password"
          required
          class="w-full px-4 py-2.5 rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-green-500 focus:border-green-500"
        >
      </div>

      <!-- Cloudflare Turnstile -->
      <div>
        <div class="cf-turnstile" data-sitekey="<%= siteKey %>"></div>
      </div>

      <!-- Submit + Link to Log in -->
      <div class="flex flex-col sm:flex-row justify-center sm:justify-between items-center gap-4 pt-6">
        <button type="submit"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 bg-green-600 text-white text-lg px-6 py-3 rounded-lg hover:bg-green-700 transition shadow-sm font-medium">
          <i class="bi bi-book"></i> Create an account
        </button>
        <a href="/user/login"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 text-center border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 px-6 py-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition text-sm font-medium">
          <i class="bi bi-box-arrow-in-right"></i> Log in
        </a>
      </div>

    </form>
    </div>
  </div>
</div>
