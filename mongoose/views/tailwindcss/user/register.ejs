<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<div class="max-w-2xl mx-auto py-10 px-4">
  <div class="bg-gray-100 dark:bg-gray-800 rounded-xl p-8 shadow">
    <h1 class="text-3xl font-bold text-center mb-8">Create an account</h1>

    <form action="/user/register" method="POST" class="space-y-6">
      <%- include('../partials/csrfHidden.ejs') %>

      <!-- Username -->
      <div>
        <label for="username" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">
          Username:
        </label>
        <input
          type="text"
          id="username"
          name="username"
          required
          class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded focus:outline-none focus:ring-2 focus:ring-green-600 dark:bg-gray-800 dark:text-white"
        >
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">
          Email:
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded focus:outline-none focus:ring-2 focus:ring-green-600 dark:bg-gray-800 dark:text-white"
        >
      </div>

      <!-- Password -->
      <div>
        <label for="password" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">
          Password:
        </label>
        <input
          type="password"
          id="password"
          name="password"
          required
          class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded focus:outline-none focus:ring-2 focus:ring-green-600 dark:bg-gray-800 dark:text-white"
        >
      </div>

      <!-- Cloudflare Turnstile -->
      <div>
        <div class="cf-turnstile" data-sitekey="<%= siteKey %>"></div>
      </div>

      <!-- Submit + Link to Log in -->
      <div class="flex flex-col sm:flex-row justify-center sm:justify-between items-center gap-4 pt-6">
        <button type="submit"
          class="w-full sm:w-auto bg-green-700 text-white text-lg px-6 py-3 rounded hover:bg-green-800 transition">
          <i class="bi bi-book"></i> Create an account
        </button>
        <a href="/user/login"
          class="w-full sm:w-auto inline-block text-center border border-gray-400 text-gray-700 dark:text-gray-300 px-6 py-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition text-sm">
          <i class="bi bi-box-arrow-in-right"></i> Log in
        </a>
      </div>

    </form>
  </div>
</div>
