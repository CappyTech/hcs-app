<div class="max-w-md mx-auto py-10 px-4">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>

    <div class="p-8">
      <h1 class="text-2xl font-bold text-center text-gray-900 dark:text-gray-100 mb-2">Reset Password</h1>
      <p class="text-center text-sm text-gray-500 dark:text-gray-400 mb-8">
        How would you like to verify your identity?
      </p>

      <form action="/user/forgot-password/choose" method="POST" class="space-y-4">
        <%- include('../partials/csrfHidden.ejs') %>

        <!-- Email option -->
        <button type="submit" name="method" value="email"
          class="w-full flex items-center gap-4 px-5 py-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 hover:border-green-500 hover:bg-green-50 dark:hover:bg-green-900/20 transition text-left group">
          <span class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400">
            <i class="bi bi-envelope text-lg"></i>
          </span>
          <div>
            <p class="text-sm font-semibold text-gray-800 dark:text-gray-100 group-hover:text-green-700 dark:group-hover:text-green-300">Send reset link by email</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">We'll email you a secure link valid for 1 hour</p>
          </div>
        </button>

        <!-- SMS option (only shown if account has a phone number) -->
        <% if (maskedPhone) { %>
        <button type="submit" name="method" value="sms"
          class="w-full flex items-center gap-4 px-5 py-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 hover:border-green-500 hover:bg-green-50 dark:hover:bg-green-900/20 transition text-left group">
          <span class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400">
            <i class="bi bi-phone text-lg"></i>
          </span>
          <div>
            <p class="text-sm font-semibold text-gray-800 dark:text-gray-100 group-hover:text-green-700 dark:group-hover:text-green-300">Send code by SMS</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">We'll text a 6-digit code to <strong><%= maskedPhone %></strong></p>
          </div>
        </button>
        <% } %>

        <!-- Authenticator app option (only shown if account has TOTP enabled) -->
        <% if (hasTOTP) { %>
        <button type="submit" name="method" value="totp"
          class="w-full flex items-center gap-4 px-5 py-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 hover:border-green-500 hover:bg-green-50 dark:hover:bg-green-900/20 transition text-left group">
          <span class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400">
            <i class="bi bi-shield-shaded text-lg"></i>
          </span>
          <div>
            <p class="text-sm font-semibold text-gray-800 dark:text-gray-100 group-hover:text-green-700 dark:group-hover:text-green-300">Use authenticator app</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Enter the current code from your 2FA authenticator app</p>
          </div>
        </button>
        <% } %>

      </form>

      <div class="mt-6 text-center">
        <a href="/user/forgot-password" class="text-sm text-gray-500 dark:text-gray-400 hover:underline">
          <i class="bi bi-arrow-left mr-1"></i> Start over
        </a>
      </div>
    </div>
  </div>
</div>
