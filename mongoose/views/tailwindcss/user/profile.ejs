<div class="max-w-6xl mx-auto py-12 px-4">
  <!-- Navigation link to account -->
  <div class="mb-4">
    <a href="/user/account" class="inline-flex items-center gap-1 text-green-600 dark:text-green-400 hover:underline text-sm font-medium">
      <i class="bi bi-gear"></i> Manage Account
    </a>
  </div>

  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-lg overflow-hidden">
    <div class="p-6">
      <div class="flex flex-col md:flex-row gap-8">
        
        <!-- Profile Information -->
        <div class="md:w-1/3 text-center">
          <!-- Avatar initial circle -->
          <div class="mx-auto w-24 h-24 rounded-full bg-green-600 flex items-center justify-center text-white text-4xl font-bold select-none">
            <%= user.username.charAt(0).toUpperCase() %>
          </div>
          <h3 class="mt-4 text-xl font-semibold text-green-700 dark:text-green-400">
            <%= user.username %>
          </h3>
          <p class="text-gray-600 dark:text-gray-300"><%= user.email %></p>
          <p class="text-gray-600 dark:text-gray-300">
            Role:
            <% if (permissions.role === 'none') { %>
              <span class="text-amber-600 dark:text-amber-400 capitalize">Pending Assignment</span>
            <% } else { %>
              <span class="text-green-700 dark:text-green-400 capitalize"><%= permissions.role %></span>
            <% } %>
          </p>

          <!-- 2FA status badge -->
          <% if (user.totpEnabled) { %>
            <p class="mt-2 px-3 py-1 inline-block bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 rounded text-sm">
              <i class="bi bi-shield-check"></i> 2FA Enabled
            </p>
          <% } else { %>
            <p class="mt-2 px-3 py-1 inline-block bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded text-sm">
              <i class="bi bi-shield-exclamation"></i> 2FA Not Enabled
            </p>
          <% } %>

          <% if (!user.emailVerified) { %>
            <p class="mt-2 px-3 py-1 inline-block bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded text-sm">
              <i class="bi bi-exclamation-triangle"></i> Email not verified
            </p>
          <% } else { %>
            <p class="mt-2 px-3 py-1 inline-block bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 rounded text-sm">
              <i class="bi bi-check-circle"></i> Email verified
            </p>
          <% } %>

          <div class="mt-4 space-y-1 text-sm text-gray-500 dark:text-gray-400">
            <p>
              <i class="bi bi-calendar-plus"></i> Account Created: <%= slimDateTime(user.createdAt, ['includeTime']) %>
            </p>
            <p>
              <i class="bi bi-clock-history"></i> Last Login: <%= lastLoginTime ? slimDateTime(lastLoginTime, ['includeTime']) : 'N/A' %>
            </p>
          </div>
        </div>

        <!-- Linked Entity Information -->
        <div class="md:w-2/3">
          <% if (user.subcontractorId && subcontractor) { %>
            <h5 class="text-lg font-semibold text-green-700 dark:text-green-400 text-center mb-4">
              <i class="bi bi-person-vcard"></i> Subcontractor Information
            </h5>
            <ul class="divide-y divide-gray-200 dark:divide-gray-700">
              <li class="py-2"><strong>Name:</strong> <%= subcontractor.name %></li>
              <li class="py-2"><strong>Company:</strong> <%= subcontractor.company %></li>
              <li class="py-2"><strong>VAT Number:</strong> <%= subcontractor.vatNumber || 'N/A' %></li>
              <li class="py-2"><strong>UTR Number:</strong> <%= subcontractor.utrNumber || 'N/A' %></li>
              <li class="py-2">
                <strong>Address:</strong>
                <%= subcontractor.line1 %> <%= subcontractor.line2 %>, <%= subcontractor.city %>,
                <%= subcontractor.county %>, <%= subcontractor.postalCode %>
              </li>
            </ul>
          
          <% } else if (user.clientId && client) { %>
            <h5 class="text-lg font-semibold text-green-700 dark:text-green-400 text-center mb-4">
              <i class="bi bi-building"></i> Client Information
            </h5>
            <ul class="divide-y divide-gray-200 dark:divide-gray-700">
              <li class="py-2"><strong>Name:</strong> <%= client.name %></li>
            </ul>

          <% } else if (user.employeeId && employee) { %>
            <h5 class="text-lg font-semibold text-green-700 dark:text-green-400 text-center mb-4">
              <i class="bi bi-person-badge"></i> Employee Information
            </h5>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6">
              <!-- Left column: Personal details -->
              <ul class="divide-y divide-gray-200 dark:divide-gray-700">
                <li class="py-2"><strong>Name:</strong> <%= employee.name %></li>
                <li class="py-2"><strong>Email:</strong> <%= employee.email || 'N/A' %></li>
                <li class="py-2"><strong>Phone:</strong> <%= employee.phoneNumber || 'N/A' %></li>
                <li class="py-2"><strong>Position:</strong> <%= employee.position || 'N/A' %></li>
                <li class="py-2"><strong>Status:</strong>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium
                    <%= employee.status === 'active' ? 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400' : 'bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-400' %>">
                    <%= employee.status %>
                  </span>
                </li>
                <li class="py-2"><strong>Hire Date:</strong> <%= slimDateTime(employee.hireDate) %></li>
              </ul>
              <!-- Right column: Rates & contract -->
              <ul class="divide-y divide-gray-200 dark:divide-gray-700">
                <li class="py-2"><strong>Defined Rate:</strong> <%= employee.definedRate || 'N/A' %></li>
                <li class="py-2"><strong>Hourly Rate:</strong> <%= employee.hourlyRate != null ? '£' + Number(employee.hourlyRate).toFixed(2) : 'N/A' %></li>
                <li class="py-2"><strong>Daily Rate:</strong> <%= employee.dailyRate != null ? '£' + Number(employee.dailyRate).toFixed(2) : 'N/A' %></li>
                <li class="py-2"><strong>Weekly Rate:</strong> <%= employee.weeklyRate != null ? '£' + Number(employee.weeklyRate).toFixed(2) : 'N/A' %></li>
                <li class="py-2"><strong>Monthly Rate:</strong> <%= employee.monthlyRate != null ? '£' + Number(employee.monthlyRate).toFixed(2) : 'N/A' %></li>
                <li class="py-2"><strong>Yearly Rate:</strong> <%= employee.yearlyRate != null ? '£' + Number(employee.yearlyRate).toFixed(2) : 'N/A' %></li>
                <% if (employee.contract) { %>
                  <li class="py-2"><strong>Contract:</strong> <%= employee.contract.type || 'N/A' %></li>
                  <% if (employee.contract.hoursPerWeek) { %>
                    <li class="py-2"><strong>Hours/Week:</strong> <%= employee.contract.hoursPerWeek %></li>
                  <% } %>
                <% } %>
                <% if (employee.holidayPolicy && employee.holidayPolicy.entitlement) { %>
                  <li class="py-2"><strong>Holiday Entitlement:</strong> <%= employee.holidayPolicy.entitlement %> days</li>
                <% } %>
              </ul>
            </div>

          <% } else { %>
            <div class="text-center py-8 text-gray-500 dark:text-gray-400">
              <i class="bi bi-info-circle text-3xl"></i>
              <p class="mt-2">No linked employee, subcontractor, or client record.</p>
            </div>
          <% } %>
        </div>

      </div>
    </div>
  </div>

  <!-- Permissions Section -->
  <div class="mt-8 bg-white dark:bg-gray-900 shadow-lg rounded-lg overflow-hidden">
    <div class="p-6">
      <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-6">
        <i class="bi bi-shield-lock"></i> Permissions
      </h2>

      <% if (permissions.role === 'none') { %>
        <!-- No permissions assigned yet -->
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-300 dark:border-amber-700 rounded-lg p-6 text-center">
          <i class="bi bi-hourglass-split text-amber-500 text-4xl"></i>
          <h3 class="mt-3 text-lg font-semibold text-amber-700 dark:text-amber-400">No Permissions Assigned</h3>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            Your account has been created but a role has not been assigned yet.
            Please contact an administrator to activate your account permissions.
          </p>
        </div>

      <% } else { %>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Departments -->
          <div>
            <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3">
              <i class="bi bi-building"></i> Departments
            </h3>
            <% if (permissions.departments.length > 0) { %>
              <ul class="space-y-2">
                <% permissions.departments.forEach(dept => { %>
                  <li class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
                    <i class="bi bi-check-circle-fill text-green-600"></i>
                    <span class="capitalize"><%= dept.replace(/-/g, ' ') %></span>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="text-gray-500 dark:text-gray-400 italic">No department access.</p>
            <% } %>
          </div>

          <!-- Data Access -->
          <div>
            <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3">
              <i class="bi bi-database"></i> Data Access
            </h3>
            <% if (permissions.models.length > 0) { %>
              <div class="space-y-3">
                <% permissions.models.forEach(m => { %>
                  <div class="bg-gray-50 dark:bg-gray-800 rounded p-3">
                    <h4 class="font-medium text-gray-800 dark:text-gray-200"><%= m.model %></h4>
                    <div class="flex flex-wrap gap-1 mt-1">
                      <% m.operations.forEach(op => { %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium
                          <%= op.ownOnly ? 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400' : 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400' %>">
                          <%= op.label %><% if (op.ownOnly) { %> <small>(own)</small><% } %>
                        </span>
                      <% }) %>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-gray-500 dark:text-gray-400 italic">No model access.</p>
            <% } %>
          </div>

        </div>

        <!-- Custom Routes -->
        <% if (permissions.customRoutes.length > 0) { %>
          <div class="mt-6">
            <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3">
              <i class="bi bi-signpost-2"></i> Accessible Pages
            </h3>
            <div class="flex flex-wrap gap-2">
              <% permissions.customRoutes.forEach(route => { %>
                <a href="<%= route %>" class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-green-100 dark:hover:bg-green-900/30 transition">
                  <i class="bi bi-link-45deg"></i> <%= route %>
                </a>
              <% }) %>
            </div>
          </div>
        <% } %>

      <% } %>
    </div>
  </div>
</div>