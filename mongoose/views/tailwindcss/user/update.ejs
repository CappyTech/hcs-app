<%- include('../partials/form-update') %>

<% if (typeof roleDetails !== 'undefined' && typeof allRoles !== 'undefined') { %>
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-cyan-500 to-blue-400"></div>
    <div class="p-6 sm:p-8">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-1">Role Permissions Preview</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">What each role grants when assigned to this user.</p>

      <div class="space-y-4" id="role-preview">
        <% allRoles.forEach(role => {
          const details = roleDetails[role] || {};
          const isSelected = formData.role === role;
        %>
          <details<%= isSelected ? ' open' : '' %> class="border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden" data-role="<%= role %>">
            <summary class="px-4 py-3 cursor-pointer select-none flex items-center gap-2 text-sm font-semibold <%= isSelected ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300' : 'bg-gray-50 dark:bg-gray-800 text-gray-700 dark:text-gray-200' %> hover:bg-gray-100 dark:hover:bg-gray-700 transition">
              <span class="capitalize"><%= role %></span>
              <% if (isSelected) { %><span class="text-xs bg-green-100 dark:bg-green-800 text-green-700 dark:text-green-200 px-2 py-0.5 rounded-full">Current</span><% } %>
            </summary>
            <div class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300 space-y-3">
              <% if (details.departments && details.departments.length) { %>
                <div>
                  <span class="font-medium text-gray-700 dark:text-gray-200">Departments:</span>
                  <span class="ml-1"><%= details.departments.join(', ') %></span>
                </div>
              <% } %>
              <% if (details.models && details.models.length) { %>
                <div>
                  <span class="font-medium text-gray-700 dark:text-gray-200">Model Access:</span>
                  <div class="mt-1 flex flex-wrap gap-1.5">
                    <% details.models.forEach(m => { %>
                      <span class="inline-flex items-center gap-1 bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded text-xs">
                        <strong><%= m.model %></strong>
                        <% m.operations.forEach(op => { %>
                          <span class="<%= op.ownOnly ? 'text-amber-600 dark:text-amber-400' : 'text-gray-500 dark:text-gray-400' %>"><%= op.label %><%= op.ownOnly ? '*' : '' %></span>
                        <% }) %>
                      </span>
                    <% }) %>
                  </div>
                </div>
              <% } %>
              <% if (details.customRoutes && details.customRoutes.length) { %>
                <div>
                  <span class="font-medium text-gray-700 dark:text-gray-200">Routes:</span>
                  <span class="ml-1 text-xs"><%= details.customRoutes.join(', ') %></span>
                </div>
              <% } %>
              <% if ((!details.departments || !details.departments.length) && (!details.models || !details.models.length)) { %>
                <p class="text-gray-400 dark:text-gray-500 italic">No permissions granted.</p>
              <% } %>
            </div>
          </details>
        <% }) %>
      </div>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-3">* = own records only</p>
    </div>
  </div>
</div>
<% } %>
