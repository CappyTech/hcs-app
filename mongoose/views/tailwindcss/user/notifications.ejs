<div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-500"></div>
    <div class="p-6 sm:p-8">
      <div class="flex justify-between items-center mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><i class="bi bi-bell-fill text-green-600"></i> Notification Settings</h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Choose which emails you receive at <strong><%= user ? user.email : '' %></strong>. Unsubscribe links in emails bring you back here.</p>
        </div>
        <a href="/user/account" class="text-indigo-600 hover:underline dark:text-indigo-400 text-sm whitespace-nowrap">← Account</a>
      </div>

      <!-- Master admin-contact switch -->
      <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-4 py-4 mb-8">
        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="font-medium text-gray-900 dark:text-gray-100">Allow administrators to email me</div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">When off, direct messages from administrators are not delivered. Security-critical emails are always sent.</p>
          </div>
          <form method="POST" action="/user/account/settings/notifications/allow-admin">
            <%- include('../partials/csrfHidden.ejs') %>
            <input type="hidden" name="allowAdminEmails" value="<%= allowAdminEmails ? 'false' : 'true' %>">
            <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-medium <%= allowAdminEmails ? 'bg-green-600 hover:bg-green-700 text-white' : 'bg-gray-200 hover:bg-gray-300 dark:bg-gray-600 dark:hover:bg-gray-500 text-gray-700 dark:text-gray-100' %>">
              <%= allowAdminEmails ? 'Allowed' : 'Blocked' %>
            </button>
          </form>
        </div>
      </div>

      <% const sections = [['System notifications', groups.system], ['Admin notifications', groups.admin]]; %>
      <% sections.forEach(function (section) { const heading = section[0], list = section[1]; if (!list.length) return; %>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1"><%= heading %></h2>
        <div class="mb-8">
          <% list.forEach(function (t) { %>
          <div id="type-<%= t.key %>" class="flex items-start justify-between gap-4 py-4 border-b border-gray-100 dark:border-gray-800 last:border-0 scroll-mt-24">
            <div class="min-w-0">
              <div class="font-medium text-gray-900 dark:text-gray-100"><%= t.label %></div>
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5"><%= t.description %></p>
              <a href="/user/account/settings/notifications/preview/<%= encodeURIComponent(t.key) %>" target="_blank" class="text-xs text-blue-600 dark:text-blue-400 hover:underline"><i class="bi bi-eye"></i> Preview</a>
            </div>
            <div class="flex flex-col items-end gap-2 whitespace-nowrap">
              <% if (!t.subscribable) { %>
                <span class="text-xs px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">Required</span>
              <% } else { %>
                <form method="POST" action="/user/account/settings/notifications/toggle">
                  <%- include('../partials/csrfHidden.ejs') %>
                  <input type="hidden" name="typeKey" value="<%= t.key %>">
                  <input type="hidden" name="subscribed" value="<%= t.subscribed ? 'false' : 'true' %>">
                  <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-medium <%= t.subscribed ? 'bg-green-600 hover:bg-green-700 text-white' : 'bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200' %>">
                    <%= t.subscribed ? 'Subscribed' : 'Unsubscribed' %>
                  </button>
                </form>
              <% } %>
              <form method="POST" action="/user/account/settings/notifications/send-test">
                <%- include('../partials/csrfHidden.ejs') %>
                <input type="hidden" name="typeKey" value="<%= t.key %>">
                <button type="submit" class="text-xs text-gray-500 dark:text-gray-400 hover:underline">Send me a test</button>
              </form>
            </div>
          </div>
          <% }); %>
        </div>
      <% }); %>
    </div>
  </div>
</div>
