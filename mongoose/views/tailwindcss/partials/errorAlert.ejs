<% if (flash.error && flash.error.length > 0) { %>
  <div class="fixed top-4 right-4 space-y-4 z-50">
    <% flash.error.forEach(function(message, index) { %>
      <div id="errorToast<%= index %>"
           class="relative flex items-start bg-red-600 text-white rounded-lg shadow-lg px-4 py-3 max-w-xs animate-slide-in">
        <div class="flex-1 pr-6">
          <p class="text-sm"><%= message %></p>
        </div>
        <button
          class="absolute top-2 right-2 text-white hover:text-gray-200"
          onclick="document.getElementById('errorToast<%= index %>').remove()"
          aria-label="Close">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    <% }); %>
  </div>

  <!-- Optional animation (Tailwind custom class) -->
  <style>
    @keyframes slide-in {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-in {
      animation: slide-in 0.3s ease-out;
    }
  </style>
<% } %>
