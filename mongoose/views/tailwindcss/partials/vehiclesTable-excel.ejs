<%
  /*
   * vehiclesTable-excel.ejs
   *
   * Props:
   *   vehicles                        "” array of vehicle docs
   *   vehicleDeploymentsByVehicleDate "” { [vehicleId]: { [YYYY-MM-DD]: deploymentDoc } }
   *   daysOfWeek                      "” array of YYYY-MM-DD strings
   *   allEmployees                    "” [{_id, uuid, name}]
   *   allSubcontractors               "” [{_id, uuid, Name}]
   *   locations                       "” [{_id, uuid, name}]
   *   activeContracts                 "” [{_id, uuid, title}]
   *   moment                          "” moment.js
   */
  const _vByD   = typeof vehicleDeploymentsByVehicleDate !== 'undefined' ? vehicleDeploymentsByVehicleDate : {};
  const _today  = new Date();
  const _warnMs = 30 * 24 * 60 * 60 * 1000;
  const _vList  = typeof vehicles         !== 'undefined' ? vehicles         : [];
  const _dows   = typeof daysOfWeek       !== 'undefined' ? daysOfWeek       : [];
  const _emps   = typeof allEmployees     !== 'undefined' ? allEmployees     : [];
  const _subs   = typeof allSubcontractors !== 'undefined' ? allSubcontractors : [];
  const _locs   = typeof locations        !== 'undefined' ? locations        : [];
  const _conts  = typeof activeContracts  !== 'undefined' ? activeContracts  : [];
  const _canEdit = canDept('management') || canDept('admin');

  const _complianceCls = (date) => {
    if (!date) return 'text-gray-400 dark:text-gray-500';
    const d = new Date(date);
    if (d < _today) return 'text-red-600 dark:text-red-400 font-semibold';
    if (d - _today < _warnMs) return 'text-amber-600 dark:text-amber-400 font-semibold';
    return 'text-gray-700 dark:text-gray-300';
  };
  const _usageBadge = {
    site:        'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
    delivery:    'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400',
    maintenance: 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400',
    office:      'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300',
    other:       'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400',
  };
%>

<% if (_vList.length === 0) { %>
  <div class="px-4 py-6 text-center text-sm text-gray-400 dark:text-gray-500">No active vehicles in the fleet.</div>
<% } else { %>
<table class="min-w-full border-collapse border border-gray-200 dark:border-gray-700 text-sm rounded-xl overflow-hidden">
  <thead>
    <tr class="bg-gray-50 dark:bg-gray-800">
      <th class="text-left font-normal border border-gray-200 dark:border-gray-700 px-3 py-2 text-gray-800 dark:text-gray-200 whitespace-nowrap">Registration</th>
      <th class="text-left font-normal border border-gray-200 dark:border-gray-700 px-3 py-2 text-gray-800 dark:text-gray-200">Type</th>
      <% _dows.forEach(function(day) { %>
        <th class="text-center text-xs font-normal border border-gray-300 dark:border-gray-700 px-2 py-2 text-gray-700 dark:text-gray-300 min-w-[90px]">
          <a href="/daily/<%= day %>" class="hover:underline hover:text-green-700 dark:hover:text-green-300"><%= moment(day).format('DD/MM') %></a><br>
          <span class="font-bold text-gray-600 dark:text-gray-400"><%= moment(day).format('ddd') %></span>
        </th>
      <% }); %>
      <th class="text-center font-normal border border-gray-200 dark:border-gray-700 px-2 py-2 text-gray-800 dark:text-gray-200 whitespace-nowrap">TAX</th>
      <th class="text-center font-normal border border-gray-200 dark:border-gray-700 px-2 py-2 text-gray-800 dark:text-gray-200 whitespace-nowrap">MOT</th>
      <th class="text-center font-normal border border-gray-200 dark:border-gray-700 px-2 py-2 text-gray-800 dark:text-gray-200 whitespace-nowrap">Insurance</th>
      <th class="text-center font-normal border border-gray-200 dark:border-gray-700 px-2 py-2 text-gray-800 dark:text-gray-200 whitespace-nowrap">Breakdown</th>
    </tr>
  </thead>
  <tbody class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100">
    <% _vList.forEach(function(v) { %>
      <%
        const _vId   = String(v._id);
        const _vDeps = _vByD[_vId] || {};
      %>
      <tr class="border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50/50 dark:hover:bg-gray-800/30">
        <!-- Registration -->
        <td class="border border-gray-300 dark:border-gray-700 px-3 py-2 whitespace-nowrap">
          <a href="/vehicle/read/<%= v._id %>" class="font-medium text-green-900 dark:text-green-400 hover:underline"><%= v.registrationNumber || '' %></a>
          <% if (v.make || v.model) { %><span class="block text-[10px] text-gray-400 dark:text-gray-500"><%= [v.make, v.model].filter(Boolean).join(' ') %></span><% } %>
        </td>
        <!-- Body type -->
        <td class="border border-gray-300 dark:border-gray-700 px-3 py-2 text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap"><%= v.bodyType || '' %></td>

        <!-- Day cells -->
        <% _dows.forEach(function(day) { %>
          <%
            const _dep = _vDeps[day];
            const _driverName = _dep
              ? (_dep.driverEmployeeId   ? _dep.driverEmployeeId.name
              : (_dep.driverSubcontractorId ? _dep.driverSubcontractorId.Name : null))
              : null;
            const _driverRef = _dep
              ? (_dep.driverEmployeeId   ? 'emp-' + String(_dep.driverEmployeeId._id)
              : (_dep.driverSubcontractorId ? 'sub-' + String(_dep.driverSubcontractorId._id) : ''))
              : '';
          %>
          <td class="border border-gray-300 dark:border-gray-700 p-0 align-top min-w-[90px]">
            <% if (_canEdit) { %>
              <button type="button" class="vdep-open w-full text-left px-2 py-1.5 min-h-[2.5rem] hover:bg-green-50 dark:hover:bg-green-900/20 transition-colors text-xs"
                data-vehicle-id="<%= _vId %>"
                data-date="<%= day %>"
                data-uuid="<%= _dep ? _dep.uuid : '' %>"
                data-is-new="<%= _dep ? 'false' : 'true' %>"
                data-driver-ref="<%= _driverRef %>"
                data-usage-type="<%= _dep ? _dep.usageType : 'site' %>"
                data-location-id="<%= (_dep && _dep.locationId) ? String(_dep.locationId._id || _dep.locationId) : '' %>"
                data-contract-id="<%= (_dep && _dep.contractId) ? String(_dep.contractId._id || _dep.contractId) : '' %>"
                data-start-mileage="<%= (_dep && _dep.startMileage != null) ? _dep.startMileage : '' %>"
                data-end-mileage="<%= (_dep && _dep.endMileage != null) ? _dep.endMileage : '' %>">
                <% if (_dep) { %>
                  <% if (_driverName) { %><span class="block font-medium text-gray-700 dark:text-gray-300 truncate"><%= _driverName %></span><% } %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium mt-0.5 <%= _usageBadge[_dep.usageType] || 'bg-gray-100 text-gray-700' %>"><%= _dep.usageType %></span>
                <% } else { %>
                  <span class="text-gray-300 dark:text-gray-600">+</span>
                <% } %>
              </button>
            <% } else { %>
              <% if (_dep) { %>
                <div class="px-2 py-1.5 text-xs">
                  <% if (_driverName) { %><span class="block font-medium text-gray-700 dark:text-gray-300 truncate"><%= _driverName %></span><% } %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium mt-0.5 <%= _usageBadge[_dep.usageType] || 'bg-gray-100 text-gray-700' %>"><%= _dep.usageType %></span>
                </div>
              <% } else { %>
                <div class="px-2 py-1.5 text-xs text-gray-200 dark:text-gray-700 text-center"></div>
              <% } %>
            <% } %>
          </td>
        <% }); %>

        <!-- Compliance columns -->
        <td class="border border-gray-300 dark:border-gray-700 px-2 py-2 text-center text-xs whitespace-nowrap <%= _complianceCls(v.roadTaxExpiryDate) %>">
          <%= v.roadTaxExpiryDate ? moment(v.roadTaxExpiryDate).format('DD/MM/YY') : '' %>
        </td>
        <td class="border border-gray-300 dark:border-gray-700 px-2 py-2 text-center text-xs whitespace-nowrap <%= _complianceCls(v.motExpiryDate) %>">
          <%= v.motExpiryDate ? moment(v.motExpiryDate).format('DD/MM/YY') : '' %>
        </td>
        <td class="border border-gray-300 dark:border-gray-700 px-2 py-2 text-center text-xs whitespace-nowrap">
          <span class="<%= _complianceCls(v.insuranceExpiryDate) %>"><%= v.insuranceExpiryDate ? moment(v.insuranceExpiryDate).format('DD/MM/YY') : '' %></span>
          <% if (v.insuranceProvider) { %><span class="block text-[9px] text-gray-400 dark:text-gray-500 mt-0.5"><%= v.insuranceProvider %></span><% } %>
        </td>
        <td class="border border-gray-300 dark:border-gray-700 px-2 py-2 text-center text-xs whitespace-nowrap">
          <span class="<%= _complianceCls(v.breakdownExpiryDate) %>"><%= v.breakdownExpiryDate ? moment(v.breakdownExpiryDate).format('DD/MM/YY') : '' %></span>
          <% if (v.breakdownProvider) { %><span class="block text-[9px] text-gray-400 dark:text-gray-500 mt-0.5"><%= v.breakdownProvider %></span><% } %>
        </td>
      </tr>
    <% }); %>
  </tbody>
</table>

<% if (_canEdit) { %>
<!-- Vehicle Deployment Modal -->
<dialog id="vdep-modal" class="rounded-xl shadow-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 p-0 max-w-md w-full">
  <div class="px-5 py-3 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
    <h3 id="vdep-modal-title" class="text-sm font-semibold">Vehicle Deployment</h3>
    <button type="button" id="vdep-close" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 text-lg leading-none">&times;</button>
  </div>
  <form id="vdep-form" class="px-5 py-4 space-y-3">
    <input type="hidden" id="vdep-uuid">
    <input type="hidden" id="vdep-is-new">
    <input type="hidden" id="vdep-vehicle-id">
    <input type="hidden" id="vdep-date">

    <div class="flex items-center gap-3">
      <label class="text-xs text-gray-500 dark:text-gray-400 w-20 shrink-0">Driver</label>
      <select id="vdep-driver-ref" class="flex-1 text-sm px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 focus:ring-1 focus:ring-green-500 focus:outline-none">
        <option value="">"” Unassigned "”</option>
        <optgroup label="Employees">
          <% _emps.forEach(function(emp) { %>
            <option value="emp-<%= emp._id %>"><%= emp.name %></option>
          <% }); %>
        </optgroup>
        <optgroup label="Subcontractors">
          <% _subs.forEach(function(sub) { %>
            <option value="sub-<%= sub._id %>"><%= sub.Name %></option>
          <% }); %>
        </optgroup>
      </select>
    </div>

    <div class="flex items-center gap-3">
      <label class="text-xs text-gray-500 dark:text-gray-400 w-20 shrink-0">Usage</label>
      <select id="vdep-usage" class="flex-1 text-sm px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 focus:ring-1 focus:ring-green-500 focus:outline-none">
        <option value="site">Site</option>
        <option value="delivery">Delivery</option>
        <option value="maintenance">Maintenance</option>
        <option value="office">Office</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div class="flex items-center gap-3">
      <label class="text-xs text-gray-500 dark:text-gray-400 w-20 shrink-0">Location</label>
      <select id="vdep-location" class="flex-1 text-sm px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 focus:ring-1 focus:ring-green-500 focus:outline-none">
        <option value="">"” None "”</option>
        <% _locs.forEach(function(loc) { %>
          <option value="<%= loc._id %>"><%= loc.name %></option>
        <% }); %>
      </select>
    </div>

    <div class="flex items-center gap-3">
      <label class="text-xs text-gray-500 dark:text-gray-400 w-20 shrink-0">Contract</label>
      <select id="vdep-contract" class="flex-1 text-sm px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 focus:ring-1 focus:ring-green-500 focus:outline-none">
        <option value="">"” None "”</option>
        <% _conts.forEach(function(c) { %>
          <option value="<%= c._id %>"><%= c.title %></option>
        <% }); %>
      </select>
    </div>

    <div class="flex items-center gap-3">
      <label class="text-xs text-gray-500 dark:text-gray-400 w-20 shrink-0">Mileage</label>
      <input type="number" id="vdep-start-mi" min="0" placeholder="Start"
        class="w-28 text-sm px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 focus:ring-1 focus:ring-green-500 focus:outline-none">
      <span class="text-xs text-gray-400"></span>
      <input type="number" id="vdep-end-mi" min="0" placeholder="End"
        class="w-28 text-sm px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 focus:ring-1 focus:ring-green-500 focus:outline-none">
    </div>

    <p id="vdep-err" class="text-xs text-red-600 dark:text-red-400" style="display:none"></p>

    <div class="flex items-center gap-2 pt-1">
      <button type="submit" id="vdep-submit" class="px-4 py-1.5 rounded text-xs font-medium bg-green-600 hover:bg-green-700 text-white transition-colors">Save</button>
      <button type="button" id="vdep-cancel" class="px-4 py-1.5 rounded text-xs font-medium bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 transition-colors">Cancel</button>
    </div>
  </form>
</dialog>

<style nonce="<%= locals.cspNonce %>">#vdep-modal::backdrop { background: rgba(0,0,0,0.5); }</style>

<script nonce="<%= locals.cspNonce %>">
(function () {
  var modal     = document.getElementById('vdep-modal');
  var submitBtn = document.getElementById('vdep-submit');
  var errEl     = document.getElementById('vdep-err');

  function closeModal() { modal.close(); }

  document.getElementById('vdep-close').addEventListener('click', closeModal);
  document.getElementById('vdep-cancel').addEventListener('click', closeModal);
  modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });

  document.querySelectorAll('.vdep-open').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var d = btn.dataset;
      document.getElementById('vdep-uuid').value       = d.uuid         || '';
      document.getElementById('vdep-is-new').value     = d.isNew        || 'true';
      document.getElementById('vdep-vehicle-id').value = d.vehicleId    || '';
      document.getElementById('vdep-date').value       = d.date         || '';
      document.getElementById('vdep-driver-ref').value = d.driverRef    || '';
      document.getElementById('vdep-usage').value      = d.usageType    || 'site';
      document.getElementById('vdep-location').value   = d.locationId   || '';
      document.getElementById('vdep-contract').value   = d.contractId   || '';
      document.getElementById('vdep-start-mi').value   = d.startMileage || '';
      document.getElementById('vdep-end-mi').value     = d.endMileage   || '';
      document.getElementById('vdep-modal-title').textContent =
        (d.isNew === 'true' ? 'Add Deployment' : 'Edit Deployment') + ' ' + d.date;
      errEl.style.display = 'none';
      submitBtn.disabled = false; submitBtn.textContent = 'Save';
      modal.showModal();
    });
  });

  document.getElementById('vdep-form').addEventListener('submit', function (e) {
    e.preventDefault();
    submitBtn.disabled = true; submitBtn.textContent = '…';
    errEl.style.display = 'none';
    var isNew  = document.getElementById('vdep-is-new').value === 'true';
    var uuid   = document.getElementById('vdep-uuid').value;
    var drRef  = (document.getElementById('vdep-driver-ref').value || '').trim();
    var smi    = document.getElementById('vdep-start-mi').value;
    var emi    = document.getElementById('vdep-end-mi').value;
    var payload = {
      vehicleId:  document.getElementById('vdep-vehicle-id').value,
      date:       document.getElementById('vdep-date').value,
      usageType:  document.getElementById('vdep-usage').value || 'site',
      locationId: document.getElementById('vdep-location').value || null,
      contractId: document.getElementById('vdep-contract').value || null,
    };
    if (drRef.startsWith('emp-')) payload.driverEmployeeId       = drRef.slice(4);
    else if (drRef.startsWith('sub-')) payload.driverSubcontractorId = drRef.slice(4);
    if (smi !== '') payload.startMileage = Number(smi);
    if (emi !== '') payload.endMileage   = Number(emi);
    var csrf = (document.querySelector('meta[name="csrf-token"]') || {}).content || '';
    fetch(isNew ? '/vehicle-deployment/inline' : '/vehicle-deployment/' + uuid, {
      method: isNew ? 'POST' : 'PATCH',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
      body: JSON.stringify(payload),
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.success) { closeModal(); window.location.reload(); return; }
        submitBtn.disabled = false; submitBtn.textContent = 'Save';
        errEl.textContent = data.error || 'Save failed.'; errEl.style.display = '';
      })
      .catch(function () {
        submitBtn.disabled = false; submitBtn.textContent = 'Save';
        errEl.textContent = 'Network error.'; errEl.style.display = '';
      });
  });
})();
</script>
<% } %>
<% } %>
