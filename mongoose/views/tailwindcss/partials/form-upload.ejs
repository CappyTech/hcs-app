<div class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">
  <a href="/<%= basePath %>/read/<%= item.uuid %>" class="inline-flex items-center gap-1.5 text-sm text-green-600 dark:text-green-400 hover:underline font-medium"><i class="bi bi-arrow-left"></i> Go Back</a>

  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-blue-500 to-blue-400"></div>
    <div class="p-6 sm:p-8">
  <h1 class="text-2xl font-semibold mb-4 text-gray-900 dark:text-gray-100">
    <%= title %> for <a href="/<%= basePath %>/read/<%= item.uuid %>" class="text-green-600 hover:underline"><%= item?.Name || item?.Number || item?.uuid %></a>
  </h1>

  <!-- Allowed types & size -->
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
    Allowed file types: <strong>.jpg, .jpeg, .png, .pdf, .doc, .docx</strong>. Max size: <strong>5MB</strong> per file.
  </p>

  <!-- Drag-and-drop file area -->
  <form id="uploadForm" method="POST" enctype="multipart/form-data" action="/<%= basePath %>/upload/<%= item.uuid %>">
    <%- include('./csrfHidden.ejs') %>
    <div id="drop-area"
      class="border-2 border-dashed border-gray-300 dark:border-gray-700 p-8 rounded-xl text-center cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800 transition">
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">Drag & drop files here or click to browse</p>
      <input id="files" name="files" type="file" multiple class="hidden" />
      <button type="button" id="browseBtn"
        class="inline-flex items-center gap-1.5 bg-green-600 text-white text-sm px-4 py-2 rounded-lg hover:bg-green-700 transition shadow-sm font-medium">Browse Files</button>
    </div>

    <div id="fileList" class="mt-4 text-sm text-gray-700 dark:text-gray-200"></div>

    <button type="submit"
      class="mt-6 inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-lg transition shadow-sm font-medium"><i class="bi bi-upload"></i> Upload</button>
  </form>
    </div>
  </div>
</div>

<script>
  const dropArea = document.getElementById('drop-area');
  const fileInput = document.getElementById('files');
  const browseBtn = document.getElementById('browseBtn');
  const fileList = document.getElementById('fileList');
  const form = document.getElementById('uploadForm');

  browseBtn.addEventListener('click', () => fileInput.click());

  dropArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropArea.classList.add('bg-gray-100');
  });

  dropArea.addEventListener('dragleave', () => {
    dropArea.classList.remove('bg-gray-100');
  });

  dropArea.addEventListener('drop', (e) => {
    e.preventDefault();
    dropArea.classList.remove('bg-gray-100');
    fileInput.files = e.dataTransfer.files;
    displayFiles();
  });

  fileInput.addEventListener('change', displayFiles);

  function displayFiles() {
    const files = fileInput.files;
    fileList.innerHTML = '';
    for (const file of files) {
      fileList.innerHTML += `<div>📎 ${file.name}</div>`;
    }
  }

  form.addEventListener('submit', function (e) {
    const files = fileInput.files;
    if (!files.length) {
      e.preventDefault();
      alert('Please select at least one file to upload.');
      return;
    }
    for (const file of files) {
      const ext = file.name.split('.').pop().toLowerCase();
      const allowed = ['jpg', 'jpeg', 'png', 'pdf', 'doc', 'docx'];
      if (!allowed.includes(ext)) {
        e.preventDefault();
        alert(`Invalid file type: ${file.name}`);
        return;
      }
      if (file.size > 5 * 1024 * 1024) {
        e.preventDefault();
        alert(`File too large: ${file.name} (Max 5MB)`);
        return;
      }
    }
  });
</script>
