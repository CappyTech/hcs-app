<div class="container mx-auto my-5 px-4">
  <a href="/<%= basePath %>s" class="text-green-600 hover:underline"><i class="bi bi-arrow-left"></i> Go Back</a>
  <!-- Header: Title + Update/Delete buttons -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold"><%= title %></h1>

    <% if (isAuthenticated && isAdmin) { %>
      <div class="flex space-x-2">
        <% if (Array.isArray(actions) && actions.length > 0) { %>
          <% actions.forEach(action => { %>
            <a href="<%= typeof action.href === 'function' ? action.href(item) : action.href %>"
              class="inline-flex items-center justify-center rounded bg-<%= action.class === 'danger' ? 'red' : action.class === 'success' ? 'green' : action.class === 'warning' ? 'yellow' : 'blue' %>-600 px-3 py-1 text-sm text-white hover:bg-<%= action.class === 'danger' ? 'red' : action.class === 'success' ? 'green' : action.class === 'warning' ? 'yellow' : 'blue' %>-700 transition">
              <% if (action.icon) { %><i class="bi <%= action.icon %>"></i><% } %>
              <span class="ml-1 hidden sm:inline"><%= action.label %></span>
            </a>
          <% }) %>
        <% } else { %>
          <% if (!config?.deny?.includes('u')) { %>
            <a href="/<%= basePath %>/update/<%= item.uuid %>" 
              class="inline-flex items-center justify-center rounded bg-green-600 px-3 py-1 text-sm text-white hover:bg-green-700 transition">
              <i class="bi bi-arrow-clockwise"></i>
              <span class="ml-1 hidden sm:inline">Update</span>
            </a>
          <% } %>
          <% if (!config?.deny?.includes('d')) { %>
            <a href="/<%= basePath %>/delete/<%= item.uuid %>" 
              class="inline-flex items-center justify-center rounded bg-red-600 px-3 py-1 text-sm text-white hover:bg-red-700 transition">
              <i class="bi bi-trash-fill"></i>
              <span class="ml-1 hidden sm:inline">Delete</span>
            </a>
          <% } %>
          <% if (config?.handlesDocuments) { %>
            <a href="/<%= basePath %>/upload/<%= item.uuid %>" 
              class="inline-flex items-center justify-center rounded bg-blue-600 px-3 py-1 text-sm text-white hover:bg-blue-700 transition">
              <i class="bi bi-upload"></i>
              <span class="ml-1 hidden sm:inline">Upload Documents</span>
            </a>
          <% } %>
        <% } %>
      </div>
    <% } %>
  </div>

  <!-- Read-only fields -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <% for (const key in schema) { %>
      <%- include('../partials/_formField', {
        key,
        field: schema[key],
        formData: item,
        referenceData,
        readOnly: true,
        showTips: false
      }) %>
    <% } %>
  </div>

<% if (config?.handlesDocuments) { %>
  <div class="mt-8">
    <h2 class="text-xl font-medium mb-2">Documents</h2>

    <% if (item.documents?.length) { %>
      <ul>
        <% item.documents.forEach(doc => { %>
          <li>
            <%= doc.name %>
            <% if (doc.name.match(/\.(pdf|jpg|jpeg|png|webp|gif)$/i)) { %>
              <a href="<%= doc.url %>" class="text-green-600 underline ml-2">View</a>
            <% } else { %>
              <a href="/<%= basePath %>/download/<%= item.uuid %>/<%= encodeURIComponent(doc.name) %>" class="text-green-600 underline ml-2">Download</a>
            <% } %>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p class="text-gray-500 italic">No documents uploaded yet.</p>
    <% } %>
  </div>
<% } %>

</div>
