<div class="w-1/2 mx-auto my-3 px-4">
  <a href="/<%= basePath %>s" class="text-green-600 dark:text-green-400 hover:underline"><i class="bi bi-arrow-left"></i> Go Back</a>
  <!-- Header: Title + Update/Delete buttons -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100"><%= title %></h1>

    <% if (isAuthenticated && isAdmin) { %>
      <div class="flex space-x-2">
        <% if (Array.isArray(actions) && actions.length > 0) { %>
          <% actions.forEach(action => { %>
            <a href="<%= typeof action.href === 'function' ? action.href(item) : action.href %>"
              class="inline-flex items-center justify-center rounded bg-<%= action.class === 'danger' ? 'red' : action.class === 'success' ? 'green' : action.class === 'warning' ? 'yellow' : 'blue' %>-600 px-3 py-1 text-sm text-white hover:bg-<%= action.class === 'danger' ? 'red' : action.class === 'success' ? 'green' : action.class === 'warning' ? 'yellow' : 'blue' %>-700 transition">
              <% if (action.icon) { %><i class="bi <%= action.icon %>"></i><% } %>
              <span class="ml-1 hidden sm:inline"><%= action.label %></span>
            </a>
          <% }) %>
        <% } else { %>
          <% if (!config?.deny?.includes('u')) { %>
            <a href="/<%= basePath %>/update/<%= item.uuid %>" 
              class="inline-flex items-center justify-center rounded bg-green-600 px-3 py-1 text-sm text-white hover:bg-green-700 transition">
              <i class="bi bi-arrow-clockwise"></i>
              <span class="ml-1 hidden sm:inline">Update</span>
            </a>
          <% } %>
          <% if (!config?.deny?.includes('d')) { %>
            <a href="/<%= basePath %>/delete/<%= item.uuid %>" 
              class="inline-flex items-center justify-center rounded bg-red-600 px-3 py-1 text-sm text-white hover:bg-red-700 transition">
              <i class="bi bi-trash-fill"></i>
              <span class="ml-1 hidden sm:inline">Delete</span>
            </a>
          <% } %>
          <% if (config?.handlesDocuments) { %>
            <a href="/<%= basePath %>/upload/<%= item.uuid %>" 
              class="inline-flex items-center justify-center rounded bg-blue-600 px-3 py-1 text-sm text-white hover:bg-blue-700 transition">
              <i class="bi bi-upload"></i>
              <span class="ml-1 hidden sm:inline">Upload Documents</span>
            </a>
          <% } %>
        <% } %>
      </div>
    <% } %>
  </div>

  <% const _desc = typeof config !== 'undefined' ? config?.description : undefined; %>
  <% const descText = typeof _desc === 'string' ? _desc : (_desc?.manage || ''); %>
  <% if (descText) { %>
    <p class="text-gray-500 dark:text-gray-400 text-sm mb-4"><%= descText %></p>
  <% } %>

  <!-- Horizontal layout: details left, sidebar with Items/Payments right -->
  <div class="grid md:grid-cols-3 gap-4">
    <!-- Main details -->
    <div class="md:col-span-2 bg-gray-100 dark:bg-gray-800 p-4 rounded-lg shadow-sm">
      <%
        const _readRendered = new Set();
        const _readKeys = Object.keys(schema).filter(k => k !== 'LineItems' && k !== 'PaymentLines');
        const _readNestedGroups = {};
        _readKeys.forEach(k => {
          const dot = k.indexOf('.');
          if (dot > -1) {
            const prefix = k.substring(0, dot);
            if (!_readNestedGroups[prefix]) _readNestedGroups[prefix] = [];
            _readNestedGroups[prefix].push(k);
          }
        });
        const _readGroupLabel = (name) => name.replace(/([a-z])([A-Z])/g, '$1 $2').replace(/\b\w/g, c => c.toUpperCase());
      %>
      <% _readKeys.forEach(key => {
        if (_readRendered.has(key)) return;
        const _dot = key.indexOf('.');
        const _prefix = _dot > -1 ? key.substring(0, _dot) : null;
        if (_prefix && _readNestedGroups[_prefix]) {
      %>
        <fieldset class="mb-4 border border-gray-300 dark:border-gray-600 rounded p-3">
          <legend class="px-2 text-sm font-semibold text-gray-700 dark:text-gray-200"><%= _readGroupLabel(_prefix) %></legend>
          <% _readNestedGroups[_prefix].forEach(gKey => {
            if (!_readRendered.has(gKey) && schema[gKey]) { %>
              <%- include('../partials/_formField', {
                key: gKey,
                field: schema[gKey],
                formData: item,
                referenceData,
                readOnly: true,
                showTips: false,
                config,
                groupPrefix: _prefix
              }) %>
          <%  _readRendered.add(gKey);
            }
          }) %>
        </fieldset>
      <% } else { %>
        <%- include('../partials/_formField', {
          key,
          field: schema[key],
          formData: item,
          referenceData,
          readOnly: true,
          showTips: false,
          config,
          groupPrefix: null
        }) %>
      <% _readRendered.add(key);
        }
      }) %>
    </div>

    <!-- Sidebar: Items and Payments stacked -->
    <div class="space-y-4">
      <% if (schema['LineItems']) { %>
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow">
          <div class="px-4 pt-3">
            <h2 class="text-lg font-medium mb-2 text-gray-900 dark:text-gray-100">Items</h2>
          </div>
          <div class="px-2 pb-3">
            <%- include('../partials/_formField', {
              key: 'LineItems',
              field: schema['LineItems'],
              formData: item,
              referenceData,
              readOnly: true,
              showTips: false,
              config
            }) %>
          </div>
        </div>
      <% } %>

      <% if (schema['PaymentLines']) { %>
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow">
          <div class="px-4 pt-3">
            <h2 class="text-lg font-medium mb-2 text-gray-900 dark:text-gray-100">Payments</h2>
          </div>
          <div class="px-2 pb-3">
            <%- include('../partials/_formField', {
              key: 'PaymentLines',
              field: schema['PaymentLines'],
              formData: item,
              referenceData,
              readOnly: true,
              showTips: false,
              config
            }) %>
          </div>
        </div>
      <% } %>
    </div>
  </div>

<% if (config?.handlesDocuments) { %>
  <div class="mt-8">
    <h2 class="text-xl font-medium mb-2 text-gray-900 dark:text-gray-100">Documents</h2>

    <% if (item.documents?.length) { %>
      <ul>
        <% item.documents.forEach(doc => { %>
          <li class="text-gray-800 dark:text-gray-200">
            <%= doc.name %>
            <% if (doc.name.match(/\.(pdf|jpg|jpeg|png|webp|gif)$/i)) { %>
              <a href="<%= doc.url %>" class="text-green-600 dark:text-green-400 underline ml-2">View</a>
            <% } else { %>
              <a href="/<%= basePath %>/download/<%= item.uuid %>/<%= encodeURIComponent(doc.name) %>" class="text-green-600 dark:text-green-400 underline ml-2">Download</a>
            <% } %>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
  <p class="text-gray-500 dark:text-gray-300 italic">No documents uploaded yet.</p>
    <% } %>
  </div>
<% } %>

  <% if (basePath === 'supplier' && (item.Subcontractor || item.IsSubcontractor) && Array.isArray(item.purchases)) { %>
    <div class="mt-8">
      <h2 class="text-xl font-medium mb-3 text-gray-900 dark:text-gray-100">CIS Calendar (Paid)</h2>
      <% 
        // Display months April→March (UK tax year). Labels aligned A M J J A S O N D J F M
        const monthsShort = ['A','M','J','J','A','S','O','N','D','J','F','M'];
        const cisMap = {};
        // Helper: map a JS Date to HMRC tax year/month (Apr=1..Mar=12)
        const toTaxYearMonth = (dateObj) => {
          if (!dateObj || isNaN(dateObj.getTime())) return null;
          const cm = dateObj.getMonth();
          const taxMonth = ((cm + 9) % 12) + 1; // Apr=1
          const calYear = dateObj.getFullYear();
          const taxYear = (cm >= 3) ? calYear : (calYear - 1);
          return { taxYear, taxMonth };
        };
        item.purchases.forEach(p => {
          // Only count months based on payment line dates (PayDate/Date)
          let dates = [];
          if (Array.isArray(p.PaymentLines)) {
            p.PaymentLines.forEach(pl => {
              const raw = pl?.PayDate || pl?.Date;
              if (!raw) return;
              let d = new Date(raw);
              if (isNaN(d.getTime()) && typeof raw === 'string') {
                const s = raw.trim();
                const isoish = s.replace(' ', 'T');
                d = new Date(isoish);
              }
              if (!isNaN(d.getTime())) dates.push(d);
            });
          }
          // If no payment line dates, do not include this purchase in CIS calendar
          if (dates.length === 0) return;
          // Increment counts for each payment date's tax month
          dates.forEach(d => {
            const t = toTaxYearMonth(d);
            if (!t) return;
            const y = t.taxYear;
            const m = t.taxMonth;
            if (!cisMap[y]) cisMap[y] = {};
            cisMap[y][m] = (cisMap[y][m] || 0) + 1;
          });
        });
        const years = Object.keys(cisMap).sort((a,b) => Number(b) - Number(a));
      %>
      <% if (years.length > 0) { %>
        <div class="overflow-x-auto rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Year</th>
                <% monthsShort.forEach(ms => { %>
                  <th class="px-2 py-2 text-center text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= ms %></th>
                <% }) %>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
              <% years.forEach(y => { %>
                <tr>
                  <td class="px-4 py-2 text-gray-800 dark:text-gray-200 font-medium"><%= y %></td>
                  <% for (let i = 1; i <= 12; i++) { %>
                    <% const count = cisMap[y][i] || 0; const has = count > 0; %>
                    <td class="px-2 py-2 text-center">
                      <% if (has) { %>
                        <a href="/CIS/Dashboard/<%= y %>/<%= i %>" 
                           class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-green-600 hover:bg-green-700 text-white text-[10px] font-medium" 
                           title="<%= count %> purchase<%= count === 1 ? '' : 's' %>"><%= count %></a>
                      <% } else { %>
                        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-300 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-[10px]" title="0 purchases">0</span>
                      <% } %>
                    </td>
                  <% } %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-gray-500 dark:text-gray-300 italic">No CIS months found for this supplier.</p>
        <% if (Array.isArray(item.purchases) && item.purchases.length > 0) { %>
          <div class="mt-3 text-xs text-gray-600 dark:text-gray-300">
            <p class="mb-1">Debug: showing payment dates detected from purchases:</p>
            <ul class="list-disc ml-5">
              <% item.purchases.forEach(p => { %>
                <% const lines = Array.isArray(p.PaymentLines) ? p.PaymentLines.map(pl => pl?.PayDate || pl?.Date).filter(Boolean) : []; %>
                <li>
                  #<%= p.Number %>: PaymentLines=<%= lines.length ? lines.join(', ') : '—' %>
                </li>
              <% }) %>
            </ul>
          </div>
        <% } %>
      <% } %>
    </div>
    <div class="mt-6">
      <h2 class="text-xl font-medium mb-3 text-gray-900 dark:text-gray-100">CIS Calendar (Issued)</h2>
      <% 
        // Issued-based calendar uses explicit TaxYear/TaxMonth when present, else maps IssuedDate to tax month
        const monthsShortIssued = ['A','M','J','J','A','S','O','N','D','J','F','M'];
        const cisIssuedMap = {};
        const toTaxYMFromIssued = (dateObj) => {
          if (!dateObj || isNaN(dateObj.getTime())) return null;
          const cm = dateObj.getMonth();
          const taxMonth = ((cm + 9) % 12) + 1;
          const calYear = dateObj.getFullYear();
          const taxYear = (cm >= 3) ? calYear : (calYear - 1);
          return { taxYear, taxMonth };
        };
        item.purchases.forEach(p => {
          let y = p.TaxYear;
          let m = p.TaxMonth;
          if ((!y || !m) && p.IssuedDate) {
            const d = new Date(p.IssuedDate);
            const t = toTaxYMFromIssued(d);
            if (t) { y = t.taxYear; m = t.taxMonth; }
          }
          if (!y || !m) return;
          if (!cisIssuedMap[y]) cisIssuedMap[y] = {};
          const mm = Number(m);
          cisIssuedMap[y][mm] = (cisIssuedMap[y][mm] || 0) + 1;
        });
        const yearsIssued = Object.keys(cisIssuedMap).sort((a,b) => Number(b) - Number(a));
      %>
      <% if (yearsIssued.length > 0) { %>
        <div class="overflow-x-auto rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Tax Year</th>
                <% monthsShortIssued.forEach(ms => { %>
                  <th class="px-2 py-2 text-center text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider"><%= ms %></th>
                <% }) %>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
              <% yearsIssued.forEach(y => { %>
                <tr>
                  <td class="px-4 py-2 text-gray-800 dark:text-gray-200 font-medium"><%= y %></td>
                  <% for (let i = 1; i <= 12; i++) { %>
                    <% const count = cisIssuedMap[y][i] || 0; const has = count > 0; %>
                    <td class="px-2 py-2 text-center">
                      <% if (has) { %>
                        <a href="/CIS/Dashboard/<%= y %>/<%= i %>" 
                           class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-blue-600 hover:bg-blue-700 text-white text-[10px] font-medium" 
                           title="<%= count %> purchase<%= count === 1 ? '' : 's' %>"><%= count %></a>
                      <% } else { %>
                        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-300 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-[10px]" title="0 purchases">0</span>
                      <% } %>
                    </td>
                  <% } %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-gray-500 dark:text-gray-300 italic">No issued months found for this supplier.</p>
      <% } %>
    </div>
  <% } %>

  <% if (basePath === 'supplier' && Array.isArray(item.purchases)) { %>
    <div class="mt-8">
      <h2 class="text-xl font-medium mb-2 text-gray-900 dark:text-gray-100">Purchases</h2>
      <% if (item.purchases.length > 0) { %>
        <div class="overflow-x-auto rounded border border-gray-200 dark:border-gray-700">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Number</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Reference</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Issued</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Net</th>
                <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">VAT</th>
                <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Gross</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
              <% item.purchases.forEach(p => { %>
                <tr>
                  <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><a class="text-green-600" href="https://app.kashflow.com/#purchases/<%= p.Number %>" target="_blank" rel="noopener noreferrer"><%= p.Number %> <i class="bi bi-box-arrow-up-right"></i></a></td>
                  <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><a class="text-green-600" href="/purchase/read/<%= p.uuid %>"><%= p.SupplierReference %></a></td>
                  <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><%= slimDateTime(p.IssuedDate) %></td>
                  <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><%= p.Status %></td>
                  <% const netAmt = (typeof p.NetAmount === 'number') ? p.NetAmount : Number(p.NetAmount);
                     const vatAmt = (typeof p.VATAmount === 'number') ? p.VATAmount : Number(p.VATAmount);
                     const grossAmt = (typeof p.GrossAmount === 'number') ? p.GrossAmount : Number(p.GrossAmount);
                  %>
                  <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= Number.isFinite(netAmt) ? formatCurrency(netAmt) : '' %></td>
                  <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= Number.isFinite(vatAmt) ? formatCurrency(vatAmt) : '' %></td>
                  <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= Number.isFinite(grossAmt) ? formatCurrency(grossAmt) : '' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-gray-500 dark:text-gray-300 italic">No purchases found for this supplier.</p>
      <% } %>
    </div>
  <% } %>

  <%# ── Vehicle-related data tables ──────────────────────────────────── %>
  <% if (basePath === 'vehicle') { %>

    <%# ── Quick actions bar ──────────────────────────────────────────── %>
    <div class="mt-8 flex flex-wrap gap-2 print:hidden">
      <a href="/vehicleFuelLog/create?vehicleId=<%= item._id %>" class="inline-flex items-center gap-1 bg-green-600 hover:bg-green-700 text-white rounded px-3 py-1.5 text-sm font-medium">
        &#9981; Log Fuel
      </a>
      <a href="/vehicleMileageLog/create?vehicleId=<%= item._id %>" class="inline-flex items-center gap-1 bg-blue-600 hover:bg-blue-700 text-white rounded px-3 py-1.5 text-sm font-medium">
        &#128663; Log Trip
      </a>
      <a href="/vehicleService/create?vehicleId=<%= item._id %>" class="inline-flex items-center gap-1 bg-purple-600 hover:bg-purple-700 text-white rounded px-3 py-1.5 text-sm font-medium">
        &#128295; Log Service
      </a>
    </div>

    <%# ── Service History ────────────────────────────────────────────── %>
    <% if (Array.isArray(item.serviceHistory)) { %>
      <div class="mt-8">
        <h2 class="text-xl font-medium mb-2 text-gray-900 dark:text-gray-100">Service History</h2>
        <% if (item.serviceHistory.length > 0) { %>
          <div class="overflow-x-auto rounded border border-gray-200 dark:border-gray-700">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Type</th>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Provider</th>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                  <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Mileage</th>
                  <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Total Cost</th>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Result</th>
                </tr>
              </thead>
              <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
                <% item.serviceHistory.forEach(s => { %>
                  <tr>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><a class="text-green-600 hover:underline" href="/vehicleService/read/<%= s.uuid %>"><%= slimDateTime(s.date) %></a></td>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><%= s.serviceType %></td>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><%= s.provider || '—' %></td>
                    <td class="px-4 py-2">
                      <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium
                        <%= s.status === 'Completed' ? 'bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400' :
                           s.status === 'In Progress' ? 'bg-blue-100 text-blue-800 dark:bg-blue-800/20 dark:text-blue-400' :
                           s.status === 'Scheduled' ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-800/20 dark:text-yellow-400' :
                           'bg-gray-100 text-gray-800 dark:bg-gray-800/20 dark:text-gray-400' %>">
                        <%= s.status %>
                      </span>
                    </td>
                    <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= s.mileageAtService != null ? Number(s.mileageAtService).toLocaleString() : '—' %></td>
                    <% const sCost = s.totalCost ? Number(s.totalCost.toString ? s.totalCost.toString() : s.totalCost) : 0; %>
                    <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= Number.isFinite(sCost) && sCost > 0 ? '£' + sCost.toFixed(2) : '—' %></td>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200">
                      <% if (s.serviceType === 'MOT' && s.passed != null) { %>
                        <span class="<%= s.passed ? 'text-green-600 font-bold' : 'text-red-600 font-bold' %>"><%= s.passed ? 'PASS' : 'FAIL' %></span>
                      <% } else { %>—<% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-gray-500 dark:text-gray-300 italic">No service records yet.</p>
        <% } %>
      </div>
    <% } %>

    <%# ── Fuel Logs ──────────────────────────────────────────────────── %>
    <% if (Array.isArray(item.fuelLogs)) { %>
      <div class="mt-8">
        <h2 class="text-xl font-medium mb-2 text-gray-900 dark:text-gray-100">Fuel Logs</h2>
        <% if (item.fuelLogs.length > 0) { %>
          <div class="overflow-x-auto rounded border border-gray-200 dark:border-gray-700">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Fuel</th>
                  <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Litres</th>
                  <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Total Cost</th>
                  <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Mileage</th>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Station</th>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Payment</th>
                </tr>
              </thead>
              <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
                <% item.fuelLogs.forEach(f => {
                  const fLitres = f.litres ? Number(f.litres.toString ? f.litres.toString() : f.litres) : 0;
                  const fCost = f.totalCost ? Number(f.totalCost.toString ? f.totalCost.toString() : f.totalCost) : 0;
                %>
                  <tr>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><a class="text-green-600 hover:underline" href="/vehicleFuelLog/read/<%= f.uuid %>"><%= slimDateTime(f.date) %></a></td>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><%= f.fuelType %></td>
                    <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= Number.isFinite(fLitres) ? fLitres.toFixed(2) : '—' %></td>
                    <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= Number.isFinite(fCost) && fCost > 0 ? '£' + fCost.toFixed(2) : '—' %></td>
                    <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= f.mileageAtFillUp != null ? Number(f.mileageAtFillUp).toLocaleString() : '—' %></td>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><%= f.station || '—' %></td>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><%= f.paymentMethod || '—' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-gray-500 dark:text-gray-300 italic">No fuel logs yet.</p>
        <% } %>
      </div>
    <% } %>

    <%# ── Mileage Logs ───────────────────────────────────────────────── %>
    <% if (Array.isArray(item.mileageLogs)) { %>
      <div class="mt-8">
        <h2 class="text-xl font-medium mb-2 text-gray-900 dark:text-gray-100">Mileage / Trip Logs</h2>
        <% if (item.mileageLogs.length > 0) { %>
          <div class="overflow-x-auto rounded border border-gray-200 dark:border-gray-700">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Purpose</th>
                  <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Start</th>
                  <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">End</th>
                  <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Distance</th>
                  <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Route</th>
                  <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Claim</th>
                </tr>
              </thead>
              <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
                <% item.mileageLogs.forEach(m => {
                  const mClaim = m.claimAmount ? Number(m.claimAmount.toString ? m.claimAmount.toString() : m.claimAmount) : 0;
                %>
                  <tr>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><a class="text-green-600 hover:underline" href="/vehicleMileageLog/read/<%= m.uuid %>"><%= slimDateTime(m.date) %></a></td>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200"><%= m.tripPurpose || '—' %></td>
                    <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= m.startMileage != null ? Number(m.startMileage).toLocaleString() : '—' %></td>
                    <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= m.endMileage != null ? Number(m.endMileage).toLocaleString() : '—' %></td>
                    <td class="px-4 py-2 text-right font-semibold text-gray-800 dark:text-gray-200"><%= m.distance != null ? Number(m.distance).toLocaleString() + ' mi' : '—' %></td>
                    <td class="px-4 py-2 text-gray-800 dark:text-gray-200 text-xs"><%= [m.startLocation, m.endLocation].filter(Boolean).join(' → ') || '—' %></td>
                    <td class="px-4 py-2 text-right text-gray-800 dark:text-gray-200"><%= m.claimable && Number.isFinite(mClaim) && mClaim > 0 ? '£' + mClaim.toFixed(2) : '—' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-gray-500 dark:text-gray-300 italic">No mileage logs yet.</p>
        <% } %>
      </div>
    <% } %>

  <% } %>

</div>
