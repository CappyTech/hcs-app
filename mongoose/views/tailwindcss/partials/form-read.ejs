<div class="container mx-auto my-5 px-4">
  <div class="flex items-center mb-4">
    <h1 class="mb-0 text-2xl font-semibold"><%= title %></h1>

    <% if (isAuthenticated && isAdmin) { %>
      <a href="<%= basePath ? '/' + basePath + '/update/' + item.uuid : '/update/' + item.uuid %>" 
         class="btn-hcs-green btn-sm ml-3 inline-flex items-center justify-center rounded px-3 py-1 text-white hover:bg-green-700 transition">
        <i class="bi bi-arrow-clockwise"></i>
      </a>

      <a href="<%= basePath ? '/' + basePath + '/delete/' + item.uuid : '/delete/' + item.uuid %>" 
         class="btn-danger btn-sm ml-2 inline-flex items-center justify-center rounded px-3 py-1 text-white bg-red-600 hover:bg-red-700 transition">
        <i class="bi bi-trash-fill"></i>
      </a>
    <% } %>
  </div>

  <table class="min-w-full border border-gray-300 rounded-sm">
    <tbody>
      <% for (const key in schema) { const field = schema[key]; %>
        <tr class="border-b border-gray-200 last:border-b-0">
          <th class="text-left font-medium px-4 py-2 bg-gray-50 w-1/3"><%= field.label %></th>
          <td class="px-4 py-2">
            <% const val = item[key]; %>

            <% if (Array.isArray(val) && val.length && typeof val[0] === 'object') { %>
              <div class="overflow-x-auto border border-gray-300 rounded mt-2">
                <table class="min-w-full text-sm">
                  <thead class="bg-gray-100 text-gray-700">
                    <tr>
                      <% Object.keys(val[0]).forEach(subKey => { %>
                        <th class="px-2 py-1 text-left border-b border-gray-300"><%= subKey %></th>
                      <% }) %>
                    </tr>
                  </thead>
                  <tbody>
                    <% val.forEach(entry => { %>
                      <tr class="border-b border-gray-200">
                        <% Object.keys(entry).forEach(subKey => { %>
                          <td class="px-2 py-1"><%= entry[subKey] %></td>
                        <% }) %>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else if (typeof val === 'object' && val !== null) { %>
              <pre><%= JSON.stringify(val, null, 2) %></pre>
            <% } else { %>
              <%= val != null ? val : '' %>
            <% } %>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
