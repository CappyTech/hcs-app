<div class="max-w-6xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">
  <a href="/<%= basePath %>s" class="inline-flex items-center gap-1.5 text-sm text-green-700 dark:text-green-400 hover:underline font-medium"><i class="bi bi-arrow-left"></i> Go Back</a>

  <!-- Main card -->
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <div class="p-6 sm:p-8">

      <!-- Header: Title + action buttons -->
      <div class="flex items-center justify-between mb-6 gap-4">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= title %></h1>

        <% if (isAuthenticated && (typeof canUpdate !== 'undefined' ? canUpdate : isAdmin)) { %>
          <%
            const _btnCls = { danger: 'bg-red-600 hover:bg-red-700', success: 'bg-green-600 hover:bg-green-700', warning: 'bg-amber-500 hover:bg-amber-600', info: 'bg-blue-600 hover:bg-blue-700' };
            const _btnColor = (cls) => _btnCls[cls] || 'bg-indigo-600 hover:bg-indigo-700';
          %>
          <div class="flex shrink-0 gap-2">
            <% if (Array.isArray(actions) && actions.length > 0) { %>
              <% actions.forEach(action => { %>
                <a href="<%= typeof action.href === 'function' ? action.href(item) : action.href %>"
                  class="inline-flex items-center justify-center gap-1.5 rounded-lg <%= _btnColor(action.class) %> px-4 py-2 text-sm font-medium text-white transition shadow-sm">
                  <% if (action.icon) { %><i class="bi <%= action.icon %>"></i><% } %>
                  <span class="hidden sm:inline"><%= action.label %></span>
                </a>
              <% }) %>
            <% } else { %>
              <% if (!config?.deny?.includes('u') && (typeof canUpdate !== 'undefined' ? canUpdate : isAdmin)) { %>
                <a href="/<%= basePath %>/update/<%= item.uuid %>"
                  class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-green-600 hover:bg-green-700 px-4 py-2 text-sm font-medium text-white transition shadow-sm">
                  <i class="bi bi-pencil"></i>
                  <span class="hidden sm:inline">Update</span>
                </a>
              <% } %>
              <% if (!config?.deny?.includes('d') && (typeof canDelete !== 'undefined' ? canDelete : isAdmin)) { %>
                <a href="/<%= basePath %>/delete/<%= item.uuid %>"
                  class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-red-600 hover:bg-red-700 px-4 py-2 text-sm font-medium text-white transition shadow-sm">
                  <i class="bi bi-trash-fill"></i>
                  <span class="hidden sm:inline">Delete</span>
                </a>
              <% } %>
              <% if (config?.handlesDocuments) { %>
                <a href="/<%= basePath %>/upload/<%= item.uuid %>"
                  class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-blue-600 hover:bg-blue-700 px-4 py-2 text-sm font-medium text-white transition shadow-sm">
                  <i class="bi bi-upload"></i>
                  <span class="hidden sm:inline">Upload</span>
                </a>
              <% } %>
            <% } %>
          </div>
        <% } %>
      </div>

      <% const _desc = typeof config !== 'undefined' ? config?.description : undefined; %>
      <% const descText = typeof _desc === 'string' ? _desc : (_desc?.manage || ''); %>
      <% if (descText) { %>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4"><%= descText %></p>
      <% } %>

      <!-- Detail grid: main fields left, sidebar (Items/Payments) right when present -->
      <% const _hasSidebar = !!(schema['LineItems'] || schema['PaymentLines']); %>
      <div class="grid gap-4 <%= _hasSidebar ? 'md:grid-cols-3' : 'grid-cols-1' %>">

        <!-- Main fields -->
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl overflow-hidden <%= _hasSidebar ? 'md:col-span-2' : '' %>">
          <%
            const _readRendered = new Set();
            const _readKeys = Object.keys(schema).filter(k => k !== 'LineItems' && k !== 'PaymentLines');
            const _readNestedGroups = {};
            _readKeys.forEach(k => {
              const dot = k.indexOf('.');
              if (dot > -1) {
                const prefix = k.substring(0, dot);
                if (!_readNestedGroups[prefix]) _readNestedGroups[prefix] = [];
                _readNestedGroups[prefix].push(k);
              }
            });
            const _readGroupLabel = (name) => name.replace(/([a-z])([A-Z])/g, '$1 $2').replace(/\b\w/g, c => c.toUpperCase());
          %>
          <% _readKeys.forEach(key => {
            if (_readRendered.has(key)) return;
            const _dot = key.indexOf('.');
            const _prefix = _dot > -1 ? key.substring(0, _dot) : null;
            if (_prefix && _readNestedGroups[_prefix]) {
          %>
            <fieldset class="border-b border-gray-100 dark:border-gray-700/50 last:border-0">
              <legend class="w-full px-5 py-2.5 text-[11px] font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-gray-800/60 border-b border-gray-100 dark:border-gray-700/50"><%= _readGroupLabel(_prefix) %></legend>
              <% _readNestedGroups[_prefix].forEach(gKey => {
                if (!_readRendered.has(gKey) && schema[gKey]) { %>
                  <%- include('../partials/_formField', {
                    key: gKey,
                    field: schema[gKey],
                    formData: item,
                    referenceData,
                    readOnly: true,
                    showTips: false,
                    config,
                    groupPrefix: _prefix
                  }) %>
              <%  _readRendered.add(gKey);
                }
              }) %>
            </fieldset>
          <% } else { %>
            <%- include('../partials/_formField', {
              key,
              field: schema[key],
              formData: item,
              referenceData,
              readOnly: true,
              showTips: false,
              config,
              groupPrefix: null
            }) %>
          <% _readRendered.add(key);
            }
          }) %>
        </div>

        <!-- Sidebar: Line Items and Payments (only when present) -->
        <% if (_hasSidebar) { %>
        <div class="space-y-4">
          <% if (schema['LineItems']) { %>
            <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
              <div class="px-4 pt-4 pb-2 border-b border-gray-100 dark:border-gray-700">
                <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Items</h2>
              </div>
              <div class="px-3 pb-4 pt-3">
                <%- include('../partials/_formField', {
                  key: 'LineItems',
                  field: schema['LineItems'],
                  formData: item,
                  referenceData,
                  readOnly: true,
                  showTips: false,
                  config
                }) %>
              </div>
            </div>
          <% } %>

          <% if (schema['PaymentLines']) { %>
            <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
              <div class="px-4 pt-4 pb-2 border-b border-gray-100 dark:border-gray-700">
                <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400">Payments</h2>
              </div>
              <div class="px-3 pb-4 pt-3">
                <%- include('../partials/_formField', {
                  key: 'PaymentLines',
                  field: schema['PaymentLines'],
                  formData: item,
                  referenceData,
                  readOnly: true,
                  showTips: false,
                  config
                }) %>
              </div>
            </div>
          <% } %>
        </div>
        <% } %>
      </div>

    </div>
  </div><!-- /main card -->

  <!-- Documents -->
  <% if (config?.handlesDocuments) { %>
    <%- include('_documents-card', { item, basePath }) %>
  <% } %>

  <!-- CIS calendars (supplier + subcontractor) -->
  <% if (basePath === 'supplier' && (item.WithholdingTaxRate != null && Number(item.WithholdingTaxRate) >= 0) && Array.isArray(item.purchases)) { %>
    <%
      const monthsShort = ['A','M','J','J','A','S','O','N','D','J','F','M'];
      const cisMap = {};
      const toTaxYearMonth = (dateObj) => {
        if (!dateObj || isNaN(dateObj.getTime())) return null;
        const cm = dateObj.getMonth();
        const taxMonth = ((cm + 9) % 12) + 1;
        const calYear = dateObj.getFullYear();
        const taxYear = (cm >= 3) ? calYear : (calYear - 1);
        return { taxYear, taxMonth };
      };
      item.purchases.forEach(p => {
        let dates = [];
        if (Array.isArray(p.PaymentLines)) {
          p.PaymentLines.forEach(pl => {
            const raw = pl?.PayDate || pl?.Date;
            if (!raw) return;
            let d = new Date(raw);
            if (isNaN(d.getTime()) && typeof raw === 'string') d = new Date(raw.trim().replace(' ', 'T'));
            if (!isNaN(d.getTime())) dates.push(d);
          });
        }
        if (dates.length === 0) return;
        dates.forEach(d => {
          const t = toTaxYearMonth(d);
          if (!t) return;
          if (!cisMap[t.taxYear]) cisMap[t.taxYear] = {};
          cisMap[t.taxYear][t.taxMonth] = (cisMap[t.taxYear][t.taxMonth] || 0) + 1;
        });
      });
      const cisYears = Object.keys(cisMap).sort((a,b) => Number(b) - Number(a));
    %>

    <!-- CIS Calendar (Paid) -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400"><i class="bi bi-calendar3 mr-1.5 text-green-500"></i>CIS Calendar — Paid</h2>
      </div>
      <div class="p-6">
        <% if (cisYears.length > 0) { %>
          <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
              <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Year</th>
                  <% monthsShort.forEach(ms => { %>
                    <th class="px-2 py-3 text-center text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"><%= ms %></th>
                  <% }) %>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-900">
                <% cisYears.forEach(y => { %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                    <td class="px-4 py-3 font-medium text-gray-800 dark:text-gray-200"><%= y %></td>
                    <% for (let i = 1; i <= 12; i++) { %>
                      <% const count = cisMap[y][i] || 0; %>
                      <td class="px-2 py-3 text-center">
                        <% if (count > 0) { %>
                          <a href="/CIS/Dashboard/<%= y %>/<%= i %>"
                             class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-green-600 hover:bg-green-700 text-white text-[10px] font-medium transition"
                             title="<%= count %> purchase<%= count === 1 ? '' : 's' %>"><%= count %></a>
                        <% } else { %>
                          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500 text-[10px]" title="0 purchases">0</span>
                        <% } %>
                      </td>
                    <% } %>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-sm text-gray-500 dark:text-gray-400 italic">No CIS months found for this supplier.</p>
          <% if (Array.isArray(item.purchases) && item.purchases.length > 0) { %>
            <div class="mt-3 text-xs text-gray-600 dark:text-gray-300">
              <p class="mb-1 font-medium">Payment dates detected from purchases:</p>
              <ul class="list-disc ml-5 space-y-0.5">
                <% item.purchases.forEach(p => { %>
                  <% const lines = Array.isArray(p.PaymentLines) ? p.PaymentLines.map(pl => pl?.PayDate || pl?.Date).filter(Boolean) : []; %>
                  <li>#<%= p.Number %>: <%= lines.length ? lines.join(', ') : '—' %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>

    <!-- CIS Calendar (Issued) -->
    <%
      const cisIssuedMap = {};
      const toTaxYMFromIssued = (dateObj) => {
        if (!dateObj || isNaN(dateObj.getTime())) return null;
        const cm = dateObj.getMonth();
        const taxMonth = ((cm + 9) % 12) + 1;
        const calYear = dateObj.getFullYear();
        const taxYear = (cm >= 3) ? calYear : (calYear - 1);
        return { taxYear, taxMonth };
      };
      item.purchases.forEach(p => {
        let y = p.TaxYear;
        let m = p.TaxMonth;
        if ((!y || !m) && p.IssuedDate) {
          const d = new Date(p.IssuedDate);
          const t = toTaxYMFromIssued(d);
          if (t) { y = t.taxYear; m = t.taxMonth; }
        }
        if (!y || !m) return;
        if (!cisIssuedMap[y]) cisIssuedMap[y] = {};
        const mm = Number(m);
        cisIssuedMap[y][mm] = (cisIssuedMap[y][mm] || 0) + 1;
      });
      const cisIssuedYears = Object.keys(cisIssuedMap).sort((a,b) => Number(b) - Number(a));
    %>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400"><i class="bi bi-calendar3 mr-1.5 text-blue-500"></i>CIS Calendar — Issued</h2>
      </div>
      <div class="p-6">
        <% if (cisIssuedYears.length > 0) { %>
          <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
              <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Tax Year</th>
                  <% monthsShort.forEach(ms => { %>
                    <th class="px-2 py-3 text-center text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"><%= ms %></th>
                  <% }) %>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-900">
                <% cisIssuedYears.forEach(y => { %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                    <td class="px-4 py-3 font-medium text-gray-800 dark:text-gray-200"><%= y %></td>
                    <% for (let i = 1; i <= 12; i++) { %>
                      <% const count = cisIssuedMap[y][i] || 0; %>
                      <td class="px-2 py-3 text-center">
                        <% if (count > 0) { %>
                          <a href="/CIS/Dashboard/<%= y %>/<%= i %>"
                             class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-blue-600 hover:bg-blue-700 text-white text-[10px] font-medium transition"
                             title="<%= count %> purchase<%= count === 1 ? '' : 's' %>"><%= count %></a>
                        <% } else { %>
                          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500 text-[10px]" title="0 purchases">0</span>
                        <% } %>
                      </td>
                    <% } %>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-sm text-gray-500 dark:text-gray-400 italic">No issued months found for this supplier.</p>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- Supplier purchases table -->
  <% if (basePath === 'supplier' && Array.isArray(item.purchases)) { %>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400"><i class="bi bi-receipt mr-1.5 text-green-500"></i>Purchases</h2>
      </div>
      <div class="p-6">
        <% if (item.purchases.length > 0) { %>
          <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
              <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Number</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Reference</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Issued</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Status</th>
                  <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Net</th>
                  <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">VAT</th>
                  <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Gross</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-900">
                <% item.purchases.forEach(p => {
                  const netAmt   = Number(p.NetAmount);
                  const vatAmt   = Number(p.VATAmount);
                  const grossAmt = Number(p.GrossAmount);
                %>
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                    <td class="px-4 py-3 text-gray-800 dark:text-gray-200">
                      <a class="inline-flex items-center gap-1 text-green-700 dark:text-green-400 hover:underline" href="https://app.kashflow.com/#purchases/<%= p.Number %>" target="_blank" rel="noopener noreferrer">
                        <%= p.Number %> <i class="bi bi-box-arrow-up-right text-xs"></i>
                      </a>
                    </td>
                    <td class="px-4 py-3"><a class="text-green-700 dark:text-green-400 hover:underline" href="/purchase/read/<%= p.uuid %>"><%= p.SupplierReference %></a></td>
                    <td class="px-4 py-3 text-gray-700 dark:text-gray-300"><%= slimDateTime(p.IssuedDate) %></td>
                    <td class="px-4 py-3 text-gray-700 dark:text-gray-300"><%= p.Status %></td>
                    <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= Number.isFinite(netAmt)   ? formatCurrency(netAmt)   : '' %></td>
                    <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= Number.isFinite(vatAmt)   ? formatCurrency(vatAmt)   : '' %></td>
                    <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= Number.isFinite(grossAmt) ? formatCurrency(grossAmt) : '' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-sm text-gray-500 dark:text-gray-400 italic">No purchases found for this supplier.</p>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- Vehicle-related sections -->
  <% if (basePath === 'vehicle') { %>

    <!-- Quick actions -->
    <div class="flex flex-wrap gap-2 print:hidden">
      <a href="/vehicleFuelLog/create?vehicleId=<%= item._id %>" class="inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white rounded-lg px-4 py-2 text-sm font-medium transition shadow-sm">
        <i class="bi bi-fuel-pump"></i> Log Fuel
      </a>
      <a href="/vehicleMileageLog/create?vehicleId=<%= item._id %>" class="inline-flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg px-4 py-2 text-sm font-medium transition shadow-sm">
        <i class="bi bi-car-front"></i> Log Trip
      </a>
      <a href="/vehicleService/create?vehicleId=<%= item._id %>" class="inline-flex items-center gap-1.5 bg-violet-600 hover:bg-violet-700 text-white rounded-lg px-4 py-2 text-sm font-medium transition shadow-sm">
        <i class="bi bi-wrench-adjustable"></i> Log Service
      </a>
    </div>

    <!-- Service History -->
    <% if (Array.isArray(item.serviceHistory)) { %>
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400"><i class="bi bi-wrench-adjustable mr-1.5 text-violet-500"></i>Service History</h2>
        </div>
        <div class="p-6">
          <% if (item.serviceHistory.length > 0) { %>
            <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
                <thead class="bg-gray-50 dark:bg-gray-800">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Date</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Type</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Provider</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Status</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Mileage</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Cost</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Result</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-900">
                  <% item.serviceHistory.forEach(s => {
                    const sCost = s.totalCost ? Number(s.totalCost.toString ? s.totalCost.toString() : s.totalCost) : 0;
                    const statusCls = s.status === 'Completed' ? 'bg-green-100 text-green-800 border-green-200 dark:bg-green-900/40 dark:text-green-300 dark:border-green-700'
                                    : s.status === 'In Progress' ? 'bg-blue-100 text-blue-800 border-blue-200 dark:bg-blue-900/40 dark:text-blue-300 dark:border-blue-700'
                                    : s.status === 'Scheduled' ? 'bg-amber-100 text-amber-800 border-amber-200 dark:bg-amber-900/40 dark:text-amber-300 dark:border-amber-700'
                                    : 'bg-gray-100 text-gray-700 border-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-700';
                  %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                      <td class="px-4 py-3"><a class="text-green-700 dark:text-green-400 hover:underline" href="/vehicleService/read/<%= s.uuid %>"><%= slimDateTime(s.date) %></a></td>
                      <td class="px-4 py-3 text-gray-700 dark:text-gray-300"><%= s.serviceType %></td>
                      <td class="px-4 py-3 text-gray-700 dark:text-gray-300"><%= s.provider || '—' %></td>
                      <td class="px-4 py-3">
                        <span class="text-[11px] px-2 py-0.5 rounded-full border <%= statusCls %>"><%= s.status %></span>
                      </td>
                      <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= s.mileageAtService != null ? Number(s.mileageAtService).toLocaleString() : '—' %></td>
                      <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= Number.isFinite(sCost) && sCost > 0 ? '£' + sCost.toFixed(2) : '—' %></td>
                      <td class="px-4 py-3">
                        <% if (s.serviceType === 'MOT' && s.passed != null) { %>
                          <span class="text-[11px] px-2 py-0.5 rounded-full border font-semibold <%= s.passed ? 'bg-green-100 text-green-800 border-green-200 dark:bg-green-900/40 dark:text-green-300 dark:border-green-700' : 'bg-red-100 text-red-800 border-red-200 dark:bg-red-900/40 dark:text-red-300 dark:border-red-700' %>">
                            <%= s.passed ? 'PASS' : 'FAIL' %>
                          </span>
                        <% } else { %>—<% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-sm text-gray-500 dark:text-gray-400 italic">No service records yet.</p>
          <% } %>
        </div>
      </div>
    <% } %>

    <!-- Fuel Logs -->
    <% if (Array.isArray(item.fuelLogs)) { %>
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400"><i class="bi bi-fuel-pump mr-1.5 text-green-500"></i>Fuel Logs</h2>
        </div>
        <div class="p-6">
          <% if (item.fuelLogs.length > 0) { %>
            <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
                <thead class="bg-gray-50 dark:bg-gray-800">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Date</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Fuel</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Litres</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Cost</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Mileage</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Station</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Payment</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-900">
                  <% item.fuelLogs.forEach(f => {
                    const fLitres = f.litres ? Number(f.litres.toString ? f.litres.toString() : f.litres) : 0;
                    const fCost   = f.totalCost ? Number(f.totalCost.toString ? f.totalCost.toString() : f.totalCost) : 0;
                  %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                      <td class="px-4 py-3"><a class="text-green-700 dark:text-green-400 hover:underline" href="/vehicleFuelLog/read/<%= f.uuid %>"><%= slimDateTime(f.date) %></a></td>
                      <td class="px-4 py-3 text-gray-700 dark:text-gray-300"><%= f.fuelType %></td>
                      <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= Number.isFinite(fLitres) ? fLitres.toFixed(2) : '—' %></td>
                      <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= Number.isFinite(fCost) && fCost > 0 ? '£' + fCost.toFixed(2) : '—' %></td>
                      <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= f.mileageAtFillUp != null ? Number(f.mileageAtFillUp).toLocaleString() : '—' %></td>
                      <td class="px-4 py-3 text-gray-700 dark:text-gray-300"><%= f.station || '—' %></td>
                      <td class="px-4 py-3 text-gray-700 dark:text-gray-300"><%= f.paymentMethod || '—' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-sm text-gray-500 dark:text-gray-400 italic">No fuel logs yet.</p>
          <% } %>
        </div>
      </div>
    <% } %>

    <!-- Mileage / Trip Logs -->
    <% if (Array.isArray(item.mileageLogs)) { %>
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400"><i class="bi bi-speedometer2 mr-1.5 text-blue-500"></i>Mileage / Trip Logs</h2>
        </div>
        <div class="p-6">
          <% if (item.mileageLogs.length > 0) { %>
            <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
                <thead class="bg-gray-50 dark:bg-gray-800">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Date</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Purpose</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Start</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">End</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Distance</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Route</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Claim</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-900">
                  <% item.mileageLogs.forEach(m => {
                    const mClaim = m.claimAmount ? Number(m.claimAmount.toString ? m.claimAmount.toString() : m.claimAmount) : 0;
                  %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                      <td class="px-4 py-3"><a class="text-green-700 dark:text-green-400 hover:underline" href="/vehicleMileageLog/read/<%= m.uuid %>"><%= slimDateTime(m.date) %></a></td>
                      <td class="px-4 py-3 text-gray-700 dark:text-gray-300"><%= m.tripPurpose || '—' %></td>
                      <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= m.startMileage != null ? Number(m.startMileage).toLocaleString() : '—' %></td>
                      <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= m.endMileage != null ? Number(m.endMileage).toLocaleString() : '—' %></td>
                      <td class="px-4 py-3 text-right font-semibold text-gray-800 dark:text-gray-200"><%= m.distance != null ? Number(m.distance).toLocaleString() + ' mi' : '—' %></td>
                      <td class="px-4 py-3 text-gray-700 dark:text-gray-300 text-xs"><%= [m.startLocation, m.endLocation].filter(Boolean).join(' → ') || '—' %></td>
                      <td class="px-4 py-3 text-right text-gray-700 dark:text-gray-300"><%= m.claimable && Number.isFinite(mClaim) && mClaim > 0 ? '£' + mClaim.toFixed(2) : '—' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-sm text-gray-500 dark:text-gray-400 italic">No mileage logs yet.</p>
          <% } %>
        </div>
      </div>
    <% } %>

  <% } %>


</div>
