<%
  // Shared editor for a type's action buttons + global header/footer opt-in.
  // Locals: `t` — the emailType (or an empty object {} for the "add new" form).
  var _t = (typeof t !== 'undefined' && t) ? t : {};
  var _actions = Array.isArray(_t.actions) ? _t.actions : [];
  var _useHeader = _t.useGlobalHeader !== false;
  var _useFooter = _t.useGlobalFooter !== false;
%>
<div class="rounded-lg border border-gray-200 dark:border-gray-700 p-4 space-y-3">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Action buttons <span class="text-gray-400 font-normal">(optional, up to 5)</span></span>
    <label class="inline-flex items-center gap-4 text-xs text-gray-600 dark:text-gray-400">
      <span class="inline-flex items-center gap-1"><input type="checkbox" name="useGlobalHeader" <%= _useHeader ? 'checked' : '' %>> Global header</span>
      <span class="inline-flex items-center gap-1"><input type="checkbox" name="useGlobalFooter" <%= _useFooter ? 'checked' : '' %>> Global footer</span>
    </label>
  </div>

  <div class="js-actions space-y-2">
    <% _actions.forEach(function (a) { %>
    <div class="js-action-row flex gap-2 items-center">
      <input type="text" name="actionLabel[]" value="<%= a.label || '' %>" placeholder="Button label" maxlength="60" class="w-1/3 border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 text-sm">
      <input type="text" name="actionUrl[]" value="<%= a.url || '' %>" placeholder="https://… or /path" maxlength="500" class="flex-1 border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 text-sm">
      <button type="button" class="js-action-remove px-2.5 py-2 rounded-lg text-sm bg-gray-100 hover:bg-red-100 dark:bg-gray-700 dark:hover:bg-red-900/40 text-gray-500 hover:text-red-600" title="Remove"><i class="bi bi-x-lg"></i></button>
    </div>
    <% }); %>
  </div>

  <button type="button" class="js-action-add text-sm text-blue-600 dark:text-blue-400 hover:underline"><i class="bi bi-plus-lg"></i> Add button</button>
</div>
