<div class="container mx-auto my-5 px-4 max-w-3xl">
  <h1 class="mb-4 text-3xl font-semibold"><%= title %></h1>
  <form action="<%= formAction %>" method="POST" novalidate>
    <% for (const key in schema) {
      const field = schema[key];
      const isRequired = field.required;
      const label = field.label + (isRequired ? ' <span class="text-red-600">*</span>' : ' <small class="text-gray-500">(optional)</small>');
    %>
    <div class="mb-6">
      <label for="<%= key %>" class="block mb-1 font-medium text-gray-700"><%- label %></label>

      <% if (field.enum) { %>
        <select id="<%= key %>" name="<%= key %>" class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-hcs-green">
          <option value="">-- Select --</option>
          <% field.enum.forEach(option => { %>
            <option value="<%= option %>" <%= formData[key] === option ? 'selected' : '' %>><%= option %></option>
          <% }) %>
        </select>
      <% } else if (field.ref && referenceData?.[key]) { %>
        <select id="<%= key %>" name="<%= key %>" class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-hcs-green">
          <option value="">-- Select --</option>
          <% referenceData[key].forEach(refItem => { %>
            <option value="<%= refItem.uuid %>" <%= formData[key] === refItem.uuid ? 'selected' : '' %>>
              <%= refItem.name || refItem.title || refItem.uuid %>
            </option>
          <% }) %>
        </select>
      <% } else if (field.type === 'Boolean') { %>
        <select id="<%= key %>" name="<%= key %>" class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-hcs-green">
          <option value="true" <%= formData[key] === true ? 'selected' : '' %>>True</option>
          <option value="false" <%= formData[key] === false ? 'selected' : '' %>>False</option>
        </select>
      <% } else if (field.type === 'Date') { %>
        <input
          type="date"
          id="<%= key %>"
          name="<%= key %>"
          value="<%= formData[key] ? new Date(formData[key]).toISOString().split('T')[0] : '' %>"
          class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-hcs-green"
        >
      <% } else if (field.readOnly) { %>
        <input
          type="text"
          id="<%= key %>"
          name="<%= key %>"
          value="<%= formData[key] || '' %>"
          readonly
          class="w-full rounded border border-gray-300 bg-gray-100 px-3 py-2 cursor-not-allowed"
        >
      <% } else { %>
        <input
          type="text"
          id="<%= key %>"
          name="<%= key %>"
          value="<%= formData[key] || '' %>"
          class="w-full rounded border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-hcs-green"
        >
      <% } %>
    </div>
    <% } %>

    <p class="text-gray-500 text-sm mb-4"><span class="text-red-600">*</span> Required fields</p>

    <button type="submit" class="btn-hcs-green px-5 py-2 rounded text-white hover:bg-green-700 transition">
      Update
    </button>
  </form>
</div>
