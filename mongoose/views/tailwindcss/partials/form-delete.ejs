<div class="max-w-3xl mx-auto my-10 px-4">
  <h1 class="text-2xl font-bold mb-4"><%= title %></h1>
  <p class="mb-6 text-gray-700 dark:text-gray-300">Are you sure you want to delete this record?</p>

  <div class="overflow-x-auto mb-6">
    <table class="min-w-full border border-gray-300 dark:border-gray-700 text-sm">
      <tbody>
        <% for (const key in item) { %>
          <tr class="border-b border-gray-200 dark:border-gray-700">
            <th class="text-left px-4 py-2 bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200 w-1/3 font-medium">
              <%= key %>
            </th>
            <td class="px-4 py-2 text-gray-900 dark:text-gray-100">
              <%= item[key] %>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <form action="<%= formAction %>" method="POST" class="flex flex-wrap gap-4">
    <button type="submit"
            class="bg-red-700 text-white px-5 py-2 rounded hover:bg-red-800 transition">
      Delete
    </button>
    <a href="<%= cancelUrl %>"
       class="border border-gray-400 text-gray-700 dark:text-gray-300 px-5 py-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">
      Cancel
    </a>
  </form>
</div>
