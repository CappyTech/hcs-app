<div class="container mx-auto my-5 px-4">
  <a href="/<%= basePath %>s" class="text-green-600 dark:text-green-400 hover:underline"><i class="bi bi-arrow-left"></i> Go Back</a>

  <!-- Header: Title (match form-read layout) -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100"><%= title %></h1>
  </div>

  <!-- Read-only fields (same grid as form-read) -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <%
      const _delRendered = new Set();
      const _delKeys = Object.keys(schema);
      const _delNestedGroups = {};
      _delKeys.forEach(k => {
        const dot = k.indexOf('.');
        if (dot > -1) {
          const prefix = k.substring(0, dot);
          if (!_delNestedGroups[prefix]) _delNestedGroups[prefix] = [];
          _delNestedGroups[prefix].push(k);
        }
      });
      const _delGroupLabel = (name) => name.replace(/([a-z])([A-Z])/g, '$1 $2').replace(/\b\w/g, c => c.toUpperCase());
    %>
    <% _delKeys.forEach(key => {
      if (_delRendered.has(key)) return;
      const _dot = key.indexOf('.');
      const _prefix = _dot > -1 ? key.substring(0, _dot) : null;
      if (_prefix && _delNestedGroups[_prefix]) {
    %>
      <fieldset class="col-span-full mb-4 border border-gray-300 dark:border-gray-600 rounded p-3">
        <legend class="px-2 text-sm font-semibold text-gray-700 dark:text-gray-200"><%= _delGroupLabel(_prefix) %></legend>
        <% _delNestedGroups[_prefix].forEach(gKey => {
          if (!_delRendered.has(gKey) && schema[gKey]) { %>
            <%- include('../partials/_formField', { key: gKey, field: schema[gKey], formData: item, referenceData, readOnly: true, showTips: false, config, groupPrefix: _prefix }) %>
        <%  _delRendered.add(gKey);
          }
        }) %>
      </fieldset>
    <% } else { %>
      <%- include('../partials/_formField', { key, field: schema[key], formData: item, referenceData, readOnly: true, showTips: false, config, groupPrefix: null }) %>
    <% _delRendered.add(key);
      }
    }) %>
  </div>

  <!-- Confirmation panel -->
  <div class="mt-8 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded p-4">
    <p class="text-red-700 dark:text-red-300 mb-4">This action cannot be undone. Are you sure you want to delete this record?</p>
    <form action="<%= formAction %>" method="POST" class="flex gap-3">
      <%- include('./csrfHidden.ejs') %>
      <button type="submit" class="bg-red-700 text-white px-5 py-2 rounded hover:bg-red-800 transition">Delete</button>
      <a href="<%= cancelUrl %>" class="border border-gray-400 dark:border-gray-600 text-gray-700 dark:text-gray-300 px-5 py-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">Cancel</a>
    </form>
  </div>
</div>