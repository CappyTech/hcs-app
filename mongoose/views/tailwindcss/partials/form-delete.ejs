<div class="container mx-auto my-5 px-4">
  <div class="flex items-center mb-4">
    <h1 class="mb-0 text-2xl font-semibold"><%= title %></h1>

  <form action="<%= formAction %>" method="POST" class="flex flex-wrap gap-4">
    <%- include('./csrfHidden.ejs') %>

    <% for (const key in schema) { %>
      <%- include('../partials/_formField', {
        key,
        field: schema[key],
        formData: item,
        referenceData,
        readOnly: true,
        showTips: false
      }) %>
    <% } %>

    <button type="submit" class="bg-red-700 text-white px-5 py-2 rounded hover:bg-red-800 transition">
      Delete
    </button>
    <a href="<%= cancelUrl %>"
       class="border border-gray-400 text-gray-700 dark:text-gray-300 px-5 py-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">
      Cancel
    </a>
  </form>
  </div>
</div>
