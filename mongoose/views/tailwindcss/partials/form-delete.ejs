<div class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">
  <a href="/<%= basePath %>s" class="inline-flex items-center gap-1 text-green-600 dark:text-green-400 hover:underline text-sm font-medium">
    <i class="bi bi-arrow-left"></i> Go Back
  </a>

  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <!-- Red accent bar for delete -->
    <div class="h-1.5 bg-gradient-to-r from-red-500 to-red-400"></div>

    <div class="p-6 sm:p-8">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6"><%= title %></h1>

      <!-- Read-only fields -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <%
      const _delRendered = new Set();
      const _delKeys = Object.keys(schema);
      const _delNestedGroups = {};
      _delKeys.forEach(k => {
        const dot = k.indexOf('.');
        if (dot > -1) {
          const prefix = k.substring(0, dot);
          if (!_delNestedGroups[prefix]) _delNestedGroups[prefix] = [];
          _delNestedGroups[prefix].push(k);
        }
      });
      const _delGroupLabel = (name) => name.replace(/([a-z])([A-Z])/g, '$1 $2').replace(/\b\w/g, c => c.toUpperCase());
    %>
    <% _delKeys.forEach(key => {
      if (_delRendered.has(key)) return;
      const _dot = key.indexOf('.');
      const _prefix = _dot > -1 ? key.substring(0, _dot) : null;
      if (_prefix && _delNestedGroups[_prefix]) {
    %>
      <fieldset class="col-span-full mb-4 border border-gray-200 dark:border-gray-700 rounded-xl p-4">
        <legend class="px-2 text-sm font-semibold text-gray-700 dark:text-gray-200"><%= _delGroupLabel(_prefix) %></legend>
        <% _delNestedGroups[_prefix].forEach(gKey => {
          if (!_delRendered.has(gKey) && schema[gKey]) { %>
            <%- include('../partials/_formField', { key: gKey, field: schema[gKey], formData: item, referenceData, readOnly: true, showTips: false, config, groupPrefix: _prefix }) %>
        <%  _delRendered.add(gKey);
          }
        }) %>
      </fieldset>
    <% } else { %>
      <%- include('../partials/_formField', { key, field: schema[key], formData: item, referenceData, readOnly: true, showTips: false, config, groupPrefix: null }) %>
    <% _delRendered.add(key);
      }
    }) %>
      </div>

      <!-- Confirmation panel -->
      <div class="mt-8 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-5">
        <p class="text-red-700 dark:text-red-300 mb-4 font-medium">This action cannot be undone. Are you sure you want to delete this record?</p>
        <form action="<%= formAction %>" method="POST" class="flex gap-3">
          <%- include('./csrfHidden.ejs') %>
          <button type="submit" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-lg text-sm font-medium bg-red-600 text-white hover:bg-red-700 transition shadow-sm">
            <i class="bi bi-trash"></i> Delete
          </button>
          <a href="<%= cancelUrl %>" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-lg text-sm font-medium bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 hover:bg-gray-300 dark:hover:bg-gray-600 transition shadow-sm">
            Cancel
          </a>
        </form>
      </div>
    </div>
  </div>
</div>