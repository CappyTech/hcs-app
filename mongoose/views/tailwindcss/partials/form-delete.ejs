<div class="container mx-auto my-5 px-4">
  <a href="/<%= basePath %>s" class="text-green-600 dark:text-green-400 hover:underline"><i class="bi bi-arrow-left"></i> Go Back</a>

  <!-- Header: Title (match form-read layout) -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100"><%= title %></h1>
  </div>

  <!-- Read-only fields (same grid as form-read) -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <% for (const key in schema) { %>
      <%- include('../partials/_formField', { key, field: schema[key], formData: item, referenceData, readOnly: true, showTips: false, config }) %>
    <% } %>
  </div>

  <!-- Confirmation panel -->
  <div class="mt-8 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded p-4">
    <p class="text-red-700 dark:text-red-300 mb-4">This action cannot be undone. Are you sure you want to delete this record?</p>
    <form action="<%= formAction %>" method="POST" class="flex gap-3">
      <%- include('./csrfHidden.ejs') %>
      <button type="submit" class="bg-red-700 text-white px-5 py-2 rounded hover:bg-red-800 transition">Delete</button>
      <a href="<%= cancelUrl %>" class="border border-gray-400 dark:border-gray-600 text-gray-700 dark:text-gray-300 px-5 py-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">Cancel</a>
    </form>
  </div>
</div>