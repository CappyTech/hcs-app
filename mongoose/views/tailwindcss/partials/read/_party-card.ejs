<%
  // Linked-party card (customer / supplier) for detail views.
  // Locals: heading, headerIcon, linkIcon (bi-* classes), href, name,
  //         code (optional), cisRate (optional — renders a CIS % badge).
  const _code = typeof code !== 'undefined' ? code : null;
  const _cis = typeof cisRate !== 'undefined' ? cisRate : null;
%>
<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-sm overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700">
    <h2 class="font-semibold text-sm uppercase tracking-wide text-gray-500 dark:text-gray-400"><i class="bi <%= headerIcon %> mr-1.5 text-green-500"></i><%= heading %></h2>
  </div>
  <div class="px-6 py-4 flex items-center gap-4 flex-wrap">
    <a href="<%= href %>" class="inline-flex items-center gap-2 text-green-700 dark:text-green-400 hover:underline font-medium">
      <i class="bi <%= linkIcon %>"></i><%= name %>
    </a>
    <% if (_code) { %><span class="text-xs text-gray-400 font-mono"><%= _code %></span><% } %>
    <% if (_cis != null && Number(_cis) >= 0) { %>
      <span class="text-[11px] px-2 py-0.5 rounded-full bg-green-100 text-green-800 border border-green-200 dark:bg-green-900/40 dark:text-green-300 dark:border-green-700">CIS <%= _cis %>%</span>
    <% } %>
  </div>
</div>
