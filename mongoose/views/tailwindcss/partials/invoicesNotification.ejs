<% if (session.user && session.user.role==='admin' ) {%>
    <% if (invoicesWithoutSubmissionDate && invoicesWithoutSubmissionDate.length> 0) { %>
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 rounded-xl p-4 m-4 print:hidden" role="alert">
            <h4 class="text-lg font-semibold text-amber-800 dark:text-amber-300 mb-1">Pending Invoices</h4>
            <p class="text-sm text-amber-700 dark:text-amber-400 mb-2">There are invoices without a submission date:</p>
            <ul class="flex flex-wrap gap-2">
                <% invoicesWithoutSubmissionDate.forEach(invoice=> { %>
                    <li>
                        <a href="/invoice/read/<%= invoice.id %>" class="text-green-600 dark:text-green-400 hover:underline text-sm font-medium">
                            <%= invoice.kashflowNumber %>
                        </a>
                    </li>
                    <% }); %>
            </ul>
        </div>
    <% } else { %>
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 rounded-xl p-4 m-4 print:hidden" role="alert">
            <h4 class="text-lg font-semibold text-green-800 dark:text-green-300 mb-1">No Pending Invoices</h4>
            <p class="text-sm text-green-700 dark:text-green-400">There are no invoices without a submission date.</p>
        </div>
    <%} %>
<%} %>