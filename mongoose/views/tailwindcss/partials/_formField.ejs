<%
  // Resolve dot-path value from nested formData (e.g., 'contract.termsType' → formData.contract.termsType)
  const _getNestedValue = (obj, dotPath) => {
    if (!obj || !dotPath) return undefined;
    if (obj[dotPath] !== undefined) return obj[dotPath]; // direct key match first
    return dotPath.split('.').reduce((o, k) => (o != null ? o[k] : undefined), obj);
  };
  // Convert dot path to bracket notation for form field name (e.g., 'contract.termsType' → 'contract[termsType]')
  const _toBracketName = (dotPath) => {
    const parts = dotPath.split('.');
    if (parts.length === 1) return dotPath;
    return parts[0] + parts.slice(1).map(p => `[${p}]`).join('');
  };

  const selectedValue = _getNestedValue(formData, key);
  const fieldName = _toBracketName(key);
  const isUuid = field.type === 'String';
  const readOnlyField = typeof readOnly === 'boolean' ? readOnly : false;
  const showFieldTips = typeof showTips === 'boolean' ? showTips : true;

  // Strip group prefix from label when inside a grouped fieldset (e.g., 'Contract.Terms Type' → 'Terms Type')
  const _groupPrefix = (typeof groupPrefix !== 'undefined') ? groupPrefix : null;
  let baseLabel = field.label;
  if (_groupPrefix && baseLabel.includes('.')) {
    baseLabel = baseLabel.substring(baseLabel.indexOf('.') + 1).trim();
  }

  let labelSuffix = '';
  if (!readOnlyField) {
    labelSuffix = field.required
      ? '<span class="text-red-600">*</span>'
      : '<small class="text-gray-500">(optional)</small>';
    if (field.default != null && typeof field.default !== 'function' && field.default !== '') {
      labelSuffix += ` <small class="text-gray-500">(default: ${field.default})</small>`;
    }
  }
  const label = baseLabel + (labelSuffix ? ' ' + labelSuffix : '');
%>
<% if (readOnlyField) { %>
  <% /* 1) Special case: Assignments array pretty table */ %>
  <% if (Array.isArray(selectedValue) && selectedValue.length > 0 && (selectedValue[0]?.contractId || selectedValue[0]?.weekStart || selectedValue[0]?.title)) { %>
    <% const assignmentsTableRaw = selectedValue.map(row => ({
      Contract: (row.contractId && (row.contractId.Name || row.contractId.Reference || row.contractId.Number || row.contractId)) || null,
      Title: row.title ?? null,
      Description: row.description ?? null,
      'Week Start': row.weekStart ? slimDateTime(row.weekStart, ['displayFormat']) : null,
      'Assigned Employees': Array.isArray(row.assignedEmployees) ? (row.assignedEmployees.length === 0 ? null : (typeof row.assignedEmployees[0] === 'object' ? row.assignedEmployees.map(e => e.name || e.username || e.uuid || String(e)).join(', ') : String(row.assignedEmployees.length + ' assignedemployees'))) : null,
      'Assigned Subcontractors': Array.isArray(row.assignedSubcontractors) ? (row.assignedSubcontractors.length === 0 ? null : (typeof row.assignedSubcontractors[0] === 'object' ? row.assignedSubcontractors.map(s => s.Name || s.name || s.uuid || String(s)).join(', ') : String(row.assignedSubcontractors.length + ' assignedsubcontractors'))) : null,
      Status: row.status ?? null,
      'Estimated Hours': row.estimatedHours != null ? String(row.estimatedHours) : null
    }));
    const isNonEmpty = (v) => {
      if (v === null || v === undefined) return false;
      if (v instanceof Date) return !isNaN(v.getTime());
      const t = typeof v;
      if (t === 'string') return v.trim().length > 0;
      if (t === 'number') return !Number.isNaN(v) && v !== 0;
      if (t === 'boolean') return true;
      if (Array.isArray(v)) return v.length > 0;
      if (t === 'object') return Object.keys(v).length > 0;
      return false;
    };
    const visibleRows = assignmentsTableRaw.filter(row => Object.values(row).some(isNonEmpty));
    const allCols = Object.keys(assignmentsTableRaw[0] || {});
    const visibleCols = allCols.filter(col => visibleRows.some(row => isNonEmpty(row[col])));
    const assignmentsTable = visibleRows;
    const assignmentsFirstRow = assignmentsTable[0] || {}; %>

    <div class="mt-4">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1"><%= key %></label>
      <div class="overflow-x-auto">
      <table class="min-w-full text-xs text-left text-gray-700 dark:text-gray-100 border border-gray-200 dark:border-gray-700 table-auto">
        <thead class="bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
          <tr>
            <% visibleCols.forEach(col => { %>
              <th class="px-3 py-2 border border-gray-200 dark:border-gray-700 text-xs font-medium"><%= col %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900">
          <% assignmentsTable.forEach(row => { %>
            <tr class="border-t border-gray-200 dark:border-gray-700">
              <% visibleCols.forEach(col => { const val = row[col]; %>
                <td class="px-3 py-2 border border-gray-200 dark:border-gray-700 align-top whitespace-normal break-words">
                  <%= (val === null || val === undefined || (typeof val === 'string' && val.trim() === '')) ? '' : val %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
    </div>

  <% /* 2) Payments/Lines tables (supports SOAP + REST) */ %>
  <% } else if ((key === 'Payments' || key === 'PaymentLines' || key === 'Lines' || key === 'LineItems') && Array.isArray(selectedValue)) { %>
    <% 
      const tableData = selectedValue.map(row => {
        const filtered = {};
        if (key === 'Payments') {
          ['PayDate', 'PayNote', 'PayAmount'].forEach(k => filtered[k] = row[k]);
        } else if (key === 'PaymentLines') {
          // REST payments: include full object fields commonly present
          const cols = ['Id','Date','AccountId','Method','Amount'];
          cols.forEach(k => filtered[k] = row[k]);
        } else if (key === 'Lines') {
          ['Description', 'Rate', 'ChargeTypeName', 'VatAmount', 'ProjID'].forEach(k => filtered[k] = row[k]);
        } else if (key === 'LineItems') {
          // REST line items
          const cols = ['Description', 'Quantity', 'Rate', 'VATAmount'];
          cols.forEach(k => filtered[k] = row[k]);
          // Prefer ProjectNumber then NominalCode for extra context
          filtered['ProjectNumber'] = row['ProjectNumber'] ?? undefined;
          filtered['NominalCode'] = row['NominalCode'] ?? undefined;
        }
        return filtered;
      });
      const firstRow = tableData[0] || {};
      // Only show columns that have at least one non-empty value across rows
      const allCols = Object.keys(firstRow);
      const isNonEmpty = (v) => {
        if (v === null || v === undefined) return false;
        if (v instanceof Date) return !isNaN(v.getTime());
        const t = typeof v;
        if (t === 'string') return v.trim().length > 0;
        if (t === 'number') return !Number.isNaN(v) && v !== 0;
        if (t === 'boolean') return true;
        if (Array.isArray(v)) return v.length > 0;
        if (t === 'object') return Object.keys(v).length > 0;
        return false;
      };
      const visibleCols = allCols.filter(col => tableData.some(row => isNonEmpty(row[col])));
    %>

    <div class="mt-4 <%= (key === 'PaymentLines' || key === 'LineItems') ? 'rounded-lg shadow bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700' : '' %>">
      <div class="flex items-center justify-between">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1 px-3 py-2"><%= key %></label>
      </div>
      <div class="overflow-x-auto <%= (key === 'PaymentLines' || key === 'LineItems') ? 'px-3 pb-3' : '' %>">
        <table class="min-w-full text-xs text-left text-gray-700 dark:text-gray-100 <%= (key === 'PaymentLines' || key === 'LineItems') ? '' : 'border border-gray-200 dark:border-gray-700' %> table-auto">
        <thead class="bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
          <tr>
            <% visibleCols.forEach(col => { %>
              <th class="px-3 py-2 border border-gray-200 dark:border-gray-700 text-xs font-medium"><%= col %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900">
          <% tableData.forEach(row => { %>
            <tr class="border-t border-gray-200 dark:border-gray-700">
              <% visibleCols.forEach(col => { const val = row[col]; %>
                <td class="px-3 py-2 border border-gray-200 dark:border-gray-700 align-top whitespace-normal break-words">
                  <% if (val && col.toLowerCase().includes('date') && typeof slimDateTime === 'function') { %>
                    <%= slimDateTime(val, ['displayFormat']) %>
                  <% } else { %>
                    <%= (val === null || val === undefined || (typeof val === 'string' && val.trim() === '')) ? '' : val %>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
        </table>
      </div>
    </div>

  <% /* 2b) Generic array-of-objects pretty table (e.g., Contacts) */ %>
  <%
    // Guard: ref arrays (assignedEmployees, assignedSubcontractors, …) hold ObjectIds,
    // which are typeof 'object'. They must be resolved to names/links by branch 3 via
    // referenceData — not dumped here as a raw table (that prints the ObjectId's internal
    // {"type":"Buffer","data":[…]}). Also skip BSON ObjectIds, Buffers and Dates.
    const _firstRow = Array.isArray(selectedValue) ? selectedValue[0] : null;
    const _isPlainObjectRow = _firstRow != null
      && typeof _firstRow === 'object'
      && !Array.isArray(_firstRow)
      && !_firstRow._bsontype
      && !(_firstRow instanceof Date)
      && !(typeof Buffer !== 'undefined' && Buffer.isBuffer(_firstRow))
      && !(typeof Buffer !== 'undefined' && Buffer.isBuffer(_firstRow.buffer));
  %>
  <% } else if (!field.ref && Array.isArray(selectedValue) && selectedValue.length > 0 && _isPlainObjectRow) { %>
    <% 
      const rows = selectedValue.map(r => r || {});
      const allCols = Array.from(new Set(rows.flatMap(r => Object.keys(r))));
      const isNonEmpty = (v) => {
        if (v === null || v === undefined) return false;
        if (v instanceof Date) return !isNaN(v.getTime());
        const t = typeof v;
        if (t === 'string') return v.trim().length > 0;
        if (t === 'number') return !Number.isNaN(v);
        if (t === 'boolean') return true;
        if (Array.isArray(v)) return v.length > 0;
        if (t === 'object') return Object.keys(v).length > 0;
        return false;
      };
      const visibleCols = allCols.filter(col => rows.some(r => isNonEmpty(r[col])));
    %>
    <div class="mt-4">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1"><%= field.label || key %></label>
      <div class="overflow-x-auto">
        <table class="min-w-full text-xs text-left text-gray-700 dark:text-gray-100 border border-gray-200 dark:border-gray-700 table-auto">
          <thead class="bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
            <tr>
              <% visibleCols.forEach(col => { %>
                <th class="px-3 py-2 border border-gray-200 dark:border-gray-700 text-xs font-medium"><%= col %></th>
              <% }) %>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-900">
            <% rows.forEach(r => { %>
              <tr class="border-t border-gray-200 dark:border-gray-700">
                <% visibleCols.forEach(col => { const v = r[col]; %>
                  <td class="px-3 py-2 border border-gray-200 dark:border-gray-700 align-top whitespace-normal break-words">
                    <% if (v && typeof v === 'object' && !(v instanceof Date)) { %>
                      <%= JSON.stringify(v) %>
                    <% } else if (v && String(col).toLowerCase().includes('date') && typeof slimDateTime === 'function') { %>
                      <%= slimDateTime(v, ['displayFormat']) %>
                    <% } else { %>
                      <%= (v === null || v === undefined || (typeof v === 'string' && v.trim() === '')) ? '' : v %>
                    <% } %>
                  </td>
                <% }) %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  <% /* 3) Default simple read-only field */ %>
  <% } else { %>
    <% 
    const value = formData?.[key];
    let displayValue = '—';
    const isNonEmptySimple = (v) => {
      if (v === null || v === undefined) return false;
      if (v instanceof Date) return !isNaN(v.getTime());
      const t = typeof v;
      if (t === 'string') return v.trim().length > 0;
      if (t === 'number') return !Number.isNaN(v) && v !== 0;
      if (t === 'boolean') return true;
      if (Array.isArray(v)) return v.length > 0;
      if (t === 'object') return Object.keys(v).length > 0;
      return false;
    };

    if (field.type === 'Date' && value) {
      displayValue = slimDateTime(value, ['displayFormat']) + ' (' + slimDateTime(value) + ')';
    } else if (field.type === 'Boolean') {
      displayValue = value === true || value === 'true' ? 'Yes' : value === false || value === 'false' ? 'No' : '—';
    } else if (Array.isArray(value)) {
      displayValue = value.length ? value.join(', ') : '—';
    } else if (typeof value === 'string' || typeof value === 'number') {
      displayValue = value || '—';
    } else if (value && typeof value === 'object' && typeof value.toString === 'function' && !isNaN(Number(value.toString())) && !(value instanceof Date)) {
      // Decimal128 (and similar BSON numeric types) — convert to number string
      displayValue = String(Number(value.toString()));
    } else if (value && typeof value === 'object') {
      displayValue = null; // rendered as key-value pairs in the template below
    }

    // Resolve ref fields to human-readable names and links
    const _cfg = typeof config !== 'undefined' ? config : {};
    let refLink = null;
    let resolvedArrayItems = null;

    if (field.ref && typeof referenceData !== 'undefined' && Array.isArray(referenceData[key])) {
      const findMatch = (v) => referenceData[key].find(r =>
        String(r._id) === String(v) ||
        String(r.uuid) === String(v) ||
        (r.Id != null && String(r.Id) === String(v))
      );
      const getLabel = (matched) => {
        if (_cfg.referenceLabelFormat && _cfg.referenceLabelFormat[key]) {
          try { return _cfg.referenceLabelFormat[key](matched); } catch(e) {}
        }
        return matched.name || matched.Name || matched.Number || matched.username || matched.title || matched.uuid || '';
      };
      const getLink = (matched) => {
        if (_cfg.fieldTransforms && _cfg.fieldTransforms[key] && _cfg.fieldTransforms[key].linkTo) {
          try { return _cfg.fieldTransforms[key].linkTo(matched); } catch(e) {}
        }
        return null;
      };

      if (Array.isArray(value) && value.length > 0) {
        resolvedArrayItems = value.map(v => {
          const matched = findMatch(v);
          if (!matched) return { name: String(v), link: null };
          return { name: getLabel(matched), link: getLink(matched) };
        });
        displayValue = resolvedArrayItems.map(i => i.name).join(', ');
      } else if (value) {
        const matched = findMatch(value);
        if (matched) {
          displayValue = getLabel(matched);
          refLink = getLink(matched);
        }
      }
    }

    // If value is empty, do not render this field at all
    const shouldRender = isNonEmptySimple(value) || (field.type === 'Boolean' && (value === true || value === 'true' || value === false || value === 'false')) || (field.type === 'Date' && !!value);
  %>
  <% if (shouldRender) { %>
    <div class="mb-2">
      <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 rounded-xl">
        <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">
          <%- label %>
        </div>
        <div class="text-sm text-gray-900 dark:text-gray-100 break-words leading-relaxed">
          <% if (resolvedArrayItems) { %>
            <% resolvedArrayItems.forEach((ri, i) => { %>
              <% if (ri.link) { %><a href="<%= ri.link %>" class="text-green-600 dark:text-green-400 hover:underline"><%= ri.name %></a><% } else { %><%= ri.name %><% } %><%= i < resolvedArrayItems.length - 1 ? ', ' : '' %>
            <% }) %>
          <% } else if (refLink) { %>
            <a href="<%= refLink %>" class="text-green-600 dark:text-green-400 hover:underline"><%= displayValue %></a>
          <% } else if (value && typeof value === 'object' && !Array.isArray(value) && !(value instanceof Date)) { %>
            <dl class="space-y-0.5">
              <% Object.entries(value).forEach(([k, v]) => { if (v === null || v === undefined || v === '') return; %>
                <div class="flex gap-1.5 text-xs"><dt class="text-gray-500 dark:text-gray-400 shrink-0"><%= k %>:</dt><dd class="text-gray-900 dark:text-gray-100"><%= v %></dd></div>
              <% }) %>
            </dl>
          <% } else { %>
            <%= displayValue %>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>
  <% } %>

<% } else { %>
  <!-- Interactive field rendering -->
  <div class="mb-6">
    <label for="<%= key %>" class="block mb-1 font-medium text-gray-700 dark:text-gray-200">
      <%- label %>
    </label>

    <% if (field.enum) { %>
      <!-- Enum -->
      <select id="<%= key %>" name="<%= fieldName %>" class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500">
        <option value="">-- Select --</option>
        <% field.enum.forEach(option => { %>
          <option value="<%= option %>" <%= selectedValue == option ? 'selected' : '' %>><%= option %></option>
        <% }) %>
      </select>

    <% } else if (field.ref && referenceData?.[key]) { %>
      <!-- Reference -->
      <% const isArray = Array.isArray(selectedValue); %>
      <%
        const _isSubcontractorRef = key.toLowerCase().includes('subcontractor') && field.ref === 'supplier';
        const _showCreateBtn = _isSubcontractorRef || !field.refDenyCreate;
        const _createLabel = _isSubcontractorRef
          ? 'Add a subcontractor'
          : `Create new ${(field.label || key).replace(/ Id$/i, '')}`;
        const _createHref = _isSubcontractorRef
          ? '/subcontractor/assign'
          : `/${field.ref}/create`;
      %>
      <% if (field.isArray) { %>
        <!-- Searchable checkbox list for multi-ref fields -->
        <div class="flex flex-col gap-1.5">
          <div class="flex gap-2 items-start">
            <div class="flex-1 flex flex-col gap-1.5">
              <div class="relative">
                <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500 pointer-events-none text-sm"></i>
                <input
                  type="text"
                  id="search_<%= key %>"
                  placeholder="Search…"
                  autocomplete="off"
                  data-reflist-target="reflist_<%= key %>"
                  class="w-full pl-9 pr-3 py-2 text-sm rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500"
                >
              </div>
              <div id="reflist_<%= key %>" class="max-h-56 overflow-y-auto rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 divide-y divide-gray-100 dark:divide-gray-700/50">
                <% if (referenceData[key].length === 0) { %>
                  <p class="px-3 py-3 text-sm text-gray-400 dark:text-gray-500 italic">No options available.</p>
                <% } %>
                <% referenceData[key].forEach(function(refItem) {
                    const _val = isUuid ? refItem.uuid : refItem._id;
                    let _lbl;
                    if (config?.referenceLabelFormat?.[key]) {
                      try { _lbl = config.referenceLabelFormat[key](refItem); } catch(e) { _lbl = '[Invalid Format]'; }
                    } else {
                      _lbl = refItem.name || refItem.Name || refItem.Number || refItem.username || refItem.title || String(_val);
                    }
                    const _checked = (selectedValue || []).map(String).includes(String(_val));
                %>
                  <label data-search="<%= _lbl.toLowerCase() %>" class="flex items-center gap-3 px-3 py-2.5 cursor-pointer hover:bg-white dark:hover:bg-gray-700 transition select-none">
                    <input
                      type="checkbox"
                      name="<%= fieldName %>[]"
                      value="<%= _val %>"
                      <%= _checked ? 'checked' : '' %>
                      class="w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-green-600 focus:ring-green-500 focus:ring-offset-0 shrink-0"
                    >
                    <span class="text-sm text-gray-900 dark:text-gray-100 leading-snug"><%= _lbl %></span>
                  </label>
                <% }); %>
              </div>
            </div>
            <% if (_showCreateBtn) { %>
            <a href="<%= _createHref %>" target="_blank" title="<%= _createLabel %>"
              class="inline-flex items-center justify-center shrink-0 w-10 h-10 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-green-600 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/30 hover:border-green-400 transition">
              <i class="bi bi-plus-lg"></i>
            </a>
            <% } %>
          </div>
          <% if (_isSubcontractorRef) { %>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
            Are you missing a subcontractor in this list?
            <a href="/help#cis-subcontractor-setup" target="_blank" class="text-green-600 dark:text-green-400 hover:underline font-medium">Follow these steps.</a>
          </p>
          <% } %>
        </div>
      <% } else { %>
        <!-- Single-ref dropdown -->
        <div class="flex gap-2 items-start">
          <select
            id="<%= key %>"
            name="<%= fieldName %>"
            class="flex-1 rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500"
          >
            <option value="">-- Select --</option>
            <% referenceData[key].forEach(function(refItem) {
                const _val = isUuid ? refItem.uuid : refItem._id;
                let _lbl;
                if (config?.referenceLabelFormat?.[key]) {
                  try { _lbl = config.referenceLabelFormat[key](refItem); } catch(e) { _lbl = '[Invalid Format]'; }
                } else {
                  _lbl = refItem.name || refItem.Name || refItem.Number || refItem.username || refItem.title || String(_val);
                }
                const _sel = String(selectedValue) === String(_val);
            %>
              <option value="<%= _val %>" <%= _sel ? 'selected' : '' %>><%= _lbl %></option>
            <% }); %>
          </select>
          <% if (_showCreateBtn) { %>
          <a href="<%= _createHref %>" target="_blank" title="<%= _createLabel %>"
            class="inline-flex items-center justify-center shrink-0 w-10 h-10 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-green-600 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/30 hover:border-green-400 transition">
            <i class="bi bi-plus-lg"></i>
          </a>
          <% } %>
        </div>
      <% } %>

    <% } else if (field.type === 'Boolean') { %>
      <!-- Boolean -->
      <select id="<%= key %>" name="<%= fieldName %>" class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500">
        <option value="">-- Select --</option>
        <option value="true" <%= selectedValue === true || selectedValue === 'true' ? 'selected' : '' %>>True</option>
        <option value="false" <%= selectedValue === false || selectedValue === 'false' ? 'selected' : '' %>>False</option>
      </select>

    <% } else if (field.type === 'Date') { %>
      <!-- Date -->
      <input
        type="date"
        id="<%= key %>"
        name="<%= fieldName %>"
        value="<%= selectedValue ? new Date(selectedValue).toISOString().split('T')[0] : '' %>"
        class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500"
      >

    <% } else if (field.type === 'Decimal128' || field.type === 'Number') { %>
      <!-- Numeric -->
      <%
        const keyLower = key.toLowerCase();
        const isHours = keyLower.includes('hours') || keyLower.includes('minutes');
        const isCurrency = keyLower.includes('rate') || keyLower.includes('amount') || keyLower.includes('cost') || keyLower.includes('price') || keyLower.includes('pay') || keyLower.includes('salary') || keyLower.includes('wage');
        const numStep = isHours ? '0.25' : isCurrency ? '0.01' : '1';
        const numMax  = isHours ? '24' : '';
        const numVal  = selectedValue != null ? (typeof selectedValue === 'object' && selectedValue.toString ? selectedValue.toString() : selectedValue) : '';
      %>
      <div class="relative">
        <% if (isCurrency) { %>
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">£</span>
        <% } %>
        <input
          type="number"
          id="<%= key %>"
          name="<%= fieldName %>"
          value="<%= numVal %>"
          min="0"
          <%= numMax ? `max="${numMax}"` : '' %>
          step="<%= numStep %>"
          placeholder="<%= isCurrency ? '0.00' : isHours ? '0' : '' %>"
          class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 <%= isCurrency ? 'pl-7' : 'px-3' %> py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500"
        >
      </div>

    <% } else { %>
      <!-- Default text -->
      <input
        type="text"
        id="<%= key %>"
        name="<%= fieldName %>"
        value="<%= selectedValue || '' %>"
        placeholder="<%= field.default ? `Default: ${field.default}` : '' %>"
        class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2 focus:ring-2 focus:ring-green-500 focus:border-green-500"
      >
    <% } %>
  </div>
<% } %>
