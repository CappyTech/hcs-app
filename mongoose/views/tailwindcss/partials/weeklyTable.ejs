<table class="min-w-full border-collapse border border-gray-300 text-sm">
  <thead>
    <tr class="bg-gray-100">
      <th class="text-center font-normal border border-gray-300 px-3 py-2">Name</th>
      <% daysOfWeek.forEach(day => { %>
        <th class="text-center text-xs font-normal border border-gray-300 px-3 py-2">
          <a href="/daily/<%= day %>" class="hover:underline">
            <%= moment(day).format('DD/MM/YYYY') %>
          </a><br>
          <span class="text-gray-600"><%= moment(day).format('dddd') %></span>
        </th>
      <% }); %>
      <th class="text-center font-normal border border-gray-300 px-3 py-2">
        Weekly Pay <br> / Total Hours
      </th>
    </tr>
  </thead>
  <tbody>
    <% entries.forEach(([, details]) => { %>
      <tr class="font-light border-b border-gray-200 hover:bg-gray-50">
        <td class="border border-gray-300 px-3 py-2">
          <% if (details.employeeId) { %>
            <a href="/employee/read/<%= details.employeeId %>" class="text-green-900 hover:underline">
              <%= details.name || 'Unnamed Employee' %>
            </a>
          <% } else { %>
            <a href="/supplier/read/<%= details.subcontractorId %>" class="text-green-900 hover:underline">
              <%= details.name || 'Unnamed Subcontractor' %>
            </a>
          <% } %>
        </td>

        <% daysOfWeek.forEach(day => { %>
          <% const dailyRecords = details.dailyRecords[day] || {}; %>
          <td class="border border-gray-300 text-center px-3 py-2 align-top">
            <% if (Object.keys(dailyRecords).length > 0) { %>
              <% Object.entries(dailyRecords).forEach(([recordId, record]) => { %>
                <% const isReceipt = recordId.startsWith('receipt-'); %>
                <% const href = isReceipt ? `/receipt/read/${recordId.split('receipt-')[1]}` : `/attendance/read/${record.uuid}`; %>

                <% if (record.contractAssignmentId?.title && record.contractAssignmentId?.uuid) { %>
                  <a 
                    href="/assignment/read/<%= record.contractAssignmentId.uuid %>" 
                    class="text-green-600 text-xs font-semibold hover:underline block">
                    <%= record.contractAssignmentId.title %>
                  </a>
                <% } %>

                <a href="<%= href %>" class="block text-green-900 hover:underline text-sm">
                  <%= record.location %> - <%= record.type %> – £<%= record.weeklyPay.toFixed(2) %>
                </a>

                <% if (record.hoursWorked) { %>
                  <a href="<%= href %>" class="block text-gray-700 text-xs">
                    <%= record.hoursWorked %> hours
                  </a>
                <% } %>
              <% }); %>
            <% } else if (details.type === 'employee') { %>
              <a href="/attendance/create?date=<%= day %>&uuid=<%= details.employeeId %>" class="text-gray-400 text-xs hover:text-gray-600 hover:underline">
                Add Attendance
              </a>
            <% } %>
          </td>
        <% }); %>

        <td class="border border-gray-300 text-center px-3 py-2 font-semibold">
          £<%= details.weeklyPay.toFixed(2) %><br>
          <span class="text-sm font-normal"><%= details.totalHoursWorked %> hours</span>
        </td>
      </tr>
    <% }); %>
  </tbody>
</table>
