<div class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8 space-y-6">
    <a href="/<%= basePath %>/read/<%= uuid %>" class="inline-flex items-center gap-1.5 text-sm text-green-600 dark:text-green-400 hover:underline font-medium">
        <i class="bi bi-arrow-left"></i> Go Back
    </a>

    <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
        <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
        <div class="p-6 sm:p-8">
    <h1 class="text-2xl font-bold mb-4 text-gray-900 dark:text-gray-100">
        <%= title %>
    </h1>

    <% if (fileType==='image' ) { %>
        <img src="<%= fileUrl %>" alt="<%= filename %>" class="max-w-full h-auto rounded-xl shadow" />
    <% } else if (fileType==='pdf' ) { %>
        <iframe src="<%= fileUrl %>#toolbar=1" class="w-full h-[90vh] rounded-xl border border-gray-200 dark:border-gray-700 shadow"></iframe>
    <% } else { %>
        <p class="text-red-600">Unsupported file type for inline viewing.</p>
        <a href="<%= fileUrl %>" download class="inline-flex items-center gap-1.5 bg-blue-600 text-white px-4 py-2 mt-4 rounded-lg shadow-sm hover:bg-blue-700 transition font-medium">Download File</a>
    <% } %>
        </div>
    </div>
</div>