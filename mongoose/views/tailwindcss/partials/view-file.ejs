<div class="max-w-4xl mx-auto p-6">
    <div class="mt-6">
        <a href="/<%= basePath %>/read/<%= uuid %>" class="text-green-600 hover:underline">
            <i class="bi bi-arrow-left"></i> Go Back
        </a>
    </div>
    <h1 class="text-2xl font-bold mb-4">
        <%= title %>
    </h1>

    <% if (fileType==='image' ) { %>
        <img src="<%= fileUrl %>" alt="<%= filename %>" class="max-w-full h-auto border rounded shadow" />
    <% } else if (fileType==='pdf' ) { %>
        <iframe src="<%= fileUrl %>#toolbar=1" class="w-full h-[90vh] border rounded shadow"></iframe>
    <% } else { %>
        <p class="text-red-600">Unsupported file type for inline viewing.</p>
        <a href="<%= fileUrl %>" download class="inline-block bg-blue-600 text-white px-4 py-2 mt-4 rounded">Download File</a>
    <% } %>
</div>