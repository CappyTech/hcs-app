<%
  // Shared status pill. Maps a free-text status to a colour family so detail views
  // (assignment, contract, …) and their child tables stay visually consistent.
  // Locals: status (string).
  const _s = (typeof status !== 'undefined' && status != null) ? String(status) : '';
  const _l = _s.toLowerCase();
  const _cls = ['done', 'completed', 'complete', 'paid', 'active', 'approved'].includes(_l)
    ? 'bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400'
    : ['in progress', 'pending', 'processing', 'review'].includes(_l)
      ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-800/20 dark:text-yellow-400'
      : ['cancelled', 'canceled', 'rejected', 'failed', 'overdue'].includes(_l)
        ? 'bg-red-100 text-red-800 dark:bg-red-800/20 dark:text-red-400'
        : 'bg-gray-100 text-gray-800 dark:bg-gray-800/20 dark:text-gray-400';
%><span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-semibold <%= _cls %>"><%= _s || '—' %></span>