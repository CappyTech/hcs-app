<div class="flex flex-col flex-grow bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
  <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
  <div class="px-5 py-3 font-bold text-gray-900 dark:text-gray-100">
    <%= title %>
  </div>
  <ul class="divide-y divide-gray-200 dark:divide-gray-700">
    <% if (tasks.length) { %>
      <% tasks.forEach(t => { %>
        <li class="px-4 py-3 flex items-start gap-2">
          <form action="/task/<%= t.uuid %>/complete" method="POST" class="shrink-0 mt-0.5">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" title="Mark complete"
                    class="w-5 h-5 rounded border-2 border-gray-300 dark:border-gray-600 hover:border-green-500 hover:bg-green-50 dark:hover:bg-green-900/30 transition flex items-center justify-center text-transparent hover:text-green-600 dark:hover:text-green-400">
              <i class="bi bi-check text-xs"></i>
            </button>
          </form>
          <div class="min-w-0 flex-grow">
            <a href="/task/read/<%= t.uuid %>" class="font-semibold text-green-700 dark:text-green-400 hover:underline">
              <%= t.title %>
            </a>
            <% if (showRecurrence && t.recurrence && t.recurrence !== 'none') { %> 🔁 <% } %>
            <% if (t.dueDate) { %>
              <div class="text-gray-500 dark:text-gray-400 text-sm mt-1">Due <%= slimDateTime(t.dueDate) %></div>
            <% } %>
            <% if (t.description) { %>
              <div class="mt-1 text-gray-700 dark:text-gray-300 text-sm"><%= t.description %></div>
            <% } %>
          </div>
        </li>
      <% }) %>
    <% } else { %>
      <li class="px-4 py-3 italic text-gray-500 dark:text-gray-400">
        <%= emptyMsg %>
      </li>
    <% } %>
  </ul>
</div>
