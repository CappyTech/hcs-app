<%
  /* Type → color mapping for cell backgrounds and badges */
  const _cellBg = {
    work:     'bg-green-50 dark:bg-green-900/20',
    training: 'bg-blue-50 dark:bg-blue-900/20',
    sick:     'bg-red-50 dark:bg-red-900/20',
    holiday:  'bg-purple-50 dark:bg-purple-900/20',
    off:      'bg-gray-100 dark:bg-gray-800',
    leave:    'bg-yellow-50 dark:bg-yellow-900/20',
    Purchase: 'bg-cyan-50 dark:bg-cyan-900/20',
    PurchaseDue: 'bg-amber-50 dark:bg-amber-900/20'
  };
  const _badgeCls = {
    work:     'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
    training: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400',
    sick:     'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
    holiday:  'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400',
    off:      'bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300',
    leave:    'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
    Purchase: 'bg-cyan-100 text-cyan-800 dark:bg-cyan-900/30 dark:text-cyan-400',
    PurchaseDue: 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400'
  };
  const _statusBadge = {
    pending:  'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400',
    approved: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
    rejected: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400'
  };
  const _dh = typeof dailyHeadcount !== 'undefined' ? dailyHeadcount : {};
  const _showHC = typeof showHeadcount !== 'undefined' ? showHeadcount : false;
  const _psMap = typeof purchaseStatementMap !== 'undefined' ? purchaseStatementMap : {};
  const _showHB = typeof showHolidayBalance !== 'undefined' ? showHolidayBalance : false;
  const _hbMap = typeof holidayBalanceMap !== 'undefined' ? holidayBalanceMap : {};
  const _canEdit = canDept('management') || canDept('admin');
%>
<table class="min-w-full border-collapse border border-gray-200 dark:border-gray-700 text-sm rounded-xl overflow-hidden">
  <thead>
    <tr class="bg-gray-50 dark:bg-gray-800">
      <th class="text-center font-normal border border-gray-200 dark:border-gray-700 px-3 py-2 text-gray-800 dark:text-gray-200">Name</th>
      <% daysOfWeek.forEach(day => { %>
        <th class="text-center text-xs font-normal border border-gray-300 dark:border-gray-700 px-3 py-2 text-gray-700 dark:text-gray-300">
          <a href="/daily/<%= day %>" class="hover:underline hover:text-green-700 dark:hover:text-green-300">
            <%= moment(day).format('DD/MM/YYYY') %>
          </a><br>
          <span class="text-gray-600 dark:text-gray-400 font-bold"><%= moment(day).format('dddd') %></span>
        </th>
      <% }); %>
      <% if (!isManagementView) { %>
        <th class="text-center font-normal border border-gray-300 dark:border-gray-700 px-3 py-2 text-gray-800 dark:text-gray-200">
          Weekly Pay
        </th>
      <% } %>
      <% if (_showHB && sectionType === 'employee') { %>
        <th class="text-center font-normal border border-gray-300 dark:border-gray-700 px-3 py-2 text-gray-800 dark:text-gray-200">
          Holiday Balance
        </th>
      <% } %>
    </tr>
  </thead>
  <tbody class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100">
    <% entries.forEach(([, details]) => {
      /* Check if any record for this person is pending */
      const _hasPending = Object.values(details.dailyRecords || {}).some(recs =>
        Object.values(recs).some(r => r.status === 'pending')
      );
    %>
      <tr class="font-light border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 <%= _hasPending ? 'ring-2 ring-inset ring-amber-300 dark:ring-amber-600' : '' %>">
        <td class="border border-gray-300 dark:border-gray-700 px-3 py-2 whitespace-nowrap">
          <% if (details.employeeId) { %>
            <a href="/employee/read/<%= details.employeeId %>" class="text-green-900 dark:text-green-400 hover:underline">
              <%= details.name || 'Unnamed Employee' %>
            </a>
          <% } else { %>
            <a href="/supplier/read/<%= details.subcontractorId %>" class="text-green-900 dark:text-green-400 hover:underline">
              <%= details.name || 'Unnamed Subcontractor' %>
            </a>
          <% } %>
        </td>

        <% daysOfWeek.forEach(day => { %>
          <% const dailyRecords = details.dailyRecords[day] || {}; %>
          <%
            /* Determine dominant type for cell color */
            const _recValues = Object.values(dailyRecords);
            const _dominantType = _recValues.length > 0
              ? (_recValues[0].paymentStatus === 'due' ? 'PurchaseDue' : (_recValues[0].type || ''))
              : '';
            const _cellClass = _recValues.length > 0 ? (_cellBg[_dominantType] || '') : '';
          %>
          <td class="border border-gray-300 dark:border-gray-700 text-center px-2 py-1.5 align-top <%= _cellClass %>">
            <% if (Object.keys(dailyRecords).length > 0) { %>
              <% Object.entries(dailyRecords).forEach(([recordId, record]) => { %>
                <% const isPurchase = recordId.startsWith('purchase-'); %>
                <% const _isDue = record.paymentStatus === 'due'; %>
                <% const _stmtAnchor = isPurchase && _isDue && _psMap[record.purchaseUuid]
                  ? `#statement-${_psMap[record.purchaseUuid]}`
                  : null; %>
                <% const href = isPurchase
                  ? (_stmtAnchor || `/purchase/read/${record.purchaseUuid}`)
                  : `/attendance/read/${record.uuid}`; %>

                <%# Pending record — click to edit via shared dialog %>
                <% if (!isPurchase && record.status === 'pending') { %>
                  <div class="mb-1">
                    <% if (record.contractAssignmentId && record.contractAssignmentId.title && record.contractAssignmentId.uuid) { %>
                      <a href="/assignment/read/<%= record.contractAssignmentId.uuid %>" class="text-green-600 dark:text-green-400 text-xs font-semibold hover:underline block">
                        <%= record.contractAssignmentId.title %>
                      </a>
                    <% } %>
                    <button type="button" class="att-open block text-left w-full hover:opacity-75 transition-opacity print:hidden"
                      data-uuid="<%= record.uuid %>"
                      data-is-new="false"
                      data-is-subcontractor="<%= sectionType === 'subcontractor' %>"
                      data-employee-id=""
                      data-subcontractor-id=""
                      data-date="<%= day %>"
                      data-type="<%= record.type || 'work' %>"
                      data-hours="<%= record.hoursWorked != null ? record.hoursWorked : '' %>"
                      data-day-rate="<%= record.dayRate != null ? record.dayRate : '' %>"
                      data-location-id="<%= record.location && record.location._id ? record.location._id : (record.locationId || '') %>"
                      data-contract-id="<%= record.contractId || '' %>">
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium <%= _badgeCls[record.type] || 'bg-gray-100 text-gray-700' %> mb-0.5">
                        <%= record.type || 'work' %>
                      </span>
                      <% if (record.location && record.location.name) { %>
                        <span class="block text-green-900 dark:text-green-400 text-xs leading-tight"><%= record.location.name %></span>
                      <% } %>
                      <% if (record.hoursWorked > 0) { %>
                        <span class="block text-gray-600 dark:text-gray-400 text-[10px]"><%= record.hoursWorked %>h</span>
                      <% } %>
                    </button>
                    <div class="mt-0.5">
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400">pending</span>
                      <span class="inline-flex gap-1 ml-0.5 print:hidden">
                        <form action="/attendance/<%= record.uuid %>/approve" method="POST" class="inline">
                          <%- include('./csrfHidden.ejs') %>
                          <button type="submit" class="text-green-600 hover:text-green-800 text-xs" title="Approve"><i class="bi bi-check-lg"></i></button>
                        </form>
                        <form action="/attendance/<%= record.uuid %>/reject" method="POST" class="inline">
                          <%- include('./csrfHidden.ejs') %>
                          <button type="submit" class="text-red-600 hover:text-red-800 text-xs" title="Reject"><i class="bi bi-x-lg"></i></button>
                        </form>
                      </span>
                    </div>
                  </div>

                <% } else { %>
                  <%# ── Static record (approved, rejected, or purchase) ── %>

                  <% if (record.contractAssignmentId?.title && record.contractAssignmentId?.uuid) { %>
                    <a
                      href="/assignment/read/<%= record.contractAssignmentId.uuid %>"
                      class="text-green-600 dark:text-green-400 text-xs font-semibold hover:underline block">
                      <%= record.contractAssignmentId.title %>
                    </a>
                  <% } %>

                  <% const _effectiveType = _isDue ? 'PurchaseDue' : (record.type || 'Purchase'); %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium <%= _badgeCls[_effectiveType] || 'bg-gray-100 text-gray-700' %> mb-0.5">
                    <%= record.type || 'Purchase' %><% if (_isDue) { %> <i class="bi bi-clock ml-0.5"></i><% } %>
                  </span>

                  <a href="<%= href %>" class="block text-green-900 dark:text-green-400 hover:underline text-xs leading-tight">
                    <% if (isPurchase) { %>
                      KF#: <%= record.invoiceNumber || '—' %> SF#: <%= record.supplierReference || '—' %>
                      <% if (!isManagementView && record.weeklyPay) { %>
                        – £<%= record.weeklyPay.toFixed(2) %>
                      <% } %>
                    <% } else { %>
                      <%= record.location?.name || '' %><% if (record.location?.name) { %> <% } %>
                      <% if (!isManagementView && record.weeklyPay) { %>
                        £<%= record.weeklyPay.toFixed(2) %>
                      <% } %>
                    <% } %>
                  </a>

                  <% if (record.hoursWorked > 0) { %>
                    <span class="block text-gray-600 dark:text-gray-400 text-[10px]"><%= record.hoursWorked %>h</span>
                  <% } %>

                  <% if (record.status && !isPurchase) { %>
                    <div class="mt-0.5">
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium <%= _statusBadge[record.status] || '' %>">
                        <%= record.status %>
                      </span>
                    </div>
                  <% } %>
                <% } %>

              <% }); %>

            <% } else { %>
              <%# ── Empty cell — open dialog to create ── %>
              <% const _entityMongoId = details.employeeMongoId ? String(details.employeeMongoId) : null; %>
              <% const _subUuid = details.subcontractorId || null; %>
              <% if (_canEdit && (_entityMongoId || _subUuid)) { %>
                <button type="button" class="att-open print:hidden w-full text-center"
                  data-uuid=""
                  data-is-new="true"
                  data-is-subcontractor="<%= sectionType === 'subcontractor' %>"
                  data-employee-id="<%= _entityMongoId || '' %>"
                  data-subcontractor-id="<%= _subUuid || '' %>"
                  data-date="<%= day %>"
                  data-type="work"
                  data-hours=""
                  data-day-rate=""
                  data-location-id=""
                  data-contract-id=""
                  title="Add attendance">
                  <span class="text-gray-400 dark:text-gray-500 text-[10px] hover:text-gray-600 dark:hover:text-gray-300">+ Add</span>
                </button>
              <% } %>
            <% } %>
          </td>
        <% }); %>

        <% if (!isManagementView) { %>
          <td class="border border-gray-300 dark:border-gray-700 text-center px-3 py-2 font-semibold whitespace-nowrap">
            £<%= details.weeklyPay.toFixed(2) %><br>
            <% if (details.totalHoursWorked > 0) { %>
            <span class="text-xs font-normal text-gray-700 dark:text-gray-300"><%= details.totalHoursWorked %>h</span>
            <% } %>
          </td>
        <% } %>
        <% if (_showHB && sectionType === 'employee') {
          const _hbKey = details.employeeMongoId ? String(details.employeeMongoId) : null;
          const _hbEntry = _hbKey && _hbMap[_hbKey];
        %>
          <td class="border border-gray-300 dark:border-gray-700 text-center px-3 py-2 whitespace-nowrap">
            <% if (_hbEntry) { %>
              <span class="font-semibold <%= _hbEntry.remaining <= 2 ? 'text-red-600 dark:text-red-400' : _hbEntry.remaining <= 5 ? 'text-amber-600 dark:text-amber-400' : 'text-gray-800 dark:text-gray-200' %>">
                <%= _hbEntry.remaining %> days
              </span>
              <span class="block text-[10px] text-gray-500 dark:text-gray-400">
                exp. <%= moment(_hbEntry.periodEnd).format('DD/MM/YY') %>
              </span>
            <% } else { %>
              <span class="text-gray-400 dark:text-gray-500 text-xs">—</span>
            <% } %>
          </td>
        <% } %>
      </tr>
    <% }); %>
  </tbody>

  <%/* Daily totals footer row */%>
  <% if (_showHC) { %>
  <tfoot>
    <tr class="bg-gray-50 dark:bg-gray-800 font-medium">
      <td class="border border-gray-300 dark:border-gray-700 px-3 py-2 text-right text-xs text-gray-600 dark:text-gray-400">
        Daily headcount
      </td>
      <% daysOfWeek.forEach(day => { %>
        <td class="border border-gray-300 dark:border-gray-700 text-center px-3 py-2 text-sm font-semibold text-gray-700 dark:text-gray-300">
          <%= _dh[day] || 0 %>
        </td>
      <% }); %>
      <% if (!isManagementView) { %>
        <td class="border border-gray-300 dark:border-gray-700"></td>
      <% } %>
      <% if (_showHB && sectionType === 'employee') { %>
        <td class="border border-gray-300 dark:border-gray-700"></td>
      <% } %>
    </tr>
  </tfoot>
  <% } %>
</table>

<% if (_canEdit) { %>
<style>#att-modal::backdrop { background: rgba(0,0,0,0.5); }</style>
<dialog id="att-modal" class="rounded-xl shadow-2xl bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-200 p-0 w-full max-w-md border border-gray-200 dark:border-gray-700">
  <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
    <h3 class="font-semibold text-base" id="att-modal-title">Attendance</h3>
    <button type="button" id="att-close" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 text-xl leading-none">&times;</button>
  </div>
  <div class="px-5 py-4 space-y-3">
    <div>
      <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Type</label>
      <select id="att-type" class="w-full text-sm px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 focus:ring-1 focus:ring-green-500 focus:outline-none">
        <option value="work">Work</option>
        <option value="training">Training</option>
        <option value="sick">Sick</option>
        <option value="holiday">Holiday</option>
        <option value="off">Off</option>
        <option value="leave">Leave</option>
      </select>
    </div>
    <div id="att-hours-row">
      <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1" id="att-hours-label">Hours</label>
      <input type="number" id="att-hours" min="0" step="0.25" placeholder="e.g. 8"
        class="w-full text-sm px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 focus:ring-1 focus:ring-green-500 focus:outline-none">
    </div>
    <div id="att-location-row">
      <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Location</label>
      <select id="att-location" class="w-full text-sm px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 focus:ring-1 focus:ring-green-500 focus:outline-none">
        <option value="">— None —</option>
      </select>
    </div>
    <div id="att-contract-row">
      <label class="block text-xs font-medium text-gray-600 dark:text-gray-400 mb-1">Contract</label>
      <select id="att-contract" class="w-full text-sm px-2 py-1.5 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 focus:ring-1 focus:ring-green-500 focus:outline-none">
        <option value="">— None —</option>
      </select>
    </div>
    <p id="att-err" class="text-xs text-red-600 dark:text-red-400" style="display:none"></p>
  </div>
  <div class="px-5 py-3 border-t border-gray-200 dark:border-gray-700 flex items-center gap-2">
    <button type="button" id="att-save" class="px-4 py-1.5 rounded text-sm font-medium bg-green-600 hover:bg-green-700 text-white transition-colors">Save</button>
    <button type="button" id="att-cancel" class="px-4 py-1.5 rounded text-sm font-medium bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 transition-colors">Cancel</button>
  </div>
</dialog>

<script>
(function () {
  var modal    = document.getElementById('att-modal');
  if (!modal) return;
  var titleEl  = document.getElementById('att-modal-title');
  var typeSel  = document.getElementById('att-type');
  var hoursIn  = document.getElementById('att-hours');
  var hoursLbl = document.getElementById('att-hours-label');
  var hoursRow = document.getElementById('att-hours-row');
  var locSel   = document.getElementById('att-location');
  var contSel  = document.getElementById('att-contract');
  var errEl    = document.getElementById('att-err');
  var saveBtn  = document.getElementById('att-save');
  var _state   = {};

  // Populate location options from JSON blob
  try {
    var locsData = JSON.parse((document.getElementById('attendance-locations-json') || {}).textContent || '[]');
    locsData.forEach(function (l) {
      var o = document.createElement('option');
      o.value = l._id; o.textContent = l.name;
      locSel.appendChild(o);
    });
  } catch (e) {}

  // Populate contract options from JSON blob
  try {
    var contrData = JSON.parse((document.getElementById('attendance-contracts-json') || {}).textContent || '[]');
    contrData.forEach(function (c) {
      var o = document.createElement('option');
      o.value = c._id; o.textContent = c.title;
      contSel.appendChild(o);
    });
  } catch (e) {}

  function toggleWorkFields() {
    var show = typeSel.value === 'work' || typeSel.value === 'training';
    hoursRow.style.display = show ? '' : 'none';
    document.getElementById('att-location-row').style.display = show ? '' : 'none';
    document.getElementById('att-contract-row').style.display = show ? '' : 'none';
  }
  typeSel.addEventListener('change', toggleWorkFields);

  function closeModal() { modal.close(); }
  document.getElementById('att-close').addEventListener('click', closeModal);
  document.getElementById('att-cancel').addEventListener('click', closeModal);

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.att-open');
    if (!btn) return;
    var d = btn.dataset;
    _state.uuid          = d.uuid;
    _state.isNew         = d.isNew === 'true';
    _state.isSubcontractor = d.isSubcontractor === 'true';
    _state.employeeId    = d.employeeId;
    _state.subcontractorId = d.subcontractorId;
    _state.date          = d.date;

    titleEl.textContent = (_state.isNew ? 'Add Attendance' : 'Edit Attendance') + ' — ' + d.date;
    errEl.style.display = 'none';
    saveBtn.disabled = false;
    saveBtn.textContent = 'Save';

    typeSel.value = d.type || 'work';
    hoursLbl.textContent = _state.isSubcontractor ? 'Day Rate (£)' : 'Hours';
    hoursIn.step  = _state.isSubcontractor ? '0.01' : '0.25';
    hoursIn.value = _state.isSubcontractor ? (d.dayRate || '') : (d.hours || '');
    locSel.value  = d.locationId  || '';
    contSel.value = d.contractId  || '';
    toggleWorkFields();

    modal.showModal();
  });

  saveBtn.addEventListener('click', function () {
    errEl.style.display = 'none';
    saveBtn.disabled = true;
    saveBtn.textContent = '…';

    var payload = { date: _state.date, type: typeSel.value };
    if (_state.employeeId) payload.employeeId = _state.employeeId;
    if (_state.subcontractorId) payload.subcontractorId = _state.subcontractorId;
    if (typeSel.value === 'work' || typeSel.value === 'training') {
      if (hoursIn.value !== '') {
        if (_state.isSubcontractor) payload.dayRate = Number(hoursIn.value);
        else payload.hoursWorked = Number(hoursIn.value);
      }
      if (locSel.value)  payload.locationId  = locSel.value;
      if (contSel.value) payload.contractId  = contSel.value;
    }

    var csrf = (document.querySelector('meta[name="csrf-token"]') || {}).content || '';
    var url    = _state.isNew ? '/attendance/inline' : '/attendance/' + _state.uuid;
    var method = _state.isNew ? 'POST' : 'PATCH';

    fetch(url, {
      method: method,
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
      body: JSON.stringify(payload),
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.success) { window.location.reload(); return; }
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save';
        errEl.textContent = data.error || 'Save failed.';
        errEl.style.display = '';
      })
      .catch(function () {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save';
        errEl.textContent = 'Network error. Please try again.';
        errEl.style.display = '';
      });
  });
})();
</script>
<% } %>
