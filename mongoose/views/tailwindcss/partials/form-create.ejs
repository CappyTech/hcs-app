<div class="container mx-auto my-5 px-4 max-w-3xl">
  <h1 class="mb-4 text-3xl font-semibold text-gray-900 dark:text-gray-100"><%= title %></h1>

  <% const _desc = typeof config !== 'undefined' ? config?.description : undefined; %>
  <% const descText = typeof _desc === 'string' ? _desc : (_desc?.create || _desc?.manage || ''); %>
  <% if (descText) { %>
    <p class="text-gray-500 dark:text-gray-400 text-sm mb-4"><%= descText %></p>
  <% } %>

  <% if (errors?.length) { %>
    <div class="bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-200 p-3 rounded mb-4 text-sm border border-red-200 dark:border-red-800">
      <% errors.forEach(error => { %>
        <p><%= error %></p>
      <% }) %>
    </div>
  <% } %>

  <form action="<%= formAction %>" method="POST" novalidate class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded p-4">
    <%- include('./csrfHidden.ejs') %>
    <%
      const xorGroups = config?.xorGroups || [];
      const xorGroupMap = {};
      xorGroups.forEach((group, i) => group.forEach(field => xorGroupMap[field] = i));

      const renderedFields = new Set();
      const keys = Object.keys(schema);

      // Pre-compute nested field groups (e.g., contract.termsType → group 'contract')
      const _nestedGroups = {};
      keys.forEach(k => {
        const dot = k.indexOf('.');
        if (dot > -1) {
          const prefix = k.substring(0, dot);
          if (!_nestedGroups[prefix]) _nestedGroups[prefix] = [];
          _nestedGroups[prefix].push(k);
        }
      });
      const _groupLabel = (name) => name.replace(/([a-z])([A-Z])/g, '$1 $2').replace(/\b\w/g, c => c.toUpperCase());
    %>

    <% keys.forEach((key, index) => {
      if (renderedFields.has(key)) return;
      const field = schema[key];
      const groupIndex = xorGroupMap[key];

      if (groupIndex != null) {
        /* Render the entire XOR group as a block when we hit its first member */
        const groupFields = xorGroups[groupIndex];
    %>
        <div class="mb-6 border-2 border-cyan-300 border-opacity-40 bg-cyan-50 bg-opacity-40 p-4 rounded dark:border-cyan-700 dark:bg-cyan-900/20">
          <p class="text-sm text-cyan-700 dark:text-cyan-300 italic mb-4">Select only one of the following:</p>
          <% groupFields.forEach(gKey => {
            if (schema[gKey] && !renderedFields.has(gKey)) { %>
              <%- include('../partials/_formField', { key: gKey, field: schema[gKey], formData, referenceData, readOnly: false, showTips: true, config, groupPrefix: null }) %>
          <%  renderedFields.add(gKey);
            }
          }) %>
        </div>
    <% } else {
        const _dot = key.indexOf('.');
        const _prefix = _dot > -1 ? key.substring(0, _dot) : null;
        if (_prefix && _nestedGroups[_prefix]) {
    %>
        <fieldset class="mb-6 border border-gray-300 dark:border-gray-600 rounded p-4">
          <legend class="px-2 text-sm font-semibold text-gray-700 dark:text-gray-200"><%= _groupLabel(_prefix) %></legend>
          <% _nestedGroups[_prefix].forEach(gKey => {
            if (!renderedFields.has(gKey) && schema[gKey]) { %>
              <%- include('../partials/_formField', { key: gKey, field: schema[gKey], formData, referenceData, readOnly: false, showTips: true, config, groupPrefix: _prefix }) %>
          <%  renderedFields.add(gKey);
            }
          }) %>
        </fieldset>
    <% } else { %>
        <%- include('../partials/_formField', { key, field, formData, referenceData, readOnly: false, showTips: true, config, groupPrefix: null }) %>
    <%  renderedFields.add(key);
      }
    }
    }) %>

    <p class="text-gray-500 dark:text-gray-300 text-sm mb-4"><span class="text-red-600">*</span> Required fields</p>

    <button type="submit" class="bg-green-700 text-white px-5 py-2 rounded hover:bg-green-800 transition">
      Create
    </button>
  </form>
</div>
