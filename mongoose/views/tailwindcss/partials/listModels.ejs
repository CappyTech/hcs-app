<div class="max-w-6xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>
    <div class="p-6 sm:p-8">
    <h1 class="text-3xl font-bold text-center mb-6 text-gray-900 dark:text-gray-100">
      <%= title %>
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-4">
      <% models.forEach(model => { %>
        <div class="flex flex-col bg-gray-50 dark:bg-gray-800 rounded-xl p-5 transition hover:shadow-md">
          <div class="flex-grow">
            <h5 class="text-xl font-semibold mb-2 text-gray-900 dark:text-gray-100">
              <%= model.title %>
            </h5>
            <p class="text-sm text-gray-600 dark:text-gray-300">
              <%= model.description %>
            </p>
          </div>
          <a href="<%= model.link %>" class="mt-4 inline-flex items-center justify-center gap-1.5 <%= model.buttonClass || 'bg-green-600 hover:bg-green-700' %> text-white text-sm px-5 py-2.5 rounded-lg transition shadow-sm font-medium">
            <%= model.title %>
          </a>
        </div>
      <% }) %>
    </div>
    </div>
  </div>
</div>
