<% const hasActions = typeof actions !== 'undefined' && Array.isArray(actions) && actions.length > 0; %>
<% const hdrActions = typeof headerActions !== 'undefined' && Array.isArray(headerActions) ? headerActions : []; %>
<div class="w-full my-10 px-4">
  <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 lg:gap-6 mb-6">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-bold text-center lg:text-left"><%= title || 'Data Table' %></h1>
      <% hdrActions.forEach(a => { %>
        <a href="<%= a.href %>" class="inline-flex items-center gap-1 text-white text-sm px-3 py-1.5 rounded <%= a.class || 'bg-green-600 hover:bg-green-700' %>">
          <% if (a.icon) { %><i class="<%= a.icon %>"></i><% } %> <%= a.label %>
        </a>
      <% }) %>
    </div>
    <div class="flex flex-wrap items-center gap-4">
      <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <!-- Pagination -->
        <nav>
          <ul class="flex justify-center flex-wrap gap-2">
            <% const range = 2; %>
            <% for (let i = 1; i <= totalPages; i++) { %>
              <% if (i === 1 || i === totalPages || Math.abs(i - page) <= range) { %>
                <li>
                  <a href="?page=<%= i %>&limit=<%= limit %><%= query ? '&search=' + encodeURIComponent(query) : '' %><%= activeTab ? '&tab=' + encodeURIComponent(activeTab) : '' %>"
                     class="px-2.5 py-0.5 rounded border text-xs
                     <%= i === page
                       ? 'bg-green-700 text-white'
                       : 'bg-white dark:bg-gray-800 dark:text-white border-gray-300 dark:border-gray-600 hover:bg-green-600 hover:text-white dark:hover:bg-green-700'
                     %> transition">
                    <%= i %>
                  </a>
                </li>
              <% } else if (i === page - range - 1 || i === page + range + 1) { %>
                <li><span class="px-3 py-1 text-sm text-gray-500 dark:text-gray-400">…</span></li>
              <% } %>
            <% } %>
          </ul>
        </nav>
      <% } %>

      <!-- Controls -->
      <form id="list-controls" method="GET" action="" class="flex flex-wrap gap-2 items-center">
        <label for="limitSelect" class="text-sm font-medium text-gray-700 dark:text-gray-200">Show</label>
  <select id="limitSelect" name="limit"
    class="text-sm border rounded pl-2 pr-6 py-1 bg-white dark:bg-gray-800 dark:text-white dark:border-gray-600 appearance-none focus:outline-none focus:ring-1 focus:ring-green-600"
    style="background-image:linear-gradient(45deg,transparent 50%,currentColor 50%),linear-gradient(135deg,currentColor 50%,transparent 50%);background-position:calc(100% - 14px) calc(50% - 3px),calc(100% - 10px) calc(50% - 3px);background-size:4px 4px,4px 4px;background-repeat:no-repeat;">
          <% [10, 50, 100].forEach(opt => { %>
            <option value="<%= opt %>" <%= limit == opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>

        <input type="hidden" name="page" value="1">
        <% if (activeTab) { %>
          <input type="hidden" name="tab" value="<%= activeTab %>">
        <% } %>

        <input type="text"
              name="search"
              placeholder="Search..."
              value="<%= typeof query === 'string' ? query : '' %>"
              class="text-sm border rounded px-3 py-1 w-48 bg-white dark:bg-gray-800 dark:text-white dark:border-gray-600">

        <button type="submit"
                class="text-sm bg-green-700 text-white px-4 py-1 rounded hover:bg-green-800 transition">
          Apply
        </button>
      </form>
    </div>
  </div>

  <!-- Tab Buttons -->
  <% if (Array.isArray(tabs) && tabs.length > 0) { %>
    <div class="mb-4 flex flex-wrap gap-2">
      <% tabs.forEach(tab => { %>
        <a href="?tab=<%= encodeURIComponent(tab.value) %>&limit=<%= limit %><%= query ? '&search=' + encodeURIComponent(query) : '' %>"
           class="px-4 py-1 rounded-full text-sm border transition
                  <%= tab.isActive
                    ? 'bg-green-700 text-white border-green-700'
                    : 'bg-white text-gray-700 border-gray-300 hover:bg-green-100 dark:bg-gray-800 dark:text-gray-200 dark:border-gray-600 dark:hover:bg-green-800 dark:hover:text-white'
                  %>">
          <%= tab.label %>
        </a>
      <% }) %>
    </div>
  <% } %>

  <% if (!rows || rows.length === 0) { %>
    <div class="bg-blue-100 text-blue-800 p-4 rounded text-sm border border-blue-300 dark:bg-blue-900 dark:text-blue-100 dark:border-blue-700">
      No records found.
    </div>
  <% } else { %>

    <!-- Table -->
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm border border-gray-300 dark:border-gray-600">
        <thead class="bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200">
          <tr>
            <% headers.forEach(h => { 
                const isSorted = query.sort === h.key;
                const isAsc = query.order === 'asc';
                const newOrder = isSorted && isAsc ? 'desc' : 'asc';
                const url = new URLSearchParams(query);
                url.set('sort', h.key);
                url.set('order', newOrder);
            %>
              <th class="px-3 py-2 text-xs border-b dark:border-gray-600 text-left font-medium">
                <a href="?<%= url.toString() %>" class="flex items-center gap-1 hover:underline">
                  <span><%= h.label %></span>
                  <% if (isSorted) { %>
                    <span><%= isAsc ? '▲' : '▼' %></span>
                  <% } %>
                </a>
              </th>
            <% }) %>
            <% if (hasActions) { %>
              <th class="px-3 py-2 border-b dark:border-gray-600 font-medium">Actions</th>
            <% } %>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100">
          <% rows.forEach(row => { %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
              <% headers.forEach(h => { %>
                <%
                  const val = row[h.key];
                  const links = typeof fieldLinks === 'function' ? fieldLinks(row) : fieldLinks;
                  const fieldHref = links?.[h.key];
                  const isOwnLink = h.key === linkField && row.uuid;
                  const href = fieldHref || (isOwnLink ? `/${basePath}/read/${row.uuid}` : null);
                %>
                <td class="px-3 py-2 border-b dark:border-gray-700">
                  <% if (href) { %>
                    <a href="<%= href %>" class="text-green-600 dark:text-green-400 hover:underline">
                      <%= (typeof val === 'string' || typeof val === 'number') ? val
                          : val instanceof Date ? slimDateTime(val)
                          : typeof val === 'object' ? val?.name || val?.Name || val?.title || val?.Code || val?.Number || '[Object]'
                          : val ?? '—' %>
                    </a>
                  <% } else { %>
                    <% if (val instanceof Date) { %>
                      <%= slimDateTime(val) %>
                    <% } else if (typeof val === 'boolean') { %>
                      <span class="inline-block px-2 py-1 text-xs rounded-full <%= val ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' : 'bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300' %>">
                        <%= val ? 'Yes' : 'No' %>
                      </span>
                    <% } else if (typeof val === 'string' && val.trim() === '') { %>
                      &mdash;
                    <% } else if (val !== null && val !== undefined) { %>
                      <% if (Array.isArray(val)) { %>
                        <% if (h.key === 'LineItems') { %>
                          <span class="inline-flex items-center gap-2">
                            <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700"><%= val.length %> item<%= val.length !== 1 ? 's' : '' %></span>
                            <% if (row.uuid) { %>
                              <a href="/<%= basePath %>/read/<%= row.uuid %>#LineItems" class="text-xs text-green-600 dark:text-green-400 hover:underline">View</a>
                            <% } %>
                          </span>
                        <% } else if (h.key === 'PaymentLines') { %>
                          <% const totalPaid = val.reduce((s, p) => s + (Number(p?.Amount) || 0), 0); %>
                          <span class="inline-flex items-center gap-2">
                            <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700"><%= val.length %> payment<%= val.length !== 1 ? 's' : '' %></span>
                            <span class="text-xs text-gray-600 dark:text-gray-300">£<%= Number(totalPaid).toFixed(2) %></span>
                            <% if (row.uuid) { %>
                              <a href="/<%= basePath %>/read/<%= row.uuid %>#PaymentLines" class="text-xs text-green-600 dark:text-green-400 hover:underline">View</a>
                            <% } %>
                          </span>
                        <% } else if (h.key === 'tags') { %>
                          <% const tagNames = val.map(t => t && (t.name || t.title || t.slug)).filter(Boolean); %>
                          <%= tagNames.length ? tagNames.join(', ') : `${val.length} tag${val.length !== 1 ? 's' : ''}` %>
                        <% } else { %>
                          <%
                            const keyLower = h.key.toLowerCase();
                            const abbr = h.key
                              .replace(/([a-z])([A-Z])/g, '$1 $2')
                              .split(/[\s_]+/)
                              .map(w => w.charAt(0).toUpperCase())
                              .join('');
                          %>
                          <% if (val.length > 0) { %>
                            <span class="inline-flex items-center gap-1">
                              <i class="bi bi-check-circle-fill text-green-600 dark:text-green-400"></i>
                              <span class="text-xs" title="<%= h.label || h.key %>"><%= val.length %> <%= abbr %></span>
                            </span>
                          <% } else { %>
                            <span class="text-gray-400 text-xs">&mdash;</span>
                          <% } %>
                        <% } %>
                      <% } else if (val && val._bsontype === 'Decimal128') { %>
                        <% const num = parseFloat(val.toString()); %>
                        <%= ['payrate', 'dayrate'].includes(h.key.toLowerCase()) ? formatCurrency(num) : num.toFixed(2) %>
                      <% } else if (typeof val === 'object') { %>
                        <%= val?.name || val?.Name || val?.title || val?.Code || val?.Number || '[Object]' %>
                      <% } else { %>
                        <%= val %>
                      <% } %>
                    <% } else { %>
                      &mdash;
                    <% } %>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%
  const sampleRows = Array.isArray(rows) ? rows.slice(0, 10) : [];
  const keySet = new Set();
  sampleRows.forEach(r => {
    if (r && typeof r === 'object') {
      Object.keys(r).forEach(k => keySet.add(k));
    }
  });
  const rowKeys = Array.from(keySet).sort();
  const headerKeys = (Array.isArray(headers) ? headers.map(h => h.key) : []).sort();
  const missing = rowKeys.filter(k => !headerKeys.includes(k));
  const extra = headerKeys.filter(k => !rowKeys.includes(k));
  const toLabel = k =>
    k.replace(/([a-z0-9])([A-Z])/g, '$1 $2')
     .replace(/[_\-]+/g, ' ')
     .replace(/\s+/g, ' ')
     .replace(/^\w/, c => c.toUpperCase());
  const suggestedHeaders = (headerKeys.length ? headerKeys : rowKeys).map(k => ({ key: k, label: toLabel(k) }));
  const snippet = `// listControllerConfig.js
    module.exports = {
      headers: ${JSON.stringify(suggestedHeaders, null, 2)},
      linkField: '${linkField || 'uuid'}'
    };`;
%>
<div class="mt-6 border rounded bg-yellow-50 text-yellow-900 border-yellow-300 dark:bg-yellow-900 dark:text-yellow-100 dark:border-yellow-700 p-4">
  <div class="mt-3 grid grid-cols-1 md:grid-cols-3 gap-3 text-xs">
    <div>
      <div class="font-medium mb-1">Detected fields</div>
      <ul class="list-disc pl-4 space-y-0.5">
        <% rowKeys.forEach(k => { %><li><code><%= k %></code></li><% }) %>
      </ul>
    </div>
    <div>
      <div class="font-medium mb-1">Configured headers</div>
      <ul class="list-disc pl-4 space-y-0.5">
        <% headerKeys.forEach(k => { %><li><code><%= k %></code></li><% }) %>
      </ul>
      <% if (extra.length) { %>
        <div class="mt-2 text-[11px]">Extra (no data): <code><%= extra.join(', ') %></code></div>
      <% } %>
    </div>
    <div>
      <div class="font-medium mb-1">Missing in headers</div>
      <% if (missing.length) { %>
        <ul class="list-disc pl-4 space-y-0.5">
          <% missing.forEach(k => { %><li><code><%= k %></code></li><% }) %>
        </ul>
      <% } else { %>
        <div>None</div>
      <% } %>
    </div>
  </div>
</div>
 

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const limitSelect = document.getElementById('limitSelect');
    const form = document.getElementById('list-controls');
    if (limitSelect && form) {
      limitSelect.addEventListener('change', () => {
        const pageInput = form.querySelector('input[name="page"]');
        if (pageInput) pageInput.value = '1';
        form.submit();
      });
    }
  });
</script>
