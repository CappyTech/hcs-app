<% const hasActions = typeof actions !== 'undefined' && Array.isArray(actions) && actions.length > 0; %>
<% const hdrActions = typeof headerActions !== 'undefined' && Array.isArray(headerActions) ? headerActions : []; %>
<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <!-- Green accent bar -->
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>

    <div class="p-6 sm:p-8">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 lg:gap-6 mb-6">
        <div class="flex items-center gap-3">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= title || 'Data Table' %></h1>
          <% if (typeof canModel === 'function' && typeof modelName !== 'undefined' && canModel(modelName, 'c')) { %>
            <a href="/<%= modelName %>/create" class="inline-flex items-center gap-1.5 text-white text-sm px-3 py-1.5 rounded-lg shadow-sm bg-green-600 hover:bg-green-700 transition">
              <i class="bi bi-plus-circle"></i> New
            </a>
          <% } %>
          <% hdrActions.forEach(a => { %>
            <a href="<%= a.href %>" class="inline-flex items-center gap-1.5 text-white text-sm px-3 py-1.5 rounded-lg shadow-sm <%= a.class || 'bg-green-600 hover:bg-green-700' %> transition">
              <% if (a.icon) { %><i class="<%= a.icon %>"></i><% } %> <%= a.label %>
            </a>
          <% }) %>
        </div>
        <div class="flex flex-wrap items-center gap-4">
      <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <!-- Pagination -->
        <nav>
          <ul class="flex justify-center flex-wrap gap-2">
            <% const range = 2; %>
            <% for (let i = 1; i <= totalPages; i++) { %>
              <% if (i === 1 || i === totalPages || Math.abs(i - page) <= range) { %>
                <li>
                  <a href="?page=<%= i %>&limit=<%= limit %><%= query ? '&search=' + encodeURIComponent(query) : '' %><%= activeTab ? '&tab=' + encodeURIComponent(activeTab) : '' %>"
                     class="px-2.5 py-0.5 rounded-lg border text-xs
                     <%= i === page
                       ? 'bg-green-600 text-white border-green-600'
                       : 'bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 hover:bg-green-50 dark:hover:bg-green-900/30 hover:text-green-600 dark:hover:text-green-400'
                     %> transition">
                    <%= i %>
                  </a>
                </li>
              <% } else if (i === page - range - 1 || i === page + range + 1) { %>
                <li><span class="px-3 py-1 text-sm text-gray-500 dark:text-gray-400">…</span></li>
              <% } %>
            <% } %>
          </ul>
        </nav>
      <% } %>

      <!-- Controls -->
      <form id="list-controls" method="GET" action="" class="flex flex-wrap gap-2 items-center">
        <label for="limitSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">Show</label>
  <select id="limitSelect" name="limit"
    class="text-sm border rounded-lg pl-2 pr-6 py-1.5 bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 appearance-none focus:outline-none focus:ring-2 focus:ring-green-500"
    style="background-image:linear-gradient(45deg,transparent 50%,currentColor 50%),linear-gradient(135deg,currentColor 50%,transparent 50%);background-position:calc(100% - 14px) calc(50% - 3px),calc(100% - 10px) calc(50% - 3px);background-size:4px 4px,4px 4px;background-repeat:no-repeat;">
          <% [10, 50, 100].forEach(opt => { %>
            <option value="<%= opt %>" <%= limit == opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>

        <input type="hidden" name="page" value="1">
        <% if (activeTab) { %>
          <input type="hidden" name="tab" value="<%= activeTab %>">
        <% } %>

        <input type="text"
              name="search"
              placeholder="Search..."
              value="<%= typeof query === 'string' ? query : '' %>"
              class="text-sm border rounded-lg px-3 py-1.5 w-48 bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500">

        <button type="submit"
                class="text-sm bg-green-600 text-white px-4 py-1.5 rounded-lg hover:bg-green-700 transition shadow-sm">
          Apply
        </button>
      </form>
    </div>
  </div>

  <!-- Tab Buttons -->
  <% if (Array.isArray(tabs) && tabs.length > 0) { %>
    <div class="mb-4 flex flex-wrap gap-2">
      <% tabs.forEach(tab => { %>
        <a href="?tab=<%= encodeURIComponent(tab.value) %>&limit=<%= limit %><%= query ? '&search=' + encodeURIComponent(query) : '' %>"
           class="px-4 py-1.5 rounded-full text-sm font-medium border transition
                  <%= tab.isActive
                    ? 'bg-transparent text-green-600 border-green-600 shadow-sm dark:text-green-400 dark:border-green-400'
                    : 'bg-transparent text-gray-700 border-gray-300 hover:text-green-600 hover:border-green-600 dark:text-gray-300 dark:border-gray-600 dark:hover:text-green-400 dark:hover:border-green-400'
                  %>">
          <%= tab.label %>
        </a>
      <% }) %>
    </div>
  <% } %>

  <% if (!rows || rows.length === 0) { %>
    <div class="bg-blue-50 text-blue-700 p-4 rounded-xl text-sm border border-blue-200 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-800">
      <i class="bi bi-info-circle mr-1"></i> No records found.
    </div>
  <% } else { %>

    <!-- Table -->
    <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
          <tr>
            <% headers.forEach(h => { 
                const isSorted = query.sort === h.key;
                const isAsc = query.order === 'asc';
                const newOrder = isSorted && isAsc ? 'desc' : 'asc';
                const url = new URLSearchParams(query);
                url.set('sort', h.key);
                url.set('order', newOrder);
            %>
              <th class="px-3 py-2.5 text-xs border-b border-gray-200 dark:border-gray-700 text-left font-semibold uppercase tracking-wide">
                <a href="?<%= url.toString() %>" class="flex items-center gap-1 hover:underline">
                  <span><%= h.label %></span>
                  <% if (isSorted) { %>
                    <span><%= isAsc ? '▲' : '▼' %></span>
                  <% } %>
                </a>
              </th>
            <% }) %>
            <% if (hasActions) { %>
              <th class="px-3 py-2.5 border-b border-gray-200 dark:border-gray-700 font-semibold text-xs uppercase tracking-wide">Actions</th>
            <% } %>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-200">
          <% rows.forEach(row => { %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <% headers.forEach(h => { %>
                <%
                  const val = row[h.key];
                  const links = typeof fieldLinks === 'function' ? fieldLinks(row) : fieldLinks;
                  const fieldHref = links?.[h.key];
                  const isOwnLink = h.key === linkField && row.uuid;
                  const href = fieldHref || (isOwnLink ? `/${basePath}/read/${row.uuid}` : null);
                %>
                <td class="px-3 py-2.5 border-b border-gray-100 dark:border-gray-800">
                  <% if (href) { %>
                    <a href="<%= href %>" class="text-green-600 dark:text-green-400 hover:underline">
                      <%= (typeof val === 'string' || typeof val === 'number') ? val
                          : val instanceof Date ? slimDateTime(val)
                          : typeof val === 'object' ? val?.name || val?.Name || val?.title || val?.Code || val?.Number || '[Object]'
                          : val ?? '—' %>
                    </a>
                  <% } else { %>
                    <% if (val instanceof Date) { %>
                      <%= slimDateTime(val) %>
                    <% } else if (typeof val === 'boolean') { %>
                      <span class="inline-block px-2 py-1 text-xs rounded-full <%= val ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' : 'bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300' %>">
                        <%= val ? 'Yes' : 'No' %>
                      </span>
                    <% } else if (typeof val === 'string' && val.trim() === '') { %>
                      &mdash;
                    <% } else if (val !== null && val !== undefined) { %>
                      <% if (Array.isArray(val)) { %>
                        <% if (h.key === 'LineItems') { %>
                          <span class="inline-flex items-center gap-2">
                            <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700"><%= val.length %> item<%= val.length !== 1 ? 's' : '' %></span>
                            <% if (row.uuid) { %>
                              <a href="/<%= basePath %>/read/<%= row.uuid %>#LineItems" class="text-xs text-green-600 dark:text-green-400 hover:underline">View</a>
                            <% } %>
                          </span>
                        <% } else if (h.key === 'PaymentLines') { %>
                          <% const totalPaid = val.reduce((s, p) => s + (Number(p?.Amount) || 0), 0); %>
                          <span class="inline-flex items-center gap-2">
                            <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700"><%= val.length %> payment<%= val.length !== 1 ? 's' : '' %></span>
                            <span class="text-xs text-gray-600 dark:text-gray-300">£<%= Number(totalPaid).toFixed(2) %></span>
                            <% if (row.uuid) { %>
                              <a href="/<%= basePath %>/read/<%= row.uuid %>#PaymentLines" class="text-xs text-green-600 dark:text-green-400 hover:underline">View</a>
                            <% } %>
                          </span>
                        <% } else if (h.key === 'tags') { %>
                          <% const tagNames = val.map(t => t && (t.name || t.title || t.slug)).filter(Boolean); %>
                          <%= tagNames.length ? tagNames.join(', ') : `${val.length} tag${val.length !== 1 ? 's' : ''}` %>
                        <% } else { %>
                          <%
                            const keyLower = h.key.toLowerCase();
                            const abbr = h.key
                              .replace(/([a-z])([A-Z])/g, '$1 $2')
                              .split(/[\s_]+/)
                              .map(w => w.charAt(0).toUpperCase())
                              .join('');
                          %>
                          <% if (val.length > 0) { %>
                            <span class="inline-flex items-center gap-1">
                              <i class="bi bi-check-circle-fill text-green-600 dark:text-green-400"></i>
                              <span class="text-xs" title="<%= h.label || h.key %>"><%= val.length %> <%= abbr %></span>
                            </span>
                          <% } else { %>
                            <span class="text-gray-400 text-xs">&mdash;</span>
                          <% } %>
                        <% } %>
                      <% } else if (val && val._bsontype === 'Decimal128') { %>
                        <% const num = parseFloat(val.toString()); %>
                        <%= ['payrate', 'dayrate'].includes(h.key.toLowerCase()) ? formatCurrency(num) : num.toFixed(2) %>
                      <% } else if (typeof val === 'object') { %>
                        <%= val?.name || val?.Name || val?.title || val?.Code || val?.Number || '[Object]' %>
                      <% } else { %>
                        <%= val %>
                      <% } %>
                    <% } else { %>
                      &mdash;
                    <% } %>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
    </div>
  </div>
</div>

 

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const limitSelect = document.getElementById('limitSelect');
    const form = document.getElementById('list-controls');
    if (limitSelect && form) {
      limitSelect.addEventListener('change', () => {
        const pageInput = form.querySelector('input[name="page"]');
        if (pageInput) pageInput.value = '1';
        form.submit();
      });
    }
  });
</script>
