<% const hasActions = typeof actions !== 'undefined' && Array.isArray(actions) && actions.length > 0; %>
<% const hdrActions = typeof headerActions !== 'undefined' && Array.isArray(headerActions) ? headerActions : []; %>
<%
  // ── Formatting helpers (available throughout the template) ─────────────────

  /** Returns a Tailwind badge class string based on a status/type value. */
  function _badgeClass(v) {
    const vl = String(v || '').toLowerCase().trim();
    if (['active', 'available', 'complete', 'completed', 'paid', 'approved', 'verified', 'inside', 'gross', 'open'].includes(vl))
      return 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300';
    if (['pending', 'draft', 'partial', 'in progress', 'processing', 'submitted', 'queued'].includes(vl))
      return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300';
    if (['inactive', 'archived', 'cancelled', 'overdue', 'rejected', 'failed', 'disposed',
         'out of service', 'outside', 'sick', 'terminated', 'closed'].includes(vl))
      return 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300';
    if (['in use', 'work', 'assigned', 'training', 'employed'].includes(vl))
      return 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300';
    if (['holiday', 'leave'].includes(vl))
      return 'bg-purple-100 text-purple-800 dark:bg-purple-900/40 dark:text-purple-300';
    if (['under maintenance', 'maintenance'].includes(vl))
      return 'bg-orange-100 text-orange-800 dark:bg-orange-900/40 dark:text-orange-300';
    if (['off'].includes(vl))
      return 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400';
    return 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300';
  }

  /** True if a field key implies a monetary (£) value. */
  const _isCurrencyKey = (k) =>
    /amount|balance|paid|gross|outstanding|labour|material|revenue|wage|salary|fee/i.test(k) ||
    /^(day|pay|hour|daily|weekly|monthly|yearly|overtime|defined|base|flat|road)rate$/i.test(k.toLowerCase());

  /** True if a field key implies a percentage (%) value. */
  const _isPercentKey = (k) =>
    /^(withholdingtaxrate|whtrate|discountrate|vatrate|accrualPercent|taxrate)$/i.test(k);

  /** True if a field key implies a badge/pill display. */
  const _isStatusKey = (k) =>
    /^(status|type|availabilitystatus|ir35|entitlementtype|accrualmethod|ownershipstatus|fueltype|bodytype)$/.test(k.toLowerCase());
%>
<%
  // Preserve current layout in generated URLs
  const _rq = typeof reqQuery !== 'undefined' ? reqQuery : {};
  const _lp = (typeof listLayout !== 'undefined' && listLayout === 'rows') ? '&layout=rows' : '';
  // Build query-string fragment for active filter params
  const _fqsParts = [];
  if (typeof filters !== 'undefined' && Array.isArray(filters)) {
    filters.forEach(fc => {
      const _fqk = `f_${fc.field}`;
      if (fc.type === 'daterange' || fc.type === 'numberrange') {
        const vf = _rq[`${_fqk}_from`]; const vt = _rq[`${_fqk}_to`];
        if (vf) _fqsParts.push(`${_fqk}_from=${encodeURIComponent(vf)}`);
        if (vt) _fqsParts.push(`${_fqk}_to=${encodeURIComponent(vt)}`);
      } else {
        const v = _rq[_fqk];
        if (v !== undefined && v !== '') _fqsParts.push(`${_fqk}=${encodeURIComponent(v)}`);
      }
    });
  }
  const _fqs = _fqsParts.length ? '&' + _fqsParts.join('&') : '';

  // Classify a header field for the rows layout
  function _classifyHeader(h, sampleRow) {
    const k = h.key;
    const kl = k.toLowerCase();
    if (_isStatusKey(k)) return 'badge';
    if (_isCurrencyKey(k)) return 'stat';
    if (_isPercentKey(k)) return 'percent';
    if (/^(note|notes|description|comment|comments|remarks|summary|detail|details)$/.test(kl)) return 'body';
    if (/date/i.test(k) || /^(created|updated|modified|issued|hired|hire|start|end|first|last|due|expiry|purchase|service)/i.test(k)) return 'date';
    if (/^(code|ref|reference|number|customercode|suppliercode|reg|registration)/i.test(kl)) return 'pill';
    const sv = sampleRow?.[k];
    if (typeof sv === 'boolean') return 'bool';
    if (typeof sv === 'number') return 'count';
    return 'meta';
  }
%>
<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <!-- Green accent bar -->
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>

    <div class="p-6 sm:p-8">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 lg:gap-6 mb-6">
        <div class="flex items-center gap-3">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= title || 'Data Table' %></h1>
          <% if (typeof canModel === 'function' && typeof modelName !== 'undefined' && canModel(modelName, 'c') && !(typeof config !== 'undefined' && Array.isArray(config && config.deny) && config.deny.includes('c'))) { %>
            <a href="/<%= modelName %>/create" class="inline-flex items-center gap-1.5 text-white text-sm px-3 py-1.5 rounded-lg shadow-sm bg-green-600 hover:bg-green-700 transition">
              <i class="bi bi-plus-circle"></i> New
            </a>
          <% } %>
          <% hdrActions.forEach(a => { %>
            <a href="<%= a.href %>" class="inline-flex items-center gap-1.5 text-white text-sm px-3 py-1.5 rounded-lg shadow-sm <%= a.class || 'bg-green-600 hover:bg-green-700' %> transition">
              <% if (a.icon) { %><i class="<%= a.icon %>"></i><% } %> <%= a.label %>
            </a>
          <% }) %>
          <%
            // Export the current view (search/tab/filters preserved) as CSV
            const _csvParams = new URLSearchParams();
            if (typeof reqQuery !== 'undefined' && reqQuery) {
              for (const [k, v] of Object.entries(reqQuery)) {
                if (k === 'page' || k === 'limit' || k === 'format' || v === undefined || v === '') continue;
                _csvParams.set(k, v);
              }
            }
            _csvParams.set('format', 'csv');
          %>
          <a href="?<%= _csvParams.toString() %>" title="Download the current view as CSV"
             class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-lg shadow-sm border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
            <i class="bi bi-download"></i> CSV
          </a>
        </div>
        <div class="flex flex-wrap items-center gap-4">
      <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <!-- Pagination -->
        <nav>
          <ul class="flex justify-center flex-wrap gap-2">
            <% const range = 2; %>
            <% for (let i = 1; i <= totalPages; i++) { %>
              <% if (i === 1 || i === totalPages || Math.abs(i - page) <= range) { %>
                <li>
                  <a href="?page=<%= i %>&limit=<%= limit %><%= query ? '&search=' + encodeURIComponent(query) : '' %><%= activeTab ? '&tab=' + encodeURIComponent(activeTab) : '' %><%= _lp %><%= _fqs %>"
                     class="px-2.5 py-0.5 rounded-lg border text-xs
                     <%= i === page
                       ? 'bg-green-600 text-white border-green-600'
                       : 'bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 hover:bg-green-50 dark:hover:bg-green-900/30 hover:text-green-600 dark:hover:text-green-400'
                     %> transition">
                    <%= i %>
                  </a></li>
              <% } else if (i === page - range - 1 || i === page + range + 1) { %>
                <li><span class="px-3 py-1 text-sm text-gray-500 dark:text-gray-400">…</span></li>
              <% } %>
            <% } %>
          </ul>
        </nav>
      <% } %>

      <!-- Controls -->
      <form id="list-controls" method="GET" action="" class="flex flex-wrap gap-2 items-center">
        <label for="limitSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">Show</label>
  <select id="limitSelect" name="limit"
    class="text-sm border rounded-lg pl-2 pr-6 py-1.5 bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 appearance-none focus:outline-none focus:ring-2 focus:ring-green-500"
    style="background-image:linear-gradient(45deg,transparent 50%,currentColor 50%),linear-gradient(135deg,currentColor 50%,transparent 50%);background-position:calc(100% - 14px) calc(50% - 3px),calc(100% - 10px) calc(50% - 3px);background-size:4px 4px,4px 4px;background-repeat:no-repeat;">
          <% [10, 50, 100].forEach(opt => { %>
            <option value="<%= opt %>" <%= limit == opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>

        <input type="hidden" name="page" value="1">
        <% if (typeof listLayout !== 'undefined' && listLayout === 'rows') { %>
          <input type="hidden" name="layout" value="rows">
        <% } %>
        <% if (activeTab) { %>
          <input type="hidden" name="tab" value="<%= activeTab %>">
        <% } %>

        <input type="text"
              name="search"
              placeholder="Search..."
              value="<%= typeof query === 'string' ? query : '' %>"
              class="text-sm border rounded-lg px-3 py-1.5 w-48 bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500">

        <button type="submit"
                class="text-sm bg-green-600 text-white px-4 py-1.5 rounded-lg hover:bg-green-700 transition shadow-sm">
          Apply
        </button>

        <% if (typeof filters !== 'undefined' && Array.isArray(filters) && filters.length > 0) { %>
          <button type="button" id="filter-toggle"
                  class="text-sm px-3 py-1.5 rounded-lg border transition inline-flex items-center gap-1.5
                         <%= (typeof activeFilterCount !== 'undefined' && activeFilterCount > 0) ? 'border-green-500 text-green-700 dark:text-green-400 bg-green-50 dark:bg-green-900/20' : 'border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400 bg-white dark:bg-gray-800 hover:border-green-500 hover:text-green-700 dark:hover:text-green-400' %>">
            <i class="bi bi-funnel<%= (typeof activeFilterCount !== 'undefined' && activeFilterCount > 0) ? '-fill' : '' %>"></i>
            Filters
            <% if (typeof activeFilterCount !== 'undefined' && activeFilterCount > 0) { %>
              <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-green-600 text-white text-xs font-bold"><%= activeFilterCount %></span>
            <% } %>
          </button>
        <% } %>
      </form>

      <% if (typeof filters !== 'undefined' && Array.isArray(filters) && filters.length > 0) { %>
        <%
          const _selectCls = 'w-full text-sm border rounded-lg px-2 py-1.5 bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500';
          const _inputCls  = 'w-full text-sm border rounded-lg px-2 py-1.5 bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500';
          const _hasActiveFilters = typeof activeFilterCount !== 'undefined' && activeFilterCount > 0;
          // Build clear-filters URL: strip all f_* params from current query
          const _clearParams = new URLSearchParams(Object.entries(_rq).filter(([k]) => !k.startsWith('f_') && k !== 'page'));
          _clearParams.set('page', '1');
          const _clearUrl = '?' + _clearParams.toString();
        %>
        <form id="filter-panel" method="GET" action="" class="<%= _hasActiveFilters ? '' : 'hidden' %> mt-3 p-4 bg-gray-50 dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700">
          <input type="hidden" name="page" value="1">
          <input type="hidden" name="limit" value="<%= limit %>">
          <% if (typeof query === 'string' && query) { %><input type="hidden" name="search" value="<%= query %>"><% } %>
          <% if (activeTab) { %><input type="hidden" name="tab" value="<%= activeTab %>"><% } %>
          <% if (typeof listLayout !== 'undefined' && listLayout === 'rows') { %><input type="hidden" name="layout" value="rows"><% } %>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
            <% filters.forEach(fc => { %>
              <% const _fqk = `f_${fc.field}`; %>
              <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-500 dark:text-gray-400"><%= fc.label %></label>
                <% if (fc.type === 'boolean') { %>
                  <select name="<%= _fqk %>" class="<%= _selectCls %>">
                    <option value="">Any</option>
                    <option value="false" <%= _rq[_fqk] === 'false' ? 'selected' : '' %>><%= fc.falseLabel || 'No' %></option>
                    <option value="true"  <%= _rq[_fqk] === 'true'  ? 'selected' : '' %>><%= fc.trueLabel  || 'Yes' %></option>
                  </select>
                <% } else if (fc.type === 'select') { %>
                  <select name="<%= _fqk %>" class="<%= _selectCls %>">
                    <option value="">Any</option>
                    <% (fc.options || []).forEach(opt => { %>
                      <option value="<%= opt.value %>" <%= String(_rq[_fqk]) === String(opt.value) ? 'selected' : '' %>><%= opt.label %></option>
                    <% }) %>
                  </select>
                <% } else if (fc.type === 'daterange') { %>
                  <div class="flex items-center gap-1">
                    <input type="date" name="<%= _fqk %>_from" value="<%= _rq[`${_fqk}_from`] || '' %>" class="<%= _inputCls %>">
                    <span class="text-xs text-gray-400 shrink-0">–</span>
                    <input type="date" name="<%= _fqk %>_to"   value="<%= _rq[`${_fqk}_to`]   || '' %>" class="<%= _inputCls %>">
                  </div>
                <% } else if (fc.type === 'numberrange') { %>
                  <div class="flex items-center gap-1">
                    <input type="number" step="any" name="<%= _fqk %>_from" value="<%= _rq[`${_fqk}_from`] || '' %>" placeholder="Min" class="<%= _inputCls %>">
                    <span class="text-xs text-gray-400 shrink-0">–</span>
                    <input type="number" step="any" name="<%= _fqk %>_to"   value="<%= _rq[`${_fqk}_to`]   || '' %>" placeholder="Max" class="<%= _inputCls %>">
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>

          <div class="flex gap-2 mt-3">
            <button type="submit" class="text-sm bg-green-600 text-white px-4 py-1.5 rounded-lg hover:bg-green-700 transition shadow-sm">Apply filters</button>
            <% if (_hasActiveFilters) { %>
              <a href="<%= _clearUrl %>" class="text-sm text-gray-500 dark:text-gray-400 hover:text-red-500 dark:hover:text-red-400 px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-red-300 transition inline-flex items-center gap-1">
                <i class="bi bi-x-circle"></i> Clear
              </a>
            <% } %>
          </div>
        </form>
      <% } %>
      <!-- Layout toggle -->
      <div class="flex items-center gap-0.5 border border-gray-200 dark:border-gray-700 rounded-lg p-0.5 bg-white dark:bg-gray-800 shrink-0">
        <% const _lqTable = '?' + new URLSearchParams({..._rq, layout: 'table', page: '1'}).toString(); %>
        <% const _lqRows  = '?' + new URLSearchParams({..._rq, layout: 'rows',  page: '1'}).toString(); %>
        <a href="<%= _lqTable %>" title="Table view" class="flex items-center justify-center w-7 h-7 rounded transition <%= (!listLayout || listLayout === 'table') ? 'bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-gray-100' : 'text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300' %>">
          <i class="bi bi-table text-sm"></i>
        </a>
        <a href="<%= _lqRows %>" title="List view" class="flex items-center justify-center w-7 h-7 rounded transition <%= (listLayout === 'rows') ? 'bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-gray-100' : 'text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300' %>">
          <i class="bi bi-list-ul text-sm"></i>
        </a>
      </div>
    </div>
  </div>

  <!-- Tab Buttons -->
  <% if (Array.isArray(tabs) && tabs.length > 0) { %>
    <div class="mb-4 flex flex-wrap gap-2">
      <% tabs.forEach(tab => { %>
        <a href="?tab=<%= encodeURIComponent(tab.value) %>&limit=<%= limit %><%= query ? '&search=' + encodeURIComponent(query) : '' %><%= _lp %><%= _fqs %>"
           class="px-4 py-1.5 rounded-full text-sm font-medium border transition
                  <%= tab.isActive
                    ? 'bg-transparent text-green-600 border-green-600 shadow-sm dark:text-green-400 dark:border-green-400'
                    : 'bg-transparent text-gray-700 border-gray-300 hover:text-green-600 hover:border-green-600 dark:text-gray-300 dark:border-gray-600 dark:hover:text-green-400 dark:hover:border-green-400'
                  %>">
          <%= tab.label %>
        </a>
      <% }) %>
    </div>
  <% } %>

  <% if (!rows || rows.length === 0) { %>
    <div class="bg-blue-50 text-blue-700 p-4 rounded-xl text-sm border border-blue-200 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-800">
      <i class="bi bi-info-circle mr-1"></i> No records found.
    </div>
  <% } else if (!listLayout || listLayout !== 'rows') { %>

    <!-- Table -->
    <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
          <tr>
            <% headers.forEach(h => { 
                const isSorted = (typeof reqQuery !== 'undefined' ? reqQuery.sort : '') === h.key;
                const isAsc = (typeof reqQuery !== 'undefined' ? reqQuery.order : '') === 'asc';
                const newOrder = isSorted && isAsc ? 'desc' : 'asc';
                const url = new URLSearchParams(typeof reqQuery !== 'undefined' ? reqQuery : {});
                url.set('sort', h.key);
                url.set('order', newOrder);              // Detect if column is numeric for right-alignment (sample from first row)
              const _sampleVal = rows.length ? rows[0][h.key] : undefined;
              const _sampleNum = (_sampleVal && _sampleVal._bsontype === 'Decimal128') ? parseFloat(_sampleVal.toString()) : _sampleVal;
              const _hIsNumeric = typeof _sampleNum === 'number' && !isNaN(_sampleNum) && !Array.isArray(_sampleNum);            %>
              <th class="px-3 py-2.5 text-xs border-b border-gray-200 dark:border-gray-700 <%= _hIsNumeric ? 'text-right' : 'text-left' %> font-semibold uppercase tracking-wide">
                <a href="?<%= url.toString() %>" class="inline-flex items-center gap-1 hover:underline <%= _hIsNumeric ? 'justify-end w-full' : '' %>">
                  <span><%= h.label %></span>
                  <% if (isSorted) { %>
                    <span><%= isAsc ? '▲' : '▼' %></span>
                  <% } %>
                </a>
              </th>
            <% }) %>
            <% if (hasActions) { %>
              <th class="px-3 py-2.5 border-b border-gray-200 dark:border-gray-700 font-semibold text-xs uppercase tracking-wide">Actions</th>
            <% } %>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-200">
          <% rows.forEach(row => { %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <% headers.forEach(h => { %>
                <%
                  const val = row[h.key];
                  const key = h.key;
                  const links = typeof fieldLinks === 'function' ? fieldLinks(row) : fieldLinks;
                  const fieldHref = links?.[key];
                  const isOwnLink = key === linkField && row.uuid;
                  const href = fieldHref || (isOwnLink ? `/${basePath}/read/${row.uuid}` : null);

                  // Normalise Decimal128 to plain number so heuristics apply uniformly
                  const _rawVal = (val && val._bsontype === 'Decimal128') ? parseFloat(val.toString()) : val;
                  const _isNum = typeof _rawVal === 'number' && !isNaN(_rawVal);
                  const _isCurr = _isNum && _isCurrencyKey(key);
                  const _isPct  = _isNum && !_isCurr && _isPercentKey(key);
                  const _isStat = _isStatusKey(key) && typeof _rawVal === 'string';
                  const _rightAlign = (_isCurr || _isPct || (_isNum && !href)) && !Array.isArray(_rawVal);
                %>
                <td class="px-3 py-2.5 border-b border-gray-100 dark:border-gray-800<%= _rightAlign ? ' text-right tabular-nums' : '' %>">
                  <% if (href) { %>
                    <a href="<%= href %>" class="text-green-600 dark:text-green-400 hover:underline font-medium">
                      <%= (typeof _rawVal === 'string' || _isNum) ? _rawVal
                          : _rawVal instanceof Date ? slimDateTime(_rawVal)
                          : _rawVal !== null && typeof _rawVal === 'object' ? (_rawVal?.name || _rawVal?.Name || _rawVal?.title || _rawVal?.Code || _rawVal?.Number || '[Object]')
                          : _rawVal ?? '—' %>
                    </a>
                  <% } else if (_rawVal instanceof Date) { %>
                    <span class="text-gray-700 dark:text-gray-300"><%= slimDateTime(_rawVal) %></span>
                  <% } else if (typeof _rawVal === 'boolean') { %>
                    <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full <%= _rawVal ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300' : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400' %>">
                      <%= _rawVal ? 'Yes' : 'No' %>
                    </span>
                  <% } else if (_rawVal === null || _rawVal === undefined || (typeof _rawVal === 'string' && _rawVal.trim() === '')) { %>
                    <span class="text-gray-400">&mdash;</span>
                  <% } else if (Array.isArray(_rawVal)) { %>
                    <% if (key === 'LineItems') { %>
                      <span class="inline-flex items-center gap-2">
                        <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300"><%= _rawVal.length %> item<%= _rawVal.length !== 1 ? 's' : '' %></span>
                        <% if (row.uuid) { %><a href="/<%= basePath %>/read/<%= row.uuid %>#LineItems" class="text-xs text-green-600 dark:text-green-400 hover:underline">View</a><% } %>
                      </span>
                    <% } else if (key === 'PaymentLines') { %>
                      <% const totalPaid = _rawVal.reduce((s, p) => s + (Number(p?.Amount) || 0), 0); %>
                      <span class="inline-flex items-center gap-2">
                        <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300"><%= _rawVal.length %> payment<%= _rawVal.length !== 1 ? 's' : '' %></span>
                        <span class="text-xs font-medium tabular-nums text-gray-700 dark:text-gray-300"><%= formatCurrency(totalPaid) %></span>
                        <% if (row.uuid) { %><a href="/<%= basePath %>/read/<%= row.uuid %>#PaymentLines" class="text-xs text-green-600 dark:text-green-400 hover:underline">View</a><% } %>
                      </span>
                    <% } else if (key === 'tags') { %>
                      <% const tagNames = _rawVal.map(t => t && (t.name || t.title || t.slug)).filter(Boolean); %>
                      <span class="text-sm text-gray-700 dark:text-gray-300"><%= tagNames.length ? tagNames.join(', ') : `${_rawVal.length} tag${_rawVal.length !== 1 ? 's' : ''}` %></span>
                    <% } else if (_rawVal.length === 0) { %>
                      <span class="text-gray-400">&mdash;</span>
                    <% } else { %>
                      <span class="inline-flex items-center gap-1.5" title="<%= h.label || key %>: <%= _rawVal.length %> item<%= _rawVal.length !== 1 ? 's' : '' %>">
                        <i class="bi bi-check-circle-fill text-green-500 dark:text-green-400 text-xs"></i>
                        <span class="text-xs text-gray-600 dark:text-gray-400"><%= _rawVal.length %> <%= h.label || key %></span>
                      </span>
                    <% } %>
                  <% } else if (_isCurr) { %>
                    <span class="font-medium text-gray-800 dark:text-gray-200"><%= formatCurrency(_rawVal) %></span>
                  <% } else if (_isPct) { %>
                    <span class="tabular-nums text-gray-700 dark:text-gray-300"><%= _rawVal %>%</span>
                  <% } else if (_isStat) { %>
                    <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full <%= _badgeClass(_rawVal) %>">
                      <%= _rawVal.replace(/\b\w/g, c => c.toUpperCase()) %>
                    </span>
                  <% } else if (_isNum) { %>
                    <span class="tabular-nums text-gray-700 dark:text-gray-300"><%= _rawVal %></span>
                  <% } else if (_rawVal !== null && typeof _rawVal === 'object') { %>
                    <span class="text-gray-700 dark:text-gray-300"><%= _rawVal?.name || _rawVal?.Name || _rawVal?.title || _rawVal?.Code || _rawVal?.Number || '[Object]' %></span>
                  <% } else { %>
                    <% const _str = String(_rawVal); %>
                    <% if (_str.length > 80) { %>
                      <span title="<%= _str %>" class="cursor-help text-gray-700 dark:text-gray-300"><%= _str.substring(0, 77) %>…</span>
                    <% } else { %>
                      <span class="text-gray-700 dark:text-gray-300"><%= _rawVal %></span>
                    <% } %>
                  <% } %>
                </td>
              <% }) %>
              <% if (hasActions) { %>
                <td class="px-3 py-2.5 border-b border-gray-100 dark:border-gray-800">
                  <% actions.forEach(a => { %>
                    <a href="<%= typeof a.href === 'function' ? a.href(row) : a.href.replace(':uuid', row.uuid || '') %>"
                       class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-lg <%= a.class || 'bg-gray-100 hover:bg-gray-200 text-gray-700 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-300' %> transition mr-1">
                      <% if (a.icon) { %><i class="<%= a.icon %>"></i><% } %><%= a.label %>
                    </a>
                  <% }) %>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <!-- Rows layout -->
    <%
      const _sample = rows[0] || {};
      const _rowGroups = { badge: [], stat: [], percent: [], body: [], date: [], pill: [], bool: [], count: [], meta: [] };
      headers.forEach(h => {
        if (h.key === linkField) return;
        const cat = _classifyHeader(h, _sample);
        (_rowGroups[cat] = _rowGroups[cat] || []).push(h);
      });
      const _gBadges  = _rowGroups.badge.slice(0, 2);
      const _gStats   = _rowGroups.stat.slice(0, 3);
      const _gPercent = _rowGroups.percent.slice(0, 1);
      const _gBody    = _rowGroups.body.slice(0, 1);
      const _gPills   = _rowGroups.pill.slice(0, 2);
      const _gDates   = _rowGroups.date.slice(0, 2);
      const _gCounts  = _rowGroups.count.slice(0, 2);
      const _gBools   = _rowGroups.bool.slice(0, 2);
      const _gMeta    = _rowGroups.meta.slice(0, 2);
      const _gMetaLine = [..._gDates, ..._gCounts, ..._gBools, ..._gMeta, ..._gPercent];
    %>
    <div class="rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden bg-white dark:bg-gray-900">
      <% rows.forEach(row => {
        const _pv = row[linkField];
        const _pvStr = _pv != null ? String(_pv) : '';
        const _links = typeof fieldLinks === 'function' ? fieldLinks(row) : (fieldLinks || {});
        const _pHref = _links?.[linkField] || (row.uuid ? `/${basePath}/read/${row.uuid}` : null);
        const _words = _pvStr.trim().split(/\s+/).filter(Boolean);
        const _initials = (_words.length >= 2 ? (_words[0][0] + _words[1][0]) : _pvStr.substring(0, 2)).toUpperCase() || '?';
      %>
        <article class="flex items-start gap-4 px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-800/40 transition-colors border-b border-gray-100 dark:border-gray-800 last:border-0">
          <!-- Avatar -->
          <div class="shrink-0 mt-0.5 w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold bg-gradient-to-br from-green-400 to-emerald-600 text-white select-none">
            <%= _initials %>
          </div>

          <div class="flex-1 min-w-0">
            <!-- Primary name + code pills + status badges -->
            <div class="flex flex-wrap items-center gap-2 mb-0.5">
              <% if (_pHref && _pvStr) { %>
                <a href="<%= _pHref %>" class="font-semibold text-gray-900 dark:text-gray-100 hover:text-green-600 dark:hover:text-green-400 leading-snug"><%= _pvStr %></a>
              <% } else { %>
                <span class="font-semibold text-gray-900 dark:text-gray-100"><%= _pvStr || '\u2014' %></span>
              <% } %>
              <% _gPills.forEach(h => { const v = row[h.key]; if (v != null && String(v).trim()) { %>
                <span class="font-mono text-xs px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 shrink-0"><%= v %></span>
              <% } }); %>
              <% _gBadges.forEach(h => { const v = row[h.key]; if (v != null && String(v).trim()) { %>
                <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full shrink-0 <%= _badgeClass(v) %>"><%= String(v).replace(/\b\w/g, c => c.toUpperCase()) %></span>
              <% } }); %>
            </div>

            <!-- Body / description -->
            <% _gBody.forEach(h => { const bv = row[h.key]; if (bv && String(bv).trim()) { %>
              <p class="text-sm text-gray-500 dark:text-gray-400 truncate mb-1"><%= String(bv).length > 120 ? String(bv).substring(0, 117) + '\u2026' : bv %></p>
            <% } }); %>

            <!-- Meta line: dates, counts, booleans, misc -->
            <% if (_gMetaLine.length > 0) { %>
              <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 text-xs text-gray-400 dark:text-gray-500 mt-1">
                <% _gMetaLine.forEach(h => {
                  const v = row[h.key];
                  const _rv = (v && v._bsontype === 'Decimal128') ? parseFloat(v.toString()) : v;
                  if (_rv === null || _rv === undefined || _rv === '' || _rv === 0) return;
                %>
                  <% if (_rv instanceof Date || (typeof _rv === 'string' && /^\d{4}-\d{2}-\d{2}/.test(_rv))) { %>
                    <% const _dvYear = new Date(_rv).getFullYear(); %>
                    <% if (_dvYear >= 2001) { %>
                      <span class="inline-flex items-center gap-1"><i class="bi bi-calendar3 opacity-70"></i><%= h.label %>: <%= slimDateTime(_rv) %></span>
                    <% } %>
                  <% } else if (typeof _rv === 'boolean') { %>
                    <% if (_rv) { %>
                      <% const _boolNeg = /archived|disposed|inactive|blocked|banned|suspended|terminated/i.test(h.key); %>
                      <span class="inline-flex items-center gap-1 <%= _boolNeg ? 'text-orange-500 dark:text-orange-400' : 'text-green-500 dark:text-green-400' %>"><i class="<%= _boolNeg ? 'bi bi-archive-fill' : 'bi bi-check2' %>"></i><%= h.label %></span>
                    <% } %>
                  <% } else if (typeof _rv === 'number' && !isNaN(_rv)) { %>
                    <span class="tabular-nums"><%= h.label %>: <%= _isCurrencyKey(h.key) ? formatCurrency(_rv) : _isPercentKey(h.key) ? _rv + '%' : _rv %></span>
                  <% } else if (typeof _rv === 'string' && _rv.trim()) { %>
                    <% const _ms = String(_rv); %>
                    <% if (_ms.trim() !== _pvStr.trim()) { %>
                      <span><%= h.label %>: <%= _ms.length > 40 ? _ms.substring(0, 37) + '\u2026' : _ms %></span>
                    <% } %>
                  <% } %>
                <% }); %>
              </div>
            <% } %>
          </div>

          <!-- Currency stats (right panel) -->
          <% if (_gStats.length > 0) { %>
            <div class="shrink-0 text-right self-center hidden sm:flex flex-col gap-2 pl-3 min-w-[90px]">
              <% _gStats.forEach(h => {
                const v = row[h.key];
                const _rv = (v && v._bsontype === 'Decimal128') ? parseFloat(v.toString()) : v;
                if (typeof _rv !== 'number' || isNaN(_rv)) return;
              %>
                <div class="<%= _rv === 0 ? 'opacity-40' : '' %>">
                  <div class="text-sm font-semibold tabular-nums text-gray-900 dark:text-gray-100"><%= formatCurrency(_rv) %></div>
                  <div class="text-xs text-gray-400 dark:text-gray-500"><%= h.label %></div>
                </div>
              <% }); %>
            </div>
          <% } %>

          <!-- Row actions -->
          <% if (hasActions) { %>
            <div class="shrink-0 self-center flex gap-1 pl-2">
              <% actions.forEach(a => { %>
                <a href="<%= typeof a.href === 'function' ? a.href(row) : a.href.replace(':uuid', row.uuid || '') %>"
                   class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-lg <%= a.class || 'bg-gray-100 hover:bg-gray-200 text-gray-700 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-300' %> transition">
                  <% if (a.icon) { %><i class="<%= a.icon %>"></i><% } %><%= a.label %>
                </a>
              <% }); %>
            </div>
          <% } %>
        </article>
      <% }); %>
    </div>
  <% } %>
    </div>
  </div>
</div>

 

<script nonce="<%= locals.cspNonce %>">
  document.addEventListener('DOMContentLoaded', function () {
    const limitSelect = document.getElementById('limitSelect');
    const form = document.getElementById('list-controls');
    if (limitSelect && form) {
      limitSelect.addEventListener('change', () => {
        const pageInput = form.querySelector('input[name="page"]');
        if (pageInput) pageInput.value = '1';
        form.submit();
      });
    }

    // Filter panel toggle
    const filterToggle = document.getElementById('filter-toggle');
    const filterPanel  = document.getElementById('filter-panel');
    if (filterToggle && filterPanel) {
      filterToggle.addEventListener('click', () => {
        filterPanel.classList.toggle('hidden');
      });
    }
  });
</script>
