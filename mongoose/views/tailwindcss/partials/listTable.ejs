<% const hasActions = typeof actions !== 'undefined' && Array.isArray(actions) && actions.length > 0; %>
<% const hdrActions = typeof headerActions !== 'undefined' && Array.isArray(headerActions) ? headerActions : []; %>
<%
  // ── Formatting helpers (available throughout the template) ─────────────────

  /** Returns a Tailwind badge class string based on a status/type value. */
  function _badgeClass(v) {
    const vl = String(v || '').toLowerCase().trim();
    if (['active', 'available', 'complete', 'completed', 'paid', 'approved', 'verified', 'inside', 'gross', 'open'].includes(vl))
      return 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300';
    if (['pending', 'draft', 'partial', 'in progress', 'processing', 'submitted', 'queued'].includes(vl))
      return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300';
    if (['inactive', 'archived', 'cancelled', 'overdue', 'rejected', 'failed', 'disposed',
         'out of service', 'outside', 'sick', 'terminated', 'closed'].includes(vl))
      return 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300';
    if (['in use', 'work', 'assigned', 'training', 'employed'].includes(vl))
      return 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300';
    if (['holiday', 'leave'].includes(vl))
      return 'bg-purple-100 text-purple-800 dark:bg-purple-900/40 dark:text-purple-300';
    if (['under maintenance', 'maintenance'].includes(vl))
      return 'bg-orange-100 text-orange-800 dark:bg-orange-900/40 dark:text-orange-300';
    if (['off'].includes(vl))
      return 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400';
    return 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300';
  }

  /** True if a field key implies a monetary (£) value. */
  const _isCurrencyKey = (k) =>
    /amount|balance|paid|gross|outstanding|labour|material|revenue|wage|salary|fee/i.test(k) ||
    /^(day|pay|hour|daily|weekly|monthly|yearly|overtime|defined|base|flat|road)rate$/i.test(k.toLowerCase());

  /** True if a field key implies a percentage (%) value. */
  const _isPercentKey = (k) =>
    /^(withholdingtaxrate|whtrate|discountrate|vatrate|accrualPercent|taxrate)$/i.test(k);

  /** True if a field key implies a badge/pill display. */
  const _isStatusKey = (k) =>
    /^(status|type|availabilitystatus|ir35|entitlementtype|accrualmethod|ownershipstatus|fueltype|bodytype)$/.test(k.toLowerCase());
%>
<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl overflow-hidden">
    <!-- Green accent bar -->
    <div class="h-1.5 bg-gradient-to-r from-green-500 to-emerald-400"></div>

    <div class="p-6 sm:p-8">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 lg:gap-6 mb-6">
        <div class="flex items-center gap-3">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= title || 'Data Table' %></h1>
          <% if (typeof canModel === 'function' && typeof modelName !== 'undefined' && canModel(modelName, 'c') && !(typeof config !== 'undefined' && Array.isArray(config && config.deny) && config.deny.includes('c'))) { %>
            <a href="/<%= modelName %>/create" class="inline-flex items-center gap-1.5 text-white text-sm px-3 py-1.5 rounded-lg shadow-sm bg-green-600 hover:bg-green-700 transition">
              <i class="bi bi-plus-circle"></i> New
            </a>
          <% } %>
          <% hdrActions.forEach(a => { %>
            <a href="<%= a.href %>" class="inline-flex items-center gap-1.5 text-white text-sm px-3 py-1.5 rounded-lg shadow-sm <%= a.class || 'bg-green-600 hover:bg-green-700' %> transition">
              <% if (a.icon) { %><i class="<%= a.icon %>"></i><% } %> <%= a.label %>
            </a>
          <% }) %>
        </div>
        <div class="flex flex-wrap items-center gap-4">
      <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <!-- Pagination -->
        <nav>
          <ul class="flex justify-center flex-wrap gap-2">
            <% const range = 2; %>
            <% for (let i = 1; i <= totalPages; i++) { %>
              <% if (i === 1 || i === totalPages || Math.abs(i - page) <= range) { %>
                <li>
                  <a href="?page=<%= i %>&limit=<%= limit %><%= query ? '&search=' + encodeURIComponent(query) : '' %><%= activeTab ? '&tab=' + encodeURIComponent(activeTab) : '' %>"
                     class="px-2.5 py-0.5 rounded-lg border text-xs
                     <%= i === page
                       ? 'bg-green-600 text-white border-green-600'
                       : 'bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 hover:bg-green-50 dark:hover:bg-green-900/30 hover:text-green-600 dark:hover:text-green-400'
                     %> transition">
                    <%= i %>
                  </a>
                </li>
              <% } else if (i === page - range - 1 || i === page + range + 1) { %>
                <li><span class="px-3 py-1 text-sm text-gray-500 dark:text-gray-400">…</span></li>
              <% } %>
            <% } %>
          </ul>
        </nav>
      <% } %>

      <!-- Controls -->
      <form id="list-controls" method="GET" action="" class="flex flex-wrap gap-2 items-center">
        <label for="limitSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">Show</label>
  <select id="limitSelect" name="limit"
    class="text-sm border rounded-lg pl-2 pr-6 py-1.5 bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 appearance-none focus:outline-none focus:ring-2 focus:ring-green-500"
    style="background-image:linear-gradient(45deg,transparent 50%,currentColor 50%),linear-gradient(135deg,currentColor 50%,transparent 50%);background-position:calc(100% - 14px) calc(50% - 3px),calc(100% - 10px) calc(50% - 3px);background-size:4px 4px,4px 4px;background-repeat:no-repeat;">
          <% [10, 50, 100].forEach(opt => { %>
            <option value="<%= opt %>" <%= limit == opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>

        <input type="hidden" name="page" value="1">
        <% if (activeTab) { %>
          <input type="hidden" name="tab" value="<%= activeTab %>">
        <% } %>

        <input type="text"
              name="search"
              placeholder="Search..."
              value="<%= typeof query === 'string' ? query : '' %>"
              class="text-sm border rounded-lg px-3 py-1.5 w-48 bg-white dark:bg-gray-800 dark:text-gray-200 border-gray-200 dark:border-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500">

        <button type="submit"
                class="text-sm bg-green-600 text-white px-4 py-1.5 rounded-lg hover:bg-green-700 transition shadow-sm">
          Apply
        </button>
      </form>
    </div>
  </div>

  <!-- Tab Buttons -->
  <% if (Array.isArray(tabs) && tabs.length > 0) { %>
    <div class="mb-4 flex flex-wrap gap-2">
      <% tabs.forEach(tab => { %>
        <a href="?tab=<%= encodeURIComponent(tab.value) %>&limit=<%= limit %><%= query ? '&search=' + encodeURIComponent(query) : '' %>"
           class="px-4 py-1.5 rounded-full text-sm font-medium border transition
                  <%= tab.isActive
                    ? 'bg-transparent text-green-600 border-green-600 shadow-sm dark:text-green-400 dark:border-green-400'
                    : 'bg-transparent text-gray-700 border-gray-300 hover:text-green-600 hover:border-green-600 dark:text-gray-300 dark:border-gray-600 dark:hover:text-green-400 dark:hover:border-green-400'
                  %>">
          <%= tab.label %>
        </a>
      <% }) %>
    </div>
  <% } %>

  <% if (!rows || rows.length === 0) { %>
    <div class="bg-blue-50 text-blue-700 p-4 rounded-xl text-sm border border-blue-200 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-800">
      <i class="bi bi-info-circle mr-1"></i> No records found.
    </div>
  <% } else { %>

    <!-- Table -->
    <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
          <tr>
            <% headers.forEach(h => { 
                const isSorted = (typeof reqQuery !== 'undefined' ? reqQuery.sort : '') === h.key;
                const isAsc = (typeof reqQuery !== 'undefined' ? reqQuery.order : '') === 'asc';
                const newOrder = isSorted && isAsc ? 'desc' : 'asc';
                const url = new URLSearchParams(typeof reqQuery !== 'undefined' ? reqQuery : {});
                url.set('sort', h.key);
                url.set('order', newOrder);              // Detect if column is numeric for right-alignment (sample from first row)
              const _sampleVal = rows.length ? rows[0][h.key] : undefined;
              const _sampleNum = (_sampleVal && _sampleVal._bsontype === 'Decimal128') ? parseFloat(_sampleVal.toString()) : _sampleVal;
              const _hIsNumeric = typeof _sampleNum === 'number' && !isNaN(_sampleNum) && !Array.isArray(_sampleNum);            %>
              <th class="px-3 py-2.5 text-xs border-b border-gray-200 dark:border-gray-700 <%= _hIsNumeric ? 'text-right' : 'text-left' %> font-semibold uppercase tracking-wide">
                <a href="?<%= url.toString() %>" class="inline-flex items-center gap-1 hover:underline <%= _hIsNumeric ? 'justify-end w-full' : '' %>">
                  <span><%= h.label %></span>
                  <% if (isSorted) { %>
                    <span><%= isAsc ? '▲' : '▼' %></span>
                  <% } %>
                </a>
              </th>
            <% }) %>
            <% if (hasActions) { %>
              <th class="px-3 py-2.5 border-b border-gray-200 dark:border-gray-700 font-semibold text-xs uppercase tracking-wide">Actions</th>
            <% } %>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-200">
          <% rows.forEach(row => { %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <% headers.forEach(h => { %>
                <%
                  const val = row[h.key];
                  const key = h.key;
                  const links = typeof fieldLinks === 'function' ? fieldLinks(row) : fieldLinks;
                  const fieldHref = links?.[key];
                  const isOwnLink = key === linkField && row.uuid;
                  const href = fieldHref || (isOwnLink ? `/${basePath}/read/${row.uuid}` : null);

                  // Normalise Decimal128 to plain number so heuristics apply uniformly
                  const _rawVal = (val && val._bsontype === 'Decimal128') ? parseFloat(val.toString()) : val;
                  const _isNum = typeof _rawVal === 'number' && !isNaN(_rawVal);
                  const _isCurr = _isNum && _isCurrencyKey(key);
                  const _isPct  = _isNum && !_isCurr && _isPercentKey(key);
                  const _isStat = _isStatusKey(key) && typeof _rawVal === 'string';
                  const _rightAlign = (_isCurr || _isPct || (_isNum && !href)) && !Array.isArray(_rawVal);
                %>
                <td class="px-3 py-2.5 border-b border-gray-100 dark:border-gray-800<%= _rightAlign ? ' text-right tabular-nums' : '' %>">
                  <% if (href) { %>
                    <a href="<%= href %>" class="text-green-600 dark:text-green-400 hover:underline font-medium">
                      <%= (typeof _rawVal === 'string' || _isNum) ? _rawVal
                          : _rawVal instanceof Date ? slimDateTime(_rawVal)
                          : _rawVal !== null && typeof _rawVal === 'object' ? (_rawVal?.name || _rawVal?.Name || _rawVal?.title || _rawVal?.Code || _rawVal?.Number || '[Object]')
                          : _rawVal ?? '—' %>
                    </a>
                  <% } else if (_rawVal instanceof Date) { %>
                    <span class="text-gray-700 dark:text-gray-300"><%= slimDateTime(_rawVal) %></span>
                  <% } else if (typeof _rawVal === 'boolean') { %>
                    <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full <%= _rawVal ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300' : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400' %>">
                      <%= _rawVal ? 'Yes' : 'No' %>
                    </span>
                  <% } else if (_rawVal === null || _rawVal === undefined || (typeof _rawVal === 'string' && _rawVal.trim() === '')) { %>
                    <span class="text-gray-400">&mdash;</span>
                  <% } else if (Array.isArray(_rawVal)) { %>
                    <% if (key === 'LineItems') { %>
                      <span class="inline-flex items-center gap-2">
                        <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300"><%= _rawVal.length %> item<%= _rawVal.length !== 1 ? 's' : '' %></span>
                        <% if (row.uuid) { %><a href="/<%= basePath %>/read/<%= row.uuid %>#LineItems" class="text-xs text-green-600 dark:text-green-400 hover:underline">View</a><% } %>
                      </span>
                    <% } else if (key === 'PaymentLines') { %>
                      <% const totalPaid = _rawVal.reduce((s, p) => s + (Number(p?.Amount) || 0), 0); %>
                      <span class="inline-flex items-center gap-2">
                        <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300"><%= _rawVal.length %> payment<%= _rawVal.length !== 1 ? 's' : '' %></span>
                        <span class="text-xs font-medium tabular-nums text-gray-700 dark:text-gray-300"><%= formatCurrency(totalPaid) %></span>
                        <% if (row.uuid) { %><a href="/<%= basePath %>/read/<%= row.uuid %>#PaymentLines" class="text-xs text-green-600 dark:text-green-400 hover:underline">View</a><% } %>
                      </span>
                    <% } else if (key === 'tags') { %>
                      <% const tagNames = _rawVal.map(t => t && (t.name || t.title || t.slug)).filter(Boolean); %>
                      <span class="text-sm text-gray-700 dark:text-gray-300"><%= tagNames.length ? tagNames.join(', ') : `${_rawVal.length} tag${_rawVal.length !== 1 ? 's' : ''}` %></span>
                    <% } else if (_rawVal.length === 0) { %>
                      <span class="text-gray-400">&mdash;</span>
                    <% } else { %>
                      <span class="inline-flex items-center gap-1.5" title="<%= h.label || key %>: <%= _rawVal.length %> item<%= _rawVal.length !== 1 ? 's' : '' %>">
                        <i class="bi bi-check-circle-fill text-green-500 dark:text-green-400 text-xs"></i>
                        <span class="text-xs text-gray-600 dark:text-gray-400"><%= _rawVal.length %> <%= h.label || key %></span>
                      </span>
                    <% } %>
                  <% } else if (_isCurr) { %>
                    <span class="font-medium text-gray-800 dark:text-gray-200"><%= formatCurrency(_rawVal) %></span>
                  <% } else if (_isPct) { %>
                    <span class="tabular-nums text-gray-700 dark:text-gray-300"><%= _rawVal %>%</span>
                  <% } else if (_isStat) { %>
                    <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full <%= _badgeClass(_rawVal) %>">
                      <%= _rawVal.replace(/\b\w/g, c => c.toUpperCase()) %>
                    </span>
                  <% } else if (_isNum) { %>
                    <span class="tabular-nums text-gray-700 dark:text-gray-300"><%= _rawVal %></span>
                  <% } else if (_rawVal !== null && typeof _rawVal === 'object') { %>
                    <span class="text-gray-700 dark:text-gray-300"><%= _rawVal?.name || _rawVal?.Name || _rawVal?.title || _rawVal?.Code || _rawVal?.Number || '[Object]' %></span>
                  <% } else { %>
                    <% const _str = String(_rawVal); %>
                    <% if (_str.length > 80) { %>
                      <span title="<%= _str %>" class="cursor-help text-gray-700 dark:text-gray-300"><%= _str.substring(0, 77) %>…</span>
                    <% } else { %>
                      <span class="text-gray-700 dark:text-gray-300"><%= _rawVal %></span>
                    <% } %>
                  <% } %>
                </td>
              <% }) %>
              <% if (hasActions) { %>
                <td class="px-3 py-2.5 border-b border-gray-100 dark:border-gray-800">
                  <% actions.forEach(a => { %>
                    <a href="<%= typeof a.href === 'function' ? a.href(row) : a.href.replace(':uuid', row.uuid || '') %>"
                       class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-lg <%= a.class || 'bg-gray-100 hover:bg-gray-200 text-gray-700 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-300' %> transition mr-1">
                      <% if (a.icon) { %><i class="<%= a.icon %>"></i><% } %><%= a.label %>
                    </a>
                  <% }) %>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
    </div>
  </div>
</div>

 

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const limitSelect = document.getElementById('limitSelect');
    const form = document.getElementById('list-controls');
    if (limitSelect && form) {
      limitSelect.addEventListener('change', () => {
        const pageInput = form.querySelector('input[name="page"]');
        if (pageInput) pageInput.value = '1';
        form.submit();
      });
    }
  });
</script>
