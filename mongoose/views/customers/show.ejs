<%- include('../../views/partials/successAlert') %>
<%- include('../../views/partials/errorAlerts') %>
<div class="container py-4">
  <div class="p-5 mb-4 bg-body-tertiary rounded-3">
    <h1 class="display-5">Customer Details</h1>
    <dl class="row">
      <dt class="col-sm-3">ID</dt>
      <dd class="col-sm-9"><%= customer.CustomerID %></dd>
      <dt class="col-sm-3">Name</dt>
      <dd class="col-sm-9"><%= customer.Name %></dd>
      <dt class="col-sm-3">Telephone</dt>
      <dd class="col-sm-9"><%= customer.Telephone %></dd>
      <dt class="col-sm-3">Email</dt>
      <dd class="col-sm-9"><%= customer.Email %></dd>
    </dl>
    <a href="/mongo/customers" class="btn btn-secondary">Back</a>
  </div>
</div>
