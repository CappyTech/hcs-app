<% if (flash.success && flash.success.length > 0) { %>
  <% flash.success.forEach(function(message, index) { %>
    <div class="position-fixed bottom-0 end-0 me-3 mb-3 p-3" style="z-index: 11">
      <div id="successToast<%= index %>" class="toast align-items-center text-bg-success border-0" role="alert"
           aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
          <div class="toast-body">
            <%= message %>
          </div>
          <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                  aria-label="Close"></button>
        </div>
      </div>
    </div>
  <% }); %>
  <script>
  window.addEventListener('load', function () {
    document.querySelectorAll('.toast').forEach(function (toastElement) {
      new bootstrap.Toast(toastElement).show();
    });
  });
</script>
<% } %>